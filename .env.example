# DATABASE_URL user must be able to CREATE DATABASE.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_ADMIN_EMAIL=
ALERT_DISK_MIN_FREE_PERCENT=10
