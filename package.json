{
  "name": "mi-sistema-empresarial",
  "version": "1.0.0",
  "description": "Simple inventory system with login and dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "backup": "node scripts/backup.js",
    "migrate-uploads": "node tools/migrate_uploads.js",
    "db:test": "node tools/db_test.js",
    "migrate:postgres": "node tools/migrate_sqlite_to_postgres.js",
    "test": "node tools/selfcheck.js",
    "seed:cuscar": "node tools/seed-cuscar-catalogs.js",
    "seed:locations": "node tools/seed-locations.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes",
      "views",
      "public",
      "middleware",
      "models",
      "services",
      "utils",
      "config"
    ],
    "ext": "js,json,ejs,css",
    "ignore": [
      "node_modules",
      "*.sqlite",
      "*.sqlite3",
      "*.db",
      "sessions",
      "uploads"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.6.0",
    "connect-sqlite3": "^0.9.15",
    "country-state-city": "^3.2.1",
    "csurf": "^1.11.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "openai": "^5.7.0",
    "pdfkit": "^0.17.1",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "sqlite3": "5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
