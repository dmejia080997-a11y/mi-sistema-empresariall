<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('settings.package_sender_title') %>
</title>
<link rel="stylesheet" href="/styles.css" />
</head>
<body class="page">
<header class="topbar">
<div class="brand">
<%= t('common.brand') %>
</div>
<nav class="nav">
<a href="/dashboard">
<%= t('nav.dashboard') %>
</a>
<a href="/logout">
<%= t('nav.logout') %>
</a>
</nav>
</header>
<main class="container">
<div class="page-header">
<div>
<h1>
<%= t('settings.package_sender_title') %>
</h1>
<p class="muted">
<%= t('settings.package_sender_subtitle') %>
</p>
</div>
<div class="actions">
<a class="btn" href="/settings">
<%= t('settings.back_settings') %>
</a>
</div>
</div>
<% if (message && message.message) { %>
<div class="alert <%= message.type || '' %>">
<%= message.message %>
</div>
<% } %>
<section class="panel">
<form method="POST" action="/settings/package-sender" class="form grid-2">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
<%= t('settings.package_sender_name_label') %>
<input type="text" name="sender_name" value="<%= senderName || '' %>" />
</label>
<label>
<%= t('settings.package_sender_store_label') %>
<input type="text" name="store_name" value="<%= storeName || '' %>" />
</label>
<div>
<button type="submit" class="btn primary">
<%= t('common.save') %>
</button>
</div>
</form>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
