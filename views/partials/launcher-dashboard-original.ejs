<section
  class="launcher-original"
  data-original-launcher
  data-csrf="<%= csrfToken %>"
  data-widget-prefs='<%- JSON.stringify(widgetPrefs || null) %>'>
  <section class="widget-panel">
    <div>
      <p class="eyebrow"><%= t('launcher.widgets_eyebrow') %></p>
      <h2><%= t('launcher.widgets_title') %></h2>
      <p class="muted"><%= t('launcher.widgets_subtitle') %></p>
    </div>
    <div class="widget-toggles">
      <label class="widget-toggle">
        <input type="checkbox" data-widget-toggle="hero" checked />
        <span><%= t('launcher.widgets_hero') %></span>
      </label>
      <label class="widget-toggle">
        <input type="checkbox" data-widget-toggle="notes" checked />
        <span><%= t('launcher.widgets_notes') %></span>
      </label>
      <label class="widget-toggle">
        <input type="checkbox" data-widget-toggle="planner" checked />
        <span><%= t('launcher.widgets_planner') %></span>
      </label>
      <label class="widget-toggle">
        <input type="checkbox" data-widget-toggle="apps" checked />
        <span><%= t('launcher.widgets_apps') %></span>
      </label>
    </div>
  </section>

  <section class="widgets-layout" data-widget-layout>
    <section class="widget-card launcher-hero" data-widget-card="hero">
      <div class="launcher-hero">
        <div>
          <p class="eyebrow"><%= t('launcher.eyebrow') %></p>
          <h1><%= (companyBrand && companyBrand.name) ? companyBrand.name : t('common.brand') %></h1>
          <p class="muted"><%= t('launcher.type.original.desc') %></p>
        </div>
        <aside class="launcher-callout">
          <div class="launcher-callout-title"><%= t('launcher.settings.current_launcher') %></div>
          <div class="launcher-callout-body">
            <div class="launcher-pill">
              <span><%= t('launcher.type.original.name') %></span>
              <strong><%= (launcherModules || []).length %></strong>
            </div>
            <div class="launcher-pill">
              <span><%= t('launcher.stats.total_packages') %></span>
              <strong><%= stats.packageCount || 0 %></strong>
            </div>
            <div class="launcher-pill">
              <span><%= t('launcher.stats.low_stock') %></span>
              <strong><%= stats.lowStock || 0 %></strong>
            </div>
          </div>
        </aside>
      </div>
      <div class="launcher-stats">
        <% (dashboardModel.statCards || []).forEach((metric) => { %>
        <article class="launcher-stat">
          <span class="launcher-stat__label"><%= metric.label %></span>
          <strong class="launcher-stat__value"><%= metric.value %></strong>
        </article>
        <% }) %>
      </div>
    </section>

    <section class="widget-card notes-board" data-widget-card="notes" data-notes-board>
      <div class="notes-header">
        <div>
          <p class="eyebrow"><%= t('launcher.notes_eyebrow') %></p>
          <h2><%= t('launcher.notes_title') %></h2>
          <p class="muted"><%= t('launcher.notes_subtitle') %></p>
        </div>
        <div class="notes-actions">
          <button class="btn primary notes-add" type="button" data-notes-add><%= t('launcher.notes_add') %></button>
          <button class="notes-layout" type="button" data-notes-layout><%= t('launcher.notes_layout_vertical') %></button>
          <button class="notes-hide" type="button" data-notes-hide><%= t('launcher.notes_hide') %></button>
        </div>
      </div>
      <div class="notes-collapsed">
        <span><%= t('launcher.notes_hidden') %></span>
        <button class="notes-show" type="button" data-notes-show><%= t('launcher.notes_show') %></button>
      </div>
      <div class="notes-grid" data-notes-grid></div>
    </section>

    <section class="widget-card planner-board" data-widget-card="planner" data-planner-board>
      <div class="planner-header">
        <div>
          <p class="eyebrow"><%= t('launcher.planner_eyebrow') %></p>
          <h2><%= t('launcher.planner_title') %></h2>
          <p class="muted"><%= t('launcher.planner_subtitle') %></p>
        </div>
        <div class="planner-actions">
          <button class="btn primary planner-quick-toggle" type="button" data-planner-quick-toggle><%= t('launcher.planner_quick_toggle') %></button>
          <label class="planner-filter">
            <span class="planner-filter-label"><%= t('launcher.planner_focus_date') %></span>
            <input class="planner-filter-input" type="date" data-planner-focus-date />
            <button class="planner-filter-clear" type="button" data-planner-focus-today><%= t('launcher.planner_today') %></button>
          </label>
          <label class="planner-filter">
            <input type="checkbox" data-planner-hide-past />
            <span><%= t('launcher.planner_hide_past') %></span>
          </label>
          <div class="planner-palette">
            <span class="planner-palette-label"><%= t('launcher.planner_color') %></span>
            <div class="planner-palette-swatches" data-planner-palette></div>
          </div>
        </div>
      </div>

      <div class="planner-quick" data-planner-quick>
        <div class="planner-quick-fields">
          <label>
            <span><%= t('launcher.planner_quick_date') %></span>
            <input type="date" data-planner-quick-date />
          </label>
          <label class="planner-quick-text">
            <span><%= t('launcher.planner_quick_text') %></span>
            <input type="text" maxlength="200" placeholder="<%= t('launcher.planner_quick_placeholder') %>" data-planner-quick-text />
          </label>
        </div>
        <div class="planner-quick-actions">
          <button class="btn primary planner-quick-save" type="button" data-planner-quick-save><%= t('launcher.planner_quick_add') %></button>
          <button class="planner-quick-cancel" type="button" data-planner-quick-cancel><%= t('launcher.planner_quick_cancel') %></button>
        </div>
      </div>

      <div class="planner-grid" data-planner-grid></div>
    </section>

    <section class="widget-card" data-widget-card="apps">
      <div class="launcher-section-head">
        <div>
          <p class="eyebrow"><%= t('launcher.section.modules') %></p>
          <h2><%= t('launcher.section.modules_title') %></h2>
          <p class="muted"><%= t('launcher.section.modules_desc') %></p>
        </div>
      </div>
      <div class="launcher-module-grid launcher-module-grid--classic">
        <% if ((launcherModules || []).length === 0) { %>
        <div class="launcher-empty-state"><%= t('launcher.no_modules') %></div>
        <% } %>
        <% (launcherModules || []).forEach((mod) => { %>
        <a class="launcher-module-card" href="<%= mod.href %>" style="--app-color:<%= mod.color %>">
          <div class="launcher-module-card__icon"><%- icons[mod.icon || mod.key] || icons.default %></div>
          <div class="launcher-module-card__body">
            <div class="launcher-module-card__name"><%= mod.name %></div>
            <div class="launcher-module-card__desc"><%= mod.desc %></div>
          </div>
        </a>
        <% }) %>
      </div>
    </section>
  </section>
</section>
