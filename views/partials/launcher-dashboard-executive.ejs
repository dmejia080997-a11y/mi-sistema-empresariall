<section class="launcher-stage launcher-stage--executive">
<div class="launcher-stage-copy">
<p class="eyebrow"><%= t('launcher.type.executive.name') %></p>
<h1><%= (companyBrand && companyBrand.name) ? companyBrand.name : t('common.brand') %></h1>
<p class="muted"><%= t('launcher.type.executive.desc') %></p>
</div>
<div class="launcher-stage-badges">
<span class="launcher-pill"><%= t('launcher.stats.total_items') %>: <strong><%= stats.itemCount || 0 %></strong></span>
<span class="launcher-pill"><%= t('launcher.stats.low_stock') %>: <strong><%= stats.lowStock || 0 %></strong></span>
</div>
</section>

<section class="launcher-executive-grid">
<section class="launcher-section launcher-section--stats">
<div class="launcher-section-head">
<div>
<p class="eyebrow"><%= t('launcher.quick_title') %></p>
<h2><%= t('launcher.section.metrics') %></h2>
</div>
</div>
<div class="launcher-stat-grid">
<% (dashboardModel.statCards || []).forEach((metric) => { %>
<article class="launcher-stat-card">
<span class="launcher-stat-card__label"><%= metric.label %></span>
<strong class="launcher-stat-card__value"><%= metric.value %></strong>
</article>
<% }) %>
</div>
</section>

<section class="launcher-section launcher-section--alerts">
<div class="launcher-section-head">
<div>
<p class="eyebrow"><%= t('launcher.section.alerts') %></p>
<h2><%= t('launcher.section.alerts_title') %></h2>
</div>
</div>
<div class="launcher-alert-list">
<% (dashboardModel.alerts || []).forEach((alertItem) => { %>
<article class="launcher-alert-card tone-<%= alertItem.tone %>">
<div>
<div class="launcher-alert-card__title"><%= alertItem.title %></div>
<div class="launcher-alert-card__desc"><%= alertItem.description %></div>
</div>
<a class="btn" href="<%= alertItem.href %>"><%= alertItem.cta %></a>
</article>
<% }) %>
</div>
</section>
</section>

<section class="launcher-section">
<div class="launcher-section-head">
<div>
<p class="eyebrow"><%= t('launcher.section.modules') %></p>
<h2><%= t('launcher.section.secondary_actions') %></h2>
</div>
</div>
<div class="launcher-module-grid launcher-module-grid--executive">
<% if ((launcherModules || []).length === 0) { %>
<div class="launcher-empty-state"><%= t('launcher.no_modules') %></div>
<% } %>
<% (launcherModules || []).forEach((mod) => { %>
<a class="launcher-module-card launcher-module-card--compact" href="<%= mod.href %>" style="--app-color:<%= mod.color %>">
<div class="launcher-module-card__icon"><%- icons[mod.icon || mod.key] || icons.default %></div>
<div class="launcher-module-card__body">
<div class="launcher-module-card__name"><%= mod.name %></div>
<div class="launcher-module-card__desc"><%= mod.desc %></div>
</div>
</a>
<% }) %>
</div>
</section>
