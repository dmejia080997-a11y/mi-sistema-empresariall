<section class="launcher-stage launcher-stage--classic">
<div class="launcher-stage-copy">
<p class="eyebrow"><%= t('launcher.eyebrow') %></p>
<h1><%= (companyBrand && companyBrand.name) ? companyBrand.name : t('common.brand') %></h1>
<p class="muted"><%= t('launcher.type.classic.desc') %></p>
</div>
<div class="launcher-stage-metrics">
<% (dashboardModel.heroMetrics || []).forEach((metric) => { %>
<article class="launcher-kpi-chip">
<span class="launcher-kpi-label"><%= metric.label %></span>
<strong class="launcher-kpi-value"><%= metric.value %></strong>
</article>
<% }) %>
</div>
</section>

<section class="launcher-section">
<div class="launcher-section-head">
<div>
<p class="eyebrow"><%= t('launcher.section.modules') %></p>
<h2><%= t('launcher.section.modules_title') %></h2>
<p class="muted"><%= t('launcher.section.modules_desc') %></p>
</div>
</div>
<div class="launcher-module-grid launcher-module-grid--classic">
<% if ((launcherModules || []).length === 0) { %>
<div class="launcher-empty-state"><%= t('launcher.no_modules') %></div>
<% } %>
<% (launcherModules || []).forEach((mod) => { %>
<a class="launcher-module-card" href="<%= mod.href %>" style="--app-color:<%= mod.color %>">
<div class="launcher-module-card__icon"><%- icons[mod.icon || mod.key] || icons.default %></div>
<div class="launcher-module-card__body">
<div class="launcher-module-card__name"><%= mod.name %></div>
<div class="launcher-module-card__desc"><%= mod.desc %></div>
</div>
</a>
<% }) %>
</div>
</section>
