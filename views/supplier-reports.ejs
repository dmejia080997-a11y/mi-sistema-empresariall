<!DOCTYPE html>
<html lang="<%= lang %>">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Reportes de proveedores</title><%- include('partials/head-assets') %><link rel="stylesheet" href="/css/suppliers.css" /></head>
<body class="page suppliers-page">
<%- include('partials/header', { moduleTabs: [{ key:'list',label:'Proveedores',href:'/suppliers' },{ key:'reports',label:'Reportes',href:'/suppliers/reports' }], activeTab:'reports', currentModule:'suppliers' }) %>
<main class="container suppliers-shell">
  <%- include('partials/page-shell', { pageTitle:'Reportes de proveedores', pageSubtitle:'Indicadores comerciales, documentales y operativos de la empresa activa.' }) %>
  <section class="supplier-kpis"><article><span>Total proveedores</span><strong><%= summary.total || 0 %></strong></article><article><span>Proveedores activos</span><strong><%= summary.active || 0 %></strong></article><article><span>Bloqueados</span><strong><%= blocked.length %></strong></article><article><span>Documentos vencidos</span><strong><%= expiredDocuments.length %></strong></article><article><span>Ordenes registradas</span><strong><%= purchases.reduce((sum,row) => sum + Number(row.order_count || 0), 0) %></strong></article></section>
  <section class="supplier-columns">
    <article class="panel"><h2>Proveedores por pais</h2><div class="table-wrap"><table><thead><tr><th>Pais</th><th>Total</th></tr></thead><tbody><% byCountry.forEach(row => { %><tr><td><%= row.label %></td><td><%= row.total %></td></tr><% }) %></tbody></table></div></article>
    <article class="panel"><h2>Nacionales e internacionales</h2><div class="table-wrap"><table><thead><tr><th>Tipo</th><th>Total</th></tr></thead><tbody><% byType.forEach(row => { %><tr><td><%= row.label === 'international' ? 'Internacional' : 'Nacional' %></td><td><%= row.total %></td></tr><% }) %></tbody></table></div></article>
  </section>
  <section class="panel"><h2>Compras por proveedor</h2><div class="table-wrap"><table><thead><tr><th>Proveedor</th><th>Ordenes</th><th>Total registrado</th></tr></thead><tbody><% purchases.forEach(row => { %><tr><td><a href="/suppliers/<%= row.id %>?tab=purchases"><%= row.code %> · <%= row.trade_name %></a></td><td><%= row.order_count %></td><td><%= Number(row.total || 0).toFixed(2) %></td></tr><% }) %></tbody></table></div></section>
  <section class="panel"><h2>Cuentas por pagar por proveedor</h2><div class="table-wrap"><table><thead><tr><th>Proveedor</th><th>Facturas</th><th>Total</th><th>Pagado</th><th>Saldo</th></tr></thead><tbody><% payables.forEach(row => { %><tr><td><a href="/suppliers/<%= row.id %>?tab=payments"><%= row.code %> · <%= row.trade_name %></a></td><td><%= row.bill_count %></td><td><%= Number(row.total || 0).toFixed(2) %></td><td><%= Number(row.paid || 0).toFixed(2) %></td><td><%= (Number(row.total || 0)-Number(row.paid || 0)).toFixed(2) %></td></tr><% }) %></tbody></table></div></section>
  <section class="supplier-columns">
    <article class="panel"><h2>Documentos vencidos</h2><div class="supplier-card-grid"><% expiredDocuments.forEach(row => { %><a class="supplier-card" href="/suppliers/<%= row.supplier_id %>?tab=documents"><strong><%= row.code %> · <%= row.trade_name %></strong><span><%= row.document_name %></span><span>Vencio: <%= row.expires_at %></span></a><% }) %></div></article>
    <article class="panel"><h2>Proveedores bloqueados</h2><div class="supplier-card-grid"><% blocked.forEach(row => { %><a class="supplier-card" href="/suppliers/<%= row.id %>"><strong><%= row.code %></strong><span><%= row.trade_name %></span><span><%= row.country || '-' %></span></a><% }) %></div></article>
  </section>
  <section class="panel"><h2>Historial de precios por proveedor</h2><div class="table-wrap"><table><thead><tr><th>Proveedor</th><th>Producto</th><th>Ultimo precio</th><th>Actualizado</th></tr></thead><tbody><% priceHistory.forEach(row => { %><tr><td><%= row.code %> · <%= row.trade_name %></td><td><%= row.item_name || '-' %></td><td><%= row.currency || 'GTQ' %> <%= Number(row.last_price || 0).toFixed(2) %></td><td><%= row.updated_at %></td></tr><% }) %></tbody></table></div></section>
  <section class="panel"><h2>Tiempo promedio de entrega</h2><div class="table-wrap"><table><thead><tr><th>Proveedor</th><th>Dias</th></tr></thead><tbody><% delivery.forEach(row => { %><tr><td><a href="/suppliers/<%= row.id %>"><%= row.code %> · <%= row.trade_name %></a></td><td><%= row.average_delivery_days %></td></tr><% }) %></tbody></table></div></section>
</main></body></html>
