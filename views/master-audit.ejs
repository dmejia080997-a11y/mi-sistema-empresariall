<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'es' %>">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Master - Auditoria</title><%- include('partials/head-assets') %></head>
<body class="page master-shell-page">
<%- include('partials/header', { headerBrandText: 'Panel Master', homeHref: '/master', showDefaultNav: false, headerActionsHtml: `<nav class="master-tabs"><a href="/master">Empresas</a><a href="/master/monitoring">Monitoreo</a><a href="/master/backups">Backups</a><a href="/master/audit" class="is-active">Auditoria</a></nav><a href="/master/logout" class="btn app-btn">Cerrar sesion</a>` }) %>
<main class="container master-page">
  <div class="page-header app-page-header"><div><p class="app-page-eyebrow">Master</p><h1>Auditoria global</h1><p class="muted">Eventos administrativos del sistema. No se elimina desde la interfaz.</p></div></div>
  <section class="app-card"><div class="app-table-wrap"><table class="app-table"><thead><tr><th>ID</th><th>Fecha</th><th>Empresa</th><th>Usuario</th><th>Accion</th><th>Modulo</th><th>Descripcion</th><th>IP</th></tr></thead><tbody><% (auditLogs || []).forEach(log => { %><tr><td><%= log.id %></td><td><%= log.created_at %></td><td><%= log.company_id || '-' %></td><td><%= log.user_name || log.user_id || '-' %></td><td><%= log.action %></td><td><%= log.module || '-' %></td><td><%= log.description || '-' %></td><td><%= log.ip_address || '-' %></td></tr><% }) %></tbody></table></div></section>
</main>
</body></html>
