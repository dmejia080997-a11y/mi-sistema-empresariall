<!DOCTYPE html>
<%
  const tabs = [
    ['general','Datos generales'], ['contacts','Contactos'], ['fiscal','Datos fiscales'], ['banks','Cuentas bancarias'],
    ['documents','Documentos'], ['purchases','Compras'], ['payments','Pagos'], ['evaluation','Evaluacion'], ['audit','Historial / auditoria']
  ];
  const statusLabel = (key) => (statuses.find(([value]) => value === key) || [null, key])[1];
  const money = (value, curr) => `${curr || supplier.primary_currency || 'GTQ'} ${Number(value || 0).toFixed(2)}`;
%>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= supplier.trade_name %> - Proveedores</title>
  <%- include('partials/head-assets') %><link rel="stylesheet" href="/css/suppliers.css" />
</head>
<body class="page suppliers-page">
  <%- include('partials/header', { moduleTabs: [{ key: 'list', label: 'Proveedores', href: '/suppliers' }, ...(can('suppliers','reports') ? [{ key:'reports',label:'Reportes',href:'/suppliers/reports' }] : []), ...(can('suppliers','create') ? [{ key: 'new', label: 'Registrar proveedor', href: '/suppliers/new' }] : [])], activeTab: 'list', currentModule: 'suppliers' }) %>
  <main class="container suppliers-shell">
    <section class="supplier-hero">
      <div><span class="eyebrow"><%= supplier.code %></span><h1><%= supplier.trade_name %></h1><p class="muted"><%= supplier.legal_name || 'Sin razon social' %> · <%= supplier.supplier_type === 'international' ? 'Internacional' : 'Nacional' %></p></div>
      <div class="supplier-hero-actions"><span class="supplier-status supplier-status-<%= supplier.status %>"><%= statusLabel(supplier.status) %></span><a class="btn" href="/suppliers">Volver</a></div>
    </section>
    <%- include('partials/toasts', { flash }) %>
    <nav class="supplier-tabs"><% tabs.forEach(([key,label]) => { if ((key === 'fiscal' && !canFiscal) || (key === 'banks' && !canBank)) return; %><a class="<%= activeSection === key ? 'active' : '' %>" href="/suppliers/<%= supplier.id %>?tab=<%= key %>"><%= label %></a><% }) %></nav>

    <% if (activeSection === 'general') { %>
      <section class="supplier-columns">
        <article class="panel"><h2>Resumen</h2><div class="detail-grid supplier-detail-grid">
          <div><strong>Identificacion fiscal</strong><span><%= supplier.tax_id || 'Restringido o no registrado' %></span></div>
          <div><strong>Pais</strong><span><%= supplier.country || '-' %></span></div><div><strong>Categoria</strong><span><%= supplier.category || '-' %></span></div>
          <div><strong>Moneda</strong><span><%= supplier.primary_currency || 'GTQ' %></span></div><div><strong>Credito</strong><span><%= supplier.credit_days || 0 %> dias</span></div>
          <div><strong>Limite</strong><span><%= money(supplier.credit_limit) %></span></div><div><strong>Entrega</strong><span><%= supplier.average_delivery_days || 0 %> dias</span></div>
          <div><strong>Pedido minimo</strong><span><%= money(supplier.minimum_order) %></span></div><div><strong>Forma de pago</strong><span><%= supplier.payment_method || '-' %></span></div>
        </div></article>
        <article class="panel"><h2>Cambiar estado</h2><form method="POST" action="/suppliers/<%= supplier.id %>/status" class="supplier-stack">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" /><select name="status">
            <% statuses.forEach(([key,label]) => { if ((['approved','active'].includes(key) && !can('suppliers','approve')) || (key === 'blocked' && !can('suppliers','block')) || (key === 'inactive' && !can('suppliers','delete'))) return; %><option value="<%= key %>" <%= supplier.status === key ? 'selected' : '' %>><%= label %></option><% }) %>
          </select><textarea name="reason" placeholder="Motivo del cambio"></textarea><button class="btn primary" type="submit">Actualizar estado</button>
        </form></article>
      </section>
      <% if (can('suppliers','edit')) { %><section class="panel"><h2>Editar informacion general</h2><form class="supplier-grid" method="POST" action="/suppliers/<%= supplier.id %>/update">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>Tipo<select name="supplier_type"><option value="national" <%= supplier.supplier_type === 'national' ? 'selected' : '' %>>Nacional</option><option value="international" <%= supplier.supplier_type === 'international' ? 'selected' : '' %>>Internacional</option></select></label>
        <label>Nombre comercial<input name="trade_name" required value="<%= supplier.trade_name || '' %>" /></label><label>Razon social<input name="legal_name" value="<%= supplier.legal_name || '' %>" /></label>
        <% if (canFiscal) { %><label>NIT / Tax ID<input name="tax_id" value="<%= supplier.tax_id || '' %>" /></label><% } %><label>Pais<input name="country" value="<%= supplier.country || '' %>" /></label><label>Pais de origen<input name="origin_country" value="<%= supplier.origin_country || '' %>" /></label>
        <label>Categoria<input name="category" value="<%= supplier.category || '' %>" /></label><label>Telefono<input name="phone" value="<%= supplier.phone || '' %>" /></label><label>Correo<input type="email" name="email" value="<%= supplier.email || '' %>" /></label>
        <label>Pagina web<input name="website" value="<%= supplier.website || '' %>" /></label><label>Moneda<input name="primary_currency" value="<%= supplier.primary_currency || 'GTQ' %>" /></label><label>Dias credito<input type="number" name="credit_days" value="<%= supplier.credit_days || 0 %>" /></label>
        <label>Limite credito<input type="number" step="0.01" name="credit_limit" value="<%= supplier.credit_limit || 0 %>" /></label><label>Forma pago<input name="payment_method" value="<%= supplier.payment_method || '' %>" /></label><label>Entrega (dias)<input type="number" name="average_delivery_days" value="<%= supplier.average_delivery_days || 0 %>" /></label>
        <label>Pedido minimo<input type="number" step="0.01" name="minimum_order" value="<%= supplier.minimum_order || 0 %>" /></label><% if (canFiscal) { %><label>Regimen fiscal<input name="tax_regime" value="<%= supplier.tax_regime || '' %>" /></label><label>Nombre factura<input name="invoice_name" value="<%= supplier.invoice_name || '' %>" /></label><% } %>
        <label>Incoterm<input name="frequent_incoterm" value="<%= supplier.frequent_incoterm || '' %>" /></label><% if (canFiscal) { %><label class="supplier-check"><input type="checkbox" name="withholding_isr" <%= supplier.withholding_isr ? 'checked' : '' %> /> Retencion ISR</label><label class="supplier-check"><input type="checkbox" name="withholding_iva" <%= supplier.withholding_iva ? 'checked' : '' %> /> Retencion IVA</label>
        <label class="supplier-check"><input type="checkbox" name="electronic_invoice" <%= supplier.electronic_invoice ? 'checked' : '' %> /> Factura electronica</label><% } %><label class="supplier-check"><input type="checkbox" name="requires_import" <%= supplier.requires_import ? 'checked' : '' %> /> Requiere importacion</label>
        <% if (canFiscal) { %><label class="full-row">Direccion fiscal<textarea name="tax_address"><%= supplier.tax_address || '' %></textarea></label><% } %><label class="full-row">Direccion bodega<textarea name="warehouse_address"><%= supplier.warehouse_address || '' %></textarea></label>
        <label class="full-row">Documentos frecuentes<textarea name="frequent_documents"><%= supplier.frequent_documents || '' %></textarea></label><label class="full-row">Observaciones<textarea name="notes"><%= supplier.notes || '' %></textarea></label>
        <div class="full-row"><button class="btn primary" type="submit">Guardar cambios</button></div>
      </form></section><% } %>
      <% if (can('suppliers','edit')) { %><section class="panel"><h2>Condiciones comerciales detalladas</h2><form class="supplier-grid" method="POST" action="/suppliers/<%= supplier.id %>/terms"><input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>Dias credito<input type="number" name="credit_days" value="<%= terms.credit_days || supplier.credit_days || 0 %>" /></label><label>Limite credito<input type="number" step="0.01" name="credit_limit" value="<%= terms.credit_limit || supplier.credit_limit || 0 %>" /></label><label>Moneda<input name="currency" value="<%= terms.currency || supplier.primary_currency || 'GTQ' %>" /></label>
        <label>Forma pago<input name="payment_method" value="<%= terms.payment_method || supplier.payment_method || '' %>" /></label><label>Entrega (dias)<input type="number" name="delivery_days" value="<%= terms.delivery_days || supplier.average_delivery_days || 0 %>" /></label><label>Pedido minimo<input type="number" step="0.01" name="minimum_order" value="<%= terms.minimum_order || supplier.minimum_order || 0 %>" /></label>
        <label>Descuento especial %<input type="number" step="0.01" name="special_discount" value="<%= terms.special_discount || 0 %>" /></label><label>Garantia<input name="warranty" value="<%= terms.warranty || '' %>" /></label><label class="full-row">Politica devolucion<textarea name="return_policy"><%= terms.return_policy || '' %></textarea></label><label class="full-row">Observaciones<textarea name="notes"><%= terms.notes || '' %></textarea></label>
        <div class="full-row"><button class="btn primary">Guardar condiciones</button></div></form></section><% } %>
    <% } %>

    <% if (activeSection === 'contacts') { %><section class="panel"><h2>Contactos</h2><div class="supplier-card-grid"><% contacts.forEach(row => { %><article class="supplier-card"><strong><%= row.name %><%= row.is_primary ? ' · Principal' : '' %></strong><span><%= row.position || row.area || '-' %></span><span><%= row.phone || row.whatsapp || '-' %></span><span><%= row.email || '-' %></span></article><% }) %></div>
      <% if (can('suppliers','edit')) { %><form class="supplier-grid supplier-inline-form" method="POST" action="/suppliers/<%= supplier.id %>/contacts"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><label>Nombre<input required name="name" /></label><label>Puesto<input name="position" /></label><label>Telefono<input name="phone" /></label><label>WhatsApp<input name="whatsapp" /></label><label>Correo<input type="email" name="email" /></label><label>Area<select name="area"><% ['Ventas','Cobros','Logistica','Aduanas','Gerencia'].forEach(v => { %><option><%= v %></option><% }) %></select></label><label class="supplier-check"><input type="checkbox" name="is_primary" /> Contacto principal</label><div><button class="btn primary">Agregar contacto</button></div></form><% } %></section><% } %>

    <% if (activeSection === 'fiscal' && canFiscal) { %><section class="panel"><h2>Datos fiscales e importacion</h2><div class="detail-grid supplier-detail-grid"><% [['NIT / Tax ID',supplier.tax_id],['Regimen fiscal',supplier.tax_regime],['Nombre para factura',supplier.invoice_name],['Direccion fiscal',supplier.tax_address],['Retencion ISR',supplier.withholding_isr ? 'Si':'No'],['Retencion IVA',supplier.withholding_iva ? 'Si':'No'],['Factura electronica',supplier.electronic_invoice ? 'Si':'No'],['Incoterm',supplier.frequent_incoterm],['Requiere importacion',supplier.requires_import ? 'Si':'No'],['Documentos frecuentes',supplier.frequent_documents]].forEach(([label,value]) => { %><div><strong><%= label %></strong><span><%= value || '-' %></span></div><% }) %></div></section><% } %>

    <% if (activeSection === 'banks' && canBank) { %><section class="panel"><h2>Cuentas bancarias</h2><div class="table-wrap"><table><thead><tr><th>Banco</th><th>Cuenta</th><th>Tipo</th><th>Moneda / pais</th><th>SWIFT / ABA / IBAN</th></tr></thead><tbody><% banks.forEach(row => { %><tr><td><%= row.bank_name || '-' %></td><td><strong><%= row.account_name || '-' %></strong><small><%= row.account_number || '-' %></small></td><td><%= row.account_type || '-' %></td><td><%= row.currency || '-' %> · <%= row.country || '-' %></td><td><%= row.swift_aba_iban || '-' %></td></tr><% }) %></tbody></table></div>
      <form class="supplier-grid supplier-inline-form" method="POST" enctype="multipart/form-data" action="/suppliers/<%= supplier.id %>/banks"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><label>Banco<input name="bank_name" required /></label><label>Nombre cuenta<input name="account_name" /></label><label>Numero cuenta<input name="account_number" /></label><label>Tipo cuenta<input name="account_type" /></label><label>Moneda<input name="currency" value="GTQ" /></label><label>Pais<input name="country" /></label><label>SWIFT / ABA / IBAN<input name="swift_aba_iban" /></label><label>Documento respaldo<input type="file" name="support_document" /></label><label class="full-row">Observaciones<textarea name="notes"></textarea></label><div class="full-row"><button class="btn primary">Agregar cuenta</button></div></form></section><% } %>

    <% if (activeSection === 'documents') { %><section class="panel"><h2>Documentos</h2><div class="table-wrap"><table><thead><tr><th>Tipo</th><th>Documento</th><th>Vence</th><th>Estado</th><th></th></tr></thead><tbody><% documents.forEach(row => { const expired = row.expires_at && row.expires_at < new Date().toISOString().slice(0,10); %><tr><td><%= row.document_type || '-' %></td><td><%= row.document_name %></td><td><%= row.expires_at || 'Sin vencimiento' %></td><td><%= expired ? 'Vencido' : row.status %></td><td><% if (row.file_url) { %><a class="btn small" href="<%= row.file_url %>" target="_blank">Abrir</a><% } %></td></tr><% }) %></tbody></table></div>
      <% if (can('suppliers','create')) { %><form class="supplier-grid supplier-inline-form" method="POST" enctype="multipart/form-data" action="/suppliers/<%= supplier.id %>/documents"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><label>Tipo<select name="document_type"><% ['RTU','Patente de comercio','DPI representante legal','Contrato','Certificacion','Catalogo de productos','Lista de precios','Acuerdo comercial','Documento fiscal','Permiso importacion/exportacion'].forEach(v => { %><option><%= v %></option><% }) %></select></label><label>Nombre<input name="document_name" /></label><label>Vencimiento<input type="date" name="expires_at" /></label><label>Archivo<input required type="file" name="document" accept=".pdf,.png,.jpg,.jpeg,.webp,.xls,.xlsx,.doc,.docx" /></label><label class="full-row">Notas<textarea name="notes"></textarea></label><div class="full-row"><button class="btn primary">Adjuntar documento</button></div></form><% } %></section><% } %>

    <% if (activeSection === 'purchases') { %><section class="supplier-columns"><article class="panel"><h2>Ordenes de compra</h2><div class="supplier-card-grid"><% purchaseOrders.forEach(row => { %><article class="supplier-card"><strong><%= row.order_number %></strong><span><%= row.order_date %> · <%= row.status %></span><span><%= money(row.total, row.currency) %></span></article><% }) %></div><% if (can('suppliers','purchase')) { %><form class="supplier-stack supplier-inline-form" method="POST" action="/suppliers/<%= supplier.id %>/purchase-orders"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><label>Fecha esperada<input type="date" name="expected_date" /></label><label>Moneda<input name="currency" value="<%= supplier.primary_currency || 'GTQ' %>" /></label><label>Total estimado<input type="number" step="0.01" name="total" /></label><label>Notas<textarea name="notes"></textarea></label><button class="btn primary">Crear orden de compra</button></form><% } %></article>
      <article class="panel"><h2>Productos relacionados</h2><div class="supplier-card-grid"><% products.forEach(row => { %><article class="supplier-card"><strong><%= row.item_name || row.supplier_sku %></strong><span><%= row.sku || '-' %> · <%= money(row.last_price, row.currency) %></span><span>Entrega: <%= row.lead_time_days || 0 %> dias</span></article><% }) %></div><% if (can('suppliers','edit')) { %><form class="supplier-stack supplier-inline-form" method="POST" action="/suppliers/<%= supplier.id %>/products"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><label>Producto<select name="item_id"><% items.forEach(row => { %><option value="<%= row.id %>"><%= row.name %> (<%= row.sku || '-' %>)</option><% }) %></select></label><label>SKU proveedor<input name="supplier_sku" /></label><label>Ultimo precio<input type="number" step="0.01" name="last_price" /></label><label>Moneda<input name="currency" value="<%= supplier.primary_currency || 'GTQ' %>" /></label><label>Entrega dias<input type="number" name="lead_time_days" /></label><label class="supplier-check"><input type="checkbox" name="is_preferred" /> Preferido</label><button class="btn primary">Relacionar producto</button></form><% } %></article></section><% } %>

    <% if (activeSection === 'payments') { %><section class="panel"><h2>Cuentas por pagar y pagos</h2><p class="muted">Facturas recibidas y pagos vinculados al proveedor desde Contabilidad.</p><div class="table-wrap"><table><thead><tr><th>Factura / proveedor</th><th>Total</th><th>Pagado</th><th>Saldo</th><th>Estado</th></tr></thead><tbody><% bills.forEach(row => { %><tr><td><%= row.vendor_name || supplier.trade_name %></td><td><%= money(row.total,row.currency) %></td><td><%= money(row.paid_total,row.currency) %></td><td><%= money(Number(row.total || 0)-Number(row.paid_total || 0),row.currency) %></td><td><%= row.status %></td></tr><% }) %></tbody></table></div><% if (can('accounting','view')) { %><a class="btn primary" href="/accounting/payables">Abrir cuentas por pagar</a><% } %>
      <% if (can('accounting','manage') && unlinkedBills.length) { %><form class="supplier-inline-form supplier-stack" method="POST" action="/suppliers/<%= supplier.id %>/bills/link"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><label>Vincular cuenta por pagar existente<select name="bill_id"><% unlinkedBills.forEach(row => { %><option value="<%= row.id %>"><%= row.vendor_name || 'Sin proveedor' %> · <%= money(row.total,row.currency) %> · <%= row.created_at %></option><% }) %></select></label><button class="btn">Vincular cuenta</button></form><% } %></section>
      <section class="panel"><h2>Gastos asociados a proyectos</h2><div class="table-wrap"><table><thead><tr><th>Proyecto</th><th>Descripcion</th><th>Total</th><th>Estado contable</th></tr></thead><tbody><% projectExpenses.forEach(row => { %><tr><td><a href="/projects/<%= row.project_id %>"><%= row.project_code || '-' %> · <%= row.project_name %></a></td><td><%= row.description || '-' %></td><td><%= money(row.total_amount || row.amount) %></td><td><%= row.accounting_status || '-' %></td></tr><% }) %></tbody></table></div><h3>Proyectos disponibles</h3><div class="supplier-card-grid"><% projects.forEach(row => { %><a class="supplier-card" href="/projects/<%= row.id %>"><strong><%= row.code || '-' %></strong><span><%= row.name %></span></a><% }) %></div></section><% } %>

    <% if (activeSection === 'evaluation') { %><section class="panel"><h2>Evaluaciones</h2><div class="supplier-card-grid"><% evaluations.forEach(row => { %><article class="supplier-card"><strong><%= row.overall_rating %> / 5 · <%= row.evaluation_status %></strong><span>Calidad <%= row.product_quality %> · Entrega <%= row.delivery_time %> · Precio <%= row.price %> · Atencion <%= row.service %></span><span><%= row.comments || '-' %></span><small><%= row.created_by_name || '-' %> · <%= row.created_at %></small></article><% }) %></div>
      <% if (can('suppliers','evaluate')) { %><form class="supplier-grid supplier-inline-form" method="POST" action="/suppliers/<%= supplier.id %>/evaluations"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><% [['product_quality','Calidad'],['delivery_time','Tiempo entrega'],['price','Precio'],['service','Atencion'],['document_compliance','Cumplimiento documental'],['overall_rating','General']].forEach(([name,label]) => { %><label><%= label %><input type="number" min="1" max="5" name="<%= name %>" value="5" /></label><% }) %><label>Estado<select name="evaluation_status"><option value="recommended">Recomendado</option><option value="observation">En observacion</option><option value="not_recommended">No recomendado</option><option value="blocked">Bloqueado</option></select></label><label class="full-row">Reclamaciones<textarea name="complaints"></textarea></label><label class="full-row">Comentarios internos<textarea name="comments"></textarea></label><div class="full-row"><button class="btn primary">Registrar evaluacion</button></div></form><% } %></section><% } %>

    <% if (activeSection === 'audit') { %><section class="panel"><h2>Historial / auditoria</h2><div class="supplier-audit"><% auditLogs.forEach(row => { %><article><strong><%= row.action %></strong><span><%= row.username || 'Sistema' %> · <%= row.created_at %></span><code><%= row.details || '{}' %></code></article><% }) %></div></section><% } %>
  </main>
</body>
</html>
