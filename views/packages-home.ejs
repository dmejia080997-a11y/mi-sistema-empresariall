<%
  var currentPackagesNav = typeof packagesNav !== 'undefined' ? packagesNav : 'list';
  var canCreatePackageTabs = can('packages', 'create');
  var packageModuleTabs = [
    { key: 'dashboard', label: t('packages.module.dashboard'), href: '/packages/dashboard' },
    { key: 'list', label: t('packages.module.list'), href: '/packages' },
    { key: 'pending_invoice', label: t('packages.module.pending_invoice'), href: '/packages/pending-invoice' }
  ];
  if (canCreatePackageTabs) {
    packageModuleTabs.push({ key: 'new', label: t('packages.module.new'), href: '/packages/new' });
  }
  packageModuleTabs.push(
    { key: 'statuses', label: t('packages.module.statuses'), href: '/packages/statuses' },
    { key: 'tracking', label: t('packages.module.tracking'), href: '/packages/tracking' }
  );
%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('packages.title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header', {
  moduleTabs: packageModuleTabs,
  activeTab: currentPackagesNav,
  currentModule: 'packages'
}) %>
<main class="container packages-module">
<div class="page-header">
<div>
<h1>
<%= t('packages.title') %>
</h1>
<p class="muted">
<%= t('packages.subtitle') %>
</p>
</div>
<div class="actions">
<a class="btn" href="/packages/new">
<%= t('packages.module.new') %>
</a>
<a class="btn" href="/packages">
<%= t('packages.module.list') %>
</a>
</div>
</div>
<section class="panel module-landing">
<div class="module-tiles">
<a class="module-tile" href="/packages/new">
<div class="module-tile-title">
<%= t('packages.module.new') %>
</div>
<div class="module-tile-sub">
<%= t('packages.new_package') %>
</div>
</a>
<a class="module-tile" href="/packages">
<div class="module-tile-title">
<%= t('packages.module.list') %>
</div>
<div class="module-tile-sub">
<%= t('packages.list') %>
</div>
</a>
<a class="module-tile" href="/packages/pending-invoice">
<div class="module-tile-title">
<%= t('packages.module.pending_invoice') %>
</div>
<div class="module-tile-sub">
<%= t('packages.pending_invoice.subtitle') %>
</div>
</a>
<a class="module-tile" href="/packages/dashboard">
<div class="module-tile-title">
<%= t('packages.module.dashboard') %>
</div>
<div class="module-tile-sub">
<%= t('packages_dashboard.subtitle') %>
</div>
</a>
<a class="module-tile" href="/packages/tracking">
<div class="module-tile-title">
<%= t('packages.module.tracking') %>
</div>
<div class="module-tile-sub">
<%= t('packages.module.tracking_desc') %>
</div>
</a>
</div>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
