<% var currentPackagesNav = typeof packagesNav !== 'undefined' ? packagesNav : 'list'; %>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('packages.title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container packages-module">
<div class="page-header">
<div>
<h1>
<%= t('packages.title') %>
</h1>
<p class="muted">
<%= t('packages.subtitle') %>
</p>
</div>
<div class="actions">
<a class="btn" href="/packages/new">
<%= t('packages.module.new') %>
</a>
<a class="btn" href="/packages">
<%= t('packages.module.list') %>
</a>
</div>
</div>
<div class="module-nav">
<a href="/packages/dashboard" class="<%= currentPackagesNav === 'dashboard' ? 'active' : '' %>">
<%= t('packages.module.dashboard') %>
</a>
<a href="/packages" class="<%= currentPackagesNav === 'list' ? 'active' : '' %>">
<%= t('packages.module.list') %>
</a>
<a href="/packages/pending-invoice" class="<%= currentPackagesNav === 'pending_invoice' ? 'active' : '' %>">
<%= t('packages.module.pending_invoice') %>
</a>
<a href="/packages/new" class="<%= currentPackagesNav === 'new' ? 'active' : '' %>">
<%= t('packages.module.new') %>
</a>
<a href="/packages/statuses" class="<%= currentPackagesNav === 'statuses' ? 'active' : '' %>">
<%= t('packages.module.statuses') %>
</a>
<a href="/packages/tracking" class="<%= currentPackagesNav === 'tracking' ? 'active' : '' %>">
<%= t('packages.module.tracking') %>
</a>
</div>
<section class="panel module-landing">
<div class="module-tiles">
<a class="module-tile" href="/packages/new">
<div class="module-tile-title">
<%= t('packages.module.new') %>
</div>
<div class="module-tile-sub">
<%= t('packages.new_package') %>
</div>
</a>
<a class="module-tile" href="/packages">
<div class="module-tile-title">
<%= t('packages.module.list') %>
</div>
<div class="module-tile-sub">
<%= t('packages.list') %>
</div>
</a>
<a class="module-tile" href="/packages/pending-invoice">
<div class="module-tile-title">
<%= t('packages.module.pending_invoice') %>
</div>
<div class="module-tile-sub">
<%= t('packages.pending_invoice.subtitle') %>
</div>
</a>
<a class="module-tile" href="/packages/dashboard">
<div class="module-tile-title">
<%= t('packages.module.dashboard') %>
</div>
<div class="module-tile-sub">
<%= t('packages_dashboard.subtitle') %>
</div>
</a>
<a class="module-tile" href="/packages/tracking">
<div class="module-tile-title">
<%= t('packages.module.tracking') %>
</div>
<div class="module-tile-sub">
<%= t('packages.module.tracking_desc') %>
</div>
</a>
</div>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
