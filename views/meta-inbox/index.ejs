<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Mensajeria meta - Meta Inbox</title>
<%- include('../partials/head-assets') %>
<link rel="stylesheet" href="/css/meta-inbox.css" />
</head>
<%
  const fmt = (value) => {
    if (!value) return 'Sin fecha';
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? value : date.toLocaleString('es-GT', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
  };
  const statusLabel = { new: 'Nuevo', open: 'Abierto', pending: 'Pendiente', closed: 'Cerrado' };
  const channelLabel = { messenger: 'Messenger', facebook_comment: 'Comentario', facebook_lead: 'Lead Ads' };
  const initials = (name) => String(name || 'FB').trim().split(/\s+/).slice(0, 2).map((p) => p.charAt(0).toUpperCase()).join('') || 'FB';
  const queryBase = new URLSearchParams();
  Object.entries(filters || {}).forEach(([key, value]) => { if (value) queryBase.set(key, value); });
%>
<body class="page">
<%- include('../partials/header') %>
<main class="container meta-inbox-page">
<%- include('../partials/page-shell', {
  pageEyebrow: 'Mensajeria meta',
  pageTitle: 'Meta Inbox',
  pageSubtitle: 'Messenger, comentarios de Facebook y Lead Ads separados por empresa.',
  pageActions: '<a class="btn app-btn app-btn-primary" href="/meta-inbox/settings">Configurar Meta</a><a class="btn app-btn" href="/mensajeria-meta">Menu</a>'
}) %>
<%- include('../partials/toasts') %>

<form method="GET" action="/meta-inbox" class="mi-filterbar">
  <input class="app-input" type="search" name="q" value="<%= filters.q || '' %>" placeholder="Cliente, correo, telefono o mensaje" />
  <select class="app-input" name="channel">
    <% [['all','Canal'],['messenger','Messenger'],['facebook_comment','Comentarios'],['facebook_lead','Leads']].forEach(([value,label]) => { %>
      <option value="<%= value %>" <%= filters.channel === value ? 'selected' : '' %>><%= label %></option>
    <% }) %>
  </select>
  <select class="app-input" name="status">
    <% [['all','Estado'],['new','Nuevo'],['open','Abierto'],['pending','Pendiente'],['closed','Cerrado']].forEach(([value,label]) => { %>
      <option value="<%= value %>" <%= filters.status === value ? 'selected' : '' %>><%= label %></option>
    <% }) %>
  </select>
  <select class="app-input" name="page_id">
    <option value="">Pagina</option>
    <% pages.forEach((page) => { %>
      <option value="<%= page.id %>" <%= Number(filters.pageId) === Number(page.id) ? 'selected' : '' %>><%= page.page_name || page.page_id %></option>
    <% }) %>
  </select>
  <select class="app-input" name="user_id">
    <option value="">Asignado</option>
    <% users.forEach((entry) => { %>
      <option value="<%= entry.id %>" <%= Number(filters.userId) === Number(entry.id) ? 'selected' : '' %>><%= entry.username %></option>
    <% }) %>
  </select>
  <input class="app-input" type="date" name="date_from" value="<%= filters.dateFrom || '' %>" />
  <input class="app-input" type="date" name="date_to" value="<%= filters.dateTo || '' %>" />
  <button class="btn app-btn" type="submit">Filtrar</button>
</form>

<section class="mi-shell">
  <aside class="mi-list">
    <% if (!conversations.length) { %>
      <div class="app-empty-state mi-empty">
        <p class="app-empty-state-text">No hay conversaciones con estos filtros.</p>
      </div>
    <% } %>
    <% conversations.forEach((conversation) => {
      const qs = new URLSearchParams(queryBase);
      qs.set('conversation', conversation.id);
    %>
      <a class="mi-thread <%= selectedConversation && Number(selectedConversation.id) === Number(conversation.id) ? 'is-active' : '' %>" href="/meta-inbox?<%= qs.toString() %>">
        <span class="mi-avatar"><%= initials(conversation.customer_name || conversation.customer_id) %></span>
        <span class="mi-thread__body">
          <strong><%= conversation.customer_name || conversation.customer_email || conversation.customer_id %></strong>
          <small><%= channelLabel[conversation.channel] || conversation.channel %> · <%= conversation.page_name || conversation.page_id || 'Pagina' %></small>
          <span><%= conversation.last_message || 'Sin mensajes.' %></span>
        </span>
        <span class="mi-thread__meta">
          <small><%= fmt(conversation.last_message_at || conversation.updated_at) %></small>
          <b class="mi-status mi-status-<%= conversation.status %>"><%= statusLabel[conversation.status] || conversation.status %></b>
        </span>
      </a>
    <% }) %>
  </aside>

  <section class="mi-chat">
    <% if (!selectedConversation) { %>
      <div class="app-empty-state mi-empty-main">
        <h2 class="app-empty-state-title">Selecciona una conversacion</h2>
        <p class="app-empty-state-text">Los eventos recibidos por webhooks oficiales de Meta apareceran aqui.</p>
      </div>
    <% } else { %>
      <header class="mi-chat__header">
        <div class="mi-person">
          <span class="mi-avatar mi-avatar-lg"><%= initials(selectedConversation.customer_name || selectedConversation.customer_id) %></span>
          <div>
            <h2><%= selectedConversation.customer_name || selectedConversation.customer_email || selectedConversation.customer_id %></h2>
            <p class="muted"><%= channelLabel[selectedConversation.channel] || selectedConversation.channel %> · <%= selectedConversation.assigned_username ? `Asignado a ${selectedConversation.assigned_username}` : 'Sin asignar' %></p>
          </div>
        </div>
        <div class="mi-tag-row">
          <% (selectedConversation.tags || []).forEach((tag) => { %>
            <span class="mi-tag" style="--tag-color:<%= tag.color || '#2563eb' %>"><%= tag.label %></span>
          <% }) %>
        </div>
      </header>

      <div class="mi-messages">
        <% if (!messages.length) { %>
          <p class="muted">Todavia no hay mensajes guardados.</p>
        <% } %>
        <% messages.forEach((message) => { %>
          <article class="mi-message <%= message.direction === 'outbound' ? 'is-outbound' : 'is-inbound' %>">
            <div class="mi-message__meta">
              <strong><%= message.direction === 'outbound' ? 'Agente' : 'Cliente' %></strong>
              <span><%= message.message_type %> · <%= fmt(message.created_at) %></span>
            </div>
            <p><%= message.body || '' %></p>
            <% if (message.status === 'failed' && message.error_message) { %>
              <small class="mi-error"><%= message.error_message %></small>
            <% } %>
          </article>
        <% }) %>
      </div>

      <% if (canReply) { %>
        <form method="POST" action="/meta-inbox/conversations/<%= selectedConversation.id %>/send" class="mi-compose">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <textarea class="app-textarea" name="body" rows="3" placeholder="Escribe una respuesta..."></textarea>
          <div class="mi-compose__actions">
            <select class="app-input" data-quick-reply-select>
              <option value="">Respuesta rapida</option>
              <% quickReplies.forEach((reply) => { %>
                <option value="<%= reply.body.replace(/"/g, '&quot;') %>"><%= reply.title %></option>
              <% }) %>
            </select>
            <button class="btn app-btn app-btn-primary" type="submit">Enviar</button>
          </div>
        </form>
      <% } %>
    <% } %>
  </section>

  <aside class="mi-detail">
    <% if (selectedConversation) { %>
      <section>
        <h3>Cliente</h3>
        <dl>
          <dt>ID</dt><dd><%= selectedConversation.customer_id || '-' %></dd>
          <dt>Email</dt><dd><%= selectedConversation.customer_email || '-' %></dd>
          <dt>Telefono</dt><dd><%= selectedConversation.customer_phone || '-' %></dd>
          <dt>Post</dt><dd><%= selectedConversation.post_id || '-' %></dd>
          <dt>Comentario</dt><dd><%= selectedConversation.comment_id || '-' %></dd>
          <dt>Lead</dt><dd><%= selectedConversation.leadgen_id || '-' %></dd>
        </dl>
      </section>

      <section>
        <h3>Gestion</h3>
        <% if (canClose) { %>
          <form method="POST" action="/meta-inbox/conversations/<%= selectedConversation.id %>/status" class="mi-stack-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <select class="app-input" name="status">
              <% ['new','open','pending','closed'].forEach((item) => { %>
                <option value="<%= item %>" <%= selectedConversation.status === item ? 'selected' : '' %>><%= statusLabel[item] %></option>
              <% }) %>
            </select>
            <button class="btn app-btn" type="submit">Cambiar estado</button>
          </form>
        <% } %>
        <% if (canAssign) { %>
          <form method="POST" action="/meta-inbox/conversations/<%= selectedConversation.id %>/assign" class="mi-stack-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <select class="app-input" name="assigned_user_id">
              <option value="">Sin asignar</option>
              <% users.forEach((entry) => { %>
                <option value="<%= entry.id %>" <%= Number(selectedConversation.assigned_user_id || 0) === Number(entry.id) ? 'selected' : '' %>><%= entry.username %></option>
              <% }) %>
            </select>
            <button class="btn app-btn" type="submit">Asignar</button>
          </form>
        <% } %>
      </section>

      <section>
        <h3>Etiquetas</h3>
        <form method="POST" action="/meta-inbox/conversations/<%= selectedConversation.id %>/tags" class="mi-inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input class="app-input" name="label" placeholder="Etiqueta" />
          <input class="app-input mi-color" type="color" name="color" value="#2563eb" />
          <button class="btn app-btn" type="submit">Agregar</button>
        </form>
      </section>

      <section>
        <h3>Notas internas</h3>
        <form method="POST" action="/meta-inbox/conversations/<%= selectedConversation.id %>/notes" class="mi-stack-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <textarea class="app-textarea" name="note" rows="3" placeholder="Nota interna"></textarea>
          <button class="btn app-btn" type="submit">Guardar</button>
        </form>
        <div class="mi-notes">
          <% notes.forEach((note) => { %>
            <article>
              <p><%= note.note %></p>
              <small class="muted"><%= note.username || 'Usuario' %> · <%= fmt(note.created_at) %></small>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>

    <section>
      <h3>Respuestas rapidas</h3>
      <form method="POST" action="/meta-inbox/quick-replies" class="mi-stack-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input class="app-input" name="title" placeholder="Titulo" />
        <textarea class="app-textarea" name="body" rows="3" placeholder="Texto"></textarea>
        <button class="btn app-btn" type="submit">Guardar</button>
      </form>
    </section>
  </aside>
</section>
</main>
<script>
document.addEventListener('change', (event) => {
  const select = event.target.closest('[data-quick-reply-select]');
  if (!select || !select.value) return;
  const form = select.closest('form');
  const textarea = form ? form.querySelector('textarea[name="body"]') : null;
  if (textarea) textarea.value = select.value;
});
</script>
<script src="/status-footer.js" defer></script>
</body>
</html>
