                    <span>Inicio</span>
                    <input class="app-input" type="date" name="start_date" value="<%= task.start_date || '' %>" />
                  </label>
                  <label class="app-field">
                    <span>Vence</span>
                    <input class="app-input" type="date" name="due_date" value="<%= task.due_date || '' %>" />
