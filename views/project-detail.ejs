                  <label class="app-field">
                    <span>Estado</span>
                    <select name="status">
                      <% taskStatuses.forEach((status) => { %>
                        <option value="<%= status.key %>" <%= task.status === status.key ? 'selected' : '' %>><%= status.label %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label class="app-field">
                    <span>Prioridad</span>
                    <select name="priority">
                      <% projectPriorities.forEach((priority) => { %>
                        <option value="<%= priority.key %>" <%= task.priority === priority.key ? 'selected' : '' %>><%= priority.label %></option>
                      <% }) %>
                    </select>
                  </label>
