<!DOCTYPE html>
<%
  const formatMoney = (value, currency = 'GTQ') => `${currency || 'GTQ'} ${Number(value || 0).toFixed(2)}`;
  const isPdfFieldSelected = (selected, key) => {
    const values = Array.isArray(selected) && selected.length ? selected : quotePdfDefaultFields;
    return values.includes(key);
  };
  const formatDate = (value) => {
    if (!value) return 'Sin fecha';
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) return value;
    return parsed.toLocaleDateString('es-GT', { year: 'numeric', month: 'short', day: 'numeric' });
  };
  const truncateOptionLabel = (value, max = 52) => {
    const text = String(value || '').trim();
    if (!text) return '';
    return text.length > max ? `${text.slice(0, max - 1)}...` : text;
  };
  const formatDateTime = (value) => {
    if (!value) return 'Sin registro';
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) return value;
    return parsed.toLocaleString('es-GT', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  };
  const statusBadge = project.status_meta ? project.status_meta.badgeClass : '';
  const pageActions = `
    <a class="btn app-btn" href="/projects">Volver a proyectos</a>
    <a class="btn app-btn" href="/projects/${project.id}?tab=tasks&task_mode=new#new-task">Nueva tarea</a>
    <a class="btn app-btn" href="/projects/${project.id}?tab=expenses&expense_mode=new#new-expense">Nuevo gasto</a>
    ${project.source_quote_id ? '' : `<a class="btn app-btn" href="/projects/${project.id}?tab=quotes#new-quote">Crear cotización</a>`}
    ${canConvertQuote ? `<a class="btn primary app-btn app-btn-primary" href="/projects/${project.id}?tab=quotes">Facturar cotizacion</a>` : ''}
    <a class="btn app-btn" href="/projects/${project.id}?tab=files#new-file">Subir archivo</a>
    <form method="POST" action="/projects/${project.id}/finalize" class="inline-form">
      <input type="hidden" name="_csrf" value="${csrfToken}" />
      <button type="submit" class="btn primary app-btn app-btn-primary">Finalizar proyecto</button>
    </form>
  `;
%>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= project.name %> | Proyectos</title>
  <%- include('partials/head-assets') %>
  <link rel="stylesheet" href="/css/projects.css" />
</head>
<body class="page projects-page">
  <%- include('partials/header', {
    moduleTabs: detailTabs,
    activeTab,
    currentModule: 'projects'
  }) %>

  <main class="container projects-shell">
    <%- include('partials/page-shell', {
      pageTitle: project.name,
      pageSubtitle: `${project.code || 'Sin código'} · ${project.client_display}`,
      pageActions
    }) %>

    <%- include('partials/toasts', { flash }) %>

    <% if (activeTab === 'summary') { %>
    <section class="projects-detail-hero">
      <article class="projects-detail-hero__card">
        <div class="projects-detail-hero__head">
          <span class="status-badge <%= statusBadge %>"><%= project.status_label %></span>
          <span class="projects-priority-chip <%= project.priority_meta.badgeClass %>"><%= project.priority_label %></span>
        </div>
        <div class="projects-progress">
          <span style="width:<%= project.progress_percent %>%"></span>
        </div>
        <div class="projects-detail-hero__meta">
          <div>
            <span>Avance</span>
            <strong><%= project.progress_percent %>%</strong>
          </div>
          <div>
            <span>Presupuesto</span>
            <strong><%= formatMoney(project.estimated_budget) %></strong>
          </div>
          <div>
            <span>Costo real</span>
            <strong><%= formatMoney(project.real_cost_resolved) %></strong>
          </div>
          <div>
            <span>Venta</span>
            <strong><%= formatMoney(project.sale_amount) %></strong>
          </div>
        </div>
      </article>

      <article class="projects-detail-hero__summary">
        <div>
          <span>Inicio</span>
          <strong><%= formatDate(project.start_date) %></strong>
        </div>
        <div>
          <span>Fin estimado</span>
          <strong><%= formatDate(project.estimated_end_date) %></strong>
        </div>
        <div>
          <span>Fin real</span>
          <strong><%= formatDate(project.real_end_date) %></strong>
        </div>
        <div>
          <span>Tareas</span>
          <strong><%= taskSummary.completed %>/<%= taskSummary.total %></strong>
        </div>
        <div>
          <span>Horas</span>
          <strong><%= Number(financial.realHours || 0).toFixed(2) %> / <%= Number(financial.estimatedHours || 0).toFixed(2) %></strong>
        </div>
        <div>
          <span>Estado financiero</span>
          <strong><%= financial.financialStatus %></strong>
        </div>
      </article>
    </section>

      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Resumen del proyecto</h2>
            <p class="muted">Edita la ficha principal sin mezclar tareas, gastos ni cronograma.</p>
          </div>
          <% if (can('projects', 'edit')) { %>
            <button type="button" class="btn app-btn" data-project-summary-edit>Editar</button>
          <% } %>
        </div>
        <form method="POST" action="/projects/<%= project.id %>/update" class="projects-form-grid projects-summary-form" data-project-summary-form>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="app-field">
            <span>Código</span>
            <input class="app-input" type="text" name="code" value="<%= project.code || '' %>" disabled />
          </label>
          <label class="app-field">
            <span>Nombre</span>
            <input class="app-input" type="text" name="name" value="<%= project.name %>" required disabled />
          </label>
          <label class="app-field">
            <span>Cliente</span>
            <select name="client_id" disabled>
              <option value="">Sin cliente</option>
              <% customers.forEach((customer) => { %>
                <option value="<%= customer.id %>" <%= Number(project.client_id) === Number(customer.id) ? 'selected' : '' %>><%= truncateOptionLabel(`${customer.customer_code ? `${customer.customer_code} - ` : ''}${customer.name}`) %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Estado</span>
            <select name="status" disabled>
              <% projectStatuses.forEach((status) => { %>
                <option value="<%= status.key %>" <%= project.status === status.key ? 'selected' : '' %>><%= status.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Prioridad</span>
            <select name="priority" disabled>
              <% projectPriorities.forEach((priority) => { %>
                <option value="<%= priority.key %>" <%= project.priority === priority.key ? 'selected' : '' %>><%= priority.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Inicio</span>
            <input class="app-input" type="date" name="start_date" value="<%= project.start_date || '' %>" disabled />
          </label>
          <label class="app-field">
            <span>Fin estimado</span>
            <input class="app-input" type="date" name="estimated_end_date" value="<%= project.estimated_end_date || '' %>" disabled />
          </label>
          <label class="app-field">
            <span>Fin real</span>
            <input class="app-input" type="date" name="real_end_date" value="<%= project.real_end_date || '' %>" disabled />
          </label>
          <label class="app-field">
            <span>Presupuesto estimado</span>
            <input class="app-input" type="number" name="estimated_budget" step="0.01" min="0" value="<%= Number(project.estimated_budget || 0).toFixed(2) %>" disabled />
          </label>
          <label class="app-field">
            <span>Venta estimada</span>
            <input class="app-input" type="number" name="sale_amount" step="0.01" min="0" value="<%= Number(project.sale_amount || 0).toFixed(2) %>" disabled />
          </label>
          <label class="app-field projects-form-full">
            <span>Descripción</span>
            <textarea class="app-textarea" name="description" rows="4" disabled><%= project.description || '' %></textarea>
          </label>
          <label class="app-field projects-form-full">
            <span>Notas</span>
            <textarea class="app-textarea" name="notes" rows="3" disabled><%= project.notes || '' %></textarea>
          </label>
          <div class="actions projects-form-full" data-project-summary-actions hidden>
            <button type="submit" class="btn primary app-btn app-btn-primary">Guardar cambios</button>
            <button type="button" class="btn app-btn" data-project-summary-cancel>Cancelar cambios</button>
          </div>
        </form>
      </section>
    <% } %>

    <% if (activeTab === 'schedule') { %>
      <section class="projects-schedule-dashboard">
        <article class="projects-schedule-overview">
          <div class="projects-schedule-overview__head">
            <div>
              <span class="projects-eyebrow">Dashboard del cronograma</span>
              <h2><%= scheduleDashboard.completionPercent %>% completado</h2>
              <p class="muted"><%= formatDate(scheduleDashboard.startDate) %> - <%= formatDate(scheduleDashboard.endDate) %></p>
            </div>
            <strong><%= scheduleDashboard.completedTasks %>/<%= scheduleDashboard.totalTasks %> tareas</strong>
          </div>
          <div class="projects-progress projects-progress--schedule">
            <span style="width:<%= scheduleDashboard.completionPercent %>%"></span>
          </div>
          <div class="projects-schedule-metrics">
            <div><span>Tareas abiertas</span><strong><%= scheduleDashboard.openTasks %></strong></div>
            <div><span>Con fecha</span><strong><%= scheduleDashboard.datedTasks %></strong></div>
            <div class="<%= scheduleDashboard.overdueTasks ? 'is-alert' : '' %>"><span>Vencidas</span><strong><%= scheduleDashboard.overdueTasks %></strong></div>
            <div>
              <span>Proxima entrega</span>
              <strong><%= scheduleDashboard.nextTask ? formatDate(scheduleDashboard.nextTask.due_date) : 'Sin pendiente' %></strong>
              <% if (scheduleDashboard.nextTask) { %><small><%= scheduleDashboard.nextTask.title %></small><% } %>
            </div>
          </div>
        </article>

        <div class="projects-essential-grid">
          <article class="projects-essential-card projects-essential-card--quote">
            <span class="projects-essential-card__dot"></span>
            <div>
              <span class="projects-eyebrow">Punto esencial 1</span>
              <h3>Enviar cotizacion</h3>
              <p class="muted"><%= commercialDashboard.sendCandidate ? 'Pendiente de enviar al cliente.' : (commercialDashboard.hasQuote ? 'Cotizacion enviada.' : 'Sin cotizacion registrada.') %></p>
            </div>
          </article>

          <article class="projects-essential-card projects-essential-card--invoice">
            <span class="projects-essential-card__dot"></span>
            <div>
              <span class="projects-eyebrow">Punto esencial 2</span>
              <h3>Crear factura</h3>
              <p class="muted"><%= commercialDashboard.invoicedCount ? `${commercialDashboard.invoicedCount} factura(s) vinculada(s).` : 'Punto pendiente del proyecto.' %></p>
            </div>
          </article>

          <article class="projects-essential-card projects-essential-card--collection">
            <span class="projects-essential-card__dot"></span>
            <div>
              <span class="projects-eyebrow">Punto esencial 3</span>
              <h3>Cobrar cotizacion</h3>
              <p class="muted">Saldo pendiente: <strong><%= formatMoney(commercialDashboard.pendingCollection) %></strong>.</p>
            </div>
          </article>
        </div>
      </section>

      <details class="panel app-panel projects-schedule-create">
        <summary class="projects-collapsible-summary">
          <div>
            <h2>Nueva actividad</h2>
            <p class="muted">Mostrar formulario para agregar una actividad al cronograma.</p>
          </div>
          <span class="projects-collapsible-summary__more">Mas</span>
          <span class="projects-collapsible-summary__less">Menos</span>
        </summary>

        <form method="POST" action="/projects/<%= project.id %>/schedule/create" class="projects-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="app-field">
            <span>Actividad</span>
            <input class="app-input" type="text" name="name" required />
          </label>
          <label class="app-field">
            <span>Inicio</span>
            <input class="app-input" type="date" name="start_date" />
          </label>
          <label class="app-field">
            <span>Fin estimado</span>
            <input class="app-input" type="date" name="estimated_end_date" />
          </label>
          <label class="app-field">
            <span>Fin real</span>
            <input class="app-input" type="date" name="real_end_date" />
          </label>
          <label class="app-field">
            <span>Responsable</span>
            <select name="responsible_id">
              <option value="">Sin responsable</option>
              <% users.forEach((userItem) => { %>
                <option value="<%= userItem.id %>"><%= userItem.username %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Estado</span>
            <select name="status">
              <% scheduleStatuses.forEach((status) => { %>
                <option value="<%= status.key %>"><%= status.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>% avance</span>
            <input class="app-input" type="number" name="progress_percent" min="0" max="100" step="1" value="0" />
          </label>
          <label class="app-field projects-form-full">
            <span>Observaciones</span>
            <textarea class="app-textarea" name="observations" rows="2"></textarea>
          </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Agregar actividad</button>
          </div>
        </form>
      </details>

      <section class="panel app-panel projects-timeline-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Cronograma</h2>
            <p class="muted">Puntos y tareas ordenados cronologicamente por fecha.</p>
          </div>
          <span class="app-chip"><%= timeline.length %> elementos</span>
        </div>
        <div class="projects-timeline" data-project-timeline>
        <% if (!timeline.length) { %>
          <div class="app-empty-state projects-empty-card">
            <p class="app-empty-state-text">Todavía no hay actividades en el cronograma.</p>
          </div>
        <% } %>
        <% timeline.forEach((item, index) => { %>
          <article class="projects-timeline-row projects-timeline-row--<%= item.timeline_type || 'schedule' %> <%= item.is_overdue ? 'is-overdue' : '' %>" data-timeline-item <%= index >= 6 ? 'hidden' : '' %>>
            <div class="projects-timeline-row__date">
              <strong><%= formatDate(item.timeline_date) %></strong>
              <% if (item.is_overdue) { %><span>Atrasada</span><% } %>
            </div>
            <span class="projects-timeline-row__dot" <% if (item.timeline_type === 'task') { %>style="--task-color:<%= item.color %>"<% } %>></span>
            <div class="projects-timeline-row__meta">
              <span class="projects-timeline-type"><%= item.timeline_label || 'Actividad' %></span>
              <strong><%= item.name %></strong>
              <small class="muted"><%= item.responsible_display %> · <%= item.status_label %></small>
            </div>
            <div class="projects-timeline-row__action">
              <% if (item.action_kind === 'task') { %>
                <a class="btn app-btn app-btn-small" href="/projects/<%= project.id %>?tab=tasks&task_id=<%= item.action_id %>#task-detail">Abrir</a>
              <% } %>
            </div>
          </article>
        <% }) %>
        </div>
        <% if (timeline.length > 6) { %>
          <div class="projects-timeline-controls">
            <button type="button" class="btn app-btn" data-timeline-toggle aria-expanded="false">
              <span data-timeline-more>Mostrar mas</span>
              <span data-timeline-less hidden>Mostrar menos</span>
            </button>
          </div>
        <% } %>
      </section>

      <details class="projects-schedule-manage">
        <summary class="projects-collapsible-summary">
          <div>
            <h2>Lista de actividades</h2>
            <p class="muted">Editar las actividades registradas.</p>
          </div>
          <span class="projects-collapsible-summary__more">Mas</span>
          <span class="projects-collapsible-summary__less">Menos</span>
        </summary>
        <section class="projects-stack">
        <% schedule.forEach((item) => { %>
          <form method="POST" action="/projects/<%= project.id %>/schedule/<%= item.id %>/update" class="panel app-panel projects-inline-form <%= item.is_overdue ? 'is-overdue' : '' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <% if (item.is_overdue) { %><strong class="projects-overdue">Actividad atrasada</strong><% } %>
            <div class="projects-inline-form__grid">
              <label class="app-field">
                <span>Actividad</span>
                <input class="app-input" type="text" name="name" value="<%= item.name %>" />
              </label>
              <label class="app-field">
                <span>Inicio</span>
                <input class="app-input" type="date" name="start_date" value="<%= item.start_date || '' %>" />
              </label>
              <label class="app-field">
                <span>Fin estimado</span>
                <input class="app-input" type="date" name="estimated_end_date" value="<%= item.estimated_end_date || '' %>" />
              </label>
              <label class="app-field">
                <span>Fin real</span>
                <input class="app-input" type="date" name="real_end_date" value="<%= item.real_end_date || '' %>" />
              </label>
              <label class="app-field">
                <span>Responsable</span>
                <select name="responsible_id">
                  <option value="">Sin responsable</option>
                  <% users.forEach((userItem) => { %>
                    <option value="<%= userItem.id %>" <%= Number(item.responsible_id) === Number(userItem.id) ? 'selected' : '' %>><%= userItem.username %></option>
                  <% }) %>
                </select>
              </label>
              <label class="app-field">
                <span>Estado</span>
                <select name="status">
                  <% scheduleStatuses.forEach((status) => { %>
                    <option value="<%= status.key %>" <%= item.status === status.key ? 'selected' : '' %>><%= status.label %></option>
                  <% }) %>
                </select>
              </label>
              <label class="app-field">
                <span>% avance</span>
                <input class="app-input" type="number" name="progress_percent" min="0" max="100" value="<%= item.progress_percent %>" />
              </label>
              <label class="app-field projects-inline-form__wide">
                <span>Observaciones</span>
                <textarea class="app-textarea" name="observations" rows="2"><%= item.observations || '' %></textarea>
              </label>
            </div>
            <div class="actions">
              <button type="submit" class="btn app-btn">Actualizar actividad</button>
            </div>
          </form>
        <% }) %>
        </section>
      </details>
    <% } %>

    <% if (activeTab === 'tasks') { %>
      <section class="projects-kpi-grid projects-kpi-grid--small">
        <article class="projects-kpi-card"><span>Total</span><strong><%= taskSummary.total %></strong></article>
        <article class="projects-kpi-card"><span>Completadas</span><strong><%= taskSummary.completed %></strong></article>
        <article class="projects-kpi-card"><span>En proceso</span><strong><%= taskSummary.inProgress %></strong></article>
        <article class="projects-kpi-card"><span>Horas estimadas</span><strong><%= Number(taskSummary.estimatedHours || 0).toFixed(2) %></strong></article>
        <article class="projects-kpi-card"><span>Horas reales</span><strong><%= Number(taskSummary.realHours || 0).toFixed(2) %></strong></article>
      </section>

      <% if (taskMode === 'new') { %>
      <section class="panel app-panel projects-subpage" id="new-task">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Nueva tarea</h2>
            <p class="muted">Las tareas finalizadas deben documentar tiempo real, complicaciones, solución aplicada y recomendación futura.</p>
          </div>
        </div>
        <form method="POST" action="/projects/<%= project.id %>/tasks/create" enctype="multipart/form-data" class="projects-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="app-field">
            <span>Título</span>
            <input class="app-input" type="text" name="title" required />
          </label>
          <label class="app-field">
            <span>Asignación</span>
            <select name="assigned_to">
              <option value="">Sin asignar</option>
              <% users.forEach((userItem) => { %>
                <option value="<%= userItem.id %>"><%= userItem.username %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Estado</span>
            <select name="status">
              <% taskStatuses.forEach((status) => { %>
                <option value="<%= status.key %>"><%= status.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Prioridad</span>
            <select name="priority">
              <% projectPriorities.forEach((priority) => { %>
                <option value="<%= priority.key %>"><%= priority.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Horas estimadas</span>
            <input class="app-input" type="number" name="estimated_hours" step="0.25" min="0" />
          </label>
          <label class="app-field">
            <span>Inicio</span>
            <input class="app-input" type="date" name="start_date" />
          </label>
          <label class="app-field">
            <span>Vence</span>
            <input class="app-input" type="date" name="due_date" />
          </label>
          <label class="app-field projects-form-full">
            <span>Descripción</span>
            <textarea class="app-textarea" name="description" rows="3"></textarea>
          </label>
          <label class="app-field projects-form-full">
            <span>Adjunto</span>
            <input class="app-input" type="file" name="attachment" />
          </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Crear tarea</button>
            <a class="btn app-btn" href="/projects/<%= project.id %>?tab=tasks">Cancelar</a>
          </div>
        </form>
      </section>
      <% } %>

      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div><h2>Tareas en orden de ejecución</h2><p class="muted">Mueve las tareas para definir el orden en que deben realizarse.</p></div>
          <a class="btn primary app-btn app-btn-primary" href="/projects/<%= project.id %>?tab=tasks&task_mode=new#new-task">Nueva tarea</a>
        </div>
        <% if (!tasks.length) { %>
          <div class="app-empty-state projects-empty-card">
            <p class="app-empty-state-text">No hay tareas registradas todavía.</p>
          </div>
        <% } %>
        <% tasks.forEach((task) => { %>
          <div class="projects-record-row projects-task-list-row">
            <strong class="projects-record-order"><%= task.sort_order || 0 %></strong>
            <div><span>Título</span><strong class="projects-task-title"><span class="projects-task-color-dot" style="--task-color:<%= task.color %>"></span><%= task.title %></strong></div>
            <div><span>Duración</span><strong><%= task.estimated_hours ? `${Number(task.estimated_hours).toFixed(2)} h` : 'Sin estimar' %></strong></div>
            <div><span>Asignación</span><strong><%= task.assigned_display %></strong></div>
            <div><span>Prioridad</span><strong class="projects-priority-chip <%= task.priority_meta.badgeClass %>"><%= task.priority_label %></strong></div>
            <div class="actions projects-record-actions">
              <form method="POST" action="/projects/<%= project.id %>/tasks/<%= task.id %>/move" class="inline-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><input type="hidden" name="direction" value="up" /><button class="btn app-btn app-btn-small" type="submit">↑</button></form>
