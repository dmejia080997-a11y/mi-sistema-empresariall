                    <span>Agregar adjunto</span>
                    <input class="app-input" type="file" name="attachment" />
                  </label>
                </div>
                <div class="actions">
                  <button type="submit" class="btn app-btn">Guardar tarea</button>
                </div>
              </form>

              <form method="POST" action="/projects/<%= project.id %>/tasks/<%= task.id %>/complete" class="projects-inline-form projects-inline-form--accent">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="projects-inline-form__grid">
                  <label class="app-field">
                    <span>Fecha finalización</span>
                    <input class="app-input" type="date" name="completed_at" value="<%= task.completed_at || '' %>" />
                  </label>
                  <label class="app-field">
                    <span>Horas reales</span>
                    <input class="app-input" type="number" name="real_hours" step="0.25" min="0" value="<%= task.real_hours || '' %>" />
                  </label>
                  <label class="app-field projects-inline-form__wide">
                    <span>Complicaciones encontradas</span>
                    <textarea class="app-textarea" name="complications" rows="2"><%= task.complications || '' %></textarea>
                  </label>
                  <label class="app-field projects-inline-form__wide">
                    <span>Cómo se solucionó</span>
                    <textarea class="app-textarea" name="solution_applied" rows="2"><%= task.solution_applied || '' %></textarea>
                  </label>
                  <label class="app-field projects-inline-form__wide">
                    <span>Recomendación / aprendizaje</span>
                    <textarea class="app-textarea" name="learned_notes" rows="2"><%= task.learned_notes || '' %></textarea>
                  </label>
                </div>
                <div class="actions">
                  <button type="submit" class="btn primary app-btn app-btn-primary">Finalizar tarea</button>
                </div>
              </form>
            </div>
          </article>
      </section>
      <% } %>
    <% } %>

