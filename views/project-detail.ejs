            </div>
          </fieldset>

          <div class="projects-quote-lines projects-form-full is-compact" data-quote-lines>
            <div class="projects-quote-lines__header">
              <div>
                <h3>Líneas de productos / servicios</h3>
                <p class="muted projects-quote-lines__hint">Los campos extra estan ocultos. Puedes mostrarlos y usar el scroll horizontal si hace falta.</p>
              </div>
              <div class="projects-quote-lines__actions">
                <button type="button" class="btn app-btn app-btn-small" data-toggle-quote-fields aria-expanded="false">Mostrar campos extra</button>
                <button type="button" class="btn app-btn app-btn-small" data-add-quote-line>Agregar línea</button>
              </div>
            </div>
            <div class="projects-quote-lines__scroll" data-quote-scroll>
              <% for (let i = 0; i < 3; i += 1) { %>
                <div class="projects-quote-line projects-quote-line--basic" data-quote-line>
                  <label class="projects-quote-line__field"><span>Descripción del servicio</span><input class="app-input" type="text" name="line_description" placeholder="Descripción del servicio" /></label>
                  <label class="projects-quote-line__field"><span>Cantidad</span><input class="app-input" type="number" name="line_qty" min="0" step="0.01" placeholder="Cant." /></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>Costo</span><input class="app-input" type="number" name="line_unit_cost" min="0" step="0.01" placeholder="Costo" /></label>
                  <label class="projects-quote-line__field"><span>Ganancia</span><input class="app-input" type="text" name="line_margin_percent" placeholder="100 o 20%" /></label>
                  <label class="projects-quote-line__field"><span>Precio</span><input class="app-input" type="number" name="line_unit_price" min="0" step="0.01" placeholder="Precio" /></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>IVA %</span><input class="app-input" type="number" name="line_tax_rate" min="0" step="0.01" placeholder="IVA %" /></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>Tipo descuento</span><select name="line_discount_type">
                      <option value="amount">Desc. monto</option>
                      <option value="percent">Desc. %</option>
                    </select></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>Descuento</span><input class="app-input" type="number" name="line_discount_value" min="0" step="0.01" placeholder="Descuento" /></label>
                </div>
              <% } %>
            </div>
          </div>

          <label class="app-field projects-form-full">
            <span>Notas</span>
            <textarea class="app-textarea" name="notes" rows="2"></textarea>
          </label>
          <label class="app-field projects-form-full">
            <span>Adjuntos para el PDF</span>
            <input class="app-input" type="file" name="quote_attachments" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.png,.jpg,.jpeg,.webp,.gif" />
          </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Guardar cotización</button>
          </div>
        </form>
      </section>
      <% } else { %>
        <section class="panel app-panel projects-subpage">
          <div class="panel-header app-panel-header">
            <div>
              <h2>Cotización de origen</h2>
              <p class="muted">Este proyecto fue creado desde una cotización. Aquí solo se permite modificar sus datos actuales.</p>
            </div>
          </div>
        </section>
      <% } %>

      <section class="projects-stack">
        <% if (!quotes.length) { %>
          <div class="app-empty-state projects-empty-card">
            <p class="app-empty-state-text">Aún no hay cotizaciones registradas.</p>
          </div>
        <% } %>
        <% quotes.forEach((quote) => { %>
          <article class="panel app-panel projects-quote-card">
            <div class="projects-quote-card__header">
              <div>
                <h3><%= quote.title %></h3>
                <p class="muted"><%= quote.customer_name || project.client_display %> · <%= quote.status_label %> · Vence <%= formatDate(quote.valid_until) %></p>
              </div>
              <strong><%= formatMoney(quote.total, quote.currency) %></strong>
            </div>
            <div class="projects-quote-card__totals">
              <span>Costo estimado <strong><%= formatMoney(quote.cost_estimated, quote.currency) %></strong></span>
              <span>Subtotal <strong><%= formatMoney(quote.subtotal, quote.currency) %></strong></span>
              <span>Impuestos <strong><%= formatMoney(quote.tax_amount, quote.currency) %></strong></span>
              <span>Descuento <strong><%= formatMoney(quote.discount_amount, quote.currency) %></strong></span>
            </div>
            <div class="projects-quote-lines-summary">
              <% quote.lines.forEach((line) => { %>
                <div class="projects-quote-lines-summary__row">
                  <span><%= line.description %></span>
                  <strong><%= Number(line.qty || 0).toFixed(2) %> × <%= formatMoney(line.unit_price, quote.currency) %></strong>
                </div>
              <% }) %>
            </div>
            <div class="actions">
              <% if (Number(project.source_quote_id) === Number(quote.id)) { %>
                <a class="btn primary app-btn app-btn-primary" href="/projects?section=quotes&quote_view=list&quote_scope=archived&quote_mode=edit&quote_id=<%= quote.id %>">Modificar</a>
              <% } else { %>
              <a class="btn app-btn" href="/projects/<%= project.id %>/quotes/<%= quote.id %>/pdf?download=1">Descargar PDF</a>
              <% if (quote.status !== 'approved') { %>
                <form method="POST" action="/projects/<%= project.id %>/quotes/<%= quote.id %>/status" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="status" value="approved" />
                  <button type="submit" class="btn app-btn">Aprobar</button>
                </form>
              <% } %>
              <% if (quote.status !== 'rejected') { %>
                <form method="POST" action="/projects/<%= project.id %>/quotes/<%= quote.id %>/status" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="status" value="rejected" />
                  <button type="submit" class="btn app-btn">Rechazar</button>
                </form>
              <% } %>
              <% if (quote.status === 'approved' && !quote.converted_invoice_id) { %>
                <form method="POST" action="/projects/<%= project.id %>/quotes/<%= quote.id %>/convert" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn primary app-btn app-btn-primary">Convertir a factura</button>
                </form>
              <% } %>
              <% if (quote.converted_invoice_id) { %>
                <a class="btn app-btn" href="/invoices/<%= quote.converted_invoice_id %>">Ver factura</a>
              <% } %>
              <% } %>
            </div>
          </article>
        <% }) %>
      </section>
    <% } %>

    <% if (activeTab === 'files') { %>
      <section class="panel app-panel" id="new-file">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Archivos del proyecto</h2>
            <p class="muted">PDF, Excel, Word, imágenes, documentos de proveedor, contratos, planos y cotizaciones.</p>
          </div>
        </div>
        <form method="POST" action="/projects/<%= project.id %>/files/upload" enctype="multipart/form-data" class="projects-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="app-field projects-form-full">
            <span>Archivo</span>
            <input class="app-input" type="file" name="project_file" required />
          </label>
          <label class="app-field projects-form-full">
            <span>Notas</span>
            <textarea class="app-textarea" name="notes" rows="2"></textarea>
          </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Subir archivo</button>
          </div>
        </form>
      </section>

      <section class="projects-file-folders">
        <% if (!files.length) { %>
          <div class="app-empty-state projects-empty-card">
            <p class="app-empty-state-text">No hay archivos cargados todavía.</p>
          </div>
        <% } %>
        <% fileFolders.forEach((folder) => { %>
          <details class="panel app-panel projects-file-folder" open>
            <summary><strong><%= folder.name %></strong><span><%= folder.files.length %> archivo(s)</span></summary>
            <div class="projects-files-grid">
              <% folder.files.forEach((file) => { %>
                <article class="projects-file-card">
                  <h3><%= file.original_name || file.filename %></h3>
                  <p class="muted">Origen: <%= file.origin_display %></p>
                  <p class="muted"><%= file.file_type || 'Archivo' %> · <%= file.uploaded_by_name || 'Sistema' %></p>
                  <p class="muted"><%= file.notes || 'Sin notas' %></p>
                  <% if (file.download_url) { %><a class="btn app-btn" href="<%= file.download_url %>" target="_blank" rel="noopener">Abrir archivo</a><% } %>
                </article>
              <% }) %>
            </div>
          </details>
        <% }) %>
      </section>
    <% } %>

    <% if (activeTab === 'knowledge') { %>
      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Bitácora y lecciones aprendidas</h2>
            <p class="muted">Registra notas manuales y consulta tareas finalizadas de proyectos anteriores para estimar mejor los próximos trabajos.</p>
          </div>
        </div>
        <form method="POST" action="/projects/<%= project.id %>/logs/create" class="projects-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="app-field">
            <span>Tipo de nota</span>
            <select name="log_type">
              <option value="manual_note">Nota manual</option>
              <option value="important_comment">Comentario importante</option>
              <option value="lesson_learned">Lección aprendida</option>
            </select>
          </label>
          <label class="app-field projects-form-full">
            <span>Mensaje</span>
            <textarea class="app-textarea" name="message" rows="3" required></textarea>
          </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Guardar nota</button>
          </div>
        </form>
      </section>

      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Base de conocimiento de tareas anteriores</h2>
            <p class="muted">Busca complicaciones, soluciones y diferencias entre tiempo estimado y real en proyectos ya terminados.</p>
          </div>
        </div>
        <form method="GET" action="/projects/<%= project.id %>" class="projects-filter-grid">
          <input type="hidden" name="tab" value="knowledge" />
          <label class="app-field">
            <span>Buscar aprendizaje</span>
            <input class="app-input" type="search" name="knowledge_q" value="<%= knowledgeSearch || '' %>" placeholder="complicación, solución, tarea..." />
          </label>
          <div class="actions projects-filter-actions">
            <button type="submit" class="btn app-btn">Buscar</button>
            <a class="btn app-btn" href="/projects/<%= project.id %>?tab=knowledge">Limpiar</a>
          </div>
        </form>
        <div class="projects-knowledge-grid">
          <% if (!knowledge.length) { %>
            <div class="app-empty-state projects-empty-card">
              <p class="app-empty-state-text">No hay tareas históricas con aprendizajes documentados.</p>
            </div>
          <% } %>
          <% knowledge.forEach((item) => { %>
            <article class="projects-knowledge-card">
              <h3><%= item.title %></h3>
              <p class="muted"><%= item.project_code ? `${item.project_code} · ` : '' %><%= item.project_name %> · <%= item.assigned_display %></p>
              <div class="projects-knowledge-card__stats">
                <span>Estimado: <strong><%= Number(item.estimated_hours || 0).toFixed(2) %>h</strong></span>
                <span>Real: <strong><%= Number(item.real_hours || 0).toFixed(2) %>h</strong></span>
                <span>Variación: <strong><%= Number(item.variance_hours || 0).toFixed(2) %>h</strong></span>
              </div>
              <p><strong>Complicaciones:</strong> <%= item.complications || 'Sin detalle' %></p>
              <p><strong>Solución aplicada:</strong> <%= item.solution_applied || 'Sin detalle' %></p>
              <p><strong>Aprendizaje:</strong> <%= item.learned_notes || 'Sin detalle' %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Bitácora del proyecto</h2>
            <p class="muted">Historial automático y manual del proyecto.</p>
          </div>
        </div>
        <div class="projects-log-list">
          <% if (!logs.length) { %>
            <div class="app-empty-state projects-empty-card">
              <p class="app-empty-state-text">No hay registros en la bitácora todavía.</p>
            </div>
          <% } %>
          <% logs.forEach((logItem) => { %>
            <article class="projects-log-entry">
              <div>
                <strong><%= logItem.type_label %></strong>
                <p><%= logItem.message %></p>
              </div>
              <small class="muted"><%= logItem.created_by_name || 'Sistema' %> · <%= formatDateTime(logItem.created_at) %></small>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (activeTab === 'financial') { %>
      <section class="projects-kpi-grid">
        <article class="projects-kpi-card"><span>Presupuesto estimado</span><strong><%= formatMoney(financial.estimatedBudget) %></strong></article>
        <article class="projects-kpi-card"><span>Gastos reales</span><strong><%= formatMoney(financial.realExpenses) %></strong></article>
        <article class="projects-kpi-card"><span>Venta cotizada</span><strong><%= formatMoney(financial.quotedSale) %></strong></article>
        <article class="projects-kpi-card"><span>Utilidad estimada</span><strong><%= formatMoney(financial.estimatedProfit) %></strong></article>
        <article class="projects-kpi-card"><span>Utilidad real</span><strong><%= formatMoney(financial.realProfit) %></strong></article>
        <article class="projects-kpi-card"><span>Diferencia costo</span><strong><%= formatMoney(financial.estimatedVsRealCostDiff) %></strong></article>
        <article class="projects-kpi-card"><span>Horas estimadas</span><strong><%= Number(financial.estimatedHours || 0).toFixed(2) %></strong></article>
        <article class="projects-kpi-card"><span>Horas reales</span><strong><%= Number(financial.realHours || 0).toFixed(2) %></strong></article>
      </section>

      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Reporte financiero del proyecto</h2>
            <p class="muted">Lectura rápida del costo esperado vs costo real y del estado financiero actual.</p>
          </div>
        </div>
        <div class="detail-grid">
          <div><strong>Estado financiero:</strong> <%= financial.financialStatus %></div>
          <div><strong>Porcentaje de avance:</strong> <%= financial.progressPercent %>%</div>
          <div><strong>Presupuesto estimado:</strong> <%= formatMoney(financial.estimatedBudget) %></div>
          <div><strong>Gasto real acumulado:</strong> <%= formatMoney(financial.realExpenses) %></div>
          <div><strong>Venta estimada / aprobada:</strong> <%= formatMoney(financial.quotedSale) %></div>
          <div><strong>Utilidad estimada:</strong> <%= formatMoney(financial.estimatedProfit) %></div>
          <div><strong>Utilidad real:</strong> <%= formatMoney(financial.realProfit) %></div>
          <div><strong>Diferencia entre costo estimado y real:</strong> <%= formatMoney(financial.estimatedVsRealCostDiff) %></div>
        </div>
      </section>
    <% } %>
  </main>

  <script>
    (function () {
      const summaryForm = document.querySelector('[data-project-summary-form]');
      const editButton = document.querySelector('[data-project-summary-edit]');
      const cancelButton = document.querySelector('[data-project-summary-cancel]');
      const summaryActions = document.querySelector('[data-project-summary-actions]');
      if (!summaryForm || !editButton || !cancelButton || !summaryActions) return;

      const editableFields = summaryForm.querySelectorAll('input:not([type="hidden"]), select, textarea');
      const setEditing = function (editing) {
        summaryForm.classList.toggle('is-editing', editing);
        editableFields.forEach(function (field) {
          field.disabled = !editing;
        });
        editButton.hidden = editing;
        summaryActions.hidden = !editing;
        if (editing && editableFields.length) editableFields[0].focus();
      };

      editButton.addEventListener('click', function () {
        setEditing(true);
      });
      cancelButton.addEventListener('click', function () {
        summaryForm.reset();
        setEditing(false);
      });
      setEditing(false);
    })();
  </script>
  <script>
    (function () {
      const toggle = document.querySelector('[data-timeline-toggle]');
      const timeline = document.querySelector('[data-project-timeline]');
      if (!toggle || !timeline) return;
      const extraItems = Array.from(timeline.querySelectorAll('[data-timeline-item]')).slice(6);
      const moreLabel = toggle.querySelector('[data-timeline-more]');
      const lessLabel = toggle.querySelector('[data-timeline-less]');
      toggle.addEventListener('click', function () {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        extraItems.forEach(function (item) { item.hidden = expanded; });
        toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        moreLabel.hidden = !expanded;
        lessLabel.hidden = expanded;
      });
    })();
  </script>
  <script>
    (function () {
      const groups = document.querySelectorAll('[data-quote-lines]');
      if (!groups.length) return;
      groups.forEach(function (container) {
        const addButton = container.querySelector('[data-add-quote-line]');
        const toggleButton = container.querySelector('[data-toggle-quote-fields]');
        const scrollArea = container.querySelector('[data-quote-scroll]') || container;
        const numberValue = function (input) {
          const value = Number(input && input.value);
          return Number.isFinite(value) ? value : 0;
        };
        const profitValue = function (input, cost) {
          const raw = String(input && input.value || '').trim().replace(',', '.');
          if (!raw) return null;
          const numeric = Number(raw.replace('%', ''));
          if (!Number.isFinite(numeric)) return null;
          return raw.includes('%') && cost > 0 ? cost * (numeric / 100) : numeric;
        };
        const syncLine = function (line) {
          if (!line) return;
          const costInput = line.querySelector('[name="line_unit_cost"]');
          const marginInput = line.querySelector('[name="line_margin_percent"]');
          const saleInput = line.querySelector('[name="line_unit_price"]');
          const profitPerUnit = profitValue(marginInput, numberValue(costInput));
          if (saleInput && profitPerUnit !== null) {
            saleInput.value = (numberValue(costInput) + profitPerUnit).toFixed(2);
          }
        };
        const bindLine = function (line) {
          if (!line || line.dataset.quoteLineBound === '1') return;
          line.dataset.quoteLineBound = '1';
          line.querySelectorAll('input, select').forEach(function (field) {
            field.addEventListener('input', function () { syncLine(line); });
            field.addEventListener('change', function () { syncLine(line); });
          });
          syncLine(line);
        };
        scrollArea.querySelectorAll('[data-quote-line]').forEach(bindLine);
        if (toggleButton) {
          const syncToggle = function () {
            const compact = container.classList.contains('is-compact');
            toggleButton.textContent = compact ? 'Mostrar campos extra' : 'Ocultar campos extra';
            toggleButton.setAttribute('aria-expanded', compact ? 'false' : 'true');
          };
          toggleButton.addEventListener('click', function () {
            container.classList.toggle('is-compact');
            syncToggle();
          });
          syncToggle();
        }
        if (!addButton) return;
        addButton.addEventListener('click', function () {
          const first = scrollArea.querySelector('[data-quote-line]');
          if (!first) return;
          const clone = first.cloneNode(true);
          clone.dataset.quoteLineBound = '';
          clone.querySelectorAll('input').forEach((input) => { input.value = ''; });
          clone.querySelectorAll('select').forEach((select) => { select.selectedIndex = 0; });
          scrollArea.appendChild(clone);
          bindLine(clone);
          scrollArea.scrollLeft = scrollArea.scrollWidth;
        });
      });
    })();
  </script>
  <script src="/status-footer.js" defer></script>
</body>
</html>
