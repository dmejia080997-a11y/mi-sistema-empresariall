<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('login.title') %>
</title>
<link rel="stylesheet" href="/styles.css" />
</head>
<body class="page">
<header class="topbar">
<div class="brand">
<%= t('common.brand') %>
</div>
<nav class="nav">
<form method="POST" action="/language" class="lang-form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label for="lang-select" class="lang-label">
<%= t('common.language') %>
</label>
<select id="lang-select" name="lang" onchange="this.form.submit()">
<option value="es" <%= lang === 'es' ? 'selected' : '' %>>Español</option>
<option value="en" <%= lang === 'en' ? 'selected' : '' %>>English</option>
</select>
</form>
</nav>
</header>
<div class="card">
<h1>
<%= t('login.heading') %>
</h1>
<p class="muted">
<%= t('login.subtitle') %>
</p>
<% if (error) { %>
<div class="alert">
<%= error %>
</div>
<% } %>
<form method="POST" action="/login" class="form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
<%= t('login.company_username') %>
<input type="text" name="company_username" required />
<span class="helper">
<%= t('login.company_username_helper') %>
</span>
</label>
<label>
<%= t('login.user_username') %>
<input type="text" name="username" required />
</label>
<label>
<%= t('login.password') %>
<input type="password" name="password" required />
</label>
<button type="submit" class="btn primary">
<%= t('login.sign_in') %>
</button>
</form>
<form method="POST" action="/language" class="login-footer">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<span class="login-footer-label">
<%= t('common.language') %>
</span>
<div class="lang-pill-group" role="group" aria-label="<%= t('common.language') %>">
<button type="submit" name="lang" value="es" class="lang-pill <%= lang === 'es' ? 'active' : '' %>">          Español        </button>
<button type="submit" name="lang" value="en" class="lang-pill <%= lang === 'en' ? 'active' : '' %>">          English        </button>
</div>
</form>
</div>
<script src="/status-footer.js" defer></script>
</body>
</html>