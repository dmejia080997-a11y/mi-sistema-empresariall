<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('login.title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<%
  const loginBrandName = (typeof loginCompany !== 'undefined' && loginCompany && loginCompany.name)
    ? loginCompany.name
    : t('common.brand');
  const loginThemeStyle = (typeof loginCompany !== 'undefined' && loginCompany && loginCompany.theme_style)
    ? loginCompany.theme_style
    : '';
  const loginFontClass = (typeof loginCompany !== 'undefined' && loginCompany && loginCompany.font_family)
    ? ` theme-font-${loginCompany.font_family}`
    : '';
%>
<body class="page login-page<%= loginFontClass %>" style="<%= loginThemeStyle %>">
<header class="topbar">
<div class="brand">
<%= loginBrandName %>
</div>
<nav class="nav">
<form method="POST" action="/language" class="lang-form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label for="lang-select" class="lang-label">
<%= t('common.language') %>
</label>
<select id="lang-select" name="lang" onchange="this.form.submit()">
<option value="es" <%= lang === 'es' ? 'selected' : '' %>>Español</option>
<option value="en" <%= lang === 'en' ? 'selected' : '' %>>English</option>
</select>
</form>
</nav>
</header>
<div class="card">
<h1>
<%= t('login.heading') %>
</h1>
<% if (typeof loginCompany !== 'undefined' && loginCompany) { %>
<div class="login-company-card">
<form method="POST" action="/login/company/reset" class="login-company-close-form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="login-company-close" aria-label="Cambiar empresa" title="Cambiar empresa">×</button>
</form>
<% if (loginCompany.logo) { %>
<img src="<%= loginCompany.logo %>" alt="Logo" class="login-company-logo" />
<% } %>
<div>
<strong><%= loginCompany.name %></strong>
<% if (loginCompany.nit) { %>
<span>NIT: <%= loginCompany.nit %></span>
<% } %>
</div>
</div>
<% } %>
<% if (error) { %>
<div class="alert">
<%= error %>
</div>
<% } %>
<form method="POST" action="/login" class="form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<% if (!(typeof loginCompany !== 'undefined' && loginCompany)) { %>
<label>
<%= t('login.company_nit') %>
<input type="text" name="company_nit" inputmode="numeric" autocomplete="organization" required />
<span class="helper">
<%= t('login.company_nit_helper') %>
</span>
</label>
<% } else { %>
<input type="hidden" name="company_nit" value="<%= loginCompany.nit || '' %>" />
<label>
<%= t('login.user_username') %>
<input type="text" name="username" autocomplete="username" required autofocus />
</label>
<label>
<%= t('login.password') %>
<input type="password" name="password" autocomplete="current-password" required />
</label>
<% } %>
<button type="submit" class="btn primary">
<%= typeof loginCompany !== 'undefined' && loginCompany ? t('login.sign_in') : t('login.continue') %>
</button>
</form>
<form method="POST" action="/language" class="login-footer">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<span class="login-footer-label">
<%= t('common.language') %>
</span>
<div class="lang-pill-group" role="group" aria-label="<%= t('common.language') %>">
<button type="submit" name="lang" value="es" class="lang-pill <%= lang === 'es' ? 'active' : '' %>">          Español        </button>
<button type="submit" name="lang" value="en" class="lang-pill <%= lang === 'en' ? 'active' : '' %>">          English        </button>
</div>
</form>
</div>
<script src="/status-footer.js" defer></script>
</body>
</html>
