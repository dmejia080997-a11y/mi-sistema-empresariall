<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('packages.pending_invoice.upload_title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header', {
  homeHref: false,
  showDefaultNav: false
}) %>
<main class="container access-card">
<div class="access-block">
<h2>
<%= t('packages.pending_invoice.upload_title') %>
</h2>
<p class="muted">
<%= t('packages.pending_invoice.upload_hint') %>
</p>
<p>
<strong><%= t('packages.tracking') %>:</strong> <%= pkg.tracking_number || pkg.internal_code || '-' %>
</p>
</div>
<% if (error) { %>
<div class="alert error">
<%= error %>
</div>
<% } %>
<% if (success) { %>
<div class="alert success">
<%= success %>
</div>
<% } %>
<form method="POST" action="/packages/invoice/upload/<%= token %>" enctype="multipart/form-data" class="form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<input type="file" name="invoice_file" accept="application/pdf,image/*" required />
<button type="submit" class="btn primary">
<%= t('packages.pending_invoice.upload') %>
</button>
</form>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
