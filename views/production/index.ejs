<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Produccion y Manufactura</title>
  <%- include('../partials/head-assets') %>
  <link rel="stylesheet" href="/css/production.css" />
</head>
<body class="page production-page">
<%- include('../partials/header', {
  moduleTabs,
  activeTab,
  currentModule: 'production'
}) %>

<main class="container app-module production-module">
  <%- include('../partials/page-shell', {
    pageTitle: 'Produccion y Manufactura',
    pageSubtitle: 'Ordenes, formulas, consumo de materiales, mano de obra, CIF y producto terminado.',
    pageActions: ''
  }) %>

  <% if (error) { %>
    <div class="alert app-message app-message-error"><%= error %></div>
  <% } %>

  <% const money = (value) => 'Q' + Number(value || 0).toFixed(2); %>
  <% const qty = (value) => Number(value || 0).toFixed(2).replace(/\.00$/, ''); %>
  <% const statusText = (value) => statusLabels[value] || value || 'Sin estado'; %>
  <% const typeText = (value) => productTypeLabels[value] || value || 'Insumo'; %>
  <% const costStyle = showCosts ? '' : 'display:none'; %>
  <% const currencyLabel = baseCurrency || 'GTQ'; %>
  <% const productCurrencyOptions = Array.isArray(currencyOptions) && currencyOptions.length ? currencyOptions : ['GTQ', 'USD']; %>
  <% const unitsList = Array.isArray(productionUnits) && productionUnits.length ? productionUnits : ['Litro', 'Tabla', 'Regla', 'Hoja']; %>
  <% const isKnownUnit = (value) => unitsList.some((unit) => String(unit).toLowerCase() === String(value || '').toLowerCase()); %>

  <% if (activeTab === 'dashboard') { %>
    <section class="production-kpis">
      <article class="metric-card"><span>Ordenes activas</span><strong><%= dashboard.active %></strong></article>
      <article class="metric-card"><span>Pendientes</span><strong><%= dashboard.pending %></strong></article>
      <article class="metric-card"><span>Finalizadas</span><strong><%= dashboard.finished %></strong></article>
      <article class="metric-card"><span>Canceladas</span><strong><%= dashboard.cancelled %></strong></article>
      <article class="metric-card" style="<%= costStyle %>"><span>Materia reservada</span><strong><%= money(dashboard.reserved) %></strong></article>
      <article class="metric-card"><span>Terminados fabricados</span><strong><%= qty(dashboard.finishedQty) %></strong></article>
      <article class="metric-card" style="<%= costStyle %>"><span>Costo producido del mes</span><strong><%= money(dashboard.monthCost) %></strong></article>
      <article class="metric-card" style="<%= costStyle %>"><span>Rentabilidad estimada</span><strong><%= money(dashboard.estimatedProfit) %></strong></article>
    </section>
    <section class="panel app-panel production-dashboard-products">
      <div class="panel-header app-panel-header">
        <h2>Productos de manufactura</h2>
        <a class="btn app-btn" href="/production/products">Ver productos</a>
      </div>
      <% if (!dashboard.products || dashboard.products.length === 0) { %>
        <div class="app-empty-state">Sin productos de manufactura.</div>
      <% } else { %>
        <div class="production-product-card-grid">
          <% dashboard.products.forEach((product) => { %>
            <% const dashboardProductPhotoUrl = buildFileUrl && product.production_photo_path ? buildFileUrl(product.production_photo_path) : null; %>
            <a class="production-product-card" href="/production/products#production-product-<%= product.id %>">
              <% if (dashboardProductPhotoUrl) { %>
                <img src="<%= dashboardProductPhotoUrl %>" alt="Foto de <%= product.name %>" />
              <% } else { %>
                <span class="production-product-card-placeholder">Sin foto</span>
              <% } %>
              <span>
                <strong><%= product.name %></strong>
                <small><%= product.sku || product.item_code || 'Sin codigo' %></small>
              </span>
            </a>
          <% }) %>
        </div>
      <% } %>
    </section>
    <section class="production-two-col production-dashboard-summary">
      <div class="panel app-panel">
        <div class="panel-header app-panel-header"><h2>Resumen de manufactura</h2></div>
        <div class="production-summary-grid">
          <div><span>Productos activos</span><strong><%= dashboard.activeProducts %></strong></div>
          <div><span>BOM activas</span><strong><%= dashboard.activeBoms %></strong></div>
          <div><span>Materia prima activa</span><strong><%= dashboard.activeMaterials %></strong></div>
          <div><span>Bajo stock</span><strong><%= dashboard.lowStock %></strong></div>
          <div><span>Lineas con faltante</span><strong><%= dashboard.shortageLines %></strong></div>
          <div style="<%= costStyle %>"><span>Costo material abierto</span><strong><%= money(dashboard.openMaterialCost) %></strong></div>
        </div>
      </div>
      <div class="panel app-panel">
        <div class="panel-header app-panel-header"><h2>Ordenes recientes</h2><a class="btn app-btn" href="/production/orders">Ver ordenes</a></div>
        <%- include('partials/orders-table', { orders, statusText, money, qty, showCosts }) %>
      </div>
    </section>
  <% } %>

  <% if (activeTab === 'orders') { %>
    <section class="panel app-panel">
      <div class="panel-header app-panel-header">
        <h2>Ordenes de produccion</h2>
        <% if (can('production', 'create_order')) { %>
          <a class="btn primary app-btn app-btn-primary" href="/production/orders/new">Nueva orden</a>
        <% } %>
      </div>
      <form method="GET" action="/production/orders" class="form app-filter-bar production-filter-grid">
        <input type="date" name="date_from" value="<%= filters.date_from || '' %>" />
        <input type="date" name="date_to" value="<%= filters.date_to || '' %>" />
        <select name="product_id"><option value="">Producto</option><% products.forEach((p) => { %><option value="<%= p.id %>" <%= String(filters.product_id || '') === String(p.id) ? 'selected' : '' %>><%= p.name %></option><% }) %></select>
        <select name="status"><option value="">Estado</option><% ['draft','pending','paused'].forEach((key) => { %><option value="<%= key %>" <%= filters.status === key ? 'selected' : '' %>><%= statusLabels[key] %></option><% }) %></select>
        <select name="user_id"><option value="">Usuario</option><% users.forEach((u) => { %><option value="<%= u.id %>" <%= String(filters.user_id || '') === String(u.id) ? 'selected' : '' %>><%= u.username %></option><% }) %></select>
        <input type="text" name="order" placeholder="Orden" value="<%= filters.order || '' %>" />
        <input type="number" step="0.01" name="cost_min" placeholder="Costo min" value="<%= filters.cost_min || '' %>" style="<%= costStyle %>" />
        <input type="number" step="0.01" name="cost_max" placeholder="Costo max" value="<%= filters.cost_max || '' %>" style="<%= costStyle %>" />
        <div class="actions"><button class="btn app-btn" type="submit">Filtrar</button><a class="btn app-btn" href="/production/orders">Limpiar</a></div>
      </form>
      <form method="POST" action="/production/orders/bulk-status" class="production-bulk-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="return_to" value="orders" />
        <div class="production-bulk-actions">
          <select name="status" required>
            <option value="">Accion multiple</option>
            <option value="cancelled">Cancelado</option>
            <option value="in_production">En proceso</option>
            <option value="paused">Pausado</option>
            <option value="finished">Terminado</option>
          </select>
          <button class="btn app-btn" type="submit">Aplicar</button>
        </div>
        <%- include('partials/orders-table', { orders, statusText, money, qty, showCosts, selectable: true }) %>
      </form>
    </section>
  <% } %>

  <% if (activeTab === 'order_new' || activeTab === 'order_edit') { %>
    <section class="panel app-panel">
      <div class="panel-header app-panel-header"><h2><%= order ? 'Editar orden' : 'Crear orden' %></h2></div>
      <form method="POST" action="<%= order ? `/production/orders/${order.id}/update` : '/production/orders/create' %>" class="form grid-2 app-form-grid">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <% if (!order) { %>
          <div class="full-row">
            <h3>Formulas BOM a producir</h3>
            <div class="production-order-bom-lines" data-order-bom-lines>
              <div class="production-order-bom-line" data-order-bom-line>
                <select name="bom_id">
                  <option value="">Seleccionar BOM</option>
                  <% boms.forEach((b) => { %><option value="<%= b.id %>"><%= b.code %> - <%= b.name %> (<%= b.product_name %>)</option><% }) %>
                </select>
                <input type="number" step="0.0001" min="0" name="quantity_planned" placeholder="Cantidad a fabricar" />
                <button class="btn app-btn production-line-remove" type="button" data-remove-order-bom-line aria-label="Quitar linea">-</button>
              </div>
            </div>
            <button class="btn app-btn production-add-line" type="button" data-add-order-bom-line>Agregar linea</button>
            <template data-order-bom-template>
              <div class="production-order-bom-line" data-order-bom-line>
                <select name="bom_id">
                  <option value="">Seleccionar BOM</option>
                  <% boms.forEach((b) => { %><option value="<%= b.id %>"><%= b.code %> - <%= b.name %> (<%= b.product_name %>)</option><% }) %>
                </select>
                <input type="number" step="0.0001" min="0" name="quantity_planned" placeholder="Cantidad a fabricar" />
                <button class="btn app-btn production-line-remove" type="button" data-remove-order-bom-line aria-label="Quitar linea">-</button>
              </div>
            </template>
          </div>
        <% } else { %>
          <div><strong><%= order.order_number %></strong><p class="muted"><%= order.status %></p></div>
        <% } %>
        <label>Inicio estimado <input type="date" name="estimated_start_date" value="<%= order ? order.estimated_start_date || '' : '' %>" /></label>
        <label>Finalizacion estimada <input type="date" name="estimated_end_date" value="<%= order ? order.estimated_end_date || '' : '' %>" /></label>
        <label class="full-row">Observaciones <textarea name="notes" rows="4"><%= order ? order.notes || '' : '' %></textarea></label>
        <div class="actions full-row"><button class="btn primary app-btn app-btn-primary" type="submit">Guardar</button><a class="btn app-btn" href="/production/orders">Cancelar</a></div>
      </form>
    </section>
  <% } %>

  <% if (activeTab === 'order_detail' || activeTab === 'order_start' || activeTab === 'order_finish') { %>
    <section class="panel app-panel">
      <div class="production-detail-head">
        <div>
          <p class="app-page-eyebrow"><%= order.order_number %></p>
          <h2><%= orderBoms && orderBoms.length > 1 ? 'Orden multiproducto' : order.product_name %></h2>
          <span class="status-pill status-<%= order.status %>"><%= statusText(order.status) %></span>
        </div>
        <div class="actions">
          <% if (can('production', 'edit_order') && ['draft','pending','paused'].includes(order.status)) { %><a class="btn app-btn" href="/production/orders/<%= order.id %>/edit">Editar</a><% } %>
          <% if (can('production', 'start_production') && ['draft','pending','paused'].includes(order.status)) { %><a class="btn primary app-btn app-btn-primary" href="/production/orders/<%= order.id %>/start">Iniciar</a><% } %>
          <% if (can('production', 'finish_production') && ['in_production','paused','pending'].includes(order.status)) { %><a class="btn primary app-btn app-btn-primary" href="/production/orders/<%= order.id %>/finish">Finalizar</a><% } %>
        </div>
      </div>
      <div class="production-summary-grid">
        <div><span>Planificado</span><strong><%= qty(order.quantity_planned) %></strong></div>
        <div><span>Finalizado</span><strong><%= qty(order.quantity_finished) %></strong></div>
        <div style="<%= costStyle %>"><span>Costo estimado</span><strong><%= money(order.estimated_cost) %></strong></div>
        <div style="<%= costStyle %>"><span>Costo real</span><strong><%= money(totals.total || order.real_cost) %></strong></div>
        <div style="<%= costStyle %>"><span>Costo unitario</span><strong><%= money(order.unit_cost) %></strong></div>
        <div><span>Avance</span><strong><%= Math.min(100, Math.round((Number(order.quantity_finished || 0) / Math.max(Number(order.quantity_planned || 1), 1)) * 100)) %>%</strong></div>
      </div>

      <% if (orderBoms && orderBoms.length) { %>
        <div class="table app-table-wrap production-table production-order-boms-table">
          <div class="table-row header production-order-bom-row"><div>BOM</div><div>Producto terminado</div><div>Planificado</div><div>Finalizado</div><div>Avance</div><div style="<%= costStyle %>">Costo est.</div></div>
          <% orderBoms.forEach((line) => { const lineProgress = Math.min(100, Math.round((Number(line.quantity_finished || 0) / Math.max(Number(line.quantity_planned || 1), 1)) * 100)); %>
            <div class="table-row production-order-bom-row">
              <div><strong><%= line.bom_code %></strong><p class="muted"><%= line.bom_name %></p></div>
              <div><%= line.product_name %><p class="muted"><%= line.sku || '' %></p></div>
              <div><%= qty(line.quantity_planned) %></div>
              <div><%= qty(line.quantity_finished) %></div>
              <div><%= lineProgress %>%</div>
              <div style="<%= costStyle %>"><%= money(line.estimated_cost) %></div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (activeTab === 'order_start') { %>
        <form method="POST" action="/production/orders/<%= order.id %>/start" class="production-action-box">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <strong>Confirmar inicio de produccion</strong>
          <p class="muted">Se descontara la materia prima requerida y se crearan movimientos de inventario tipo Consumo produccion.</p>
          <button class="btn primary app-btn app-btn-primary" type="submit">Iniciar produccion</button>
        </form>
      <% } %>
      <% if (activeTab === 'order_finish') { %>
        <form method="POST" action="/production/orders/<%= order.id %>/finish" class="production-action-box">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <% if (orderBoms && orderBoms.length) { %>
            <div class="production-finish-lines">
              <% orderBoms.forEach((line) => { %>
                <label><%= line.product_name %> / <%= line.bom_code %>
                  <input type="hidden" name="order_bom_id" value="<%= line.id %>" />
                  <input type="number" step="0.0001" min="0" name="quantity_finished" placeholder="Cantidad producida ahora" />
                </label>
              <% }) %>
            </div>
          <% } else { %>
            <label>Cantidad producida ahora <input type="number" step="0.0001" min="0.0001" name="quantity_finished" required /></label>
          <% } %>
          <p class="muted">Permite finalizacion parcial. El sistema ingresa producto terminado al inventario con costo real unitario.</p>
          <button class="btn primary app-btn app-btn-primary" type="submit">Registrar entrada de produccion</button>
        </form>
      <% } %>

      <div class="actions production-order-actions">
        <% if (can('production', 'edit_order') && ['draft','pending'].includes(order.status)) { %>
          <form method="POST" action="/production/orders/<%= order.id %>/reserve"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><button class="btn app-btn" type="submit">Reservar materiales</button></form>
          <form method="POST" action="/production/orders/<%= order.id %>/submit"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><button class="btn app-btn" type="submit">Marcar pendiente</button></form>
        <% } %>
        <% if (can('production', 'cancel_production') && !['finished','cancelled'].includes(order.status)) { %>
          <form method="POST" action="/production/orders/<%= order.id %>/cancel" class="inline-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><input type="text" name="reason" placeholder="Motivo de cancelacion" required /><button class="btn danger app-btn app-btn-danger" type="submit">Cancelar</button></form>
        <% } %>
      </div>
    </section>

    <section class="panel app-panel">
      <div class="panel-header app-panel-header"><h2>Materiales requeridos</h2></div>
      <div class="table app-table-wrap production-table">
        <div class="table-row header production-material-row"><div>Producto</div><div>Requerido</div><div>Reservado</div><div>Consumido</div><div>Disponible real</div><div style="<%= costStyle %>">Costo</div></div>
        <% materials.forEach((m) => { const available = Number(m.stock_qty || 0) - Math.max(0, Number(m.reserved_total || 0) - Number(m.quantity_reserved || 0)); %>
          <div class="table-row production-material-row"><div><strong><%= m.product_name %></strong><p class="muted"><%= m.sku %></p></div><div><%= qty(m.quantity_required) %></div><div><%= qty(m.quantity_reserved) %></div><div><%= qty(m.quantity_consumed) %></div><div><%= qty(available) %></div><div style="<%= costStyle %>"><%= money(Number(m.quantity_consumed || m.quantity_required || 0) * Number(m.unit_cost || 0)) %></div></div>
        <% }) %>
      </div>
    </section>

    <section class="production-two-col">
      <div class="panel app-panel">
        <div class="panel-header app-panel-header"><h2>Mano de obra</h2></div>
        <% if (can('production', 'record_labor')) { %>
          <form method="POST" action="/production/orders/<%= order.id %>/labor" class="form grid-2 app-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label>Empleado RRHH <select name="employee_id"><option value="">Manual</option><% employees.forEach((e) => { %><option value="<%= e.id %>"><%= e.full_name %></option><% }) %></select></label>
            <label>Trabajador manual <input type="text" name="worker_name" /></label>
            <label>Horas <input type="number" step="0.01" name="hours" required /></label>
            <label>Costo hora <input type="number" step="0.01" name="hourly_cost" /></label>
            <label class="full-row">Notas <input type="text" name="notes" /></label>
            <button class="btn app-btn full-row" type="submit">Agregar mano de obra</button>
          </form>
        <% } %>
        <% labor.forEach((l) => { %><div class="production-line"><span><%= l.worker_name %> - <%= qty(l.hours) %> h</span><strong style="<%= costStyle %>"><%= money(l.total_cost) %></strong></div><% }) %>
      </div>
      <div class="panel app-panel">
        <div class="panel-header app-panel-header"><h2>Costos indirectos</h2></div>
        <% if (can('production', 'edit_costs')) { %>
          <form method="POST" action="/production/orders/<%= order.id %>/overhead" class="form grid-2 app-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label>Tipo <input type="text" name="cost_type" placeholder="Energia, alquiler, depreciacion" required /></label>
            <label>Monto <input type="number" step="0.01" name="amount" required /></label>
            <label>Distribucion <select name="distribution_method"><option value="order">Por orden</option><option value="unit">Por unidad producida</option><option value="percentage">Por porcentaje</option><option value="manual">Manual</option></select></label>
            <label>Descripcion <input type="text" name="description" /></label>
            <button class="btn app-btn full-row" type="submit">Agregar CIF</button>
          </form>
        <% } %>
        <% overhead.forEach((o) => { %><div class="production-line"><span><%= o.cost_type %> - <%= o.distribution_method %></span><strong style="<%= costStyle %>"><%= money(o.amount) %></strong></div><% }) %>
      </div>
    </section>

    <section class="panel app-panel">
      <div class="panel-header app-panel-header"><h2>Desperdicio / merma</h2></div>
      <% if (can('production', 'record_waste')) { %>
        <form method="POST" action="/production/orders/<%= order.id %>/waste" class="form production-filter-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <select name="product_id" required><option value="">Producto</option><% products.forEach((p) => { %><option value="<%= p.id %>"><%= p.name %></option><% }) %></select>
          <input type="number" step="0.0001" name="quantity" placeholder="Cantidad" required />
          <select name="reason"><% wasteReasons.forEach((r) => { %><option value="<%= r %>"><%= r %></option><% }) %></select>
          <input type="text" name="notes" placeholder="Notas" />
          <button class="btn app-btn" type="submit">Registrar merma</button>
        </form>
      <% } %>
      <% waste.forEach((w) => { %><div class="production-line"><span><%= w.product_name %> - <%= qty(w.quantity) %> - <%= w.reason %></span><strong style="<%= costStyle %>"><%= money(w.cost) %></strong></div><% }) %>
    </section>
  <% } %>

  <% if (activeTab === 'bom') { %>
    <section class="panel app-panel">
      <div class="panel-header app-panel-header">
        <h2>BOM</h2>
        <% if (can('production', 'create_order')) { %>
          <a class="btn primary app-btn app-btn-primary" href="/production/bom/new">Nueva BOM</a>
        <% } %>
      </div>
      <div class="table app-table-wrap production-table">
        <div class="table-row header production-bom-row"><div>Codigo</div><div>Formula</div><div>Producto terminado</div><div>Version</div><div>Estado</div><div>Base</div><div>Acciones</div></div>
        <% boms.forEach((b) => { %><div class="table-row production-bom-row"><div><%= b.code %></div><div><strong><%= b.name %></strong></div><div><%= b.product_name %></div><div><%= b.version %></div><div><%= b.status %></div><div><%= qty(b.base_quantity) %> <%= b.unit || '' %></div><div><a class="btn app-btn" href="/production/bom/<%= b.id %>/edit">Editar</a></div></div><% }) %>
      </div>
    </section>
  <% } %>

  <% if (activeTab === 'products') { %>
    <section class="panel app-panel">
      <div class="panel-header app-panel-header">
        <h2>Productos</h2>
        <% if (can('production', 'edit_order')) { %>
          <a class="btn primary app-btn app-btn-primary" href="/production/products/new">Nuevo producto</a>
        <% } %>
      </div>
      <div class="table app-table-wrap production-table production-products-table">
        <div class="table-row header production-products-row"><div>Producto</div><div>Foto</div><div>BOM</div><div>Materia prima</div><div style="<%= costStyle %>">Mano de obra</div><div>Dias</div><div>Estado</div><div>Observaciones</div><div>Soporte</div><div>Acciones</div></div>
        <% if (!products || products.length === 0) { %><div class="table-row empty app-empty-state">Sin productos de produccion.</div><% } %>
        <% (products || []).forEach((p) => { %>
          <% const productPhotoUrl = buildFileUrl && p.production_photo_path ? buildFileUrl(p.production_photo_path) : null; %>
          <% const productSupportUrl = buildFileUrl && p.production_support_path ? buildFileUrl(p.production_support_path) : null; %>
          <form id="production-product-<%= p.id %>" method="POST" action="/production/products/<%= p.id %>/update" enctype="multipart/form-data" class="table-row production-products-row production-product-edit-form" data-production-product-form>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div data-label="Producto"><strong><%= p.name %></strong><p class="muted"><%= p.sku || p.item_code || '' %></p></div>
            <div class="production-product-media" data-label="Foto">
              <% if (productPhotoUrl) { %>
                <img src="<%= productPhotoUrl %>" alt="Foto de <%= p.name %>" />
              <% } else { %>
                <span class="production-product-placeholder">Sin foto</span>
              <% } %>
              <label class="production-file-picker">
                <input type="file" name="product_photo" accept="image/*" data-production-edit-field disabled />
                <span><%= productPhotoUrl ? 'Cambiar foto' : 'Agregar foto' %></span>
              </label>
            </div>
            <div data-label="BOM"><%= p.bom_count %><p class="muted"><%= p.first_bom_code || 'Sin BOM' %></p></div>
            <div data-label="Materia prima"><%= p.material_count %><p class="muted"><%= p.material_names || 'Sin materia prima' %></p></div>
