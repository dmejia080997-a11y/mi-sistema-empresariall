<div class="modal-overlay hidden production-support-modal" data-production-support-modal aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="production-support-title">
    <div class="modal-header">
      <h2 id="production-support-title" data-production-support-title>Soporte</h2>
      <button class="btn app-btn production-support-close" type="button" data-production-support-close aria-label="Cerrar">X</button>
    </div>
    <iframe title="Vista de soporte" data-production-support-frame></iframe>
  </div>
</div>
<div class="modal-overlay hidden production-confirm-modal" data-production-confirm-modal aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="production-confirm-title">
    <div class="modal-header">
      <h2 id="production-confirm-title">Eliminar linea</h2>
    </div>
    <p>Esta seguro de eliminar la linea?</p>
    <div class="actions">
      <button class="btn danger app-btn app-btn-danger" type="button" data-production-confirm-accept>Aceptar</button>
      <button class="btn app-btn" type="button" data-production-confirm-cancel>Cancelar</button>
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const confirmModal = document.querySelector('[data-production-confirm-modal]');
    const confirmAcceptButton = document.querySelector('[data-production-confirm-accept]');
    const confirmCancelButton = document.querySelector('[data-production-confirm-cancel]');
    const supportModal = document.querySelector('[data-production-support-modal]');
    const supportFrame = document.querySelector('[data-production-support-frame]');
    const supportTitle = document.querySelector('[data-production-support-title]');
    const supportCloseButton = document.querySelector('[data-production-support-close]');
    let pendingRemoveLine = null;
    let pendingSyncRemoveButtons = null;

    const openRemoveConfirm = (line, syncRemoveButtons) => {
      pendingRemoveLine = line;
      pendingSyncRemoveButtons = syncRemoveButtons;
      if (!confirmModal) return;
      confirmModal.classList.remove('hidden');
      confirmModal.setAttribute('aria-hidden', 'false');
      if (confirmAcceptButton) confirmAcceptButton.focus();
    };

    const closeRemoveConfirm = () => {
      pendingRemoveLine = null;
      pendingSyncRemoveButtons = null;
      if (!confirmModal) return;
      confirmModal.classList.add('hidden');
      confirmModal.setAttribute('aria-hidden', 'true');
    };

    if (confirmAcceptButton) {
      confirmAcceptButton.addEventListener('click', () => {
        if (pendingRemoveLine) pendingRemoveLine.remove();
        if (typeof pendingSyncRemoveButtons === 'function') pendingSyncRemoveButtons();
        closeRemoveConfirm();
      });
    }

    if (confirmCancelButton) confirmCancelButton.addEventListener('click', closeRemoveConfirm);
    if (confirmModal) {
      confirmModal.addEventListener('click', (event) => {
        if (event.target === confirmModal) closeRemoveConfirm();
      });
    }

    const closeSupportModal = () => {
      if (!supportModal) return;
      supportModal.classList.add('hidden');
      supportModal.setAttribute('aria-hidden', 'true');
      if (supportFrame) supportFrame.src = 'about:blank';
    };

    document.querySelectorAll('[data-production-support-open]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!supportModal || !supportFrame) return;
        if (supportTitle) supportTitle.textContent = button.dataset.supportTitle || 'Soporte';
        supportFrame.src = button.dataset.supportUrl || 'about:blank';
        supportModal.classList.remove('hidden');
        supportModal.setAttribute('aria-hidden', 'false');
        if (supportCloseButton) supportCloseButton.focus();
      });
    });

    if (supportCloseButton) supportCloseButton.addEventListener('click', closeSupportModal);
    if (supportModal) {
      supportModal.addEventListener('click', (event) => {
        if (event.target === supportModal) closeSupportModal();
      });
    }

    document.querySelectorAll('[data-production-product-form]').forEach((form) => {
      const deleteForm = form.nextElementSibling && form.nextElementSibling.matches('[data-production-product-delete-form]')
        ? form.nextElementSibling
        : null;
      const editButton = form.querySelector('[data-production-product-edit]');
      const deleteButton = form.querySelector('[data-production-product-delete]');
      const editFields = Array.from(form.querySelectorAll('[data-production-edit-field]'));

      if (editButton) {
        editButton.addEventListener('click', () => {
          if (!form.classList.contains('is-editing')) {
            form.classList.add('is-editing');
            editFields.forEach((field) => { field.disabled = false; });
            editButton.textContent = 'Guardar';
            editButton.classList.add('primary', 'app-btn-primary');
            const firstField = editFields.find((field) => field.type !== 'file');
            if (firstField) firstField.focus();
            return;
          }
          form.requestSubmit();
        });
      }

      if (deleteButton && deleteForm) {
        deleteButton.addEventListener('click', () => {
          if (window.confirm('Esta seguro que desea eliminar este producto de manufactura?')) {
            deleteForm.submit();
          }
        });
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeSupportModal();
      }
    });

    const initUnitField = (field) => {
      const select = field.querySelector('[data-production-unit-select]');
      const custom = field.querySelector('[data-production-unit-custom]');
      if (!select || !custom || field.dataset.productionUnitReady === '1') return;
      field.dataset.productionUnitReady = '1';
      const syncUnitCustom = () => {
        const isOther = select.value === '__other';
        custom.hidden = !isOther;
        custom.required = isOther;
        if (!isOther) custom.value = '';
      };
      select.addEventListener('change', syncUnitCustom);
      syncUnitCustom();
    };

    const productNameInput = document.querySelector('[data-product-name-input]');
    const productCodeInput = document.querySelector('[data-product-code-input]');
    const productCurrencySelect = document.querySelector('[data-product-currency-select]');
    if (productCurrencySelect) {
      const syncProductCurrencyLabels = () => {
        document.querySelectorAll('[data-product-currency-label]').forEach((label) => {
          label.textContent = productCurrencySelect.value || 'GTQ';
        });
      };
      productCurrencySelect.addEventListener('change', syncProductCurrencyLabels);
      syncProductCurrencyLabels();
    }

    if (productNameInput && productCodeInput) {
      const buildProductPrefix = (value) => String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toUpperCase()
        .replace(/[^A-Z0-9]/g, '')
        .slice(0, 3);

      const normalizeProductCode = (value) => String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toUpperCase()
        .replace(/[^A-Z0-9-]/g, '')
        .slice(0, 40);

      const syncProductCodePrefix = () => {
        const previousPrefix = productCodeInput.dataset.productPrefix || '';
        const nextPrefix = buildProductPrefix(productNameInput.value);
        const currentCode = normalizeProductCode(productCodeInput.value);
        let suffix = currentCode;
        if (previousPrefix && currentCode.startsWith(previousPrefix)) {
          suffix = currentCode.slice(previousPrefix.length);
        } else if (nextPrefix && currentCode.startsWith(nextPrefix)) {
          suffix = currentCode.slice(nextPrefix.length);
        }
        productCodeInput.dataset.productPrefix = nextPrefix;
        if (nextPrefix) productCodeInput.value = `${nextPrefix}${suffix}`.slice(0, 40);
      };

      productNameInput.addEventListener('input', syncProductCodePrefix);
      productCodeInput.addEventListener('input', () => {
        const prefix = productCodeInput.dataset.productPrefix || buildProductPrefix(productNameInput.value);
        const code = normalizeProductCode(productCodeInput.value);
        productCodeInput.value = prefix && !code.startsWith(prefix) ? `${prefix}${code}`.slice(0, 40) : code;
      });
      syncProductCodePrefix();
    }

    const bomFinishedProductSelect = document.querySelector('[data-bom-finished-product]');
    const bomCodeInput = document.querySelector('[data-bom-code-input]');
    const bomNameInput = document.querySelector('[data-bom-name-input]');
    if (bomFinishedProductSelect && bomCodeInput && bomNameInput) {
      const productNameFromSelect = () => {
        const option = bomFinishedProductSelect.options[bomFinishedProductSelect.selectedIndex];
        return option && option.value ? option.textContent.trim() : '';
      };

      const buildBomName = () => [bomCodeInput.value.trim(), productNameFromSelect()].filter(Boolean).join(' - ');
      const shouldSyncBomName = () => {
        const current = bomNameInput.value.trim();
        const previous = bomNameInput.dataset.generatedName || '';
        return !current || current === previous;
      };
      const syncBomName = () => {
        if (!shouldSyncBomName()) return;
        const generated = buildBomName();
        bomNameInput.dataset.generatedName = generated;
        bomNameInput.value = generated;
      };

      bomCodeInput.addEventListener('input', syncBomName);
      bomFinishedProductSelect.addEventListener('change', syncBomName);
      bomNameInput.dataset.generatedName = buildBomName();
      syncBomName();
    }

    const linesContainer = document.querySelector('[data-order-bom-lines]');
    const addButton = document.querySelector('[data-add-order-bom-line]');
    const template = document.querySelector('[data-order-bom-template]');
    if (linesContainer && addButton && template) {
      const syncRemoveButtons = () => {
        const lines = linesContainer.querySelectorAll('[data-order-bom-line]');
        lines.forEach((line) => {
          const removeButton = line.querySelector('[data-remove-order-bom-line]');
          if (removeButton) removeButton.disabled = lines.length <= 1;
        });
      };

      addButton.addEventListener('click', () => {
        const fragment = template.content.cloneNode(true);
        linesContainer.appendChild(fragment);
        syncRemoveButtons();
      });

      linesContainer.addEventListener('click', (event) => {
        const removeButton = event.target.closest('[data-remove-order-bom-line]');
        if (!removeButton) return;
        const lines = linesContainer.querySelectorAll('[data-order-bom-line]');
        if (lines.length <= 1) return;
        openRemoveConfirm(removeButton.closest('[data-order-bom-line]'), syncRemoveButtons);
      });

      syncRemoveButtons();
    }

    document.querySelectorAll('[data-production-bom-lines]').forEach((bomLinesContainer) => {
      const bomAddButton = bomLinesContainer.parentElement.querySelector('[data-add-production-bom-line]');
      const bomTemplate = bomLinesContainer.parentElement.querySelector('[data-production-bom-template]');

      const syncRemoveButtons = () => {
        const lines = bomLinesContainer.querySelectorAll('[data-production-bom-line]');
        lines.forEach((line) => {
          const removeButton = line.querySelector('[data-remove-production-bom-line]');
          if (removeButton) removeButton.disabled = lines.length <= 1;
        });
      };

      if (bomAddButton && bomTemplate) {
        bomAddButton.addEventListener('click', () => {
          const fragment = bomTemplate.content.cloneNode(true);
          fragment.querySelectorAll('[data-production-unit-field]').forEach(initUnitField);
          bomLinesContainer.appendChild(fragment);
          syncRemoveButtons();
        });
      }

      bomLinesContainer.addEventListener('click', (event) => {
        const removeButton = event.target.closest('[data-remove-production-bom-line]');
        if (!removeButton) return;
        const lines = bomLinesContainer.querySelectorAll('[data-production-bom-line]');
        if (lines.length <= 1) return;
        openRemoveConfirm(removeButton.closest('[data-production-bom-line]'), syncRemoveButtons);
      });

      syncRemoveButtons();
    });

    document.querySelectorAll('[data-production-unit-field]').forEach(initUnitField);
  });
</script>
<script src="/status-footer.js" defer></script>
</body>
</html>
