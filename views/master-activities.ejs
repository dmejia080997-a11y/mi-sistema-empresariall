<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'es' %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Panel Master - Actividades</title>
<%- include('partials/head-assets') %>
</head>
<body class="page master-shell-page">
<%- include('partials/header', {
  headerBrandText: 'Panel Master',
  homeHref: '/master',
  showDefaultNav: false,
  headerActionsHtml: `
    <nav class="master-tabs" aria-label="Navegacion Master">
      <a href="/master">Empresas</a>
      <a href="/master/activities" class="is-active">Actividad</a>
    </nav>
    <a href="/master/logout" class="btn app-btn">Cerrar sesion</a>
  `
}) %>

<main class="container master-page">
  <div class="master-hero page-header app-page-header">
    <div class="app-page-header__content">
      <p class="master-eyebrow app-page-eyebrow">Panel master</p>
      <h1>Actividad</h1>
      <p class="master-sub muted">Define los giros de negocio y los modulos habilitados para cada uno.</p>
    </div>
    <div class="master-hero-actions app-page-actions">
      <a href="/master" class="btn app-btn">Volver a empresas</a>
    </div>
  </div>

  <% if (flash && flash.message) { %>
  <div class="alert app-message app-message-<%= flash.type || 'info' %> <%= flash.type || '' %>">
    <%= flash.message %>
  </div>
  <% } %>

  <section class="master-card app-card" aria-labelledby="activity-create-title">
    <div class="app-card-header">
      <div>
        <h2 id="activity-create-title" class="app-card-title">Crear actividad</h2>
        <p class="muted">Selecciona los modulos que recibiran las empresas creadas con esta actividad.</p>
      </div>
    </div>
    <form action="/master/activities/create" method="POST" class="app-form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label class="app-field">
        <span>Nombre de la actividad</span>
        <input type="text" name="name" placeholder="Ej: Logistica y paqueteria" required>
      </label>
      <div class="full-row">
        <p class="app-field-caption">Modulos habilitados</p>
        <div class="module-grid">
          <% (modules || []).forEach(m => { %>
            <label class="module-item">
              <input type="checkbox" name="modules" value="<%= m.code %>">
              <span><%= m.name %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div class="actions">
        <button class="btn primary app-btn app-btn-primary">Guardar actividad</button>
      </div>
    </form>
  </section>

  <section aria-labelledby="activities-title">
    <div class="app-card-header master-section-heading">
      <div>
        <h2 id="activities-title" class="app-card-title">Actividades registradas</h2>
        <p class="muted">Administra las configuraciones que se relacionan con empresas dentro de Master.</p>
      </div>
      <span class="app-chip"><%= (activities || []).length %> actividades</span>
    </div>

    <div class="master-table-wrap app-table-wrap">
      <table class="master-table app-table">
        <thead>
          <tr>
            <th>Actividad</th>
            <th>Modulos habilitados</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (!activities || activities.length === 0) { %>
          <tr>
            <td colspan="3">
              <div class="app-empty-state">No hay actividades registradas.</div>
            </td>
          </tr>
          <% } %>
          <% (activities || []).forEach(activity => { %>
          <tr>
            <td class="app-cell-min-md">
              <strong><%= activity.name %></strong>
            </td>
            <td>
              <div class="muted app-flow-bottom">
                <%= activity.module_labels && activity.module_labels.length ? activity.module_labels.join(', ') : '-' %>
              </div>
              <form action="/master/activities/<%= activity.id %>/update" method="POST" class="master-inline-edit">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <label class="app-field">
                  <span>Nombre</span>
                  <input type="text" name="name" value="<%= activity.name %>" class="app-input-compact">
                </label>
                <div>
                  <p class="app-field-caption">Modulos</p>
                  <div class="module-grid">
                    <% (modules || []).forEach(m => { %>
                      <label class="module-item">
                        <input type="checkbox" name="modules" value="<%= m.code %>" <%= activity.modules && activity.modules.includes(m.code) ? 'checked' : '' %>>
                        <span><%= m.name %></span>
                      </label>
                    <% }) %>
                  </div>
                </div>
                <div class="activity-actions app-flow-top">
                  <button class="btn app-btn">Actualizar</button>
                </div>
              </form>
            </td>
            <td class="app-cell-min-sm">
              <form action="/master/activities/<%= activity.id %>/delete" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button class="btn danger app-btn app-btn-danger">Eliminar</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
