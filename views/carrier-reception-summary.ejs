<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('reception.summary_title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container reception-module">
<div class="page-header">
<div>
<h1>
<%= t('reception.summary_title') %>
</h1>
<p class="muted">
<%= t('reception.subtitle') %>
</p>
</div>
</div>
<div class="module-nav reception-module-nav">
<a class="<%= activeReceptionTab === 'summary' ? 'active' : '' %>" href="/carrier-reception/summary">
<%= t('reception.summary_title') %>
</a>
<a class="<%= activeReceptionTab === 'quick' ? 'active' : '' %>" href="/carrier-reception/quick">
<%= t('reception.quick_title') %>
</a>
<a class="<%= activeReceptionTab === 'list' ? 'active' : '' %>" href="/carrier-reception/list">
<%= t('reception.list_title') %>
</a>
</div>
<div class="reception-layout reception-layout-single">
<div class="reception-column reception-column-summary">
<section class="panel">
<div class="panel-header">
<h2>
<%= t('reception.summary_title') %>
</h2>
</div>
<div class="grid">
<div class="stat">
<div class="stat-label">
<%= t('reception.stats.received_today') %>
</div>
<div class="stat-value">
<%= stats.receivedToday || 0 %>
</div>
</div>
<div class="stat">
<div class="stat-label">
<%= t('reception.stats.pending') %>
</div>
<div class="stat-value">
<%= stats.pending || 0 %>
</div>
</div>
<div class="stat">
<div class="stat-label">
<%= t('reception.stats.processed') %>
</div>
<div class="stat-value">
<%= stats.processed || 0 %>
</div>
</div>
</div>
<div class="summary-strip reception-carriers">
<div class="summary-item">
<span class="summary-label">
<%= t('reception.stats.by_carrier') %>
</span>
<div class="pill-list">
<% if (carrierTotals && carrierTotals.length) { %>
<% carrierTotals.forEach((row) => { %>
<span class="pill">
<%= row.carrier || t('common.unassigned') %> · <%= row.count %>
</span>
<% }) %>
<% } else { %>
<span class="muted">
<%= t('reception.empty_carriers') %>
</span>
<% } %>
</div>
</div>
</div>
</section>
</div>
</div>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>