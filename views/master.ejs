<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'es' %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Panel Master SaaS</title>
<%- include('partials/head-assets') %>
</head>
<body class="page master-shell-page">
<%- include('partials/header', {
  headerBrandText: 'Panel Master',
  homeHref: '/master',
  showDefaultNav: false,
  headerActionsHtml: `
    <nav class="master-tabs" aria-label="Navegacion Master">
      <a href="/master" class="is-active">Empresas</a>
      <a href="/master/monitoring">Monitoreo</a>
      <a href="/master/backups">Backups</a>
      <a href="/master/audit">Auditoria</a>
      <a href="/master/activities">Actividad</a>
    </nav>
    <a href="/master/logout" class="btn app-btn">Cerrar sesion</a>
  `
}) %>

<main class="container master-page">
  <div class="master-hero page-header app-page-header">
    <div class="app-page-header__content">
      <p class="master-eyebrow app-page-eyebrow">SaaS Control Center</p>
      <h1>Administracion del sistema</h1>
      <p class="master-sub muted">Clientes, licencias, tenants PostgreSQL, backups y salud tecnica.</p>
    </div>
    <div class="master-hero-actions app-page-actions">
      <a href="/companies" class="btn primary app-btn app-btn-primary">Crear empresa</a>
      <a href="/master/monitoring" class="btn app-btn">Monitoreo</a>
    </div>
  </div>

  <% if (flash && flash.message) { %>
  <div class="alert app-message app-message-<%= flash.type || 'info' %> <%= flash.type || '' %>"><%= flash.message %></div>
  <% } %>
  <% if (tempReset && tempReset.password) { %>
  <div class="app-card app-message app-message-success">
    <strong>Credenciales temporales generadas</strong>
    <span>Empresa ID: <%= tempReset.company_id %></span>
    <span>Contrasena temporal: <code><%= tempReset.password %></code></span>
  </div>
  <% } %>

  <section class="app-kpi-grid master-kpi-grid">
    <article class="app-card master-kpi-card"><span class="muted">Empresas activas</span><strong><%= stats.activeCompanies %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Suspendidas</span><strong><%= stats.suspendedCompanies %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Vencidas</span><strong><%= stats.expiredCompanies %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Usuarios totales</span><strong><%= stats.totalUsers %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Espacio utilizado</span><strong><%= stats.totalStorageLabel %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Espacio disponible</span><strong><%= health.disk && health.disk.ok ? health.disk.availableLabel : 'No disponible' %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Ultimo backup</span><strong><%= latestBackup ? latestBackup.createdAtLabel : 'Sin backup' %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">PostgreSQL</span><strong><%= health.postgres.label %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">PM2</span><strong><%= health.pm2.label %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Cron</span><strong><%= health.cron.label %></strong></article>
    <article class="app-card master-kpi-card"><span class="muted">Uptime</span><strong><%= health.uptime %></strong></article>
  </section>

  <section class="app-card master-companies-card">
    <div class="app-card-header">
      <div>
        <h2 class="app-card-title">Empresas</h2>
        <p class="muted">Estado comercial, tecnico y de licencia por tenant.</p>
      </div>
      <span class="app-chip"><%= companies.length %> empresas</span>
    </div>
    <div class="app-table-wrap master-table-scroll">
      <table class="app-table master-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Empresa</th>
            <th>Plan</th>
            <th>Usuarios</th>
            <th>Max</th>
            <th>Espacio</th>
            <th>Ultimo backup</th>
            <th>Base PostgreSQL</th>
            <th>Inicio</th>
            <th>Vencimiento</th>
            <th>Licencia</th>
            <th>Salud</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (!companies.length) { %>
          <tr><td colspan="13"><div class="app-empty-state">No hay empresas registradas.</div></td></tr>
          <% } %>
          <% companies.forEach(company => { %>
          <tr>
            <td><%= company.id %></td>
            <td><strong><%= company.name %></strong><div class="muted"><%= company.nit || company.username || '-' %></div></td>
            <td><%= company.plan %></td>
            <td><%= company.users_count || 0 %></td>
            <td><%= company.users_max || '-' %></td>
            <td><%= company.storage_used_label %></td>
            <td><%= company.last_backup || '-' %></td>
            <td><%= company.database_name || '-' %></td>
            <td><%= company.license_starts_at || company.active_from || '-' %></td>
            <td><%= company.license_ends_at || company.active_until || '-' %></td>
            <td>
              <span class="app-badge <%= company.license_status_computed === 'expired' ? 'app-badge-danger' : company.license_status_computed === 'suspended' || company.license_status_computed === 'expiring' ? 'app-badge-warning' : 'app-badge-success' %>">
                <%= company.license_status_label %>
              </span>
            </td>
            <td>
              <span class="app-badge <%= company.health === 'red' ? 'app-badge-danger' : company.health === 'yellow' ? 'app-badge-warning' : 'app-badge-success' %>">
                <%= company.health === 'red' ? 'Rojo' : company.health === 'yellow' ? 'Amarillo' : 'Verde' %>
              </span>
            </td>
            <td>
              <div class="actions app-table-actions">
                <a href="/master/companies/<%= company.id %>" class="btn app-btn app-btn-small">Ver</a>
                <form action="/master/companies/<%= company.id %>/enter" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn app-btn app-btn-small">Entrar</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
