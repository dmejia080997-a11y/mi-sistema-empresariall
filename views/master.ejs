<style>
  .master-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 28px 50px;
  }
  .master-hero {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    margin-bottom: 18px;
  }
  .master-eyebrow {
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    color: #7b8794;
    margin: 0 0 8px;
    font-weight: 700;
  }
  .master-hero h1 {
    margin: 0 0 6px;
    font-size: 2.2rem;
  }
  .master-sub {
    margin: 0;
    color: #5b6472;
    font-size: 0.98rem;
    max-width: 640px;
  }
  .master-hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .master-hero-actions.master-tabs {
    margin-bottom: 0;
  }
  .master-tabs {
    display: inline-flex;
    gap: 8px;
    padding: 6px;
    border-radius: 999px;
    border: 1px solid #e5e7eb;
    background: #ffffff;
    margin-bottom: 18px;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.06);
  }
  .master-tabs a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    text-decoration: none;
    color: #4b5563;
    font-weight: 600;
    font-size: 0.92rem;
  }
  .master-tabs a.is-active {
    background: #eef2ff;
    color: #3730a3;
  }
  .master-page .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .master-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 13px;
    min-width: 1200px;
    background: #ffffff;
  }
  .master-table th, .master-table td {
    border-bottom: 1px solid #edf0f4;
    padding: 6px 8px;
    vertical-align: top;
  }
  .master-table .col-legal,
  .master-table .col-tax-address,
  .master-table .col-address,
  .master-table .col-business-type {
    max-width: 220px;
    white-space: normal;
    word-break: break-word;
  }
  .master-table th {
    background: #f8fafc;
    text-align: left;
    font-weight: 600;
    color: #3a4453;
  }
  .master-table tr:last-child td {
    border-bottom: none;
  }
  .master-table tbody tr:hover {
    background: #f8fbff;
  }
  .alert {
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    color: #1f2937;
  }
  .alert.success {
    background: #ecfdf3;
    border-color: #c6f6d5;
    color: #166534;
  }
  .alert.error {
    background: #fff0ed;
    border-color: #f0b3a9;
    color: #8a2a1c;
  }
  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    border: 1px solid transparent;
  }
  .badge--active {
    background: #e9f7ef;
    color: #1e7b47;
    border-color: #bfe7cf;
  }
  .badge--expired {
    background: #fdecec;
    color: #a33a3a;
    border-color: #f7c9c9;
  }
  .badge--inactive {
    background: #fff7ed;
    color: #9a3412;
    border-color: #fed7aa;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .actions form {
    margin: 0;
  }
  .actions button {
    padding: 4px 8px;
    font-size: 12px;
  }
  .master-table-wrap {
    overflow-x: auto;
    border-radius: 18px;
    border: 1px solid #e5e7eb;
    background: #ffffff;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  }
  details.action-details summary {
    cursor: pointer;
    font-weight: 600;
  }
  details.action-details form {
    margin-top: 6px;
    display: grid;
    gap: 8px;
  }
  .master-card {
    padding: 16px;
    border-radius: 16px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
  }
  .master-card--success {
    border-color: #bfe7cf;
    background: #f0fdf4;
  }
  .master-card form {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    align-items: end;
  }
  .master-card input,
  details.action-details form input {
    padding: 8px 10px;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    font-family: inherit;
    background: #ffffff;
  }
  .master-table textarea {
    padding: 4px 6px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    font-size: 12px;
    width: 180px;
    min-height: 38px;
    resize: vertical;
  }
  details.action-details summary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    background: #f8fafc;
  }
  details.action-details[open] summary {
    background: #eef2ff;
    border-color: #c7d2fe;
  }
</style>
<div class="master-page">
<div class="master-hero">
  <div>
    <p class="master-eyebrow">Panel master</p>
    <h1>Panel Master</h1>
    <p class="master-sub">Administra empresas, credenciales y el estado de cada cuenta.</p>
  </div>
  <div class="master-hero-actions master-tabs">
    <a href="/companies">Crear nueva empresa</a>
    <a href="/master/logout">Cerrar sesión</a>
  </div>
</div>
<nav class="master-tabs">
  <a href="/master" class="is-active">Empresas</a>
  <a href="/master/activities">Actividad</a>
</nav>
<% if (flash && flash.message) { %>
<div class="alert <%= flash.type || "" %>" style="margin: 12px 0;">
  <%= flash.message %>
</div>
<% } %>
<h2>Empresas registradas</h2>
<% if (tempReset && tempReset.password) { %>
<div class="master-card master-card--success" style="margin: 12px 0;">
  <strong>Credenciales temporales generadas</strong>
  <br>Empresa ID: <%= tempReset.company_id %>
  <br>Contraseña temporal (solo se muestra una vez): <%= tempReset.password %>
</div>
<% } %>
<div class="master-card" style="margin: 12px 0;">
  <h3>Restablecimiento de contraseña de usuario</h3>
  <form action="/master/reset-user-password" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="number" name="company_id" placeholder="ID de empresa" required>
    <input type="text" name="username" placeholder="Usuario" required>
    <input type="password" name="password" placeholder="Nueva contraseña" required>
    <button class="btn">Restablecer</button>
  </form>
</div>
<div class="master-table-wrap">
<table class="master-table">
  <tr>
    <th>ID</th>
    <th>Empresa (nombre)</th>
    <th class="col-address">Dirección</th>
    <th>Usuario empresa</th>
    <th>NIT</th>
    <th class="col-business-type">Tipo</th>
    <th class="col-legal">Nombre legal</th>
    <th class="col-tax-address">Domicilio fiscal</th>
    <th>Moneda base</th>
    <th>Usuarios</th>
    <th>Inicio</th>
    <th>Vence</th>
    <th>Estado</th>
    <th>Acciones</th>
    <th>Anular</th>
  </tr>
  <% companies.forEach(company => { %>
  <tr>
    <td><%= company.id %></td>
    <td><%= company.name %></td>
    <td class="col-address"><%= company.address || '-' %></td>
    <td><%= company.username || '-' %></td>
    <td><%= company.nit || '-' %></td>
    <td class="col-business-type"><%= company.business_type || '-' %></td>
    <td class="col-legal"><%= company.legal_name || '-' %></td>
    <td class="col-tax-address"><%= company.tax_address || '-' %></td>
    <td><%= company.base_currency || company.currency || '-' %></td>
    <td><%= company.users_count || 0 %></td>
    <td><%= company.active_from || '-' %></td>
    <td><%= company.active_until || '-' %></td>
    <td>
      <% if (company.status === 'inactive') { %>
      <span class="badge badge--inactive">Inactiva</span>
      <% } else if (company.status === 'expired') { %>
      <span class="badge badge--expired">Vencida</span>
      <% } else { %>
      <span class="badge badge--active">Activa</span>
      <% } %>
    </td>
    <td>
      <div class="actions">
        <a href="/master/companies/<%= company.id %>">
          <button class="btn">Ver</button>
        </a>
        <form action="/master/companies/<%= company.id %>/enter" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn">Entrar</button>
        </form>
        <form action="/master/companies/<%= company.id %>/reset-credentials" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn">Restablecer clave</button>
        </form>
      </div>
    </td>
    <td>
      <% if (company.status === 'inactive') { %>
      <form action="/master/companies/<%= company.id %>/reactivate" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="return_to" value="/master" />
        <button class="btn">Reactivar</button>
      </form>
      <% } else { %>
      <form action="/master/companies/<%= company.id %>/deactivate" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="return_to" value="/master" />
        <textarea name="inactive_reason" placeholder="Motivo de anulacion" required></textarea>
        <button class="btn danger">Anular</button>
      </form>
      <% } %>
    </td>
  </tr>
  <% }) %>
</table>
</div>
</div>
