<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'es' %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Panel Master - Empresas</title>
<%- include('partials/head-assets') %>
</head>
<body class="page master-shell-page">
<%- include('partials/header', {
  headerBrandText: 'Panel Master',
  homeHref: '/master',
  showDefaultNav: false,
  headerActionsHtml: `
    <nav class="master-tabs" aria-label="Navegacion Master">
      <a href="/master" class="is-active">Empresas</a>
      <a href="/master/activities">Actividad</a>
    </nav>
    <a href="/master/logout" class="btn app-btn">Cerrar sesion</a>
  `
}) %>

<main class="container master-page master-company-list-page companies-module">
  <div class="master-hero page-header app-page-header">
    <div class="app-page-header__content">
      <p class="master-eyebrow app-page-eyebrow">Panel master</p>
      <h1>Empresas</h1>
      <p class="master-sub muted">Administra empresas, credenciales y el estado operativo de cada cuenta.</p>
    </div>
    <div class="master-hero-actions app-page-actions">
      <a href="/companies" class="btn primary app-btn app-btn-primary">Crear nueva empresa</a>
      <a href="/master/activities" class="btn app-btn">Configurar actividades</a>
    </div>
  </div>

  <% if (flash && flash.message) { %>
  <div class="alert app-message app-message-<%= flash.type || 'info' %> <%= flash.type || '' %> app-flow-item">
    <%= flash.message %>
  </div>
  <% } %>

  <% if (tempReset && tempReset.password) { %>
  <div class="master-card master-card--success app-card app-message app-message-success app-flow-item">
    <strong>Credenciales temporales generadas</strong>
    <span>Empresa ID: <%= tempReset.company_id %></span>
    <span>Contrasena temporal: <code><%= tempReset.password %></code></span>
  </div>
  <% } %>

  <section class="master-card app-card" aria-labelledby="master-reset-title">
    <div class="app-card-header">
      <div>
        <h2 id="master-reset-title" class="app-card-title">Restablecer acceso de usuario</h2>
        <p class="muted">Actualiza la contrasena de un usuario dentro de una empresa.</p>
      </div>
    </div>
    <form action="/master/reset-user-password" method="POST" class="app-form-grid app-form-grid-fluid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label class="app-field">
        <span>ID de empresa</span>
        <input type="number" name="company_id" placeholder="Ej: 12" required>
      </label>
      <label class="app-field">
        <span>Usuario</span>
        <input type="text" name="username" placeholder="Ej: admin" required>
      </label>
      <label class="app-field">
        <span>Nueva contrasena</span>
        <input type="password" name="password" placeholder="Nueva contrasena" required>
      </label>
      <button class="btn app-btn app-btn-secondary">Restablecer</button>
    </form>
  </section>

  <section class="app-toolbar master-list-toolbar" aria-label="Filtros de empresas">
    <div class="app-filter-grid">
      <label class="app-field">
        <span>Buscar</span>
        <input type="search" data-master-search placeholder="Nombre, NIT, usuario o direccion">
      </label>
      <label class="app-field">
        <span>Estado</span>
        <select data-master-status>
          <option value="">Todos los estados</option>
          <option value="active">Activas</option>
          <option value="inactive">Inactivas</option>
          <option value="expired">Vencidas</option>
        </select>
      </label>
    </div>
  </section>

  <section aria-labelledby="master-companies-title">
    <div class="app-card-header master-section-heading">
      <div>
        <h2 id="master-companies-title" class="app-card-title">Empresas registradas</h2>
        <p class="muted">Listado maestro con accesos, vigencias y acciones administrativas.</p>
      </div>
      <span class="app-chip"><%= (companies || []).length %> empresas</span>
    </div>

    <div class="master-table-wrap app-table-wrap">
      <table class="master-table app-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Empresa</th>
            <th class="col-address">Direccion</th>
            <th>Usuario</th>
            <th>NIT</th>
            <th class="col-business-type">Tipo</th>
            <th>Moneda</th>
            <th>Usuarios</th>
            <th>Inicio</th>
            <th>Vence</th>
            <th>Estado</th>
            <th>Acciones</th>
            <th>Anular</th>
          </tr>
        </thead>
        <tbody>
          <% if (!companies || companies.length === 0) { %>
          <tr>
            <td colspan="13">
              <div class="app-empty-state">No hay empresas registradas.</div>
            </td>
          </tr>
          <% } %>
          <% (companies || []).forEach(company => { %>
          <tr data-company-row data-status="<%= company.status || 'active' %>" data-search="<%= [company.id, company.name, company.address, company.username, company.nit, company.business_type, company.legal_name, company.tax_address, company.base_currency || company.currency].filter(Boolean).join(' ').toLowerCase() %>">
            <td><%= company.id %></td>
            <td>
              <strong><%= company.name %></strong>
              <% if (company.legal_name) { %>
              <div class="muted"><%= company.legal_name %></div>
              <% } %>
            </td>
            <td class="col-address"><%= company.address || '-' %></td>
            <td><%= company.username || '-' %></td>
            <td><%= company.nit || '-' %></td>
            <td class="col-business-type"><%= company.business_type || '-' %></td>
            <td><%= company.base_currency || company.currency || '-' %></td>
            <td><%= company.users_count || 0 %></td>
            <td><%= company.active_from || '-' %></td>
            <td><%= company.active_until || '-' %></td>
            <td>
              <% if (company.status === 'inactive') { %>
              <span class="badge app-badge app-badge-warning badge--inactive">Inactiva</span>
              <% } else if (company.status === 'expired') { %>
              <span class="badge app-badge app-badge-danger badge--expired">Vencida</span>
              <% } else { %>
              <span class="badge app-badge app-badge-success badge--active">Activa</span>
              <% } %>
            </td>
            <td>
              <div class="actions app-table-actions">
                <a href="/master/companies/<%= company.id %>" class="btn app-btn app-btn-small">Ver</a>
                <form action="/master/companies/<%= company.id %>/enter" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn app-btn app-btn-small">Entrar</button>
                </form>
                <form action="/master/companies/<%= company.id %>/reset-credentials" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn app-btn app-btn-small">Restablecer clave</button>
                </form>
              </div>
            </td>
            <td>
              <% if (company.status === 'inactive') { %>
              <form action="/master/companies/<%= company.id %>/reactivate" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="return_to" value="/master" />
                <button class="btn app-btn app-btn-success app-btn-small">Reactivar</button>
              </form>
              <% } else { %>
              <details class="action-details">
                <summary>Anular</summary>
                <form action="/master/companies/<%= company.id %>/deactivate" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="return_to" value="/master" />
                  <textarea name="inactive_reason" placeholder="Motivo de anulacion" required></textarea>
                  <button class="btn danger app-btn app-btn-danger app-btn-small">Confirmar</button>
                </form>
              </details>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="master-company-cards" data-master-card-list>
      <% if (!companies || companies.length === 0) { %>
      <div class="app-empty-state">No hay empresas registradas.</div>
      <% } %>
      <% (companies || []).forEach(company => { %>
      <article class="master-company-card app-card" data-company-card data-status="<%= company.status || 'active' %>" data-search="<%= [company.id, company.name, company.address, company.username, company.nit, company.business_type, company.legal_name, company.tax_address, company.base_currency || company.currency].filter(Boolean).join(' ').toLowerCase() %>">
        <div class="master-company-card__header">
          <div>
            <span class="app-chip">ID <%= company.id %></span>
            <h3><%= company.name %></h3>
            <p class="muted"><%= company.legal_name || company.business_type || 'Empresa registrada' %></p>
          </div>
          <% if (company.status === 'inactive') { %>
          <span class="badge app-badge app-badge-warning">Inactiva</span>
          <% } else if (company.status === 'expired') { %>
          <span class="badge app-badge app-badge-danger">Vencida</span>
          <% } else { %>
          <span class="badge app-badge app-badge-success">Activa</span>
          <% } %>
        </div>
        <dl class="master-company-card__meta">
          <div><dt>NIT</dt><dd><%= company.nit || '-' %></dd></div>
          <div><dt>Usuario</dt><dd><%= company.username || '-' %></dd></div>
          <div><dt>Moneda</dt><dd><%= company.base_currency || company.currency || '-' %></dd></div>
          <div><dt>Vence</dt><dd><%= company.active_until || '-' %></dd></div>
        </dl>
        <div class="actions master-company-card__actions">
          <a href="/master/companies/<%= company.id %>" class="btn app-btn">Ver</a>
          <form action="/master/companies/<%= company.id %>/enter" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn app-btn">Entrar</button>
          </form>
          <form action="/master/companies/<%= company.id %>/reset-credentials" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn app-btn">Restablecer clave</button>
          </form>
          <% if (company.status === 'inactive') { %>
          <form action="/master/companies/<%= company.id %>/reactivate" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="return_to" value="/master" />
            <button class="btn app-btn app-btn-success">Reactivar</button>
          </form>
          <% } %>
        </div>
      </article>
      <% }) %>
    </div>
  </section>
</main>

<script>
  (function () {
    const searchInput = document.querySelector('[data-master-search]');
    const statusSelect = document.querySelector('[data-master-status]');
    const rows = Array.from(document.querySelectorAll('[data-company-row]'));
    const cards = Array.from(document.querySelectorAll('[data-company-card]'));

    function normalize(value) {
      return String(value || '').trim().toLowerCase();
    }

    function applyFilters() {
      const query = normalize(searchInput && searchInput.value);
      const status = normalize(statusSelect && statusSelect.value);
      [...rows, ...cards].forEach((item) => {
        const matchesSearch = !query || normalize(item.dataset.search).includes(query);
        const matchesStatus = !status || normalize(item.dataset.status) === status;
        item.hidden = !(matchesSearch && matchesStatus);
      });
    }

    if (searchInput) searchInput.addEventListener('input', applyFilters);
    if (statusSelect) statusSelect.addEventListener('change', applyFilters);
  })();
</script>
<script src="/status-footer.js" defer></script>
</body>
</html>
