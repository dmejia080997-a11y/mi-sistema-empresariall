<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Libro mayor</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header', {
  headerNavItems: [
    { href: '/dashboard', label: 'Dashboard' },
    { href: '/accounting/reports', label: 'Reportes' },
    { href: '/logout', label: t('nav.logout') }
  ]
}) %>
<main class="container">
<h1>Libro mayor</h1>
<nav class="subnav">
<a href="/accounting/accounts">Catálogo</a>
<a href="/accounting/categories">Categorías</a>
<a href="/accounting/categories/rules">Reglas</a>
<a href="/accounting/journal">Pólizas</a>
<a href="/accounting/reports" class="<%= active === 'reports' ? 'active' : '' %>">Reportes</a>
<a href="/accounting/settings">Configuración</a>
</nav>

<section class="panel">
<form class="form" method="get" action="/accounting/reports/mayor">
<label>
Desde
<input type="date" name="start" value="<%= startDate || '' %>" />
</label>
<label>
Hasta
<input type="date" name="end" value="<%= endDate || '' %>" />
</label>
<button class="btn primary" type="submit">Filtrar</button>
</form>
<div class="actions">
<a class="btn" href="/accounting/reports/mayor/export?format=xlsx&start=<%= startDate || '' %>&end=<%= endDate || '' %>">Exportar Excel</a>
<a class="btn" href="/accounting/reports/mayor/export?format=pdf&start=<%= startDate || '' %>&end=<%= endDate || '' %>">Exportar PDF</a>
</div>
</section>

<section class="panel">
<% if (!ledger.length) { %>
<div class="table-row empty">No hay movimientos en el rango seleccionado.</div>
<% } %>
<% ledger.forEach(account => { %>
<div class="panel">
<div class="panel-header">
<h2><%= account.code %> - <%= account.name %></h2>
<span class="helper"><%= account.type %></span>
</div>
<div class="table">
<div class="table-row header accounting-ledger">
<div>Fecha</div>
<div>Descripción</div>
<div>Debe</div>
<div>Haber</div>
</div>
<% if (!account.lines.length) { %>
<div class="table-row empty">Sin movimientos.</div>
<% } %>
<% account.lines.forEach(line => { %>
<div class="table-row accounting-ledger">
<div><%= line.entry_date %></div>
<div><%= line.description || line.line_memo || '-' %></div>
<div><%= baseCurrency %> <%= Number(line.debit || 0).toFixed(2) %></div>
<div><%= baseCurrency %> <%= Number(line.credit || 0).toFixed(2) %></div>
</div>
<% }) %>
</div>
</div>
<% }) %>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>

