?<%
  var currentPackagesNav = typeof packagesNav !== 'undefined' ? packagesNav : 'list';
  var safeStats = typeof stats !== 'undefined' && stats ? stats : {
    total: 0,
    receivedToday: 0,
    pending: 0,
    delivered: 0,
    inTransit: 0,
    customsHold: 0
  };
  var calcVolWeight = function (pkg) {
    var length = Number(pkg.length_cm || 0);
    var width = Number(pkg.width_cm || 0);
    var height = Number(pkg.height_cm || 0);
    var value = ((length * width * height) / 5000) * 2.2046;
    return Number.isFinite(value) && value > 0 ? value : 0;
  };
  var canCreatePackageTabs = can('packages', 'create');
  var packageModuleTabs = [
    { key: 'dashboard', label: t('packages.module.dashboard'), href: '/packages/dashboard' },
    { key: 'list', label: t('packages.module.list'), href: '/packages' },
    { key: 'pending_invoice', label: t('packages.module.pending_invoice'), href: '/packages/pending-invoice' }
  ];
  if (canCreatePackageTabs) {
    packageModuleTabs.push({ key: 'new', label: t('packages.module.new'), href: '/packages/new' });
  }
  packageModuleTabs.push(
    { key: 'statuses', label: t('packages.module.statuses'), href: '/packages/statuses' },
    { key: 'tracking', label: t('packages.module.tracking'), href: '/packages/tracking' }
  );
%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('packages.title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page packages-page">
<%- include('partials/header', {
  moduleTabs: packageModuleTabs,
  activeTab: currentPackagesNav,
  currentModule: 'packages'
}) %>
<main class="container packages-module app-module">
<% const canPackagesCreate = canCreatePackageTabs; %>
<% const canPackagesExport = can('packages', 'export'); %>
<% const canPackagesEdit = can('packages', 'edit'); %>
<% const canPackagesStatus = can('packages', 'change_status'); %>
<div class="page-header app-page-header">
<div class="app-page-header__content">
<h1>
<%= t('packages.title') %>
</h1>
<p class="muted">
<%= t('packages.subtitle') %>
</p>
</div>
<div class="actions page-actions app-page-actions">
<a class="btn app-btn" href="/packages/home">
<%= t('packages.module.home') %>
</a>
<% if (canPackagesCreate) { %>
<a class="btn app-btn" href="/packages/new">
<%= t('packages.module.new') %>
</a>
<% } %>
<a class="btn app-btn" href="/packages/dashboard">
<%= t('packages.dashboard_link') %>
</a>
</div>
</div>
<div class="packages-quick-actions app-action-bar">
<span class="quick-label">
<%= t('packages.module.home') %>
</span>
<div class="actions">
<% if (canPackagesCreate) { %>
<a class="btn primary app-btn app-btn-primary" href="/packages/new">
<%= t('packages.module.new') %>
</a>
<% } %>
<a class="btn app-btn" href="/packages/dashboard">
<%= t('packages.module.dashboard') %>
</a>
<a class="btn app-btn" href="/packages/tracking">
<%= t('packages.module.tracking') %>
</a>
</div>
</div>
<%- include('partials/toasts') %>
<section class="panel app-panel">
<div class="panel-header app-panel-header">
<h2>
<%= t('packages.summary') %>
</h2>
<% if (canPackagesExport) { %>
<a class="btn app-btn" href="<%= exportUrl %>">
<%= t('packages.export_csv') %>
</a>
<% } %>
</div>
<div class="grid">
<% statuses.forEach(status => { %>
<% const found = (statusCounts || []).find(row => row.status === status); %>
<div class="stat">
<div class="stat-label">
<%= status %>
</div>
<div class="stat-value">
<%= found ? found.count : 0 %>
</div>
</div>
<% }) %>
</div>
</section>
<section class="panel app-panel">
<h2>
<%= t('packages.list') %>
</h2>
<div class="muted">
<%= t('packages.urgent_hint', {          stuck: urgentConfig.stuckDays,          invoice: urgentConfig.invoiceDays,          customs: urgentConfig.customsDays        }) %>
</div>
<div class="summary-strip app-toolbar">
<div class="summary-item app-card">
<span class="summary-label">
<%= t('packages_dashboard.total') %>
</span>
<span class="summary-value">
<%= safeStats.total || 0 %>
</span>
</div>
<div class="summary-item app-card">
<span class="summary-label">
<%= t('packages_dashboard.pending_invoice') %>
</span>
<span class="summary-value">
<%= safeStats.pendingInvoice || 0 %>
</span>
</div>
<div class="summary-item app-card">
<span class="summary-label">
<%= t('packages_dashboard.delivered') %>
</span>
<span class="summary-value">
<%= safeStats.delivered || 0 %>
</span>
</div>
</div>
<div class="filters-bar app-filter-bar">
<form method="GET" action="/packages" class="filters-form app-filter-grid">
<label class="filters-field">
<span>
<%= t('packages.filter_search') %>
</span>
<input              type="text"              name="q"              value="<%= filters.q || '' %>"              placeholder="<%= t('packages.filter_search_hint') %>"            />
</label>
<label class="filters-field">
<span>
<%= t('packages.filter_status') %>
</span>
<select name="status">
<option value="" <%= !filters.status ? 'selected' : '' %>>
<%= t('common.reset') %>
</option>
<% statuses.forEach(status => { %>
<option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>>
<%= status %>
</option>
<% }) %>
</select>
</label>
<label class="filters-field">
<span>
<%= t('packages.filter_customer') %>
</span>
<select name="customer">
<option value="" <%= !filters.customer ? 'selected' : '' %>>
<%= t('common.reset') %>
</option>
<% customers.forEach(customer => { %>
<option value="<%= customer.id %>" <%= String(filters.customer) === String(customer.id) ? 'selected' : '' %>>
<%= customer.customer_code ? `${customer.customer_code} - ` : '' %><%= customer.name %>
</option>
<% }) %>
</select>
</label>
<label class="filters-field">
<span>
<%= t('packages.filter_carrier') %>
</span>
<input type="text" name="carrier" value="<%= filters.carrier || '' %>" />
</label>
<label class="filters-field">
<span>
<%= t('packages.filter_received_date') %>
</span>
<input type="date" name="received_date" value="<%= filters.received_date || '' %>" />
</label>
<div class="filters-actions">
<button type="submit" class="btn small app-btn app-btn-small">
<%= t('packages.apply_filter') %>
</button>
<a class="btn small app-btn app-btn-small" href="/packages">
<%= t('packages.reset_filters') %>
</a>
</div>
</form>
</div>
<form id="bulk-actions-form" method="POST">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<div class="bulk-actions-bar app-action-bar">
<label class="checkbox">
<input type="checkbox" id="select-all-packages" />
<span>
<%= t('packages.module.select_all') %>
</span>
</label>
<% if (canPackagesExport) { %>
<div class="bulk-form">
<button type="submit" class="btn small app-btn app-btn-small" formaction="/packages/labels/print">
<%= t('packages.print_labels') %>
</button>
</div>
<a class="btn small app-btn app-btn-small" href="<%= exportUrl %>">
<%= t('packages.export_csv') %>
</a>
<% } %>
</div>
<%          const statusClassMap = {            'Recibido en bodega USA': 'status-received',            'Recibido en bodega': 'status-received',            'Pendiente de factura': 'status-pending',            'Factura subida': 'status-invoice',            'Cargado a vuelo': 'status-loaded',          'En tránsito': 'status-transit',          'En aduana de destino': 'status-customs',          'En proceso de aduana': 'status-customs',          'Liberado': 'status-released',          'En entrega': 'status-delivery',          'Entregado': 'status-delivered'          };        %>
<div class="table compact packages-table app-table-wrap">
<div class="table-row header packages-compact">
<div>
<%= t('packages.table.internal_code') %>
</div>
<div>
<%= t('packages.table.tracking') %>
</div>
<div>
<%= t('packages.consignatario') %>
</div>
<div>
<%= t('packages.table.description') %>
</div>
<div>
<%= t('packages.table.weight') %>
</div>
<div>
Archivos
</div>
<div>
<%= t('packages.table.carrier') %>
</div>
<div>
<%= t('packages.table.status') %>
</div>
<div>
<%= t('packages.table.actions') %>
</div>
</div>
<% if (packages.length === 0) { %>
<div class="table-row empty app-empty-state">
<%= t('packages.no_packages') %>
</div>
<% } %>
<% packages.forEach(pkg => { %>
<% const stuckTooLong = pkg.days_in_status !== null && pkg.days_in_status >= urgentConfig.stuckDays; %>
<% const invoiceTooLong = (pkg.invoice_status !== 'uploaded') && pkg.days_since_received !== null && pkg.days_since_received >= urgentConfig.invoiceDays; %>
<% const inCustoms = pkg.status === 'En aduana de destino' || pkg.status === 'En proceso de aduana'; %>
<% const customsTooLong = inCustoms && pkg.days_in_status !== null && pkg.days_in_status >= urgentConfig.customsDays; %>
<% const statusClass = statusClassMap[pkg.status] || 'status-default'; %>
<div class="table-row packages-compact app-table-row <%= (stuckTooLong || invoiceTooLong || customsTooLong) ? 'urgent' : '' %>">
<div class="cell-ellipsis" title="<%= pkg.internal_code || '-' %>">
<%= pkg.internal_code || '-' %>
</div>
<div class="cell-ellipsis" title="<%= pkg.tracking_number || '-' %>">
<%= pkg.tracking_number || '-' %>
</div>
<div class="cell-ellipsis" title="<%= pkg.consignatario_name || (pkg.customer_code ? `${pkg.customer_code} - ` : '') + (pkg.customer_name || t('common.unassigned')) %>">
<%= pkg.consignatario_name || (pkg.customer_code ? `${pkg.customer_code} - ` : '') + (pkg.customer_name || t('common.unassigned')) %>
</div>
<div class="cell-ellipsis" title="<%= pkg.description || '-' %>">
<%= pkg.description || '-' %>
</div>
<div>
<div><%= pkg.weight_lbs ? Number(pkg.weight_lbs).toFixed(2) + ' lbs' : '-' %></div>
<small class="muted">Vol: <%= calcVolWeight(pkg).toFixed(2) %> lbs</small>
</div>
<div class="package-media-actions">
<% if (pkg.first_photo_url) { %>
<button type="button" class="btn small app-btn app-btn-small" data-package-media data-package-id="<%= pkg.id %>" data-package-media-type="photos">
Fotos (<%= pkg.photo_count || 0 %>)
</button>
<% } else { %>
<span class="muted">Fotos: 0</span>
<% } %>
<% if (pkg.invoice_file_url) { %>
<button type="button" class="btn small app-btn app-btn-small" data-package-media data-package-id="<%= pkg.id %>" data-package-media-type="invoice">
Documento
</button>
<% } else { %>
<span class="muted">Sin doc.</span>
<% } %>
</div>
<div class="cell-ellipsis" title="<%= pkg.carrier || '-' %>">
<%= pkg.carrier || '-' %>
</div>
<div class="status-cell">
<span class="status-badge app-badge <%= statusClass %>">
<%= pkg.status %>
</span>
</div>
<div class="actions actions-compact actions-packages">
<input                type="checkbox"                name="package_ids[]"                value="<%= pkg.id %>"                class="package-select"                aria-label="Seleccionar paquete"              />
<a class="btn small app-btn app-btn-small" href="/packages/<%= pkg.id %>">
<%= t('packages.action.view_short') %>
</a>
<% if (canPackagesEdit) { %>
<a class="btn small app-btn app-btn-small" href="/packages/<%= pkg.id %>/edit">
<%= t('packages.action.edit_short') %>
</a>
<% } %>
<a class="btn small app-btn app-btn-small" href="/packages/<%= pkg.id %>/label">
<%= t('packages.action.label_short') %>
</a>
</div>
</div>
<% }) %>
</div>
</form>
</section>
<div class="modal-overlay hidden package-media-modal" data-package-media-modal aria-hidden="true">
<div class="modal-card package-media-modal__card" role="dialog" aria-modal="true" aria-labelledby="package-media-title">
<div class="modal-header">
<h2 id="package-media-title">Vista previa</h2>
<button type="button" class="btn small app-btn app-btn-small" data-media-close>Cerrar</button>
</div>
<div class="package-media-modal__body" data-media-body></div>
</div>
</div>
</main>
<script>    (function () {      const selectAll = document.getElementById('select-all-packages');      const boxes = Array.from(document.querySelectorAll('.package-select'));      if (!selectAll || boxes.length === 0) return;      selectAll.addEventListener('change', function () {        boxes.forEach((box) => {          box.checked = selectAll.checked;        });      });    })();  </script>
<script>
  (function () {
    const modal = document.querySelector('[data-package-media-modal]');
    if (!modal) return;
    const title = modal.querySelector('#package-media-title');
    const body = modal.querySelector('[data-media-body]');
    const closeButtons = modal.querySelectorAll('[data-media-close]');
    const close = () => {
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      if (body) body.innerHTML = '';
    };
    const renderMedia = (items) => {
      if (!body) return;
      if (!items.length) {
        body.innerHTML = '<p class="muted">No hay archivos para mostrar.</p>';
        return;
      }
      if (items.length === 1) {
        const item = items[0];
        body.innerHTML = item.kind === 'pdf'
          ? `<iframe src="${item.src}" title="Documento del paquete"></iframe>`
          : `<img src="${item.src}" alt="Archivo del paquete" />`;
        return;
      }
      body.innerHTML = `<div class="package-media-gallery">${items.map((item) => (
        item.kind === 'pdf'
          ? `<iframe src="${item.src}" title="Documento del paquete"></iframe>`
          : `<img src="${item.src}" alt="Foto del paquete" />`
      )).join('')}</div>`;
    };
    const open = (button) => {
      const src = button.getAttribute('data-media-src');
      const kind = button.getAttribute('data-media-kind');
      if (!src || !body) return;
      if (title) title.textContent = button.getAttribute('data-media-title') || 'Vista previa';
      renderMedia([{ src, kind }]);
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
    };
    const openPackageMedia = async (button) => {
      const packageId = button.getAttribute('data-package-id');
      const type = button.getAttribute('data-package-media-type');
      if (!packageId || !body) return;
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      body.innerHTML = '<p class="muted">Cargando...</p>';
      try {
        const response = await fetch(`/packages/${packageId}/media`, { headers: { Accept: 'application/json' } });
        const data = await response.json();
        if (!data || !data.ok) throw new Error('media_load_failed');
        if (title) title.textContent = `${type === 'invoice' ? 'Documento' : 'Fotos'} ${data.package && data.package.title ? data.package.title : ''}`.trim();
        if (type === 'invoice') {
          renderMedia(data.invoice ? [{ src: data.invoice.url, kind: data.invoice.isPdf ? 'pdf' : 'image' }] : []);
        } else {
          renderMedia((data.photos || []).map((src) => ({ src, kind: 'image' })));
        }
      } catch (err) {
        body.innerHTML = '<p class="muted">No se pudo cargar la vista previa.</p>';
      }
    };
    document.querySelectorAll('[data-media-open]').forEach((button) => {
      button.addEventListener('click', () => open(button));
    });
    document.querySelectorAll('[data-package-media]').forEach((button) => {
      button.addEventListener('click', () => openPackageMedia(button));
    });
    closeButtons.forEach((button) => button.addEventListener('click', close));
    modal.addEventListener('click', (event) => {
      if (event.target === modal) close();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  })();
</script>
<script src="/status-footer.js" defer></script>
</body>
</html>


