<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Libro diario</title>
<link rel="stylesheet" href="/styles.css" />
</head>
<body class="page">
<header class="topbar">
<div class="brand"><%= t('common.brand') %></div>
<nav class="nav">
<a href="/dashboard">Dashboard</a>
<a href="/accounting/reports">Reportes</a>
<a href="/logout"><%= t('nav.logout') %></a>
</nav>
</header>
<main class="container">
<h1>Libro diario</h1>
<nav class="subnav">
<a href="/accounting/accounts">Catálogo</a>
<a href="/accounting/categories">Categorías</a>
<a href="/accounting/categories/rules">Reglas</a>
<a href="/accounting/journal">Pólizas</a>
<a href="/accounting/reports" class="<%= active === 'reports' ? 'active' : '' %>">Reportes</a>
<a href="/accounting/settings">Configuración</a>
</nav>

<section class="panel">
<form class="form" method="get" action="/accounting/reports/diario">
<label>
Desde
<input type="date" name="start" value="<%= startDate || '' %>" />
</label>
<label>
Hasta
<input type="date" name="end" value="<%= endDate || '' %>" />
</label>
<button class="btn primary" type="submit">Filtrar</button>
</form>
<div class="actions">
<a class="btn" href="/accounting/reports/diario/export?format=xlsx&start=<%= startDate || '' %>&end=<%= endDate || '' %>">Exportar Excel</a>
<a class="btn" href="/accounting/reports/diario/export?format=pdf&start=<%= startDate || '' %>&end=<%= endDate || '' %>">Exportar PDF</a>
</div>
</section>

<section class="panel">
<% if (!entries.length) { %>
<div class="table-row empty">No hay movimientos en el rango seleccionado.</div>
<% } %>
<% entries.forEach(entry => { %>
<div class="panel">
<div class="detail-grid">
<div><strong>Fecha:</strong> <%= entry.entry_date %></div>
<div><strong>Descripción:</strong> <%= entry.description || '-' %></div>
<div><strong>Usuario:</strong> <%= entry.user_name || '-' %></div>
</div>
<div class="table">
<div class="table-row header accounting-ledger">
<div>Cuenta</div>
<div>Detalle</div>
<div>Debe</div>
<div>Haber</div>
</div>
<% entry.lines.forEach(line => { %>
<div class="table-row accounting-ledger">
<div><%= line.account_code %> - <%= line.account_name %></div>
<div><%= line.line_memo || '-' %></div>
<div><%= baseCurrency %> <%= Number(line.debit || 0).toFixed(2) %></div>
<div><%= baseCurrency %> <%= Number(line.credit || 0).toFixed(2) %></div>
</div>
<% }) %>
</div>
</div>
<% }) %>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>

