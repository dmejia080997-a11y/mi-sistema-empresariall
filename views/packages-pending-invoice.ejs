<% var currentPackagesNav = typeof packagesNav !== 'undefined' ? packagesNav : 'pending_invoice'; %>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('packages.pending_invoice.title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container packages-module">
<% const canPackagesCreate = can('packages', 'create'); %>
<% const canPackagesEdit = can('packages', 'edit'); %>
<div class="page-header">
<div>
<h1>
<%= t('packages.pending_invoice.title') %>
</h1>
<p class="muted">
<%= t('packages.pending_invoice.subtitle') %>
</p>
</div>
<div class="actions">
<a class="btn" href="/packages/home">
<%= t('packages.module.home') %>
</a>
<a class="btn" href="/packages">
<%= t('packages.module.list') %>
</a>
</div>
</div>
<div class="module-nav">
<a href="/packages/dashboard" class="<%= currentPackagesNav === 'dashboard' ? 'active' : '' %>">
<%= t('packages.module.dashboard') %>
</a>
<a href="/packages" class="<%= currentPackagesNav === 'list' ? 'active' : '' %>">
<%= t('packages.module.list') %>
</a>
<a href="/packages/pending-invoice" class="<%= currentPackagesNav === 'pending_invoice' ? 'active' : '' %>">
<%= t('packages.module.pending_invoice') %>
</a>
<% if (canPackagesCreate) { %>
<a href="/packages/new" class="<%= currentPackagesNav === 'new' ? 'active' : '' %>">
<%= t('packages.module.new') %>
</a>
<% } %>
<a href="/packages/statuses" class="<%= currentPackagesNav === 'statuses' ? 'active' : '' %>">
<%= t('packages.module.statuses') %>
</a>
<a href="/packages/tracking" class="<%= currentPackagesNav === 'tracking' ? 'active' : '' %>">
<%= t('packages.module.tracking') %>
</a>
</div>
<% if (error) { %>
<div class="alert">
<%= error %>
</div>
<% } %>
<% if (flash) { %>
<div class="alert <%= flash.type %>">
<%= flash.message %>
</div>
<% } %>
<section class="panel">
<h2>
<%= t('packages.pending_invoice.title') %>
</h2>
<p class="muted">
<%= t('packages.pending_invoice.subtitle') %>
</p>
<div class="table compact packages-table">
<div class="table-row header packages-compact">
<div>
<%= t('packages.table.internal_code') %>
</div>
<div>
<%= t('packages.table.tracking') %>
</div>
<div>
<%= t('packages.table.customer') %>
</div>
<div>
<%= t('packages.received_at') %>
</div>
<div>
<%= t('packages.table.actions') %>
</div>
</div>
<% if (packages.length === 0) { %>
<div class="table-row empty">
<%= t('packages.pending_invoice.empty') %>
</div>
<% } %>
<% packages.forEach(pkg => { %>
<div class="table-row packages-compact">
<div class="cell-ellipsis" title="<%= pkg.internal_code || '-' %>">
<%= pkg.internal_code || '-' %>
</div>
<div class="cell-ellipsis" title="<%= pkg.tracking_number || '-' %>">
<%= pkg.tracking_number || '-' %>
</div>
<div class="cell-ellipsis" title="<%= pkg.consignatario_name || (pkg.customer_code ? `${pkg.customer_code} - ` : '') + (pkg.customer_name || t('common.unassigned')) %>">
<%= pkg.consignatario_name || (pkg.customer_code ? `${pkg.customer_code} - ` : '') + (pkg.customer_name || t('common.unassigned')) %>
</div>
<div>
<%= pkg.received_at || pkg.created_at || '-' %>
</div>
<div class="pending-invoice-actions">
<% if (canPackagesEdit) { %>
<form method="POST" action="/packages/<%= pkg.id %>/request-invoice/whatsapp">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn small">
<%= t('packages.pending_invoice.whatsapp') %>
</button>
</form>
<form method="POST" action="/packages/<%= pkg.id %>/request-invoice/email">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn small">
<%= t('packages.pending_invoice.email') %>
</button>
</form>
<form method="POST" action="/packages/<%= pkg.id %>/invoice" enctype="multipart/form-data">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<input type="file" name="invoice_file" accept="application/pdf,image/*" required />
<button type="submit" class="btn small">
<%= t('packages.pending_invoice.upload') %>
</button>
</form>
<% } %>
</div>
</div>
<% }) %>
</div>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
