                    <label class="projects-quote-line__field" data-quote-optional><span>Unidad</span><input class="app-input" type="text" name="line_service_unit" value="<%= line.service_unit || '' %>" placeholder="Unidad" /></label>
                    <label class="projects-quote-line__field"><span>Descripcion comercial</span><input class="app-input" type="text" name="line_description" value="<%= line.description || '' %>" placeholder="Descripcion comercial" /></label>
                    <label class="projects-quote-line__field"><span>Cantidad</span><input class="app-input" type="number" name="line_qty" min="0" step="0.01" value="<%= Number(line.qty || 0).toFixed(2) %>" placeholder="Cant." /></label>
                    <label class="projects-quote-line__field"><span>Costo</span><input class="app-input" type="number" name="line_unit_cost" min="0" step="0.01" value="<%= Number(line.unit_cost || 0).toFixed(2) %>" placeholder="Costo" /></label>
                    <label class="projects-quote-line__field"><span>Ganancia</span><input class="app-input" type="text" name="line_margin_percent" value="<%= `${quoteLineMarginPercent(line).toFixed(2)}%` %>" placeholder="100 o 20%" /></label>
                    <label class="projects-quote-line__field"><span>Ganancia Q</span><input class="app-input" type="number" name="line_profit_amount" min="0" step="0.01" value="<%= Number(line.profit_amount || ((Number(line.qty || 0) || 0) * ((Number(line.unit_price || 0) || 0) - (Number(line.unit_cost || 0) || 0)))).toFixed(2) %>" placeholder="Ganancia Q" readonly /></label>
                    <label class="projects-quote-line__field"><span>Venta</span><input class="app-input" type="number" name="line_unit_price" min="0" step="0.01" value="<%= Number(line.unit_price || 0).toFixed(2) %>" placeholder="Venta" readonly /></label>
                    <label class="projects-quote-line__field" data-quote-optional><span>IVA %</span><input class="app-input" type="number" name="line_tax_rate" min="0" step="0.01" value="<%= Number(line.tax_rate || 0).toFixed(2) %>" placeholder="IVA %" /></label>
                    <label class="projects-quote-line__field" data-quote-optional><span>Tipo descuento</span><select name="line_discount_type">
                        <option value="percent" <%= line.discount_type === 'percent' ? 'selected' : '' %>>Desc. %</option>
                        <option value="amount" <%= line.discount_type === 'amount' ? 'selected' : '' %>>Desc. monto</option>
                      </select></label>
                    <label class="projects-quote-line__field"><span>Descuento</span><input class="app-input" type="number" name="line_discount_value" min="0" step="0.01" value="<%= Number(line.discount_value || 0).toFixed(2) %>" placeholder="Desc. %" /></label>
                    <label class="projects-quote-line__field"><span>Descuento Q</span><input class="app-input" type="number" name="line_discount_amount" min="0" step="0.01" value="<%= Number(line.discount_amount || 0).toFixed(2) %>" placeholder="Desc. Q" readonly /></label>
                  </div>
                <% }) %>
                <% for (let i = 0; i < editingEmptyLineCount; i += 1) { %>
                  <div class="projects-quote-line projects-quote-line--extended" data-quote-line>
                    <label class="projects-quote-line__field"><span>Servicio</span><input class="app-input" type="text" name="line_service_name" placeholder="Servicio" /></label>
                    <label class="projects-quote-line__field" data-quote-optional><span>Detalle o alcance</span><input class="app-input" type="text" name="line_service_details" placeholder="Detalle o alcance" /></label>
                    <label class="projects-quote-line__field" data-quote-optional><span>Unidad</span><input class="app-input" type="text" name="line_service_unit" placeholder="Unidad" /></label>
                    <label class="projects-quote-line__field"><span>Descripcion comercial</span><input class="app-input" type="text" name="line_description" placeholder="Descripcion comercial" /></label>
                    <label class="projects-quote-line__field"><span>Cantidad</span><input class="app-input" type="number" name="line_qty" min="0" step="0.01" placeholder="Cant." /></label>
                    <label class="projects-quote-line__field"><span>Costo</span><input class="app-input" type="number" name="line_unit_cost" min="0" step="0.01" placeholder="Costo" /></label>
                    <label class="projects-quote-line__field"><span>Ganancia</span><input class="app-input" type="text" name="line_margin_percent" placeholder="100 o 20%" /></label>
                    <label class="projects-quote-line__field"><span>Ganancia Q</span><input class="app-input" type="number" name="line_profit_amount" min="0" step="0.01" placeholder="Ganancia Q" readonly /></label>
                    <label class="projects-quote-line__field"><span>Venta</span><input class="app-input" type="number" name="line_unit_price" min="0" step="0.01" placeholder="Venta" readonly /></label>
                    <label class="projects-quote-line__field" data-quote-optional><span>IVA %</span><input class="app-input" type="number" name="line_tax_rate" min="0" step="0.01" placeholder="IVA %" /></label>
                    <label class="projects-quote-line__field" data-quote-optional><span>Tipo descuento</span><select name="line_discount_type">
                        <option value="percent">Desc. %</option>
                        <option value="amount">Desc. monto</option>
                      </select></label>
                    <label class="projects-quote-line__field"><span>Descuento</span><input class="app-input" type="number" name="line_discount_value" min="0" step="0.01" placeholder="Desc. %" /></label>
                    <label class="projects-quote-line__field"><span>Descuento Q</span><input class="app-input" type="number" name="line_discount_amount" min="0" step="0.01" placeholder="Desc. Q" readonly /></label>
                  </div>
                <% } %>
              </div>
            </div>

            <label class="app-field projects-form-full">
              <span>Notas</span>
              <textarea class="app-textarea" name="notes" rows="2"><%= editingQuote.notes || '' %></textarea>
            </label>
            <label class="app-field projects-form-full">
              <span>Adjuntos para el PDF</span>
              <input class="app-input" type="file" name="quote_attachments" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.png,.jpg,.jpeg,.webp,.gif" />
            </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Guardar cambios</button>
            <a class="btn app-btn" href="<%= quoteListHref %>">Regresar al listado</a>
          </div>
        </form>
      </section>
      <% } %>

      <% if (!isEditingQuote) { %>
      <section class="projects-stack">
        <% if (!quotes.length) { %>
          <div class="app-empty-state projects-empty-card">
            <p class="app-empty-state-text"><%= listEmptyMessage %></p>
          </div>
        <% } %>
        <% quotes.forEach((quote) => { %>
          <article class="panel app-panel projects-quote-card">
            <div class="projects-quote-card__header">
              <div>
                <div class="projects-detail-hero__head">
                  <span class="status-badge <%= quoteStatusClass[quote.status] || 'project-status-draft' %>"><%= quote.status_label %></span>
                  <% if (quote.isArchived) { %>
                    <span class="status-badge <%= quoteStatusClass.archived %>">Archivada</span>
                  <% } %>
                  <span class="<%= quote.isExpired ? 'projects-overdue' : 'muted' %>"><%= quote.isExpired ? 'Vencida' : 'Vigente' %></span>
                </div>
                <h3><%= quote.title %></h3>
                <p class="muted"><%= quote.project_display %> · <%= quote.customer_display %> · Valida <%= formatDate(quote.valid_until) %></p>
              </div>
              <strong><%= formatMoney(quote.total, quote.currency) %></strong>
            </div>
            <div class="projects-quote-card__totals">
              <span>Lineas <strong><%= quote.line_count %></strong></span>
              <span>Costo estimado <strong><%= formatMoney(quote.cost_estimated, quote.currency) %></strong></span>
              <span>Subtotal <strong><%= formatMoney(quote.subtotal, quote.currency) %></strong></span>
              <span>Impuestos <strong><%= formatMoney(quote.tax_amount, quote.currency) %></strong></span>
              <span>Descuento <strong><%= formatMoney(quote.discount_amount, quote.currency) %></strong></span>
            </div>
            <div class="projects-quote-lines-summary">
              <% quote.lines.forEach((line) => { %>
                <div class="projects-quote-lines-summary__row">
                  <div>
                    <strong><%= line.service_display || line.description %></strong>
                    <% if (line.service_meta) { %>
                      <p class="muted"><%= line.service_meta %></p>
                    <% } %>
                  </div>
                  <strong><%= Number(line.qty || 0).toFixed(2) %> x <%= formatMoney(line.unit_price, quote.currency) %></strong>
                  <p class="muted">
                    Costo <%= formatMoney(line.unit_cost, quote.currency) %> · Ganancia <%= Number(line.margin_percent || quoteLineMarginPercent(line) || 0).toFixed(2) %>% / <%= formatMoney(line.profit_amount, quote.currency) %> · Desc. <%= formatMoney(line.discount_amount, quote.currency) %>
                  </p>
                </div>
              <% }) %>
            </div>
            <% if (quote.rejection_comment) { %>
              <p class="muted"><strong>Motivo de anulacion:</strong> <%= quote.rejection_comment %></p>
            <% } %>
            <div class="actions">
              <a class="btn app-btn" href="/projects/quotes/<%= quote.id %>">Ver</a>
              <a class="btn app-btn" href="/projects/quotes/<%= quote.id %>/pdf?download=1">Imprimir PDF</a>
              <% if (quote.project_id) { %>
                <a class="btn app-btn" href="/projects/<%= quote.project_id %>?tab=quotes">Abrir proyecto</a>
              <% } %>
              <% if (!quote.project_id && !quote.isArchived) { %>
                <form method="POST" action="/projects/quotes/<%= quote.id %>/project" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="return_to" value="<%= quoteReturnUrl %>" />
                  <button type="submit" class="btn primary app-btn app-btn-primary">Transformar a proyecto</button>
                </form>
              <% } %>
              <% if (!quote.converted_invoice_id) { %>
                <a class="btn app-btn" href="<%= buildDashboardUrl({ section: 'quotes', quote_view: 'list', quote_mode: 'edit', quote_id: quote.id }) %>">Seguir editando</a>
              <% } %>
              <% if (quote.project_id && !quote.isArchived && quote.status !== 'approved' && quote.status !== 'converted') { %>
                <form method="POST" action="/projects/<%= quote.project_id %>/quotes/<%= quote.id %>/status" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="status" value="approved" />
                  <input type="hidden" name="return_to" value="<%= quoteReturnUrl %>" />
                  <button type="submit" class="btn app-btn">Aprobar</button>
                </form>
              <% } %>
              <% if (quote.project_id && !quote.isArchived && quote.status === 'approved' && !quote.converted_invoice_id) { %>
                <form method="POST" action="/projects/<%= quote.project_id %>/quotes/<%= quote.id %>/convert" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="return_to" value="<%= quoteReturnUrl %>" />
                  <button type="submit" class="btn primary app-btn app-btn-primary">Convertir</button>
                </form>
              <% } %>
              <% if (quote.converted_invoice_id) { %>
                <a class="btn app-btn" href="/invoices/<%= quote.converted_invoice_id %>">Ver factura</a>
              <% } %>
              <form method="POST" action="/projects/quotes/<%= quote.id %>/archive" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="archive_action" value="<%= quote.isArchived ? 'restore' : 'archive' %>" />
                <input type="hidden" name="return_to" value="<%= quoteReturnUrl %>" />
                <button type="submit" class="btn app-btn"><%= quote.isArchived ? 'Restaurar' : 'Archivar' %></button>
              </form>
            </div>
          </article>
        <% }) %>
      </section>
      <% } %>
      <% } %>

      <% if (currentQuoteView === 'status' && can('projects', 'quotes')) { %>
      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Cambiar de estado</h2>
            <p class="muted">Selecciona una o varias cotizaciones y aplica el estado o accion necesaria.</p>
          </div>
        </div>
        <% if (quoteSelectorOptions && quoteSelectorOptions.length) { %>
          <form method="POST" action="/projects/quotes/bulk-status" class="projects-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="return_to" value="<%= buildDashboardUrl({ section: 'quotes', quote_view: 'status', quote_mode: '', quote_id: '' }) %>" />
            <label class="app-field">
              <span>Accion</span>
              <select name="bulk_action">
                <option value="status">Cambiar estado</option>
                <option value="invoice">Facturar seleccionadas</option>
                <option value="project">Transformar a proyecto</option>
              </select>
            </label>
            <label class="app-field">
              <span>Estado</span>
              <select name="status">
                <% quoteEditableStatuses.forEach((status) => { %>
                  <option value="<%= status.key %>"><%= status.label %></option>
                <% }) %>
              </select>
            </label>
            <label class="app-field projects-form-full">
              <span>Cotizaciones</span>
              <div class="projects-quote-lines-summary">
                <% quoteSelectorOptions.forEach((quote) => { %>
                  <label class="projects-quote-lines-summary__row">
                    <span>
                      <input type="checkbox" name="quote_ids" value="<%= quote.id %>" />
                      <strong><%= quote.title %></strong>
                      <span class="muted"> · <%= quote.project_display %> · <%= quote.status_label %><%= quote.isArchived ? ' · Archivada' : '' %></span>
                    </span>
                    <strong><%= formatMoney(quote.total, quote.currency) %></strong>
                  </label>
                <% }) %>
              </div>
            </label>
            <label class="app-field projects-form-full">
              <span>Motivo de anulacion</span>
              <textarea class="app-textarea" name="rejection_comment" rows="2" placeholder="Solo requerido si el estado es Rechazada."></textarea>
            </label>
            <div class="actions projects-form-full">
              <button type="submit" class="btn primary app-btn app-btn-primary">Aplicar a seleccionadas</button>
            </div>
          </form>

          <form method="GET" action="/projects" class="projects-form-grid">
            <input type="hidden" name="section" value="quotes" />
            <input type="hidden" name="quote_view" value="status" />
            <label class="app-field projects-form-full">
              <span>Selecciona una cotizacion</span>
              <select name="quote_target_id" onchange="this.form.submit()">
                <% quoteSelectorOptions.forEach((quote) => { %>
                  <option value="<%= quote.id %>" <%= String((filters.quote_target_id || (selectedStatusQuote ? selectedStatusQuote.id : ''))) === String(quote.id) ? 'selected' : '' %>>
                    <%= truncateOptionLabel(`${quote.title} - ${quote.project_display}`) %>
                  </option>
                <% }) %>
              </select>
            </label>
          </form>

          <% if (selectedStatusQuote) { %>
            <article class="panel app-panel projects-quote-card">
              <div class="projects-quote-card__header">
                <div>
                  <div class="projects-detail-hero__head">
                    <span class="status-badge <%= quoteStatusClass[selectedStatusQuote.status] || 'project-status-draft' %>"><%= selectedStatusQuote.status_label %></span>
                    <% if (selectedStatusQuote.isArchived) { %>
                      <span class="status-badge <%= quoteStatusClass.archived %>">Archivada</span>
                    <% } %>
                  </div>
                  <h3><%= selectedStatusQuote.title %></h3>
                  <p class="muted"><%= selectedStatusQuote.project_display %> · <%= selectedStatusQuote.customer_display %> · Valida <%= formatDate(selectedStatusQuote.valid_until) %></p>
                </div>
                <strong><%= formatMoney(selectedStatusQuote.total, selectedStatusQuote.currency) %></strong>
              </div>
              <% if (selectedStatusQuote.rejection_comment) { %>
                <p class="muted"><strong>Motivo guardado:</strong> <%= selectedStatusQuote.rejection_comment %></p>
              <% } %>
              <div class="actions">
                <% if (selectedStatusQuote.project_id) { %>
                  <a class="btn app-btn" href="/projects/<%= selectedStatusQuote.project_id %>?tab=quotes">Abrir proyecto asociado</a>
                <% } %>
                <% if (!selectedStatusQuote.project_id && !selectedStatusQuote.isArchived) { %>
                  <form method="POST" action="/projects/quotes/<%= selectedStatusQuote.id %>/project" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="return_to" value="<%= buildDashboardUrl({ section: 'quotes', quote_view: 'status', quote_target_id: selectedStatusQuote.id, quote_mode: '', quote_id: '' }) %>" />
                    <button type="submit" class="btn primary app-btn app-btn-primary">Transformar a proyecto</button>
                  </form>
                <% } %>
                <% if (selectedStatusQuote.project_id && !selectedStatusQuote.isArchived && selectedStatusQuote.status !== 'approved' && selectedStatusQuote.status !== 'converted') { %>
                  <form method="POST" action="/projects/<%= selectedStatusQuote.project_id %>/quotes/<%= selectedStatusQuote.id %>/status" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="status" value="approved" />
                    <input type="hidden" name="return_to" value="<%= buildDashboardUrl({ section: 'quotes', quote_view: 'status', quote_target_id: selectedStatusQuote.id, quote_mode: '', quote_id: '' }) %>" />
                    <button type="submit" class="btn app-btn">Aprobar cotizacion</button>
                  </form>
                <% } %>
                <% if (selectedStatusQuote.project_id && !selectedStatusQuote.isArchived && selectedStatusQuote.status === 'approved' && !selectedStatusQuote.converted_invoice_id) { %>
                  <form method="POST" action="/projects/<%= selectedStatusQuote.project_id %>/quotes/<%= selectedStatusQuote.id %>/convert" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="return_to" value="<%= buildDashboardUrl({ section: 'quotes', quote_view: 'status', quote_target_id: selectedStatusQuote.id, quote_mode: '', quote_id: '' }) %>" />
                    <button type="submit" class="btn primary app-btn app-btn-primary">Facturar de una vez</button>
                  </form>
                <% } %>
                <% if (selectedStatusQuote.converted_invoice_id) { %>
                  <a class="btn app-btn" href="/invoices/<%= selectedStatusQuote.converted_invoice_id %>">Ver factura</a>
                <% } %>
              </div>
            </article>

            <% if (selectedStatusQuote.project_id && !selectedStatusQuote.isArchived && !selectedStatusQuote.converted_invoice_id) { %>
              <section class="panel app-panel">
                <div class="panel-header app-panel-header">
                  <div>
                    <h3>Anular cotizacion</h3>
                    <p class="muted">El comentario es obligatorio y queda guardado como motivo de rechazo.</p>
                  </div>
                </div>
                <form method="POST" action="/projects/<%= selectedStatusQuote.project_id %>/quotes/<%= selectedStatusQuote.id %>/status" class="projects-form-grid">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="status" value="rejected" />
                  <input type="hidden" name="return_to" value="<%= buildDashboardUrl({ section: 'quotes', quote_view: 'status', quote_target_id: selectedStatusQuote.id, quote_mode: '', quote_id: '' }) %>" />
                  <label class="app-field projects-form-full">
                    <span>Motivo de anulacion</span>
                    <textarea class="app-textarea" name="rejection_comment" rows="3" placeholder="Escribe por que se anula esta cotizacion..." required><%= selectedStatusQuote.status === 'rejected' ? (selectedStatusQuote.rejection_comment || '') : '' %></textarea>
                  </label>
                  <div class="actions projects-form-full">
                    <button type="submit" class="btn app-btn">Guardar anulacion</button>
                  </div>
                </form>
              </section>
            <% } %>
          <% } %>
        <% } else { %>
          <div class="app-empty-state projects-empty-card">
            <p class="app-empty-state-text">No hay cotizaciones registradas para cambiar de estado.</p>
          </div>
        <% } %>
      </section>
      <% } %>

      <% if (currentQuoteView === 'new' && can('projects', 'quotes')) { %>
      <section class="panel app-panel" id="new-quote">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Nueva cotizacion</h2>
            <p class="muted">Agrega servicios, cantidades y condiciones comerciales desde una vista dedicada.</p>
          </div>
          <a class="btn app-btn" href="<%= quoteListHref %>">Ver listado</a>
        </div>
        <form method="POST" action="/projects/quotes/create" enctype="multipart/form-data" class="projects-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="app-field">
            <span>Proyecto</span>
            <select name="project_id">
              <option value="">Sin proyecto</option>
              <% projectOptions.forEach((project) => { %>
                <option value="<%= project.id %>" <%= String(filters.quote_project_id || '') === String(project.id) ? 'selected' : '' %>><%= project.code ? `${project.code} - ` : '' %><%= project.name %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Titulo</span>
            <input class="app-input" type="text" name="title" placeholder="Cotizacion principal del proyecto" />
          </label>
          <label class="app-field">
            <span>Cliente</span>
            <select name="customer_id">
              <option value="">Usar cliente del proyecto</option>
              <% customers.forEach((customer) => { %>
                <option value="<%= customer.id %>"><%= truncateOptionLabel(`${customer.customer_code ? `${customer.customer_code} - ` : ''}${customer.name}`) %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Valida hasta</span>
            <input class="app-input" type="date" name="valid_until" />
          </label>
          <label class="app-field">
            <span>Moneda</span>
            <select name="currency">
              <% currencyOptions.forEach((currency) => { %>
                <option value="<%= currency %>" <%= baseCurrency === currency ? 'selected' : '' %>><%= currency %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Tipo de cambio</span>
            <input class="app-input" type="number" name="exchange_rate" step="0.0001" min="0" value="1" />
          </label>
          <label class="app-field">
            <span>Estado</span>
            <select name="status">
              <% quoteEditableStatuses.forEach((status) => { %>
                <option value="<%= status.key %>" <%= createDefaults.quote_status === status.key ? 'selected' : '' %>><%= status.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Margen %</span>
            <input class="app-input" type="number" name="margin_percent" step="0.01" min="-100" value="0" />
          </label>
          <label class="app-field">
            <span>Impuesto global %</span>
            <input class="app-input" type="number" name="tax_rate" step="0.01" min="0" value="0" />
          </label>
          <label class="app-field">
            <span>Descuento</span>
            <select name="discount_type">
              <option value="amount">Monto</option>
              <option value="percent">%</option>
            </select>
          </label>
          <label class="app-field">
            <span>Valor descuento</span>
            <input class="app-input" type="number" name="discount_value" step="0.01" min="0" value="0" />
          </label>
          <label class="app-field projects-form-full">
            <span>Descripcion general</span>
            <textarea class="app-textarea" name="description" rows="2" placeholder="Alcance general, tiempos, condiciones y entregables."></textarea>
          </label>
          <fieldset class="app-field projects-form-full">
            <legend>Campos visibles en PDF</legend>
            <input type="hidden" name="pdf_fields_submitted" value="1" />
            <div class="projects-quote-lines-summary">
              <% quotePdfFieldGroups.forEach((group) => { %>
                <div class="projects-quote-lines-summary__row">
                  <strong><%= group.label %></strong>
                  <span>
                    <% group.fields.forEach((field) => { %>
                      <label class="inline-form">
                        <input type="checkbox" name="pdf_fields" value="<%= field.key %>" checked />
                        <span><%= field.label %></span>
                      </label>
                    <% }) %>
                  </span>
                </div>
              <% }) %>
            </div>
          </fieldset>

          <div class="projects-quote-lines projects-form-full is-compact" data-quote-lines>
            <div class="projects-quote-lines__header">
              <div>
                <h3>Servicios cotizados</h3>
                <p class="muted projects-quote-lines__hint">Los campos extra estan ocultos. Puedes mostrarlos y usar el scroll horizontal si hace falta.</p>
              </div>
              <div class="projects-quote-lines__actions">
                <button type="button" class="btn app-btn app-btn-small" data-toggle-quote-fields aria-expanded="false">Mostrar campos extra</button>
                <button type="button" class="btn app-btn app-btn-small" data-add-quote-line>Agregar linea</button>
              </div>
            </div>
            <div class="projects-quote-lines__scroll" data-quote-scroll>
              <% for (let i = 0; i < 2; i += 1) { %>
                <div class="projects-quote-line projects-quote-line--extended" data-quote-line>
                  <label class="projects-quote-line__field"><span>Servicio</span><input class="app-input" type="text" name="line_service_name" placeholder="Servicio" /></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>Detalle o alcance</span><input class="app-input" type="text" name="line_service_details" placeholder="Detalle o alcance" /></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>Unidad</span><input class="app-input" type="text" name="line_service_unit" placeholder="Unidad" /></label>
                  <label class="projects-quote-line__field"><span>Descripcion comercial</span><input class="app-input" type="text" name="line_description" placeholder="Descripcion comercial" /></label>
                  <label class="projects-quote-line__field"><span>Cantidad</span><input class="app-input" type="number" name="line_qty" min="0" step="0.01" placeholder="Cant." /></label>
                  <label class="projects-quote-line__field"><span>Costo</span><input class="app-input" type="number" name="line_unit_cost" min="0" step="0.01" placeholder="Costo" /></label>
                  <label class="projects-quote-line__field"><span>Ganancia</span><input class="app-input" type="text" name="line_margin_percent" placeholder="100 o 20%" /></label>
                  <label class="projects-quote-line__field"><span>Ganancia Q</span><input class="app-input" type="number" name="line_profit_amount" min="0" step="0.01" placeholder="Ganancia Q" readonly /></label>
                  <label class="projects-quote-line__field"><span>Venta</span><input class="app-input" type="number" name="line_unit_price" min="0" step="0.01" placeholder="Venta" readonly /></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>IVA %</span><input class="app-input" type="number" name="line_tax_rate" min="0" step="0.01" placeholder="IVA %" /></label>
                  <label class="projects-quote-line__field" data-quote-optional><span>Tipo descuento</span><select name="line_discount_type">
                      <option value="percent">Desc. %</option>
                      <option value="amount">Desc. monto</option>
                    </select></label>
                  <label class="projects-quote-line__field"><span>Descuento</span><input class="app-input" type="number" name="line_discount_value" min="0" step="0.01" placeholder="Desc. %" /></label>
                  <label class="projects-quote-line__field"><span>Descuento Q</span><input class="app-input" type="number" name="line_discount_amount" min="0" step="0.01" placeholder="Desc. Q" readonly /></label>
                </div>
              <% } %>
            </div>
          </div>

          <label class="app-field projects-form-full">
            <span>Notas</span>
            <textarea class="app-textarea" name="notes" rows="2"></textarea>
          </label>
          <label class="app-field projects-form-full">
            <span>Adjuntos para el PDF</span>
            <input class="app-input" type="file" name="quote_attachments" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.png,.jpg,.jpeg,.webp,.gif" />
          </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Guardar cotizacion</button>
          </div>
        </form>
      </section>
      <% } %>
    <% } %>
  </main>

  <script>
    (function () {
      const groups = document.querySelectorAll('[data-quote-lines]');
      if (!groups.length) return;
      groups.forEach(function (container) {
        const addButton = container.querySelector('[data-add-quote-line]');
        const toggleButton = container.querySelector('[data-toggle-quote-fields]');
        const scrollArea = container.querySelector('[data-quote-scroll]') || container;
        const numberValue = function (input) {
          const value = Number(input && input.value);
          return Number.isFinite(value) ? value : 0;
        };
        const profitValue = function (input, cost) {
          const raw = String(input && input.value || '').trim().replace(',', '.');
          if (!raw) return 0;
          const numeric = Number(raw.replace('%', ''));
          if (!Number.isFinite(numeric)) return 0;
          return raw.includes('%') && cost > 0 ? cost * (numeric / 100) : numeric;
        };
        const syncLine = function (line) {
          if (!line) return;
          const qtyInput = line.querySelector('[name="line_qty"]');
          const costInput = line.querySelector('[name="line_unit_cost"]');
          const marginInput = line.querySelector('[name="line_margin_percent"]');
          const profitInput = line.querySelector('[name="line_profit_amount"]');
          const saleInput = line.querySelector('[name="line_unit_price"]');
          const discountTypeInput = line.querySelector('[name="line_discount_type"]');
          const discountValueInput = line.querySelector('[name="line_discount_value"]');
          const discountAmountInput = line.querySelector('[name="line_discount_amount"]');
          const qty = numberValue(qtyInput);
          const cost = numberValue(costInput);
          const profitPerUnit = profitValue(marginInput, cost);
          const sale = cost + profitPerUnit;
          const profitAmount = Math.max(0, qty * (sale - cost));
          const discountValue = numberValue(discountValueInput);
          const discountBase = qty * sale;
          const discountAmount = discountTypeInput && discountTypeInput.value === 'amount'
            ? discountValue
            : discountBase * (discountValue / 100);
          if (saleInput) saleInput.value = sale ? sale.toFixed(2) : '';
          if (profitInput) profitInput.value = profitAmount ? profitAmount.toFixed(2) : '';
          if (discountAmountInput) discountAmountInput.value = discountAmount ? discountAmount.toFixed(2) : '';
        };
        const bindLine = function (line) {
          if (!line || line.dataset.quoteLineBound === '1') return;
          line.dataset.quoteLineBound = '1';
          line.querySelectorAll('input, select').forEach(function (field) {
            field.addEventListener('input', function () { syncLine(line); });
            field.addEventListener('change', function () { syncLine(line); });
          });
          syncLine(line);
        };
        scrollArea.querySelectorAll('[data-quote-line]').forEach(bindLine);
        if (toggleButton) {
          const syncToggle = function () {
            const compact = container.classList.contains('is-compact');
            toggleButton.textContent = compact ? 'Mostrar campos extra' : 'Ocultar campos extra';
            toggleButton.setAttribute('aria-expanded', compact ? 'false' : 'true');
          };
          toggleButton.addEventListener('click', function () {
            container.classList.toggle('is-compact');
            syncToggle();
          });
          syncToggle();
        }
        if (!addButton) return;
        addButton.addEventListener('click', function () {
          const first = scrollArea.querySelector('[data-quote-line]');
          if (!first) return;
          const clone = first.cloneNode(true);
          clone.dataset.quoteLineBound = '';
          clone.querySelectorAll('input').forEach((input) => { input.value = ''; });
          clone.querySelectorAll('select').forEach((select) => { select.selectedIndex = 0; });
          scrollArea.appendChild(clone);
          bindLine(clone);
          scrollArea.scrollLeft = scrollArea.scrollWidth;
        });
      });
    })();
  </script>
  <script src="/status-footer.js" defer></script>
</body>
</html>
