<!DOCTYPE html>
<%
  const moduleTabs = [
    { key: 'dashboard', label: 'Dashboard de proyectos', href: '/projects' }
  ];
  const formatMoney = (value, currency = 'GTQ') => `${currency || 'GTQ'} ${Number(value || 0).toFixed(2)}`;
  const formatDate = (value) => {
    if (!value) return 'Sin fecha';
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) return value;
    return parsed.toLocaleDateString('es-GT', { year: 'numeric', month: 'short', day: 'numeric' });
  };
  const truncateOptionLabel = (value, max = 52) => {
    const text = String(value || '').trim();
    if (!text) return '';
    return text.length > max ? `${text.slice(0, max - 3)}...` : text;
  };
  const isPdfFieldSelected = (selected, key) => {
    const values = Array.isArray(selected) && selected.length ? selected : quotePdfDefaultFields;
    return values.includes(key);
  };
  const quoteLineMarginPercent = (line) => {
    const saved = Number(line && line.margin_percent);
    if (Number.isFinite(saved) && saved !== 0) return saved;
    const cost = Number(line && line.unit_cost) || 0;
    const price = Number(line && line.unit_price) || 0;
    return cost > 0 ? ((price - cost) / cost) * 100 : saved || 0;
  };
  const taskStatusClass = {
    pending: 'project-status-planning',
    in_progress: 'project-status-progress',
    paused: 'project-status-paused',
    completed: 'project-status-completed',
    cancelled: 'project-status-cancelled'
  };
  const quoteStatusClass = {
    draft: 'project-status-draft',
    sent: 'project-status-progress',
    approved: 'project-status-completed',
    rejected: 'project-status-cancelled',
    converted_project: 'project-status-planning',
    converted: 'project-status-planning',
    archived: 'project-status-paused'
  };
  const buildDashboardUrl = (overrides = {}) => {
    const values = {
      section: activeSection || 'summary',
      view: dashboardView || 'kanban',
      quote_view: quoteView || 'summary',
      q: filters.q || '',
      status: filters.status || 'all',
      created_from: filters.created_from || '',
      created_to: filters.created_to || '',
      finished_from: filters.finished_from || '',
      finished_to: filters.finished_to || '',
      task_q: filters.task_q || '',
      task_project_id: filters.task_project_id || '',
      task_status: filters.task_status || 'all',
      assigned_to: filters.assigned_to || '',
      due_from: filters.due_from || '',
      due_to: filters.due_to || '',
      quote_q: filters.quote_q || '',
      quote_project_id: filters.quote_project_id || '',
      quote_status: filters.quote_status || 'all',
      quote_scope: filters.quote_scope || 'active',
      valid_from: filters.valid_from || '',
      valid_to: filters.valid_to || '',
      quote_target_id: filters.quote_target_id || '',
      ...overrides
    };
    const params = new URLSearchParams();
    Object.entries(values).forEach(([key, value]) => {
      if (value === undefined || value === null) return;
      const text = String(value).trim();
      if (!text) return;
      if ((key === 'status' || key === 'task_status' || key === 'quote_status') && text === 'all') return;
      if (key === 'quote_scope' && text === 'active') return;
      params.set(key, text);
    });
    const queryString = params.toString();
    return queryString ? `/projects?${queryString}` : '/projects';
  };
  const sectionTabs = [
    { key: 'summary', label: 'Resumen', href: buildDashboardUrl({ section: 'summary' }) },
    { key: 'quotes', label: 'Cotizaciones', href: buildDashboardUrl({ section: 'quotes' }) },
    { key: 'projects', label: 'Proyectos', href: buildDashboardUrl({ section: 'projects' }) },
    { key: 'tasks', label: 'Tareas', href: buildDashboardUrl({ section: 'tasks' }) }
  ];
  const sectionSubtitle = {
    summary: 'Vista ejecutiva del modulo con estado general, cierres y proyectos con atraso.',
    projects: 'Tablero general de proyectos con alta rapida, filtros y orden por etapa.',
    tasks: 'Control general de tareas por proyecto, con filtros y alta centralizada.',
    quotes: 'Cotizaciones del modulo con servicios, filtros y seguimiento comercial.'
  };
  const visibleProjectsLabel = filteredSummary.totalProjects === 1
    ? '1 proyecto visible'
    : `${filteredSummary.totalProjects} proyectos visibles`;
  const visibleTasksLabel = taskSummary.total === 1
    ? '1 tarea visible'
    : `${taskSummary.total} tareas visibles`;
  const visibleQuotesLabel = quoteSummary.total === 1
    ? '1 cotizacion visible'
    : `${quoteSummary.total} cotizaciones visibles`;
%>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Proyectos</title>
  <%- include('partials/head-assets') %>
  <link rel="stylesheet" href="/css/projects.css" />
</head>
<body class="page projects-page">
  <%- include('partials/header', {
    moduleTabs,
    activeTab: 'dashboard',
    currentModule: 'projects'
  }) %>

  <main class="container projects-shell">
    <%- include('partials/page-shell', {
      pageTitle: 'Proyectos',
      pageSubtitle: sectionSubtitle[activeSection] || sectionSubtitle.summary
    }) %>

    <%- include('partials/toasts', { flash }) %>

    <section class="projects-section-nav" aria-label="Menu del modulo de proyectos">
      <% sectionTabs.forEach((tab) => { %>
        <a
          href="<%= tab.href %>"
          class="projects-section-tab <%= activeSection === tab.key ? 'is-active' : '' %>"
          <%= activeSection === tab.key ? 'aria-current="page"' : '' %>
        >
          <span><%= tab.label %></span>
        </a>
      <% }) %>
    </section>

    <% if (activeSection === 'summary') { %>
      <section class="projects-kpi-grid">
        <article class="projects-kpi-card">
          <span>Total proyectos</span>
          <strong><%= summary.totalProjects %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Activos</span>
          <strong><%= summary.activeProjects %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Finalizados</span>
          <strong><%= summary.completedProjects %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>% cierre</span>
          <strong><%= summary.completionRate %>%</strong>
        </article>
        <article class="projects-kpi-card">
          <span>Presupuesto estimado</span>
          <strong><%= formatMoney(summary.estimatedBudget) %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Costo real</span>
          <strong><%= formatMoney(summary.realCost) %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Venta proyectada</span>
          <strong><%= formatMoney(summary.saleAmount) %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Utilidad estimada</span>
          <strong><%= formatMoney(summary.estimatedProfit) %></strong>
        </article>
      </section>

      <section class="projects-summary-grid">
        <article class="panel app-panel">
          <div class="panel-header app-panel-header">
            <div>
              <h2>Control de tareas</h2>
              <p class="muted">Lectura general de ejecucion entre todos los proyectos.</p>
            </div>
            <a class="btn app-btn" href="<%= buildDashboardUrl({ section: 'tasks' }) %>">Abrir tareas</a>
          </div>
          <div class="projects-home-metrics">
            <div><span>Total</span><strong><%= taskPortfolioSummary.total %></strong></div>
            <div><span>En proceso</span><strong><%= taskPortfolioSummary.inProgress %></strong></div>
            <div><span>Completadas</span><strong><%= taskPortfolioSummary.completed %></strong></div>
            <div><span>Vencidas</span><strong><%= taskPortfolioSummary.overdue %></strong></div>
            <div><span>Horas estimadas</span><strong><%= Number(taskPortfolioSummary.estimatedHours || 0).toFixed(2) %></strong></div>
            <div><span>Horas reales</span><strong><%= Number(taskPortfolioSummary.realHours || 0).toFixed(2) %></strong></div>
          </div>
        </article>

        <article class="panel app-panel">
          <div class="panel-header app-panel-header">
            <div>
              <h2>Control de cotizaciones</h2>
              <p class="muted">Seguimiento central de cotizaciones y montos visibles.</p>
            </div>
            <a class="btn app-btn" href="<%= buildDashboardUrl({ section: 'quotes' }) %>">Abrir cotizaciones</a>
          </div>
          <div class="projects-home-metrics">
            <div><span>Total</span><strong><%= quotePortfolioSummary.total %></strong></div>
            <div><span>Borrador</span><strong><%= quotePortfolioSummary.draft %></strong></div>
            <div><span>Enviadas</span><strong><%= quotePortfolioSummary.sent %></strong></div>
            <div><span>Aprobadas</span><strong><%= quotePortfolioSummary.approved %></strong></div>
            <div><span>Vencidas</span><strong><%= quotePortfolioSummary.expired %></strong></div>
            <div><span>Monto</span><strong><%= formatMoney(quotePortfolioSummary.totalAmount) %></strong></div>
          </div>
        </article>
      </section>

      <section class="panel app-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Resumen por etapa</h2>
            <p class="muted">Cada tarjeta concentra cantidad de proyectos y montos de cada etapa.</p>
          </div>
        </div>
        <div class="projects-status-grid">
          <% statusOverview.forEach((item) => { %>
            <article class="projects-status-card">
              <div class="projects-status-card__head">
                <span class="status-badge <%= item.badgeClass %>"><%= item.label %></span>
                <strong><%= item.count %></strong>
              </div>
              <div class="projects-status-card__body">
                <div><span>Presupuesto</span><strong><%= formatMoney(item.estimatedBudget) %></strong></div>
                <div><span>Costo real</span><strong><%= formatMoney(item.realCost) %></strong></div>
                <div><span>Venta</span><strong><%= formatMoney(item.saleAmount) %></strong></div>
              </div>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="projects-summary-grid">
        <article class="panel app-panel">
          <div class="panel-header app-panel-header">
            <div>
              <h2>Proyectos finalizados recientemente</h2>
              <p class="muted">Ultimos cierres registrados en el sistema.</p>
            </div>
          </div>
          <div class="projects-mini-list">
            <% if (!recentCompletedProjects.length) { %>
              <div class="app-empty-state projects-empty-card">
                <p class="app-empty-state-text">No hay proyectos finalizados todavia.</p>
              </div>
            <% } %>
            <% recentCompletedProjects.forEach((project) => { %>
              <a href="/projects/<%= project.id %>" class="projects-mini-item">
                <div>
                  <strong><%= project.name %></strong>
                  <p class="muted"><%= project.client_display %></p>
                </div>
                <span><%= formatDate(project.real_end_date) %></span>
              </a>
            <% }) %>
          </div>
        </article>

        <article class="panel app-panel">
          <div class="panel-header app-panel-header">
            <div>
              <h2>Proyectos con atraso</h2>
              <p class="muted">Pendientes que ya superaron la fecha estimada.</p>
            </div>
          </div>
          <div class="projects-mini-list">
            <% if (!overdueProjects.length) { %>
              <div class="app-empty-state projects-empty-card">
                <p class="app-empty-state-text">No hay proyectos atrasados en este momento.</p>
              </div>
            <% } %>
            <% overdueProjects.forEach((project) => { %>
              <a href="/projects/<%= project.id %>" class="projects-mini-item">
                <div>
                  <strong><%= project.name %></strong>
                  <p class="muted"><%= project.client_display %></p>
                </div>
                <span class="projects-overdue"><%= formatDate(project.estimated_end_date) %></span>
              </a>
            <% }) %>
          </div>
        </article>
      </section>
    <% } %>

    <% if (activeSection === 'projects') { %>
      <section class="panel app-panel projects-toolbar-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Tablero de proyectos</h2>
            <p class="muted">Filtra por etapa, fecha de creacion y fecha de finalizacion para ordenar mejor la operacion.</p>
          </div>
          <div class="actions">
            <a class="btn app-btn <%= dashboardView === 'kanban' ? 'primary app-btn-primary' : '' %>" href="<%= buildDashboardUrl({ section: 'projects', view: 'kanban' }) %>">Vista Kanban</a>
            <a class="btn app-btn <%= dashboardView === 'list' ? 'primary app-btn-primary' : '' %>" href="<%= buildDashboardUrl({ section: 'projects', view: 'list' }) %>">Vista Lista</a>
            <% if (can('projects', 'create')) { %>
              <a class="btn primary app-btn app-btn-primary" href="#new-project">Nuevo proyecto</a>
            <% } %>
          </div>
        </div>

        <form method="GET" action="/projects" class="projects-filter-grid">
          <input type="hidden" name="section" value="projects" />
          <input type="hidden" name="view" value="<%= dashboardView %>" />
          <label class="app-field">
            <span>Buscar</span>
            <input class="app-input" type="search" name="q" value="<%= filters.q || '' %>" placeholder="Codigo, proyecto o cliente..." />
          </label>
          <label class="app-field">
            <span>Etapa</span>
            <select name="status">
              <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>Todas</option>
              <% projectStatuses.forEach((status) => { %>
                <option value="<%= status.key %>" <%= filters.status === status.key ? 'selected' : '' %>><%= status.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Creado desde</span>
            <input class="app-input" type="date" name="created_from" value="<%= filters.created_from || '' %>" />
          </label>
          <label class="app-field">
            <span>Creado hasta</span>
            <input class="app-input" type="date" name="created_to" value="<%= filters.created_to || '' %>" />
          </label>
          <label class="app-field">
            <span>Finalizado desde</span>
            <input class="app-input" type="date" name="finished_from" value="<%= filters.finished_from || '' %>" />
          </label>
          <label class="app-field">
            <span>Finalizado hasta</span>
            <input class="app-input" type="date" name="finished_to" value="<%= filters.finished_to || '' %>" />
          </label>
          <div class="actions projects-filter-actions">
            <span class="projects-filter-results"><%= visibleProjectsLabel %></span>
            <button type="submit" class="btn primary app-btn app-btn-primary">Aplicar</button>
            <a class="btn app-btn" href="/projects?section=projects&view=<%= dashboardView %>">Limpiar</a>
          </div>
        </form>
      </section>

      <% if (dashboardView === 'kanban') { %>
        <section class="projects-kanban-board">
          <% projectColumns.forEach((column) => { %>
            <article class="projects-kanban-column">
              <header class="projects-kanban-column__header">
                <div>
                  <h3><%= column.label %></h3>
                  <span class="muted"><%= column.count %> proyecto(s)</span>
                </div>
              </header>

              <% if (!column.projects.length) { %>
                <div class="app-empty-state projects-empty-card">
                  <p class="app-empty-state-text">Sin proyectos en esta etapa.</p>
                </div>
              <% } %>

              <% column.projects.forEach((project) => { %>
                <a href="/projects/<%= project.id %>" class="projects-card">
                  <div class="projects-card__top">
                    <span class="status-badge <%= project.status_meta.badgeClass %>"><%= project.status_label %></span>
                    <span class="projects-card__code"><%= project.code || 'Sin codigo' %></span>
                  </div>
                  <h4><%= project.name %></h4>
                  <p class="muted"><%= project.client_display %></p>
                  <div class="projects-card__stats">
                    <span>Avance <strong><%= project.progress_percent %>%</strong></span>
                    <span>Tareas <strong><%= project.completed_tasks || 0 %>/<%= project.task_count || 0 %></strong></span>
                  </div>
                  <div class="projects-progress">
                    <span style="width:<%= project.progress_percent %>%"></span>
                  </div>
                  <div class="projects-card__footer">
                    <span><%= formatMoney(project.estimated_budget) %></span>
                    <span class="<%= project.isOverdue ? 'projects-overdue' : '' %>"><%= formatDate(project.estimated_end_date) %></span>
                  </div>
                </a>
              <% }) %>
            </article>
          <% }) %>
        </section>
      <% } else { %>
        <section class="panel app-panel">
          <div class="panel-header app-panel-header">
            <div>
              <h2>Lista de proyectos</h2>
              <p class="muted">Vista ordenada para revisar fechas, etapa, presupuesto y avance del proyecto.</p>
            </div>
          </div>
          <div class="table app-table-wrap projects-table">
            <div class="table-row header projects-list-row">
              <div>Codigo</div>
              <div>Proyecto</div>
              <div>Cliente</div>
              <div>Estado</div>
              <div>Prioridad</div>
              <div>Fin</div>
              <div>Presupuesto</div>
              <div>Costo real</div>
              <div>Avance</div>
              <div>Acciones</div>
            </div>
            <% if (!projects.length) { %>
              <div class="table-row empty app-empty-state">
                <div>No hay proyectos para los filtros seleccionados.</div>
              </div>
            <% } %>
            <% projects.forEach((project) => { %>
              <div class="table-row projects-list-row">
                <div><strong><%= project.code || 'Sin codigo' %></strong></div>
                <div>
                  <strong><%= project.name %></strong>
                  <small class="muted">Creado <%= formatDate(project.created_at) %></small>
                </div>
                <div><%= project.client_display %></div>
                <div><span class="status-badge <%= project.status_meta.badgeClass %>"><%= project.status_label %></span></div>
                <div><span class="projects-priority-chip <%= project.priority_meta.badgeClass %>"><%= project.priority_label %></span></div>
                <div>
                  <strong><%= formatDate(project.real_end_date || project.estimated_end_date) %></strong>
                  <small class="muted"><%= project.real_end_date ? 'Real' : 'Estimado' %></small>
                </div>
                <div><%= formatMoney(project.estimated_budget) %></div>
                <div><%= formatMoney(project.real_cost_resolved) %></div>
                <div>
                  <div class="projects-progress projects-progress--compact">
                    <span style="width:<%= project.progress_percent %>%"></span>
                  </div>
                  <small class="muted"><%= project.progress_percent %>%</small>
                </div>
                <div class="actions">
                  <a class="btn app-btn app-btn-small" href="/projects/<%= project.id %>">Abrir</a>
                </div>
              </div>
            <% }) %>
          </div>
        </section>
      <% } %>

      <section class="panel app-panel" id="new-project" style="<%= can('projects', 'create') ? '' : 'display:none' %>">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Nuevo proyecto</h2>
            <p class="muted">Captura solo la ficha base. El resto se administra dentro del detalle del proyecto.</p>
          </div>
        </div>

        <form method="POST" action="/projects/create" class="projects-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="app-field projects-form-full">
            <span>Cotizacion base (opcional)</span>
            <select name="quote_id">
              <option value="">Crear proyecto desde cero</option>
              <% availableProjectQuoteOptions.forEach((quote) => { %>
                <option value="<%= quote.id %>"><%= truncateOptionLabel(`${quote.title} - ${quote.customer_display} - ${formatMoney(quote.total, quote.currency)}`, 80) %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Codigo</span>
            <input class="app-input" type="text" name="code" placeholder="Se genera automaticamente si lo dejas vacio" />
          </label>
          <label class="app-field">
            <span>Nombre del proyecto</span>
            <input class="app-input" type="text" name="name" required />
          </label>
          <label class="app-field">
            <span>Cliente</span>
            <select name="client_id">
              <option value="">Sin cliente</option>
              <% customers.forEach((customer) => { %>
                <option value="<%= customer.id %>"><%= customer.customer_code ? `${customer.customer_code} - ` : '' %><%= customer.name %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Estado</span>
            <select name="status">
              <% projectStatuses.forEach((status) => { %>
                <option value="<%= status.key %>" <%= createDefaults.status === status.key ? 'selected' : '' %>><%= status.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Prioridad</span>
            <select name="priority">
              <% projectPriorities.forEach((priority) => { %>
                <option value="<%= priority.key %>" <%= createDefaults.priority === priority.key ? 'selected' : '' %>><%= priority.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="app-field">
            <span>Inicio</span>
            <input class="app-input" type="date" name="start_date" value="<%= createDefaults.start_date %>" />
          </label>
          <label class="app-field">
            <span>Fin estimado</span>
            <input class="app-input" type="date" name="estimated_end_date" />
          </label>
          <label class="app-field">
            <span>Presupuesto estimado</span>
            <input class="app-input" type="number" step="0.01" min="0" name="estimated_budget" value="0" />
          </label>
          <label class="app-field">
            <span>Venta estimada</span>
            <input class="app-input" type="number" step="0.01" min="0" name="sale_amount" value="0" />
          </label>
          <label class="app-field projects-form-full">
            <span>Descripcion</span>
            <textarea class="app-textarea" name="description" rows="3" placeholder="Objetivo, alcance, entregables y observaciones base."></textarea>
          </label>
          <label class="app-field projects-form-full">
            <span>Notas</span>
            <textarea class="app-textarea" name="notes" rows="2"></textarea>
          </label>
          <div class="actions projects-form-full">
            <button type="submit" class="btn primary app-btn app-btn-primary">Guardar proyecto</button>
          </div>
        </form>
      </section>
    <% } %>

    <% if (activeSection === 'tasks') { %>
      <section class="projects-kpi-grid">
        <article class="projects-kpi-card">
          <span>Total visibles</span>
          <strong><%= taskSummary.total %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>En proceso</span>
          <strong><%= taskSummary.inProgress %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Completadas</span>
          <strong><%= taskSummary.completed %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Vencidas</span>
          <strong><%= taskSummary.overdue %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Horas estimadas</span>
          <strong><%= Number(taskSummary.estimatedHours || 0).toFixed(2) %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>Horas reales</span>
          <strong><%= Number(taskSummary.realHours || 0).toFixed(2) %></strong>
        </article>
        <article class="projects-kpi-card">
          <span>% completadas</span>
          <strong><%= taskSummary.completedRate %>%</strong>
        </article>
        <article class="projects-kpi-card">
          <span>Proyectos con tareas</span>
          <strong><%= new Set(tasks.map((task) => Number(task.project_id))).size %></strong>
        </article>
      </section>

      <section class="panel app-panel projects-toolbar-panel">
        <div class="panel-header app-panel-header">
          <div>
            <h2>Filtro general de tareas</h2>
            <p class="muted">Consulta el avance por proyecto y ordena el trabajo pendiente del modulo.</p>
