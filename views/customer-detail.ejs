<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('customers.detail_title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container">
<div class="page-header">
<div>
<div class="eyebrow">
<%= t('customers.detail_header') %>
</div>
<h1>
<%= customer.name %>
</h1>
<div class="muted">
<%= customer.document_type || '-' %> ? <%= customer.document_number || '-' %>
</div>
</div>
<div class="actions">
<% if (customer.is_voided) { %>
<span class="pill danger">
<%= t('customers.status_voided') %>
</span>
<% } %>
  <span class="btn">
    <%= t('consignatarios.title') %> (<%= consignatariosCount || 0 %>)
  </span>
<form method="POST" action="/customers/<%= customer.id %>/void" class="inline-form" style="<%= !customer.is_voided && can('customers', 'void') ? '' : 'display:none' %>" onsubmit="return confirm('<%= t('customers.void_confirm') %>');">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn danger">
<%= t('customers.void_button') %>
</button>
</form>
<a class="btn" href="/customers">
<%= t('common.back') %>
</a>
</div>
</div>
<section class="panel" id="editar" style="<%= can('customers', 'edit') ? '' : 'display:none' %>">
<h2>
