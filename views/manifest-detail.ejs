<%  const statusLabel = formatManifestStatus(manifest, t);  const statusClass = manifestStatusClass(manifest);  const isClosed = manifest.status === 'closed';%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('manifests.detail') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container manifest-detail <%= isClosed ? 'manifest-closed' : '' %>">
<div class="page-header manifest-header">
<div>
<h1>
<%= t('manifests.detail') %>
</h1>
<div class="airway-block">
<div class="airway-label">
<%= t('manifests.manifest_number') %>
</div>
<div class="airway-value">
<%= formatManifestNumber(manifest) %>
</div>
<div class="airway-label">
<%= t('manifests.airway_bill') %>
</div>
<div class="airway-value">
<%= manifest.transport_document_type ? `${manifest.transport_document_type === 'CARTA_PORTE' ? 'Carta Porte' : (manifest.transport_document_type === 'AWB' || manifest.transport_document_type === 'MAWB' ? 'AWB' : manifest.transport_document_type)} - ` : '' %><%= manifest.airway_bill_number || '-' %>
</div>
</div>
</div>
<div class="actions">
<span class="status-badge <%= statusClass %>">
<%= statusLabel %>
</span>
<a class="btn" href="/manifests">
<%= t('manifests.list') %>
</a>
</div>
</div>
<% if (error) { %>
<div class="alert error">
<%= error %>
</div>
<% } %>
<% if (success) { %>
<div class="alert success">
<%= success %>
</div>
<% } %>
<section class="panel">
<div class="panel-header">
<h2>
<%= t('manifests.status') %>
</h2>
<div class="actions">
<% if (can('manifests', 'export')) { %>
<a class="btn" href="/manifests/<%= manifest.id %>/export/pdf">
<%= t('manifests.download_pdf') %>
</a>
<a class="btn" href="/manifests/<%= manifest.id %>/export/excel">
<%= t('manifests.download_excel') %>
</a>
<% } %>
<% if (!isClosed && canEditManifest) { %>
<form method="POST" action="/manifests/<%= manifest.id %>/save-draft">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn">
<%= t('manifests.save_draft') %>
</button>
</form>
<% } %>
<% if (manifest.status === 'open' && canEditManifest) { %>
<form method="POST" action="/manifests/<%= manifest.id %>/close">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn danger">
<%= t('manifests.close') %>
</button>
</form>
<% } %>
<% if (manifest.status === 'closed' && isAdmin) { %>
<form method="POST" action="/manifests/<%= manifest.id %>/reopen">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn">
<%= t('manifests.reopen') %>
</button>
</form>
<% } %>
</div>
</div>
<div class="form grid-2">
<form method="POST" action="/manifests/<%= manifest.id %>/airway-bill" class="form" data-manifest-transport-form>
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
Tipo de documento de transporte
<select name="transport_document_type" data-transport-type <%= canEditManifest ? '' : 'disabled' %> required>
<option value="BL" <%= selectedType === 'BL' ? 'selected' : '' %>>BL</option>
<option value="AWB" <%= selectedType === 'AWB' || selectedType === 'MAWB' ? 'selected' : '' %>>AWB</option>
<option value="CARTA_PORTE" <%= selectedType === 'CARTA_PORTE' ? 'selected' : '' %>>Carta Porte</option>
</select>
</label>
<label>
<%= t('manifests.airway_bill') %>
<select name="transport_document_id" data-transport-document <%= canEditManifest ? '' : 'disabled' %> required>
<option value="">Seleccione una guia</option>
<% (transportDocuments || []).forEach((doc) => { %>
<option value="<%= doc.id %>" data-type="<%= doc.type %>" <%= String(doc.id) === String(manifest.transport_document_id || '') && (String(doc.type || '') === String(manifest.transport_document_type || '') || (doc.type === 'AWB' && manifest.transport_document_type === 'MAWB')) ? 'selected' : '' %>>
<%= doc.type === 'CARTA_PORTE' ? 'Carta Porte' : (doc.type === 'AWB' || doc.type === 'MAWB' ? 'AWB' : doc.type) %> - <%= doc.document_number %><%= doc.client_name ? ` - ${doc.client_name}` : '' %><%= doc.issue_date ? ` (${doc.issue_date})` : '' %><%= String(doc.id) === String(manifest.transport_document_id || '') && (String(doc.type || '') === String(manifest.transport_document_type || '') || (doc.type === 'AWB' && manifest.transport_document_type === 'MAWB')) ? ' (actual)' : '' %>
</option>
<% }) %>
</select>
<small class="muted">
Las guias ya usadas en otro manifiesto no aparecen en esta lista.
</small>
</label>
<% if (canEditManifest) { %>
<button type="submit" class="btn small">
<%= t('manifests.update_airway') %>
</button>
<% } %>
</form>
<% if (canEditManifest && manifest.transport_document_id) { %>
<form method="POST" action="/manifests/<%= manifest.id %>/unlink-transport-document" class="form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
Guia bloqueada
<input type="text" value="<%= manifest.airway_bill_number || '' %>" disabled />
</label>
<button type="submit" class="btn danger small">Desvincular guia</button>
</form>
<% } %>
<form method="POST" action="/manifests/<%= manifest.id %>/notes" class="form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
<%= t('manifests.notes') %>
<textarea name="notes" rows="3" <%= canEditManifest ? '' : 'disabled' %>>
<%= manifest.notes || '' %>
</textarea>
</label>
<% if (canEditManifest) { %>
<button type="submit" class="btn small">
<%= t('manifests.update_notes') %>
</button>
<% } %>
</form>
</div>
</section>
<section class="panel">
<div class="panel-header">
<h2>
<%= t('manifests.summary') %>
</h2>
</div>
<div class="summary-strip">
<div class="summary-item">
<span class="summary-label">
<%= t('manifests.total_pieces') %>
</span>
<span class="summary-value">
<%= summary ? summary.totalPieces : 0 %>
</span>
</div>
<div class="summary-item">
<span class="summary-label">
<%= t('manifests.total_packages') %>
</span>
<span class="summary-value">
<%= summary ? summary.totalPackages : 0 %>
</span>
</div>
<div class="summary-item">
<span class="summary-label">
<%= t('manifests.total_weight') %>
</span>
<span class="summary-value">
<%= summary ? (Number(summary.totalWeight) || 0).toFixed(2) : '0.00' %>
</span>
</div>
</div>
</section>
<section class="panel">
<div class="panel-header">
<h2>
<%= t('manifests.pieces') %>
</h2>
<% if (canEditManifest) { %>
<div class="actions">
<% if (pieces && pieces.length > 0) { %>
<form method="POST" action="/manifests/<%= manifest.id %>/packages/scan" class="piece-action">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<select name="piece_id" required>
<option value="">
<%= t('manifests.scan_piece_select') %>
</option>
<% (pieces || []).forEach((piece) => { %>
<option value="<%= piece.id %>" <%= lastScanPieceId === piece.id ? 'selected' : '' %>>
<%= t('manifests.piece_number', { number: piece.piece_number }) %>
</option>
<% }) %>
</select>
<input                  type="text"                  name="scan_value"                  placeholder="<%= t('manifests.scan_placeholder') %>"                  autocomplete="off"                  autofocus                />
<button type="submit" class="btn small">
<%= t('manifests.scan_button') %>
</button>
</form>
<% } %>
<form method="POST" action="/manifests/<%= manifest.id %>/pieces">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn">
<%= t('manifests.add_piece') %>
</button>
</form>
</div>
<% } %>
</div>
<% if (!pieces || pieces.length === 0) { %>
<div class="alert info">
<%= t('manifests.no_pieces') %>
</div>
<% } %>
<% (pieces || []).forEach((piece) => { %>
<div class="manifest-piece-card">
<div class="piece-header">
<div>
<div class="piece-eyebrow">
<%= t('manifests.pieces') %>
</div>
<h3>
<%= t('manifests.piece_number', { number: piece.piece_number }) %>
</h3>
</div>
<% if (canEditManifest) { %>
<form method="POST" action="/manifests/<%= manifest.id %>/pieces/<%= piece.id %>/packages" class="piece-action">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<select name="package_id">
<option value="">
<%= t('manifests.package_select') %>
</option>
<% (availablePackages || []).forEach((pkg) => { %>
<option value="<%= pkg.id %>">
<%= pkg.internal_code || pkg.tracking_number || ('#' + pkg.id) %>
<% if (pkg.customer_name) { %> - <%= pkg.customer_code ? `${pkg.customer_code} - ` : '' %><%= pkg.customer_name %>
<% } %>
</option>
<% }) %>
</select>
<button type="submit" class="btn small">
<%= t('manifests.add_package') %>
</button>
</form>
<% } %>
<a class="btn small" href="/manifests/<%= manifest.id %>/pieces/<%= piece.id %>/sticker/pdf">
<%= t('manifests.piece_sticker') %>
</a>
</div>
<div class="manifest-packages">
<div class="package-row header">
<div>
<%= t('packages.table.internal_code') %>
</div>
<div>
<%= t('packages.table.tracking') %>
</div>
<div>
<%= t('packages.table.customer') %>
</div>
<div>
<%= t('packages.table.status') %>
</div>
<div>
<%= t('packages.table.weight') %>
</div>
<div>
<%= t('manifests.actions') %>
</div>
</div>
<% if (!piece.packages || piece.packages.length === 0) { %>
<div class="package-row empty">
<%= t('manifests.no_packages') %>
</div>
<% } %>
<% (piece.packages || []).forEach((pkg) => { %>
<div class="package-row">
<div>
<%= pkg.internal_code || '-' %>
</div>
<div>
<%= pkg.tracking_number || '-' %>
</div>
<div>
<%= pkg.customer_code ? `${pkg.customer_code} - ` : '' %><%= pkg.customer_name || '-' %>
</div>
<div>
<span class="status-badge status-default">
<%= pkg.status || '-' %>
</span>
</div>
<div>
<%= pkg.weight_lbs ? pkg.weight_lbs : '-' %>
</div>
<div class="actions">
<% if (canEditManifest) { %>
<form method="POST" action="/manifests/<%= manifest.id %>/pieces/<%= piece.id %>/packages/<%= pkg.id %>/delete">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button type="submit" class="btn danger small">
<%= t('common.delete') %>
</button>
</form>
<% } else { %>
<span class="muted">-</span>
<% } %>
</div>
</div>
<% }) %>
</div>
</div>
<% }) %>
</section>
</main>
<script src="/status-footer.js" defer></script>
<script>
(function () {
  const form = document.querySelector('[data-manifest-transport-form]');
  if (!form) return;
  const typeSelect = form.querySelector('[data-transport-type]');
  const documentSelect = form.querySelector('[data-transport-document]');
  if (!typeSelect || !documentSelect) return;
  const options = Array.from(documentSelect.options);
  function syncDocuments() {
    const selectedType = typeSelect.value;
    let hasSelectedVisible = false;
    options.forEach((option) => {
      const optionType = option.dataset.type || '';
      const visible = !option.value || optionType === selectedType;
      option.hidden = !visible;
      option.disabled = !visible;
      if (visible && option.selected) hasSelectedVisible = true;
    });
    if (!hasSelectedVisible) documentSelect.value = '';
  }
  typeSelect.addEventListener('change', syncDocuments);
  syncDocuments();
})();
</script>
</body>
</html>
