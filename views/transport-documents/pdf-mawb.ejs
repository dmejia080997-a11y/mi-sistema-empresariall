<%
const data = document.data || {};
const items = document.items || [];
function val(value) { return value || '&nbsp;'; }
%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8" />
<title>AWB <%= document.document_number %></title>
<style>
  @page { size: letter; margin: 10mm; }
  * { box-sizing: border-box; }
  body { margin: 0; font-family: Arial, sans-serif; color: #102033; background: #fff; }
  .sheet { width: 100%; max-width: 8in; margin: 0 auto; border: 2px solid #1f4e79; }
  .title { display: grid; grid-template-columns: 1fr 1.2fr 1fr; align-items: center; border-bottom: 2px solid #1f4e79; color: #1f4e79; }
  .title div { padding: 8px; min-height: 46px; border-right: 1px solid #1f4e79; }
  .title div:last-child { border-right: 0; text-align: right; font-weight: 700; font-size: 18px; }
  .title h1 { margin: 0; text-align: center; font-size: 20px; letter-spacing: 0; }
  .grid { display: grid; grid-template-columns: repeat(12, 1fr); }
  .box { min-height: 44px; padding: 4px 6px; border-right: 1px solid #1f4e79; border-bottom: 1px solid #1f4e79; }
  .box:nth-child(12n) { border-right: 0; }
  .span-2 { grid-column: span 2; } .span-3 { grid-column: span 3; } .span-4 { grid-column: span 4; }
  .span-5 { grid-column: span 5; } .span-6 { grid-column: span 6; } .span-7 { grid-column: span 7; }
  .span-8 { grid-column: span 8; } .span-12 { grid-column: span 12; }
  .tall { min-height: 82px; }
  .label { font-size: 8px; color: #1f4e79; text-transform: uppercase; font-weight: 700; }
  .value { margin-top: 5px; font-size: 11px; white-space: pre-wrap; }
  table { width: 100%; border-collapse: collapse; font-size: 9px; }
  th, td { border: 1px solid #1f4e79; padding: 4px; vertical-align: top; height: 28px; }
  th { color: #1f4e79; font-size: 8px; text-transform: uppercase; }
  .signatures { display: grid; grid-template-columns: repeat(3, 1fr); }
  .signature { min-height: 58px; border-right: 1px solid #1f4e79; padding: 6px; }
  .signature:last-child { border-right: 0; }
  @media print { .no-print { display: none; } .sheet { max-width: none; } }
</style>
</head>
<body>
<div class="no-print" style="padding:8px;text-align:right;"><button onclick="window.print()">Imprimir</button></div>
<section class="sheet">
  <div class="title">
    <div>Not negotiable unless signed by issuing carrier</div>
    <div><h1>AWB - GUIA AEREA</h1></div>
    <div><%= document.document_number %></div>
  </div>
  <div class="grid">
    <div class="box span-6 tall"><div class="label">Shipper Name and Address</div><div class="value"><%= document.shipper || '' %></div></div>
    <div class="box span-3"><div class="label">Shipper Account Number</div><div class="value"><%= val(data.shipper_account_number) %></div></div>
    <div class="box span-3"><div class="label">Issuing Carrier Agent</div><div class="value"><%= val(data.issuing_carrier_agent) %></div></div>
    <div class="box span-6 tall"><div class="label">Consignee Name and Address</div><div class="value"><%= document.consignee || '' %></div></div>
    <div class="box span-3"><div class="label">Consignee Account Number</div><div class="value"><%= val(data.consignee_account_number) %></div></div>
    <div class="box span-3"><div class="label">Agent IATA Code / Account</div><div class="value"><%= [data.agent_iata_code, data.account_number].filter(Boolean).join(' / ') %></div></div>
    <div class="box span-5"><div class="label">Airport of Departure</div><div class="value"><%= document.origin || '' %></div></div>
    <div class="box span-3"><div class="label">Requested Routing</div><div class="value"><%= val(data.requested_routing) %></div></div>
    <div class="box span-4"><div class="label">Reference / Optional Shipping Info</div><div class="value"><%= [data.reference_number, data.optional_shipping_information].filter(Boolean).join(' / ') %></div></div>
    <div class="box span-1"><div class="label">To</div><div class="value"><%= val(data.to_1) %></div></div>
    <div class="box span-2"><div class="label">By First Carrier</div><div class="value"><%= val(data.by_first_carrier) %></div></div>
    <div class="box span-3"><div class="label">Routing and Destination</div><div class="value"><%= document.destination || data.routing_destination || '' %></div></div>
    <div class="box span-1"><div class="label">Currency</div><div class="value"><%= val(data.currency) %></div></div>
    <div class="box span-1"><div class="label">CHGS</div><div class="value"><%= val(data.chgs_code) %></div></div>
    <div class="box span-2"><div class="label">WT/VAL PPD/COLL</div><div class="value"><%= [data.wtval_ppd, data.wtval_coll].filter(Boolean).join(' / ') %></div></div>
    <div class="box span-2"><div class="label">Other PPD/COLL</div><div class="value"><%= [data.other_ppd, data.other_coll].filter(Boolean).join(' / ') %></div></div>
    <div class="box span-3"><div class="label">Declared Value for Carriage</div><div class="value"><%= val(data.declared_value_carriage) %></div></div>
    <div class="box span-3"><div class="label">Declared Value for Customs</div><div class="value"><%= val(data.declared_value_customs) %></div></div>
    <div class="box span-3"><div class="label">Airport of Destination</div><div class="value"><%= document.destination || '' %></div></div>
    <div class="box span-3"><div class="label">Requested Flight/Date</div><div class="value"><%= val(data.requested_flight_date) %></div></div>
    <div class="box span-12"><div class="label">Handling Information / SCI</div><div class="value"><%= [data.handling_information, data.sci].filter(Boolean).join(' / ') %></div></div>
  </div>
  <table>
    <thead><tr><th>No. Pieces / RCP</th><th>Gross Weight</th><th>Kg/Lb</th><th>Rate Class</th><th>Commodity Item No.</th><th>Chargeable Weight</th><th>Rate</th><th>Charge</th><th>Nature and Quantity of Goods</th></tr></thead>
    <tbody>
      <% (items.length ? items : [{}, {}, {}, {}, {}]).forEach((row) => { %>
      <tr><td><%= row.pieces || '' %></td><td><%= row.gross_weight || '' %></td><td><%= row.kg_lb || '' %></td><td><%= row.rate_class || '' %></td><td><%= row.commodity_item_no || '' %></td><td><%= row.chargeable_weight || '' %></td><td><%= row.rate || '' %></td><td><%= row.charge || '' %></td><td><%= row.description || '' %></td></tr>
      <% }) %>
    </tbody>
  </table>
  <div class="grid">
    <div class="box span-4"><div class="label">Prepaid / Collect Weight Charge</div><div class="value"><%= [data.prepaid_weight_charge, data.collect_weight_charge].filter(Boolean).join(' / ') %></div></div>
    <div class="box span-4"><div class="label">Valuation / Tax / Other Charges</div><div class="value"><%= [data.valuation_charge, data.tax, data.total_other_charges_due_agent, data.total_other_charges_due_carrier].filter(Boolean).join(' / ') %></div></div>
    <div class="box span-4"><div class="label">Totals / Destination Charges</div><div class="value"><%= [data.total_prepaid, data.total_collect, data.currency_conversion_rates, data.charges_at_destination, data.total_collect_charges].filter(Boolean).join(' / ') %></div></div>
  </div>
  <div class="signatures">
    <div class="signature"><div class="label">Signature of Shipper or Agent</div><div class="value"><%= val(data.shipper_signature) %></div></div>
    <div class="signature"><div class="label">Executed on Date / at Place</div><div class="value"><%= [data.executed_date, data.executed_place].filter(Boolean).join(' / ') %></div></div>
    <div class="signature"><div class="label">Signature of Issuing Carrier or Agent</div><div class="value"><%= val(data.issuing_carrier_signature) %></div></div>
  </div>
</section>
<% if (autoPrint) { %><script>window.print();</script><% } %>
</body>
</html>
