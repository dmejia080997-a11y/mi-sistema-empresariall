<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<%- include('../partials/head', { title: 'Editar Documento de Transporte', extraStyles: ['/css/transport-documents.css'] }) %>
</head>
<body class="page">
<%- include('../partials/header', { currentModule: 'transport_documents' }) %>
<main class="container">
  <div class="page-header">
    <div>
      <h1>Editar Documento de Transporte</h1>
      <p class="muted"><%= typeLabels[document.type] || document.type %> <%= document.document_number || '' %></p>
    </div>
    <a class="btn" href="/transport-documents/<%= document.id %>">Ver</a>
  </div>
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>
  <%- include('_form', { document, action: '/transport-documents/' + document.id + '/update', csrfToken, typeLabels, statusLabels }) %>
</main>
<script src="/js/transport-documents/form.js" defer></script>
</body>
</html>
