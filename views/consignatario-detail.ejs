<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('consignatarios.detail_title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container">
<div class="page-header">
<div>
<div class="eyebrow">
<%= t('consignatarios.detail_header') %>
</div>
<h1>
<%= consignatario.name %>
</h1>
<div class="muted">
<%= consignatario.document_type || '-' %> ? <%= consignatario.document_number || '-' %>
</div>
</div>
<div class="actions">
<a class="btn" href="/consignatarios">
<%= t('consignatarios.back_list') %>
</a>
<a class="btn" href="/customers/<%= consignatario.customer_id %>">
<%= t('consignatarios.back_customer') %>
</a>
</div>
</div>
<section class="panel">
<h2>
<%= t('consignatarios.detail_info') %>
</h2>
<div class="detail-grid">
<div>
<strong>
<%= t('consignatarios.customer') %>:</strong>
<%= consignatario.customer_code ? `${consignatario.customer_code} - ` : '' %><%= consignatario.customer_name || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.document_type') %>:</strong>
<%= consignatario.document_type || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.document_number') %>:</strong>
<%= consignatario.document_number || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.phone') %>:</strong>
<%= consignatario.phone || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.mobile') %>:</strong>
<%= consignatario.mobile || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.email') %>:</strong>
<%= consignatario.email || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.full_address') %>:</strong>
<%= consignatario.full_address || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.zone') %>:</strong>
<%= consignatario.zone || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.municipality') %>:</strong>
<%= consignatario.municipality || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.department') %>:</strong>
<%= consignatario.department || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.country') %>:</strong>
<%= consignatario.country || '-' %>
</div>
<div>
<strong>
<%= t('customers.sat_status') %>:</strong>
<%= consignatario.sat_verified ? t('customers.sat_verified') : t('customers.sat_manual') %>
</div>
<div>
<strong>
<%= t('customers.sat_name') %>:</strong>
<%= consignatario.sat_name || '-' %>
</div>
<div>
<strong>
<%= t('customers.sat_checked_at') %>:</strong>
<%= consignatario.sat_checked_at || '-' %>
</div>
<div>
<strong>
<%= t('consignatarios.notes') %>:</strong>
<%= consignatario.notes || '-' %>
</div>
</div>
</section>
<section class="panel">
<h2>
<%= t('consignatarios.edit_title') %>
</h2>
<form method="POST" action="/consignatarios/<%= consignatario.id %>/update" class="form grid-2" data-sat-form data-gt-address-form>
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
<%= t('consignatarios.document_type') %>
<select name="document_type" data-sat-type>
<% documentTypes.forEach(type => { %>
<option value="<%= type %>" <%= consignatario.document_type === type ? 'selected' : '' %>>
<%= type %>
</option>
<% }) %>
</select>
</label>
<label>
<%= t('consignatarios.document_number') %>
<input type="text" name="document_number" value="<%= consignatario.document_number || '' %>" data-sat-number />
</label>
<div class="actions full-row">
<button type="button" class="btn" data-sat-verify>
<%= t('customers.verify_sat') %>
</button>
<button type="button" class="btn" data-sat-manual>
<%= t('customers.sat_manual_action') %>
</button>
<span class="helper" data-sat-status>
<%= consignatario.sat_verified ? t('customers.sat_verified') : t('customers.sat_hint') %>
</span>
<span class="helper" data-sat-warning>
</span>
<input type="hidden" name="sat_verified" value="<%= consignatario.sat_verified ? '1' : '0' %>" data-sat-verified />
<input type="hidden" name="sat_name" value="<%= consignatario.sat_name || '' %>" data-sat-name />
<input type="hidden" name="sat_checked_at" value="<%= consignatario.sat_checked_at || '' %>" data-sat-checked-at />
</div>
<label>
<%= t('consignatarios.name') %>
<input type="text" name="name" required value="<%= consignatario.name %>" data-sat-name-target />
</label>
<label>
<%= t('consignatarios.email') %>
<input type="email" name="email" value="<%= consignatario.email || '' %>" />
</label>
<label>
<%= t('consignatarios.phone') %>
<input type="text" name="phone" value="<%= consignatario.phone || '' %>" />
</label>
<label>
<%= t('consignatarios.mobile') %>
<input type="text" name="mobile" value="<%= consignatario.mobile || '' %>" />
</label>
<label>
<%= t('consignatarios.country') %>
<select name="country" data-country data-selected="<%= consignatario.country || '' %>">
<% countries.forEach(country => { %>
<option value="<%= country %>" <%= consignatario.country === country ? 'selected' : '' %>>
<%= country %>
</option>
<% }) %>
</select>
</label>
<label>
<%= t('consignatarios.department') %>
<select name="department" data-department data-selected="<%= consignatario.department || '' %>" data-placeholder="<%= t('consignatarios.select_department') %>">
<option value=""><%= t('consignatarios.select_department') %></option>
</select>
</label>
<label>
<%= t('consignatarios.municipality') %>
<select name="municipality" data-municipality data-selected="<%= consignatario.municipality || '' %>" data-placeholder="<%= t('consignatarios.select_municipality') %>">
<option value=""><%= t('consignatarios.select_municipality') %></option>
</select>
</label>
<label>
<%= t('consignatarios.zone') %>
<input type="text" name="zone" placeholder="<%= t('consignatarios.zone') %>" value="<%= consignatario.zone || '' %>" />
</label>
<label>
<%= t('consignatarios.full_address') %>
<textarea name="full_address" rows="2" placeholder="<%= t('consignatarios.full_address') %>">
<%= consignatario.full_address || '' %>
</textarea>
</label>
<label>
<%= t('consignatarios.notes') %>
<textarea name="notes" rows="2">
<%= consignatario.notes || '' %>
</textarea>
</label>
<div class="actions full-row">
<button type="submit" class="btn primary">
<%= t('common.save') %>
</button>
</div>
</form>
</section>
<section class="panel">
<div class="panel-header">
<h2>
<%= t('consignatarios.packages_title') %>
</h2>
<span class="pill">
<%= packages.length %>
</span>
</div>
<% if (packages.length === 0) { %>
<div class="empty">
<%= t('consignatarios.packages_empty') %>
</div>
<% } %>
<div class="table">
<div class="table-row header packages-extended">
<div>
<%= t('packages.table.internal_code') %>
</div>
<div>
<%= t('packages.table.tracking') %>
</div>
<div>
<%= t('packages.table.status') %>
</div>
<div>
<%= t('packages.table.actions') %>
</div>
</div>
<% packages.forEach(pkg => { %>
<div class="table-row packages-extended">
<div>
<%= pkg.internal_code || '-' %>
</div>
<div>
<%= pkg.tracking_number || '-' %>
</div>
<div>
<span class="pill">
<%= pkg.status || '-' %>
</span>
</div>
<div class="actions">
<a class="btn" href="/packages/<%= pkg.id %>">
<%= t('packages.view_detail') %>
</a>
</div>
</div>
<% }) %>
</div>
</section>
</main>
<script src="/gt-locations.js">
</script>
<script src="/address-gt.js">
</script>
<script>    function initSatForm(form) {      const typeSelect = form.querySelector('[data-sat-type]');      const numberInput = form.querySelector('[data-sat-number]');      const nameInput = form.querySelector('[data-sat-name-target]');      const verifyBtn = form.querySelector('[data-sat-verify]');      const manualBtn = form.querySelector('[data-sat-manual]');      const statusEl = form.querySelector('[data-sat-status]');      const warningEl = form.querySelector('[data-sat-warning]');      const satVerified = form.querySelector('[data-sat-verified]');      const satName = form.querySelector('[data-sat-name]');      const satCheckedAt = form.querySelector('[data-sat-checked-at]');      function setManualStatus(message, portalUrl) {        if (statusEl) statusEl.textContent = '<%= t('customers.sat_manual_action') %>';        if (warningEl) {          if (portalUrl) {            warningEl.innerHTML = `${message || '<%= t('customers.sat_unavailable') %>'} <a href=\"${portalUrl}\" target=\"_blank\" rel=\"noopener\">${'<%= t('customers.sat_portal_link') %>'}</a>`;          } else {            warningEl.textContent = message || '<%= t('customers.sat_unavailable') %>';          }        }        if (satVerified) satVerified.value = '0';        if (satName) satName.value = '';        if (satCheckedAt) satCheckedAt.value = '';      }      function clearWarning() {        if (warningEl) warningEl.textContent = '';      }      function toggleSatControls() {        const isNit = typeSelect && typeSelect.value === 'NIT';        if (verifyBtn) verifyBtn.disabled = !isNit;        if (manualBtn) manualBtn.disabled = !isNit;        if (!isNit) {          if (statusEl) statusEl.textContent = '<%= t('customers.sat_manual') %>';          clearWarning();          if (satVerified) satVerified.value = '0';          if (satName) satName.value = '';          if (satCheckedAt) satCheckedAt.value = '';        }      }      async function verifySat() {        if (!numberInput || !statusEl) return;        statusEl.textContent = '<%= t('customers.sat_checking') %>';        clearWarning();        try {          const response = await fetch('/sat/verify', {            method: 'POST',            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },            body: JSON.stringify({ document_number: numberInput.value })          });          const data = await response.json();          if (data && data.ok) {            statusEl.textContent = '<%= t('customers.sat_verified') %>';            if (nameInput && data.name) {              nameInput.value = data.name;            }            if (satVerified) satVerified.value = '1';            if (satName) satName.value = data.name || '';            if (satCheckedAt) satCheckedAt.value = new Date().toISOString();            return;          }          setManualStatus(data && data.message ? data.message : '<%= t('customers.sat_unavailable') %>', data && data.portal_url);        } catch (err) {          setManualStatus('<%= t('customers.sat_unavailable') %>');        }      }      if (typeSelect) typeSelect.addEventListener('change', toggleSatControls);      if (verifyBtn) verifyBtn.addEventListener('click', verifySat);      if (manualBtn) manualBtn.addEventListener('click', () => setManualStatus('<%= t('customers.sat_manual_action') %>'));      toggleSatControls();    }    document.querySelectorAll('[data-sat-form]').forEach(initSatForm);  </script>
<script src="/status-footer.js" defer></script>
</body>
</html>
