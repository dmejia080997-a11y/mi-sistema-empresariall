<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= mode === 'edit' ? 'Editar empleado' : 'Nuevo empleado' %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="page hr-page">
  <header class="topbar">
    <div class="brand">RRHH</div>
    <nav class="nav">
      <a href="/rrhh?tab=employees">Volver a empleados</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/logout"><%= t('nav.logout') %></a>
    </nav>
  </header>

  <main class="container hr-shell">
    <% if (flash) { %>
      <div class="alert <%= flash.type || 'info' %>"><%= flash.message %></div>
    <% } %>

    <section class="panel">
      <div class="panel-header">
        <div>
          <div class="eyebrow">Ficha de empleado</div>
          <h1><%= mode === 'edit' ? 'Editar empleado' : 'Nuevo empleado' %></h1>
          <p class="muted">Formulario completo con datos generales, laborales, bancarios y adjuntos.</p>
        </div>
        <div class="actions">
          <% if (mode === 'edit' && employee) { %>
            <a class="btn" href="/rrhh/employees/<%= employee.id %>">Ver detalle</a>
          <% } %>
          <a class="btn" href="/rrhh?tab=employees">Listado</a>
        </div>
      </div>

      <form method="POST" enctype="multipart/form-data" action="<%= mode === 'edit' && employee ? `/rrhh/employees/${employee.id}/update` : '/rrhh/employees/create' %>" class="form hr-form-grid hr-form-grid--wide">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <label>
          Nombres
          <input type="text" name="first_name" required value="<%= (employee && employee.first_name) || '' %>" />
        </label>
        <label>
          Apellidos
          <input type="text" name="last_name" required value="<%= (employee && employee.last_name) || '' %>" />
        </label>
        <label>
          Código de empleado
          <input type="text" name="employee_code" required value="<%= (employee && employee.employee_code) || '' %>" />
        </label>

        <label>
          DPI
          <input type="text" name="dpi_number" value="<%= (employee && employee.dpi_number) || '' %>" />
        </label>
        <label>
          Emitido en
          <input type="text" name="dpi_issued_at" value="<%= (employee && employee.dpi_issued_at) || '' %>" />
        </label>
        <label>
          Fecha de nacimiento
          <input type="date" name="birth_date" value="<%= (employee && employee.birth_date) || '' %>" />
        </label>

        <label>
          Estado civil
          <input type="text" name="marital_status" value="<%= (employee && employee.marital_status) || '' %>" />
        </label>
        <label>
          Apellido de casada
          <input type="text" name="married_last_name" value="<%= (employee && employee.married_last_name) || '' %>" />
        </label>
        <label>
          Género
          <input type="text" name="gender" value="<%= (employee && employee.gender) || '' %>" />
        </label>

        <label>
          Teléfono
          <input type="text" name="phone" value="<%= (employee && employee.phone) || '' %>" />
        </label>
        <label>
          Correo
          <input type="email" name="email" value="<%= (employee && employee.email) || '' %>" />
        </label>
        <label>
          Dirección
          <input type="text" name="address" value="<%= (employee && employee.address) || '' %>" />
        </label>

        <label>
          Nivel educativo
          <input type="text" name="education_level" value="<%= (employee && employee.education_level) || '' %>" />
        </label>
        <label>
          Etnia
          <input type="text" name="ethnicity" value="<%= (employee && employee.ethnicity) || '' %>" />
        </label>
        <label>
          Idiomas
          <input type="text" name="languages" value="<%= (employee && employee.languages) || '' %>" placeholder="Español, Inglés" />
        </label>

        <label>
          Puesto
          <input type="text" name="position" value="<%= (employee && employee.position) || '' %>" />
        </label>
        <label>
          Departamento
          <input type="text" name="department" value="<%= (employee && employee.department) || '' %>" />
        </label>
        <label>
          Jefe inmediato
          <select name="immediate_boss_id">
            <option value="">Sin asignar</option>
            <% employees.forEach((boss) => { if (!(employee && String(employee.id) === String(boss.id))) { %>
              <option value="<%= boss.id %>" <%= String((employee && employee.immediate_boss_id) || '') === String(boss.id) ? 'selected' : '' %>><%= `${boss.first_name} ${boss.last_name}` %></option>
            <% } }) %>
          </select>
        </label>

        <label>
          Fecha de ingreso
          <input type="date" name="hire_date" required value="<%= (employee && employee.hire_date) || '' %>" />
        </label>
        <label>
          Estado laboral
          <input type="text" name="employment_status" value="<%= (employee && employee.employment_status) || 'Activo' %>" />
        </label>
        <label>
          Tipo de contrato
          <input type="text" name="contract_type" value="<%= (employee && employee.contract_type) || '' %>" />
        </label>

        <label>
          Salario base
          <input type="number" step="0.01" name="salary_base" value="<%= (employee && employee.salary_base) || '' %>" />
        </label>
        <label>
          Bono
          <input type="number" step="0.01" name="bonus_amount" value="<%= (employee && employee.bonus_amount) || '' %>" />
        </label>
        <label>
          Tipo de cálculo de planilla
          <input type="text" name="payroll_calculation_type" value="<%= (employee && employee.payroll_calculation_type) || '' %>" />
        </label>

        <label>
          Cuenta bancaria
          <input type="text" name="bank_account_number" value="<%= (employee && employee.bank_account_number) || '' %>" />
        </label>
        <label>
          Tipo de cuenta
          <input type="text" name="bank_account_type" value="<%= (employee && employee.bank_account_type) || '' %>" />
        </label>
        <label>
          Banco
          <input type="text" name="bank_name" value="<%= (employee && employee.bank_name) || '' %>" />
        </label>

        <label>
          Descripción de puesto
          <select name="job_description_id">
            <option value="">No asignada</option>
            <% descriptions.forEach((description) => { %>
              <option value="<%= description.id %>" <%= String((employee && employee.job_description_id) || '') === String(description.id) ? 'selected' : '' %>><%= `${description.position_name} - ${description.department}` %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Activo
          <div class="toggle-row">
            <input type="checkbox" name="is_active" <%= !employee || employee.is_active ? 'checked' : '' %> />
            <span class="badge status active">Visible en RRHH</span>
          </div>
        </label>

        <label class="full-row">
          Notas
          <textarea name="notes" rows="4"><%= (employee && employee.notes) || '' %></textarea>
        </label>

        <section class="hr-attachments-panel full-row">
          <div class="panel-header">
            <div>
              <h2>Adjuntos</h2>
              <p class="muted">Los archivos se guardan organizados por módulo y empresa.</p>
            </div>
          </div>

          <div class="hr-form-grid">
            <label>
              Foto
              <input type="file" name="photo" accept="image/*" />
              <% if (employee && employee.photo_url) { %>
                <a class="helper" href="<%= employee.photo_url %>" target="_blank" rel="noopener">Ver foto actual</a>
              <% } %>
            </label>
            <label>
              Solicitud de empleo
              <input type="file" name="job_application" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.webp" />
              <% if (employee && employee.job_application_url) { %>
                <a class="helper" href="<%= employee.job_application_url %>" target="_blank" rel="noopener">Ver solicitud actual</a>
              <% } %>
            </label>
            <label>
              DPI frente
              <input type="file" name="dpi_front" accept=".pdf,.png,.jpg,.jpeg,.webp" />
            </label>
            <label>
              DPI reverso
              <input type="file" name="dpi_back" accept=".pdf,.png,.jpg,.jpeg,.webp" />
            </label>
            <label>
              Contrato firmado
              <input type="file" name="signed_contract" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.webp" />
            </label>
            <label>
              Otros documentos
              <input type="file" name="other_documents" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.webp" multiple />
            </label>
          </div>

          <% if (attachments && attachments.length) { %>
            <div class="table">
              <div class="table-row header hr-generic">
                <div>Tipo</div>
                <div>Documento</div>
                <div>Fecha</div>
              </div>
              <% attachments.forEach((attachment) => { %>
                <div class="table-row hr-generic">
                  <div><%= attachment.attachment_label %></div>
                  <div><a class="btn" href="<%= attachment.file_url %>" target="_blank" rel="noopener">Abrir documento</a></div>
                  <div><%= attachment.created_at || '-' %></div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <div class="actions full-row">
          <button type="submit" class="btn primary"><%= mode === 'edit' ? 'Guardar cambios' : 'Crear empleado' %></button>
          <% if (mode === 'edit' && employee) { %>
            <a class="btn" href="/rrhh/employees/<%= employee.id %>">Cancelar</a>
          <% } else { %>
            <a class="btn" href="/rrhh?tab=employees">Cancelar</a>
          <% } %>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
