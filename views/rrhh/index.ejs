<%
const currentQuery = query || {};
function cloneParams(extra) {
  const params = new URLSearchParams();
  Object.keys(currentQuery).forEach((key) => {
    const value = currentQuery[key];
    if (value === undefined || value === null || value === '') return;
    params.set(key, value);
  });
  Object.keys(extra || {}).forEach((key) => {
    const value = extra[key];
    if (value === undefined || value === null || value === '') {
      params.delete(key);
      return;
    }
    params.set(key, value);
  });
  return params.toString();
}
function tabUrl(tab, extra) {
  const qs = cloneParams({ ...extra, tab });
  return `/rrhh${qs ? `?${qs}` : ''}`;
}
function pageUrl(page) {
  const qs = cloneParams({ page, tab: activeTab });
  return `/rrhh?${qs}`;
}
const activeFilters =
  activeTab === 'employees' ? (employees && employees.filters) || {} :
  activeTab === 'contracts' ? (contracts && contracts.filters) || {} :
  activeTab === 'salaries' ? (salaries && salaries.filters) || {} :
  activeTab === 'overtime' ? (overtime && overtime.filters) || {} :
  activeTab === 'attendance' ? (attendance && attendance.filters) || {} :
  activeTab === 'warnings' ? (warnings && warnings.filters) || {} :
  activeTab === 'descriptions' ? (descriptions && descriptions.filters) || {} :
  activeTab === 'permissions' ? (permissions && permissions.filters) || {} :
  activeTab === 'vacations' ? (vacations && vacations.filters) || {} :
  {};
const activePagination =
  activeTab === 'employees' ? (employees && employees.pagination) || null :
  activeTab === 'contracts' ? (contracts && contracts.pagination) || null :
  activeTab === 'salaries' ? (salaries && salaries.pagination) || null :
  activeTab === 'overtime' ? (overtime && overtime.pagination) || null :
  activeTab === 'attendance' ? (attendance && attendance.pagination) || null :
  activeTab === 'warnings' ? (warnings && warnings.pagination) || null :
  activeTab === 'descriptions' ? (descriptions && descriptions.pagination) || null :
  activeTab === 'permissions' ? (permissions && permissions.pagination) || null :
  activeTab === 'vacations' ? (vacations && vacations.pagination) || null :
  null;
%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RRHH</title>
  <%- include('../partials/head-assets') %>
  <script src="/js/rrhh.js" defer></script>
</head>
<body class="page hr-page app-module-page">
  <%- include('../partials/header', {
    headerBrandText: 'RRHH',
    headerNavItems: [
      { href: '/dashboard', label: 'Dashboard' },
      { href: '/logout', label: t('nav.logout') }
    ]
  }) %>

  <main class="container hr-shell app-module app-module-shell">
    <%- include('../partials/toasts') %>

    <section class="hr-hero app-module-hero app-page-header">
      <div>
        <div class="eyebrow app-page-eyebrow">Talento humano</div>
        <h1>Módulo RRHH</h1>
        <p class="muted">Gestión multiempresa de empleados, contratos, salarios, asistencia, permisos y vacaciones.</p>
      </div>
      <div class="hr-summary-grid">
        <article class="hr-summary-card app-card app-metric-card">
          <span class="muted">Empleados</span>
          <strong><%= summary.employeeTotal %></strong>
          <span class="helper"><%= summary.activeEmployeeTotal %> activos</span>
        </article>
        <article class="hr-summary-card app-card app-metric-card">
          <span class="muted">Contratos</span>
          <strong><%= summary.contractTotal %></strong>
          <span class="helper"><%= summary.activeContractTotal %> vigentes</span>
        </article>
        <article class="hr-summary-card app-card app-metric-card">
          <span class="muted">Asistencias</span>
          <strong><%= summary.attendanceTotal %></strong>
          <span class="helper"><%= summary.lateAttendanceTotal %> tardanzas</span>
        </article>
        <article class="hr-summary-card app-card app-metric-card">
          <span class="muted">Vacaciones</span>
          <strong><%= summary.vacationTotal %></strong>
          <span class="helper"><%= summary.approvedVacationTotal %> aprobadas</span>
        </article>
      </div>
    </section>

    <nav class="module-nav hr-tabs app-toolbar app-module-tabs">
      <% hrTabs.forEach((tab) => { %>
        <a href="<%= tabUrl(tab.key, { page: 1, editId: null }) %>" class="<%= activeTab === tab.key ? 'active' : '' %>"><%= tab.label %></a>
      <% }) %>
    </nav>

    <% if (activeTab === 'employees') { const data = employees || { rows: [], filters: {}, pagination: null, view: 'list' }; %>
      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Ficha de empleado</h2>
            <p class="muted">Listado principal con búsqueda, filtros y cambio entre vista lista y cards.</p>
          </div>
          <div class="actions">
            <a class="btn primary" href="/rrhh/employees/new">Nuevo empleado</a>
            <a class="btn <%= data.view === 'list' ? 'primary' : '' %>" href="<%= tabUrl('employees', { view: 'list', page: 1 }) %>">Vista lista</a>
            <a class="btn <%= data.view === 'cards' ? 'primary' : '' %>" href="<%= tabUrl('employees', { view: 'cards', page: 1 }) %>">Vista cards</a>
          </div>
        </div>

        <form method="GET" action="/rrhh" class="form grid-3">
          <input type="hidden" name="tab" value="employees" />
          <label>
            Buscar
            <input type="text" name="q" value="<%= data.filters.q || '' %>" placeholder="Nombre, DPI, código, puesto o departamento" />
          </label>
          <label>
            Departamento
            <select name="department">
              <option value="">Todos</option>
              <% departments.forEach((department) => { %>
                <option value="<%= department %>" <%= data.filters.department === department ? 'selected' : '' %>><%= department %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Estado
            <select name="status">
              <option value="">Todos</option>
              <option value="Activos" <%= data.filters.status === 'Activos' ? 'selected' : '' %>>Activos</option>
              <option value="Inactivos" <%= data.filters.status === 'Inactivos' ? 'selected' : '' %>>Inactivos</option>
            </select>
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary">Buscar</button>
            <a class="btn" href="/rrhh?tab=employees">Limpiar</a>
          </div>
        </form>

        <% if (data.view === 'cards') { %>
          <div class="hr-employee-cards">
            <% if (!data.rows.length) { %>
              <div class="table-row empty">No hay empleados registrados con esos filtros.</div>
            <% } %>
            <% data.rows.forEach((row) => { %>
              <article class="hr-employee-card">
                <div class="hr-employee-card__media">
                  <% if (row.photo_url) { %>
                    <img src="<%= row.photo_url %>" alt="<%= row.full_name %>" />
                  <% } else { %>
                    <div class="hr-avatar-placeholder"><%= (row.first_name || 'E').charAt(0) %></div>
                  <% } %>
                </div>
                <div class="hr-employee-card__body">
                  <h3><%= row.full_name %></h3>
                  <div class="muted"><%= row.position || '-' %></div>
                  <div class="helper"><%= row.department || 'Sin departamento' %></div>
                  <div class="helper">Jefe: <%= row.immediate_boss_name || 'No asignado' %></div>
                  <span class="status-badge <%= row.is_active ? 'status-delivered' : 'status-default' %>"><%= row.is_active ? 'Activo' : 'Inactivo' %></span>
                </div>
                <div class="actions">
                  <a class="btn" href="/rrhh/employees/<%= row.id %>">Ver</a>
                  <a class="btn" href="/rrhh/employees/<%= row.id %>/edit">Editar</a>
                  <form method="POST" action="/rrhh/employees/<%= row.id %>/toggle-status" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn <%= row.is_active ? 'danger' : '' %>"><%= row.is_active ? 'Desactivar' : 'Reactivar' %></button>
                  </form>
                  <a class="btn" href="/rrhh/employees/<%= row.id %>/print" target="_blank" rel="noopener">Imprimir</a>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="table">
            <div class="table-row header hr-employees">
              <div>Empleado</div>
              <div>Puesto</div>
              <div>Departamento</div>
              <div>Jefe inmediato</div>
              <div>Estado</div>
              <div>Acciones</div>
            </div>
            <% if (!data.rows.length) { %>
              <div class="table-row empty">No hay empleados registrados con esos filtros.</div>
            <% } %>
            <% data.rows.forEach((row) => { %>
              <div class="table-row hr-employees">
                <div class="hr-employee-inline">
                  <% if (row.photo_url) { %>
                    <img src="<%= row.photo_url %>" alt="<%= row.full_name %>" class="hr-inline-photo" />
                  <% } else { %>
                    <div class="hr-avatar-placeholder hr-avatar-placeholder--small"><%= (row.first_name || 'E').charAt(0) %></div>
                  <% } %>
                  <div>
                    <strong><%= row.full_name %></strong>
                    <div class="muted"><%= row.employee_code || '-' %></div>
                  </div>
                </div>
                <div><%= row.position || '-' %></div>
                <div><%= row.department || '-' %></div>
                <div><%= row.immediate_boss_name || '-' %></div>
                <div><span class="status-badge <%= row.is_active ? 'status-delivered' : 'status-default' %>"><%= row.is_active ? 'Activo' : 'Inactivo' %></span></div>
                <div class="actions">
                  <a class="btn" href="/rrhh/employees/<%= row.id %>">Ver</a>
                  <a class="btn" href="/rrhh/employees/<%= row.id %>/edit">Editar</a>
                  <form method="POST" action="/rrhh/employees/<%= row.id %>/toggle-status" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn <%= row.is_active ? 'danger' : '' %>"><%= row.is_active ? 'Desactivar' : 'Reactivar' %></button>
                  </form>
                  <a class="btn" href="/rrhh/employees/<%= row.id %>/print" target="_blank" rel="noopener">Imprimir</a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% } %>

    <% if (activeTab === 'contracts') { const data = contracts || { rows: [], filters: {}, pagination: null }; %>
      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Contratos</h2>
            <p class="muted">Historial contractual por empleado con vista previa, impresión y exportación PDF.</p>
          </div>
          <div class="actions">
            <a class="btn primary" href="/rrhh/contracts/new">Nuevo contrato</a>
          </div>
        </div>

        <form method="GET" action="/rrhh" class="form grid-3">
          <input type="hidden" name="tab" value="contracts" />
          <label>
            Empleado
            <select name="employee_id">
              <option value="">Todos</option>
              <% employees.forEach((employee) => { %>
                <option value="<%= employee.id %>" <%= String(data.filters.employee_id || '') === String(employee.id) ? 'selected' : '' %>><%= `${employee.first_name} ${employee.last_name}` %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Estado
            <select name="status">
              <option value="">Todos</option>
              <option value="Borrador" <%= data.filters.status === 'Borrador' ? 'selected' : '' %>>Borrador</option>
              <option value="Vigente" <%= data.filters.status === 'Vigente' ? 'selected' : '' %>>Vigente</option>
              <option value="Finalizado" <%= data.filters.status === 'Finalizado' ? 'selected' : '' %>>Finalizado</option>
            </select>
          </label>
          <label>
            Buscar
            <input type="text" name="q" value="<%= data.filters.q || '' %>" placeholder="Empleado, tipo o lugar de trabajo" />
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary">Buscar</button>
            <a class="btn" href="/rrhh?tab=contracts">Limpiar</a>
          </div>
        </form>

        <div class="table">
          <div class="table-row header hr-contracts">
            <div>Empleado</div>
            <div>Tipo</div>
            <div>Inicio</div>
            <div>Fin</div>
            <div>Estado</div>
            <div>Acciones</div>
          </div>
          <% if (!data.rows.length) { %>
            <div class="table-row empty">No hay contratos para mostrar.</div>
          <% } %>
          <% data.rows.forEach((row) => { %>
            <div class="table-row hr-contracts">
              <div>
                <strong><%= row.employee_name %></strong>
                <div class="muted"><%= row.employee_position || '-' %></div>
              </div>
              <div><%= row.contract_type || '-' %></div>
              <div><%= row.start_date || '-' %></div>
              <div><%= row.end_date || 'Indefinido' %></div>
              <div><span class="status-badge"><%= row.status || '-' %></span></div>
              <div class="actions">
                <a class="btn" href="/rrhh/contracts/<%= row.id %>/edit">Editar</a>
                <a class="btn" href="/rrhh/contracts/<%= row.id %>/print" target="_blank" rel="noopener">Vista previa</a>
                <a class="btn" href="/rrhh/contracts/<%= row.id %>/export/pdf?download=1">PDF</a>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (activeTab === 'salaries') { const data = salaries || { rows: [], filters: {}, pagination: null, summary: {} }; %>
      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Salarios</h2>
            <p class="muted">Historial salarial, aumentos, bonos y deducciones fijas.</p>
          </div>
          <div class="hr-mini-summary">
            <span class="pill">Base actual: Q<%= data.summary.currentSalary || '0.00' %></span>
            <span class="pill">Bono actual: Q<%= data.summary.currentBonus || '0.00' %></span>
          </div>
        </div>

        <form method="GET" action="/rrhh" class="form grid-3">
          <input type="hidden" name="tab" value="salaries" />
          <label>
            Empleado
            <select name="employee_id">
              <option value="">Todos</option>
              <% employees.forEach((employee) => { %>
                <option value="<%= employee.id %>" <%= String(data.filters.employee_id || '') === String(employee.id) ? 'selected' : '' %>><%= `${employee.first_name} ${employee.last_name}` %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Desde
            <input type="date" name="from" value="<%= data.filters.from || '' %>" />
          </label>
          <label>
            Hasta
            <input type="date" name="to" value="<%= data.filters.to || '' %>" />
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary">Filtrar</button>
            <a class="btn" href="/rrhh?tab=salaries">Limpiar</a>
          </div>
        </form>

        <form method="POST" action="<%= editRecord ? `/rrhh/salaries/${editRecord.id}/update` : '/rrhh/salaries/create' %>" class="form hr-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label>
            Empleado
            <select name="employee_id" required>
              <option value="">Selecciona</option>
              <% employees.forEach((employee) => { %>
                <option value="<%= employee.id %>" <%= String((editRecord && editRecord.employee_id) || '') === String(employee.id) ? 'selected' : '' %>><%= `${employee.first_name} ${employee.last_name}` %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Fecha efectiva
            <input type="date" name="effective_date" required value="<%= (editRecord && editRecord.effective_date) || '' %>" />
          </label>
          <label>
            Salario base
            <input type="number" step="0.01" name="salary_base" value="<%= (editRecord && editRecord.salary_base) || '' %>" />
          </label>
          <label>
            Bono
            <input type="number" step="0.01" name="bonus_amount" value="<%= (editRecord && editRecord.bonus_amount) || '' %>" />
          </label>
          <label>
            Bono extra
            <input type="number" step="0.01" name="extra_bonus" value="<%= (editRecord && editRecord.extra_bonus) || '' %>" />
          </label>
          <label>
            Deducciones fijas
            <input type="number" step="0.01" name="fixed_deductions" value="<%= (editRecord && editRecord.fixed_deductions) || '' %>" />
          </label>
          <label>
            Método de pago
            <input type="text" name="payment_method" value="<%= (editRecord && editRecord.payment_method) || '' %>" />
          </label>
          <label>
            Cuenta bancaria
            <input type="text" name="bank_account_number" value="<%= (editRecord && editRecord.bank_account_number) || '' %>" />
          </label>
          <label>
            Estado
            <select name="status">
              <option value="Vigente" <%= !editRecord || editRecord.status === 'Vigente' ? 'selected' : '' %>>Vigente</option>
              <option value="Histórico" <%= editRecord && editRecord.status === 'Histórico' ? 'selected' : '' %>>Histórico</option>
              <option value="Suspendido" <%= editRecord && editRecord.status === 'Suspendido' ? 'selected' : '' %>>Suspendido</option>
            </select>
          </label>
          <label class="full-row">
            Notas
            <textarea name="notes" rows="3"><%= (editRecord && editRecord.notes) || '' %></textarea>
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary"><%= editRecord ? 'Actualizar salario' : 'Registrar salario' %></button>
            <% if (editRecord) { %>
              <a class="btn" href="/rrhh?tab=salaries">Cancelar edición</a>
            <% } %>
          </div>
        </form>

        <div class="table">
          <div class="table-row header hr-generic">
            <div>Empleado</div>
            <div>Fecha</div>
            <div>Base</div>
            <div>Bono</div>
            <div>Método</div>
            <div>Estado</div>
            <div>Acciones</div>
          </div>
          <% if (!data.rows.length) { %>
            <div class="table-row empty">No hay salarios registrados.</div>
          <% } %>
          <% data.rows.forEach((row) => { %>
            <div class="table-row hr-generic">
              <div><%= row.employee_name %></div>
              <div><%= row.effective_date || '-' %></div>
              <div>Q<%= Number(row.salary_base || 0).toFixed(2) %></div>
              <div>Q<%= Number(row.bonus_amount || 0).toFixed(2) %></div>
              <div><%= row.payment_method || '-' %></div>
              <div><span class="status-badge"><%= row.status || '-' %></span></div>
              <div class="actions">
                <a class="btn" href="<%= tabUrl('salaries', { editId: row.id }) %>">Editar</a>
                <form method="POST" action="/rrhh/salaries/<%= row.id %>/delete" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn danger">Eliminar</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (activeTab === 'overtime') { const data = overtime || { rows: [], filters: {}, pagination: null, summary: {} }; %>
      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Horas extras</h2>
            <p class="muted">Cálculo automático por rango horario, aprobación y resumen mensual.</p>
          </div>
          <span class="pill"><%= data.summary.monthlyHours || '0.00' %> horas en el mes</span>
        </div>

        <form method="GET" action="/rrhh" class="form grid-3">
          <input type="hidden" name="tab" value="overtime" />
          <label>
            Empleado
            <select name="employee_id">
              <option value="">Todos</option>
              <% employees.forEach((employee) => { %>
                <option value="<%= employee.id %>" <%= String(data.filters.employee_id || '') === String(employee.id) ? 'selected' : '' %>><%= `${employee.first_name} ${employee.last_name}` %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Mes
            <input type="month" name="month" value="<%= data.filters.month || '' %>" />
          </label>
          <label>
            Estado
            <select name="status">
              <option value="">Todos</option>
              <option value="Pendiente" <%= data.filters.status === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
              <option value="Aprobada" <%= data.filters.status === 'Aprobada' ? 'selected' : '' %>>Aprobada</option>
              <option value="Rechazada" <%= data.filters.status === 'Rechazada' ? 'selected' : '' %>>Rechazada</option>
            </select>
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary">Filtrar</button>
            <a class="btn" href="/rrhh?tab=overtime">Limpiar</a>
          </div>
        </form>

        <form method="POST" action="<%= editRecord ? `/rrhh/overtime/${editRecord.id}/update` : '/rrhh/overtime/create' %>" class="form hr-form-grid" data-hr-hours-form>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label>
            Empleado
            <select name="employee_id" required>
              <option value="">Selecciona</option>
              <% employees.forEach((employee) => { %>
                <option value="<%= employee.id %>" <%= String((editRecord && editRecord.employee_id) || '') === String(employee.id) ? 'selected' : '' %>><%= `${employee.first_name} ${employee.last_name}` %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Fecha
            <input type="date" name="overtime_date" required value="<%= (editRecord && editRecord.overtime_date) || '' %>" />
          </label>
          <label>
            Hora inicio
            <input type="time" name="start_time" value="<%= (editRecord && editRecord.start_time) || '' %>" data-hr-start />
          </label>
          <label>
            Hora fin
            <input type="time" name="end_time" value="<%= (editRecord && editRecord.end_time) || '' %>" data-hr-end />
          </label>
          <label>
            Total horas
            <input type="number" step="0.01" name="total_hours" value="<%= (editRecord && editRecord.total_hours) || '' %>" data-hr-total readonly />
          </label>
          <label>
            Tipo
            <input type="text" name="overtime_type" value="<%= (editRecord && editRecord.overtime_type) || '' %>" />
          </label>
          <label>
            Aprobado por
            <input type="text" name="approved_by" value="<%= (editRecord && editRecord.approved_by) || '' %>" />
          </label>
          <label>
            Estado
            <select name="status">
              <option value="Pendiente" <%= !editRecord || editRecord.status === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
              <option value="Aprobada" <%= editRecord && editRecord.status === 'Aprobada' ? 'selected' : '' %>>Aprobada</option>
              <option value="Rechazada" <%= editRecord && editRecord.status === 'Rechazada' ? 'selected' : '' %>>Rechazada</option>
            </select>
          </label>
          <label class="full-row">
            Motivo
            <textarea name="reason" rows="2"><%= (editRecord && editRecord.reason) || '' %></textarea>
          </label>
          <label class="full-row">
            Notas
            <textarea name="notes" rows="2"><%= (editRecord && editRecord.notes) || '' %></textarea>
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary"><%= editRecord ? 'Actualizar horas extras' : 'Registrar horas extras' %></button>
            <% if (editRecord) { %><a class="btn" href="/rrhh?tab=overtime">Cancelar edición</a><% } %>
          </div>
        </form>

        <div class="table">
          <div class="table-row header hr-generic">
            <div>Empleado</div>
            <div>Fecha</div>
            <div>Horario</div>
            <div>Total</div>
            <div>Tipo</div>
