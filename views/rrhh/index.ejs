            Estado
            <select name="status">
              <option value="Pendiente" <%= !editRecord || editRecord.status === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
              <option value="Aprobada" <%= editRecord && editRecord.status === 'Aprobada' ? 'selected' : '' %>>Aprobada</option>
              <option value="Rechazada" <%= editRecord && editRecord.status === 'Rechazada' ? 'selected' : '' %>>Rechazada</option>
            </select>
          </label>
          <label>
            Adjunto
            <input type="file" name="attachment" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.webp" />
          </label>
          <label class="full-row">
            Motivo
            <textarea name="reason" rows="2"><%= (editRecord && editRecord.reason) || '' %></textarea>
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary"><%= editRecord ? 'Actualizar permiso' : 'Registrar permiso' %></button>
            <% if (editRecord) { %><a class="btn" href="/rrhh?tab=permissions">Cancelar edición</a><% } %>
          </div>
        </form>

        <div class="table">
          <div class="table-row header hr-generic">
            <div>Empleado</div>
            <div>Tipo</div>
            <div>Rango</div>
            <div>Días</div>
            <div>Con goce</div>
            <div>Acciones</div>
          </div>
          <% if (!data.rows.length) { %><div class="table-row empty">No hay permisos registrados.</div><% } %>
          <% data.rows.forEach((row) => { %>
            <div class="table-row hr-generic">
              <div><%= row.employee_name %></div>
              <div><%= row.permission_type || '-' %></div>
              <div><%= row.start_date || '-' %> al <%= row.end_date || '-' %></div>
              <div><%= Number(row.total_days || 0).toFixed(2) %></div>
              <div><%= row.with_pay ? 'Sí' : 'No' %></div>
              <div class="actions">
                <% if (row.attachment_url) { %><a class="btn" href="<%= row.attachment_url %>" target="_blank" rel="noopener">Adjunto</a><% } %>
                <a class="btn" href="<%= tabUrl('permissions', { editId: row.id }) %>">Editar</a>
                <a class="btn" href="/rrhh/print/permissions/<%= row.id %>" target="_blank" rel="noopener">Imprimir</a>
                <form method="POST" action="/rrhh/permissions/<%= row.id %>/delete" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn danger">Eliminar</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (activeTab === 'vacations') { const data = vacations || { rows: [], filters: {}, pagination: null, summary: { byDepartment: [] } }; %>
      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Vacaciones</h2>
            <p class="muted">Saldo estimado, historial y reportes por departamento.</p>
          </div>
        </div>

        <form method="GET" action="/rrhh" class="form grid-3">
          <input type="hidden" name="tab" value="vacations" />
          <label>
            Empleado
            <select name="employee_id">
              <option value="">Todos</option>
              <% employees.forEach((employee) => { %>
                <option value="<%= employee.id %>" <%= String(data.filters.employee_id || '') === String(employee.id) ? 'selected' : '' %>><%= `${employee.first_name} ${employee.last_name}` %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Departamento
            <select name="department">
              <option value="">Todos</option>
              <% departments.forEach((department) => { %>
                <option value="<%= department %>" <%= data.filters.department === department ? 'selected' : '' %>><%= department %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Estado
            <select name="status">
              <option value="">Todos</option>
              <option value="Pendiente" <%= data.filters.status === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
              <option value="Aprobada" <%= data.filters.status === 'Aprobada' ? 'selected' : '' %>>Aprobada</option>
              <option value="Rechazada" <%= data.filters.status === 'Rechazada' ? 'selected' : '' %>>Rechazada</option>
            </select>
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary">Filtrar</button>
            <a class="btn" href="/rrhh?tab=vacations">Limpiar</a>
          </div>
        </form>

        <% if (data.summary.byDepartment && data.summary.byDepartment.length) { %>
          <div class="hr-department-summary">
            <% data.summary.byDepartment.forEach((entry) => { %>
              <div class="pill"><strong><%= entry.department %></strong>: <%= entry.total %></div>
            <% }) %>
          </div>
        <% } %>

        <form method="POST" action="<%= editRecord ? `/rrhh/vacations/${editRecord.id}/update` : '/rrhh/vacations/create' %>" class="form hr-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label>
            Empleado
            <select name="employee_id" required>
              <option value="">Selecciona</option>
              <% employees.forEach((employee) => { %>
                <option value="<%= employee.id %>" <%= String((editRecord && editRecord.employee_id) || '') === String(employee.id) ? 'selected' : '' %>><%= `${employee.first_name} ${employee.last_name}` %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Periodo
            <input type="text" name="vacation_period" value="<%= (editRecord && editRecord.vacation_period) || '' %>" placeholder="2026" />
          </label>
          <label>
            Fecha ingreso base
            <input type="date" name="hire_date_snapshot" value="<%= (editRecord && editRecord.hire_date_snapshot) || '' %>" />
          </label>
          <label>
            Días ganados
            <input type="number" step="0.01" name="earned_days" value="<%= (editRecord && editRecord.earned_days) || '' %>" />
          </label>
          <label>
            Días usados
            <input type="number" step="0.01" name="used_days" value="<%= (editRecord && editRecord.used_days) || '' %>" />
          </label>
          <label>
            Inicio vacaciones
            <input type="date" name="vacation_start" required value="<%= (editRecord && editRecord.vacation_start) || '' %>" />
          </label>
          <label>
            Fin vacaciones
            <input type="date" name="vacation_end" required value="<%= (editRecord && editRecord.vacation_end) || '' %>" />
          </label>
          <label>
            Regreso
            <input type="date" name="return_date" value="<%= (editRecord && editRecord.return_date) || '' %>" />
          </label>
          <label>
            Estado
            <select name="status">
              <option value="Pendiente" <%= !editRecord || editRecord.status === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
              <option value="Aprobada" <%= editRecord && editRecord.status === 'Aprobada' ? 'selected' : '' %>>Aprobada</option>
              <option value="Rechazada" <%= editRecord && editRecord.status === 'Rechazada' ? 'selected' : '' %>>Rechazada</option>
            </select>
          </label>
          <label class="full-row">
            Notas
            <textarea name="notes" rows="2"><%= (editRecord && editRecord.notes) || '' %></textarea>
          </label>
          <div class="actions full-row">
            <button type="submit" class="btn primary"><%= editRecord ? 'Actualizar vacaciones' : 'Registrar vacaciones' %></button>
            <% if (editRecord) { %><a class="btn" href="/rrhh?tab=vacations">Cancelar edición</a><% } %>
          </div>
        </form>

        <div class="table">
          <div class="table-row header hr-generic">
            <div>Empleado</div>
            <div>Periodo</div>
            <div>Ganados</div>
            <div>Usados</div>
            <div>Disponibles</div>
            <div>Acciones</div>
          </div>
          <% if (!data.rows.length) { %><div class="table-row empty">No hay vacaciones registradas.</div><% } %>
          <% data.rows.forEach((row) => { %>
            <div class="table-row hr-generic">
              <div><strong><%= row.employee_name %></strong><div class="muted"><%= row.department || '-' %></div></div>
              <div><%= row.vacation_period || '-' %></div>
              <div><%= Number(row.earned_days || 0).toFixed(2) %></div>
              <div><%= Number(row.used_days || 0).toFixed(2) %></div>
              <div><%= Number(row.available_days || 0).toFixed(2) %></div>
              <div class="actions">
                <a class="btn" href="<%= tabUrl('vacations', { editId: row.id }) %>">Editar</a>
                <form method="POST" action="/rrhh/vacations/<%= row.id %>/delete" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn danger">Eliminar</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (activePagination && activePagination.totalPages > 1) { %>
      <nav class="hr-pagination">
        <% if (activePagination.hasPrev) { %>
          <a class="btn" href="<%= pageUrl(activePagination.page - 1) %>">Anterior</a>
        <% } %>
        <span class="pill">Página <%= activePagination.page %> de <%= activePagination.totalPages %></span>
        <% if (activePagination.hasNext) { %>
          <a class="btn" href="<%= pageUrl(activePagination.page + 1) %>">Siguiente</a>
        <% } %>
      </nav>
    <% } %>
  </main>
</body>
</html>
