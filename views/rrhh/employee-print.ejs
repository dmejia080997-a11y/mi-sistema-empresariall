<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ficha de <%= employee.full_name %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="page hr-print-page" onload="window.print()">
  <main class="container hr-print-shell">
    <section class="panel hr-print-panel">
      <div class="panel-header">
        <div>
          <div class="eyebrow">RRHH</div>
          <h1>Ficha de empleado</h1>
          <p class="muted"><%= employee.full_name %></p>
        </div>
        <% if (employee.photo_url) { %>
          <img src="<%= employee.photo_url %>" alt="<%= employee.full_name %>" class="hr-print-photo" />
        <% } %>
      </div>

      <h2>Datos personales</h2>
      <div class="hr-print-grid">
        <div><strong>Nombres:</strong> <%= employee.first_name || '-' %></div>
        <div><strong>Apellidos:</strong> <%= employee.last_name || '-' %></div>
        <div><strong>DPI:</strong> <%= employee.dpi_number || '-' %></div>
        <div><strong>Lugar de emision:</strong> <%= employee.dpi_issued_at || '-' %></div>
        <div><strong>Estado civil:</strong> <%= employee.marital_status || '-' %></div>
        <div><strong>Apellido de casada:</strong> <%= employee.married_last_name || '-' %></div>
        <div><strong>Genero:</strong> <%= employee.gender || '-' %></div>
        <div><strong>Nacimiento:</strong> <%= employee.birth_date || '-' %></div>
        <div><strong>Telefono:</strong> <%= employee.phone || '-' %></div>
        <div><strong>Correo:</strong> <%= employee.email || '-' %></div>
        <div class="full-row"><strong>Direccion:</strong> <%= employee.address || '-' %></div>
      </div>

      <h2>Datos laborales</h2>
      <div class="hr-print-grid">
        <div><strong>Puesto:</strong> <%= employee.position || '-' %></div>
        <div><strong>Departamento:</strong> <%= employee.department || '-' %></div>
        <div><strong>Jefe inmediato:</strong> <%= employee.immediate_boss_name || '-' %></div>
        <div><strong>Codigo:</strong> <%= employee.employee_code || '-' %></div>
        <div><strong>Fecha de ingreso:</strong> <%= employee.hire_date || '-' %></div>
        <div><strong>Tipo de contrato:</strong> <%= employee.contract_type || '-' %></div>
        <div><strong>Estado:</strong> <%= employee.employment_status || '-' %></div>
        <div><strong>Descripcion asignada:</strong> <%= employee.description_position_name || '-' %></div>
        <div class="full-row"><strong>Observaciones laborales:</strong> <%= employee.labor_observations || '-' %></div>
      </div>

      <h2>Educacion</h2>
      <div class="hr-print-grid">
        <div><strong>Escolaridad:</strong> <%= employee.education_level || '-' %></div>
        <div><strong>Etnia:</strong> <%= employee.ethnicity || '-' %></div>
        <div><strong>Idiomas:</strong> <%= employee.languages || '-' %></div>
        <div><strong>Profesion:</strong> <%= employee.profession || '-' %></div>
        <div class="full-row"><strong>Cursos o certificaciones:</strong> <%= employee.courses_certifications || '-' %></div>
      </div>

      <h2>Bancos y salarios</h2>
      <div class="hr-print-grid">
        <div><strong>Salario base:</strong> Q<%= Number(employee.salary_base || 0).toFixed(2) %></div>
        <div><strong>Bono incentivo:</strong> Q<%= Number(employee.bonus_amount || 0).toFixed(2) %></div>
        <div><strong>Otros bonos:</strong> Q<%= Number(employee.extra_bonus || 0).toFixed(2) %></div>
        <div><strong>Tipo de calculo:</strong> <%= employee.payroll_calculation_type || '-' %></div>
        <div><strong>Metodo de pago:</strong> <%= employee.payment_method || '-' %></div>
        <div><strong>Banco:</strong> <%= employee.bank_name || '-' %></div>
        <div><strong>Tipo de cuenta:</strong> <%= employee.bank_account_type || '-' %></div>
        <div><strong>Numero de cuenta:</strong> <%= employee.bank_account_number || '-' %></div>
      </div>

      <h2>Documentos</h2>
      <div class="hr-print-list">
        <div><strong>Solicitud de empleo:</strong> <%= employee.job_application_url ? 'Documento cargado' : '-' %></div>
        <% if (!attachments.length) { %>
          <div>-</div>
        <% } %>
        <% attachments.forEach((attachment) => { %>
          <div><strong><%= attachment.attachment_label %>:</strong> <%= attachment.original_name || 'Documento cargado' %></div>
        <% }) %>
      </div>

      <h2>Informacion adicional</h2>
      <div class="hr-print-grid">
        <div><strong>Contacto de emergencia:</strong> <%= employee.emergency_contact_name || '-' %></div>
        <div><strong>Telefono de emergencia:</strong> <%= employee.emergency_contact_phone || '-' %></div>
        <div class="full-row"><strong>Observaciones generales:</strong> <%= employee.general_observations || '-' %></div>
        <div class="full-row"><strong>Notas internas:</strong> <%= employee.notes || '-' %></div>
      </div>
    </section>
  </main>
</body>
</html>
