<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('consignatarios.title') %>
</title>
<link rel="stylesheet" href="/styles.css" />
</head>
<body class="page consignatarios-module">
<header class="topbar">
<div class="brand">
<%= t('common.brand') %>
</div>
<nav class="nav">
<a href="/dashboard">
<%= t('nav.dashboard') %>
</a>
<a href="/logout">
<%= t('nav.logout') %>
</a>
</nav>
</header>
<main class="container">
<h1>
<%= t('consignatarios.title') %>
</h1>
<% const sortBase = sortBaseQuery ? `${sortBaseQuery}&` : ''; %>
<% const nextDir = (key) => (sort && sort.key === key && sort.dir === 'ASC' ? 'desc' : 'asc'); %>
<% const dirLabel = (key) => (sort && sort.key === key ? (sort.dir === 'ASC' ? ' ASC' : ' DESC') : ''); %>
<div class="module-nav consignatarios-nav">
<a href="#consignatarios-listado" class="active" data-section="list">
<%= t('consignatarios.menu_list') %>
</a>
<a href="#consignatarios-filtros" data-section="filters">
<%= t('consignatarios.menu_filters') %>
</a>
<a href="#consignatarios-gestionar" data-section="manage">
<%= t('consignatarios.menu_manage') %>
</a>
</div>
<section class="consignatarios-section" id="consignatarios-listado">
<section class="panel">
<div class="panel-header">
<h2>
<%= t('consignatarios.filters_title') %>
</h2>
<a class="btn" href="/consignatarios">
<%= t('common.clear') %>
</a>
</div>
<form method="GET" action="/consignatarios" class="form grid-2">
<label>
<%= t('consignatarios.search_name') %>
<input type="text" name="name" value="<%= filters.name || '' %>" />
</label>
<div class="actions full-row">
<button type="submit" class="btn primary">
<%= t('common.search') %>
</button>
</div>
</form>
</section>
<section class="panel">
<h2>
<%= t('consignatarios.list') %>
</h2>
<div class="table">
<div class="table-row header consignatarios">
<div>
<a href="/consignatarios?<%= sortBase %>sort=name&dir=<%= nextDir('name') %>">
<%= t('consignatarios.table.name') %><%= dirLabel('name') %>
</a>
</div>
<div>
<a href="/consignatarios?<%= sortBase %>sort=customer&dir=<%= nextDir('customer') %>">
<%= t('consignatarios.table.customer') %><%= dirLabel('customer') %>
</a>
</div>
<div>
<a href="/consignatarios?<%= sortBase %>sort=phone&dir=<%= nextDir('phone') %>">
<%= t('consignatarios.table.contact') %><%= dirLabel('phone') %>
</a>
</div>
<div>
<%= t('consignatarios.table.actions') %>
</div>
</div>
<% if (consignatarios.length === 0) { %>
<div class="table-row empty">
<%= t('consignatarios.no_consignatarios') %>
</div>
<% } %>
<% consignatarios.forEach(consignatario => { %>
<div class="table-row consignatarios">
<div>
<div>
<strong>
<%= consignatario.name %>
</strong>
</div>
<div class="muted">
<%= consignatario.document_type || '-' %> ? <%= consignatario.document_number || '-' %>
</div>
</div>
<div>
<%= consignatario.customer_code ? `${consignatario.customer_code} - ` : '' %><%= consignatario.customer_name || '-' %>
</div>
<div>
<div>
<%= consignatario.phone || '-' %>
</div>
<div class="muted">
<%= consignatario.email || '-' %>
</div>
</div>
<div class="actions">
<a class="btn" href="/consignatarios/<%= consignatario.id %>">
<%= t('common.view') %>
</a>
</div>
</div>
<% }) %>
</div>
</section>
</section>
<section class="consignatarios-section" id="consignatarios-filtros">
<section class="panel">
<div class="panel-header">
<h2>
<%= t('consignatarios.filters_title') %>
</h2>
<div class="actions">
<a class="btn" href="/consignatarios">
<%= t('common.clear') %>
</a>
<a class="btn primary" href="<%= exportUrl %>" style="<%= can('consignatarios', 'export') ? '' : 'display:none' %>">
<%= t('consignatarios.export_excel') %>
</a>
</div>
</div>
<form method="GET" action="/consignatarios" class="form grid-2">
<label>
<%= t('consignatarios.search_name') %>
<input type="text" name="name" value="<%= filters.name || '' %>" />
</label>
<label>
<%= t('consignatarios.search_document') %>
<input type="text" name="document_number" value="<%= filters.document_number || '' %>" />
</label>
<label>
<%= t('consignatarios.filter_customer') %>
<select name="customer_id">
<option value="">
<%= t('common.all') %>
</option>
<% customers.forEach(customer => { %>
<option value="<%= customer.id %>" <%= String(filters.customer_id) === String(customer.id) ? 'selected' : '' %>>
<%= customer.customer_code ? `${customer.customer_code} - ` : '' %><%= customer.name %>
</option>
<% }) %>
</select>
</label>
<div class="actions full-row">
<button type="submit" class="btn primary">
<%= t('common.search') %>
</button>
</div>
</form>
</section>
<section class="panel">
<h2>
<%= t('consignatarios.list') %>
</h2>
<div class="table">
<div class="table-row header consignatarios">
<div>
<a href="/consignatarios?<%= sortBase %>sort=name&dir=<%= nextDir('name') %>">
<%= t('consignatarios.table.name') %><%= dirLabel('name') %>
</a>
</div>
<div>
<a href="/consignatarios?<%= sortBase %>sort=customer&dir=<%= nextDir('customer') %>">
<%= t('consignatarios.table.customer') %><%= dirLabel('customer') %>
</a>
</div>
<div>
<a href="/consignatarios?<%= sortBase %>sort=phone&dir=<%= nextDir('phone') %>">
<%= t('consignatarios.table.contact') %><%= dirLabel('phone') %>
</a>
</div>
<div>
<%= t('consignatarios.table.actions') %>
</div>
</div>
<% if (consignatarios.length === 0) { %>
<div class="table-row empty">
<%= t('consignatarios.no_consignatarios') %>
</div>
<% } %>
<% consignatarios.forEach(consignatario => { %>
<div class="table-row consignatarios">
<div>
<div>
<strong>
<%= consignatario.name %>
</strong>
</div>
<div class="muted">
<%= consignatario.document_type || '-' %> ? <%= consignatario.document_number || '-' %>
</div>
</div>
<div>
<%= consignatario.customer_code ? `${consignatario.customer_code} - ` : '' %><%= consignatario.customer_name || '-' %>
</div>
<div>
<div>
<%= consignatario.phone || '-' %>
</div>
<div class="muted">
<%= consignatario.email || '-' %>
</div>
</div>
<div class="actions">
<a class="btn" href="/consignatarios/<%= consignatario.id %>">
<%= t('common.view') %>
</a>
</div>
</div>
<% }) %>
</div>
</section>
</section>
<section class="consignatarios-section" id="consignatarios-gestionar">
<section class="panel" style="<%= can('consignatarios', 'edit') ? '' : 'display:none' %>">
<h2>
<%= t('consignatarios.edit_shortcut_title') %>
</h2>
<form class="form grid-2" data-consignatario-edit-shortcut>
<label>
<%= t('consignatarios.edit_select') %>
<select name="consignatario_id" data-edit-select>
<option value="">
<%= t('common.choose') %>
</option>
<% consignatarios.forEach(consignatario => { %>
<option value="<%= consignatario.id %>">
<%= consignatario.name %>
</option>
<% }) %>
</select>
</label>
<div class="actions full-row">
<button type="button" class="btn primary" data-edit-go>
<%= t('consignatarios.edit_go') %>
</button>
</div>
</form>
</section>
<section class="panel" style="<%= can('consignatarios', 'create') ? '' : 'display:none' %>">
<h2>
<%= t('consignatarios.add_title') %>
</h2>
<% if (flash) { %>
<div class="alert <%= flash.type %>">
<%= flash.message %>
</div>
<% } %>
<% if (error) { %>
<div class="alert">
<%= error %>
</div>
<% } %>
<form method="POST" action="/consignatarios/create" class="form grid-2" data-sat-form data-gt-address-form>
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
<%= t('consignatarios.customer') %>
<select name="customer_id" required>
<option value="">
<%= t('common.choose') %>
</option>
<% customers.forEach(customer => { %>
<option value="<%= customer.id %>">
<%= customer.customer_code ? `${customer.customer_code} - ` : '' %><%= customer.name %>
</option>
<% }) %>
</select>
</label>
<label>
<%= t('consignatarios.document_type') %>
<select name="document_type" data-sat-type>
<% documentTypes.forEach(type => { %>
<option value="<%= type %>">
<%= type %>
</option>
<% }) %>
</select>
</label>
<label>
<%= t('consignatarios.document_number') %>
<input type="text" name="document_number" data-sat-number />
</label>
<div class="actions full-row">
<button type="button" class="btn" data-sat-verify>
<%= t('customers.verify_sat') %>
</button>
<button type="button" class="btn" data-sat-manual>
<%= t('customers.sat_manual_action') %>
</button>
<span class="helper" data-sat-status>
<%= t('customers.sat_hint') %>
</span>
<span class="helper" data-sat-warning>
</span>
<input type="hidden" name="sat_verified" value="0" data-sat-verified />
<input type="hidden" name="sat_name" value="" data-sat-name />
<input type="hidden" name="sat_checked_at" value="" data-sat-checked-at />
</div>
<label>
<%= t('consignatarios.name') %>
<input type="text" name="name" required data-sat-name-target />
</label>
<label>
<%= t('consignatarios.email') %>
<input type="email" name="email" />
</label>
<label>
<%= t('consignatarios.phone') %>
<input type="text" name="phone" />
</label>
<label>
<%= t('consignatarios.mobile') %>
<input type="text" name="mobile" />
</label>
<label>
<%= t('consignatarios.country') %>
<select name="country" data-country data-selected="">
<% countries.forEach(country => { %>
<option value="<%= country %>">
<%= country %>
</option>
<% }) %>
</select>
</label>
<label>
<%= t('consignatarios.department') %>
<select name="department" data-department data-selected="" data-placeholder="<%= t('consignatarios.select_department') %>">
<option value=""><%= t('consignatarios.select_department') %></option>
</select>
</label>
<label>
<%= t('consignatarios.municipality') %>
<select name="municipality" data-municipality data-selected="" data-placeholder="<%= t('consignatarios.select_municipality') %>">
<option value=""><%= t('consignatarios.select_municipality') %></option>
</select>
</label>
<label>
<%= t('consignatarios.zone') %>
<input type="text" name="zone" placeholder="<%= t('consignatarios.zone') %>" />
</label>
<label>
<%= t('consignatarios.full_address') %>
<textarea name="full_address" rows="2" placeholder="<%= t('consignatarios.full_address') %>">
</textarea>
</label>
<label>
<%= t('consignatarios.notes') %>
<textarea name="notes" rows="2">
</textarea>
</label>
<div class="actions full-row">
<button type="submit" class="btn primary">
<%= t('consignatarios.add') %>
</button>
</div>
</form>
</section>
</section>
<script src="/gt-locations.js">
</script>
<script src="/address-gt.js">
</script>
</main>
<script>    function initSatForm(form) {      const typeSelect = form.querySelector('[data-sat-type]');      const numberInput = form.querySelector('[data-sat-number]');      const nameInput = form.querySelector('[data-sat-name-target]');      const verifyBtn = form.querySelector('[data-sat-verify]');      const manualBtn = form.querySelector('[data-sat-manual]');      const statusEl = form.querySelector('[data-sat-status]');      const warningEl = form.querySelector('[data-sat-warning]');      const satVerified = form.querySelector('[data-sat-verified]');      const satName = form.querySelector('[data-sat-name]');      const satCheckedAt = form.querySelector('[data-sat-checked-at]');      function setManualStatus(message, portalUrl) {        if (statusEl) statusEl.textContent = '<%= t('customers.sat_manual_action') %>';        if (warningEl) {          if (portalUrl) {            warningEl.innerHTML = `${message || '<%= t('customers.sat_unavailable') %>'} <a href="${portalUrl}" target="_blank" rel="noopener">${'<%= t('customers.sat_portal_link') %>'}</a>`;          } else {            warningEl.textContent = message || '<%= t('customers.sat_unavailable') %>';          }        }        if (satVerified) satVerified.value = '0';        if (satName) satName.value = '';        if (satCheckedAt) satCheckedAt.value = '';      }      function clearWarning() {        if (warningEl) warningEl.textContent = '';      }      function toggleSatControls() {        const isNit = typeSelect && typeSelect.value === 'NIT';        if (verifyBtn) verifyBtn.disabled = !isNit;        if (manualBtn) manualBtn.disabled = !isNit;        if (!isNit) {          if (statusEl) statusEl.textContent = '<%= t('customers.sat_manual') %>';          clearWarning();          if (satVerified) satVerified.value = '0';          if (satName) satName.value = '';          if (satCheckedAt) satCheckedAt.value = '';        }      }      async function verifySat() {        if (!numberInput || !statusEl) return;        statusEl.textContent = '<%= t('customers.sat_checking') %>';        clearWarning();        try {          const response = await fetch('/sat/verify', {            method: 'POST',            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },            body: JSON.stringify({ document_number: numberInput.value })          });          const data = await response.json();          if (data && data.ok) {            statusEl.textContent = '<%= t('customers.sat_verified') %>';            if (nameInput && data.name) {              nameInput.value = data.name;            }            if (satVerified) satVerified.value = '1';            if (satName) satName.value = data.name || '';            if (satCheckedAt) satCheckedAt.value = new Date().toISOString();            return;          }          setManualStatus(data && data.message ? data.message : '<%= t('customers.sat_unavailable') %>', data && data.portal_url);        } catch (err) {          setManualStatus('<%= t('customers.sat_unavailable') %>');        }      }      if (typeSelect) typeSelect.addEventListener('change', toggleSatControls);      if (verifyBtn) verifyBtn.addEventListener('click', verifySat);      if (manualBtn) manualBtn.addEventListener('click', () => setManualStatus('<%= t('customers.sat_manual_action') %>'));      toggleSatControls();    }    function initConsignatariosTabs() {      const nav = document.querySelector('.consignatarios-nav');      if (!nav) return;      const links = Array.from(nav.querySelectorAll('a'));      const sections = Array.from(document.querySelectorAll('.consignatarios-section'));      if (!links.length || !sections.length) return;      document.body.classList.add('consignatarios-tabs');      function getTargetId() {        const hash = window.location.hash;        if (hash) {          const targetId = hash.replace('#', '');          if (document.getElementById(targetId)) {            return targetId;          }        }        return sections[0].id;      }      function setActive(targetId) {        sections.forEach((section) => {          section.classList.toggle('is-active', section.id === targetId);        });        links.forEach((link) => {          const href = link.getAttribute('href');          link.classList.toggle('active', href === `#${targetId}`);        });      }      setActive(getTargetId());      window.addEventListener('hashchange', () => {        setActive(getTargetId());      });    }    function initConsignatarioEditShortcut() {      const form = document.querySelector('[data-consignatario-edit-shortcut]');      if (!form) return;      const select = form.querySelector('[data-edit-select]');      const button = form.querySelector('[data-edit-go]');      if (!select || !button) return;      button.addEventListener('click', () => {        const id = select.value;        if (!id) {          select.focus();          return;        }        window.location.href = `/consignatarios/${id}`;      });    }    document.querySelectorAll('[data-sat-form]').forEach(initSatForm);    initConsignatariosTabs();    initConsignatarioEditShortcut();  </script>
<script src="/status-footer.js" defer></script>
</body>
</html>
