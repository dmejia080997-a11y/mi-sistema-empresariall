<% var currentPackagesNav = typeof packagesNav !== 'undefined' ? packagesNav : 'new'; %>
<%
  var canCreatePackageTabs = can('packages', 'create');
  var packageModuleTabs = [
    { key: 'dashboard', label: t('packages.module.dashboard'), href: '/packages/dashboard' },
    { key: 'list', label: t('packages.module.list'), href: '/packages' },
    { key: 'pending_invoice', label: t('packages.module.pending_invoice'), href: '/packages/pending-invoice' }
  ];
  if (canCreatePackageTabs) {
    packageModuleTabs.push({ key: 'new', label: t('packages.module.new'), href: '/packages/new' });
  }
  packageModuleTabs.push(
    { key: 'statuses', label: t('packages.module.statuses'), href: '/packages/statuses' },
    { key: 'tracking', label: t('packages.module.tracking'), href: '/packages/tracking' }
  );
%>
<% var prefillData = typeof prefill !== 'undefined' && prefill ? prefill : {}; %>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('packages.new_package') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header', {
  moduleTabs: packageModuleTabs,
  activeTab: currentPackagesNav,
  currentModule: 'packages'
}) %>
<main class="container packages-module">
<div class="page-header">
<div>
<h1>
<%= t('packages.new_package') %>
</h1>
<p class="muted">
<%= t('packages.subtitle') %>
</p>
</div>
<div class="actions">
<a class="btn" href="/packages/home">
<%= t('packages.module.home') %>
</a>
<a class="btn" href="/packages">
<%= t('packages.module.list') %>
</a>
</div>
</div>
<section class="panel">
<h2>
<%= t('packages.new_package') %>
</h2>
<% if (error) { %>
<div class="alert">
<%= error %>
</div>
<% } %>
<% if (prefillData && prefillData.reception_id) { %>
<div class="alert info">
<%= t('packages.reception_prefill') %>
</div>
<% } %>
<form method="POST" action="/packages/new" enctype="multipart/form-data" class="form grid-2" style="<%= can('packages', 'create') ? '' : 'display:none' %>">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<% if (prefillData && prefillData.reception_id) { %>
<input type="hidden" name="reception_id" value="<%= prefillData.reception_id %>" />
<% } %>
<div class="package-weight-summary">
<div>
<span class="muted">Peso ingresado</span>
<strong data-weight-entered>0.00 lbs</strong>
</div>
<div>
<span class="muted">Peso vol</span>
<strong data-weight-volume>0.00 lbs</strong>
</div>
</div>
<label>
<%= t('packages.consignatario') %>
<select name="consignatario_id" id="consignatario-select" required>
<option value="">
<%= t('packages.select_consignatario') %>
</option>
<% consignatarios.forEach(consignatario => { %>
<option value="<%= consignatario.id %>">
<%= consignatario.name %>
</option>
<% }) %>
</select>
</label>
<label>
<%= t('packages.declared_value') %>
<input type="number" name="declared_value" step="0.01" min="0" />
</label>
<label>
<%= t('packages.description') %>
<textarea name="description" rows="3">
</textarea>
</label>
<label>
<%= t('packages.weight_lbs') %>
<input type="number" name="weight_lbs" step="0.01" min="0" />
</label>
<label>
<%= t('packages.length_cm') %>
<input type="number" name="length_cm" step="0.01" min="0" />
</label>
<label>
<%= t('packages.width_cm') %>
<input type="number" name="width_cm" step="0.01" min="0" />
</label>
<label>
<%= t('packages.height_cm') %>
<input type="number" name="height_cm" step="0.01" min="0" />
</label>
<label>
Peso vol
<input type="number" name="volumetric_weight_lbs" step="0.01" min="0" readonly data-weight-volume-input value="0.00" />
</label>
<label>
<%= t('packages.shipping_type') %>
<select name="shipping_type">
<option value="">
<%= t('common.reset') %>
</option>
<option value="air">
<%= t('packages.shipping_air') %>
</option>
<option value="sea">
<%= t('packages.shipping_sea') %>
</option>
<option value="land">
<%= t('packages.shipping_land') %>
</option>
</select>
</label>
<label>
<%= t('packages.branch_destination') %>
<input type="text" name="branch_destination" />
</label>
<label>
<%= t('packages.delivery_type') %>
<select name="delivery_type">
<option value="">
<%= t('common.reset') %>
</option>
<option value="pickup">
<%= t('packages.delivery_pickup') %>
</option>
<option value="delivery">
<%= t('packages.delivery_delivery') %>
</option>
</select>
</label>
<label>
<%= t('packages.payment_status') %>
<select name="payment_status">
<option value="pending" selected>
<%= t('packages.payment_pending') %>
</option>
<option value="paid">
<%= t('packages.payment_paid') %>
</option>
</select>
</label>
<label>
<%= t('packages.invoice_status') %>
<select name="invoice_status">
<option value="pending" selected>
<%= t('packages.invoice_pending') %>
</option>
<option value="uploaded">
<%= t('packages.invoice_uploaded') %>
</option>
</select>
</label>
<label>
<%= t('packages.carrier') %>
<input type="text" name="carrier" value="<%= prefillData.carrier || '' %>" />
</label>
<label>
<%= t('packages.tracking') %>
<input type="text" name="tracking_number" required value="<%= prefillData.tracking_number || '' %>" />
</label>
<label>
<%= t('packages.received_at') %>
<input type="date" name="received_at_display" value="<%= prefillData.received_at || '' %>" readonly aria-readonly="true" />
</label>
<label>
<%= t('packages.invoice_file') %>
<input type="file" name="invoice_file" accept="application/pdf,image/*" />
</label>
<label>
<%= t('packages.photos') %>
<div class="package-photo-upload" data-photo-upload data-max-photos="6">
<div class="package-photo-upload__list" data-photo-list>
<input type="file" name="photos" accept="image/*" data-photo-input />
</div>
<button type="button" class="btn small" data-add-photo>Agregar otra foto</button>
<small class="muted" data-photo-count>1 de 6 fotos</small>
</div>
</label>
<label>
<%= t('packages.notes') %>
<textarea name="notes" rows="3">
</textarea>
</label>
<div>
<button type="submit" class="btn primary">
<%= t('packages.create_button') %>
</button>
</div>
</form>
</section>
</main>
<script>
  (function () {
    const form = document.querySelector('form[action="/packages/new"]');
    if (!form) return;
    const weightInput = form.querySelector('[name="weight_lbs"]');
    const lengthInput = form.querySelector('[name="length_cm"]');
    const widthInput = form.querySelector('[name="width_cm"]');
    const heightInput = form.querySelector('[name="height_cm"]');
    const enteredNode = form.querySelector('[data-weight-entered]');
    const volumeNode = form.querySelector('[data-weight-volume]');
    const volumeInput = form.querySelector('[data-weight-volume-input]');
    const readNumber = (input) => {
      const value = Number(input && input.value ? input.value : 0);
      return Number.isFinite(value) && value > 0 ? value : 0;
    };
    const format = (value) => value.toFixed(2);
    const updateWeights = () => {
      const entered = readNumber(weightInput);
      const volume = ((readNumber(lengthInput) * readNumber(widthInput) * readNumber(heightInput)) / 5000) * 2.2046;
      const safeVolume = Number.isFinite(volume) ? volume : 0;
      if (enteredNode) enteredNode.textContent = `${format(entered)} lbs`;
      if (volumeNode) volumeNode.textContent = `${format(safeVolume)} lbs`;
      if (volumeInput) volumeInput.value = format(safeVolume);
    };
    [weightInput, lengthInput, widthInput, heightInput].forEach((input) => {
      if (input) input.addEventListener('input', updateWeights);
    });
    updateWeights();
  })();
  (function () {
    const upload = document.querySelector('[data-photo-upload]');
    if (!upload) return;
    const list = upload.querySelector('[data-photo-list]');
    const addButton = upload.querySelector('[data-add-photo]');
    const countNode = upload.querySelector('[data-photo-count]');
    const maxPhotos = Number(upload.getAttribute('data-max-photos') || 6);
    const updateState = () => {
      const inputs = list ? list.querySelectorAll('input[type="file"][name="photos"]') : [];
      if (countNode) countNode.textContent = `${inputs.length} de ${maxPhotos} fotos`;
      if (addButton) addButton.disabled = inputs.length >= maxPhotos;
    };
    if (addButton && list) {
      addButton.addEventListener('click', () => {
        const current = list.querySelectorAll('input[type="file"][name="photos"]').length;
        if (current >= maxPhotos) return;
        const input = document.createElement('input');
        input.type = 'file';
        input.name = 'photos';
        input.accept = 'image/*';
        input.setAttribute('data-photo-input', '');
        list.appendChild(input);
        updateState();
      });
    }
    updateState();
  })();
</script>
<script src="/status-footer.js" defer></script>
</body>
</html>
