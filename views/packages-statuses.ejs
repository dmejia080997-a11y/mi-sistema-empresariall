<% var currentPackagesNav = typeof packagesNav !== 'undefined' ? packagesNav : 'list'; %>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('packages.module.statuses') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container packages-module">
<div class="page-header">
<div>
<h1>
<%= t('packages.module.statuses') %>
</h1>
<p class="muted">
<%= t('packages.module.statuses_desc') %>
</p>
</div>
<div class="actions">
<a class="btn" href="/packages/home">
<%= t('packages.module.home') %>
</a>
</div>
</div>
<section class="panel">
<div class="panel-header">
<h2>
<%= t('packages.module.statuses') %>
</h2>
</div>
<div class="pill-list">
<% statuses.forEach(status => { %>
<span class="pill">
<%= status %>
</span>
<% }) %>
</div>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
