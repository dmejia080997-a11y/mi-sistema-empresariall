<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('awb.title') %>
</title>
<%- include('partials/head-assets') %>
</head>
<body class="page">
<%- include('partials/header') %>
<main class="container">
<%
const documentTypeLabels = { bl: t('awb.document_type.bl'), awb: t('awb.document_type.awb'), carta_porte: t('awb.document_type.carta_porte') };
const currentFilters = typeof filters !== 'undefined' && filters ? filters : { document_type: 'all', status: 'active' };
%>
<div class="page-header">
<div>
<h1>
<%= t('awb.title') %>
</h1>
<p class="muted">
<%= t('awb.subtitle') %>
</p>
</div>
<div class="actions">
<% if (can('airway_bills', 'create')) { %>
<a class="btn primary" href="/airway-bills/new">
<%= t('awb.new') %>
</a>
<% } %>
</div>
</div>
<% if (error) { %>
<div class="alert error">
<%= error %>
</div>
<% } %>
<% if (success) { %>
<div class="alert success">
<%= success %>
</div>
<% } %>
<section class="panel">
<div class="panel-header">
<h2>
<%= t('awb.list') %>
</h2>
</div>
<form method="GET" action="/airway-bills" class="filters">
<label>
<%= t('awb.document_type') %>
<select name="document_type">
<option value="all" <%= currentFilters.document_type === 'all' ? 'selected' : '' %>><%= t('common.all') %></option>
<option value="bl" <%= currentFilters.document_type === 'bl' ? 'selected' : '' %>><%= t('awb.document_type.bl') %></option>
<option value="awb" <%= currentFilters.document_type === 'awb' ? 'selected' : '' %>><%= t('awb.document_type.awb') %></option>
<option value="carta_porte" <%= currentFilters.document_type === 'carta_porte' ? 'selected' : '' %>><%= t('awb.document_type.carta_porte') %></option>
</select>
</label>
<label>
<%= t('awb.status') %>
<select name="status">
<option value="active" <%= currentFilters.status === 'active' ? 'selected' : '' %>><%= t('awb.status.active') %></option>
<option value="draft" <%= currentFilters.status === 'draft' ? 'selected' : '' %>><%= t('awb.status.draft') %></option>
<option value="issued" <%= currentFilters.status === 'issued' ? 'selected' : '' %>><%= t('awb.status.issued') %></option>
<option value="applied" <%= currentFilters.status === 'applied' ? 'selected' : '' %>><%= t('awb.status.applied') %></option>
<option value="cancelled" <%= currentFilters.status === 'cancelled' ? 'selected' : '' %>><%= t('awb.status.cancelled') %></option>
</select>
</label>
<button class="btn small" type="submit"><%= t('common.filter') %></button>
<a class="btn small" href="/airway-bills"><%= t('common.clear') %></a>
<a class="btn small" href="/airway-bills/applied"><%= t('awb.applied') %></a>
<a class="btn small" href="/airway-bills/cancelled"><%= t('awb.cancelled') %></a>
</form>
<div class="table">
<div class="table-row header awbs">
<div>
<%= t('awb.document_type') %>
</div>
<div>
<%= t('awb.awb_number') %>
</div>
<div>
<%= t('awb.awb_type') %>
</div>
<div>
<%= t('awb.shipper') %>
</div>
<div>
<%= t('awb.consignee') %>
</div>
<div>
<%= t('awb.status') %>
</div>
<div>
<%= t('awb.created_at') %>
</div>
<div>
<%= t('awb.applied_manifest') %>
</div>
<div>
<%= t('awb.actions') %>
</div>
</div>
<% if (!awbs || awbs.length === 0) { %>
<div class="table-row empty awbs">
<%= t('awb.no_awbs') %>
</div>
<% } %>
<% (awbs || []).forEach((awb) => { %>
<div class="table-row awbs">
<div>
<%= documentTypeLabels[awb.document_type || 'awb'] || awb.document_type || '-' %>
</div>
<div>
<%= awb.awb_number || '-' %>
</div>
<div>
<%= awb.awb_type || '-' %>
</div>
<div>
<%= awb.shipper_name || '-' %>
</div>
<div>
<%= awb.consignee_name || '-' %>
</div>
<div>
<span class="status-badge status-<%= awb.status %>">
<%= t(`awb.status.${awb.status || 'draft'}`) %>
</span>
</div>
<div>
<%= awb.created_at || '-' %>
</div>
<div>
<%= awb.applied_manifests || '-' %>
</div>
<div class="actions">
<a class="btn small" href="/airway-bills/<%= awb.id %>">
<%= t('awb.view') %>
</a>
<% if (can('airway_bills', 'edit') && awb.status !== 'cancelled') { %>
<form method="POST" action="/airway-bills/<%= awb.id %>/cancel">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button class="btn small danger" type="submit"><%= t('awb.cancel') %></button>
</form>
<% if (awb.applied_manifests) { %>
<form method="POST" action="/airway-bills/<%= awb.id %>/apply">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button class="btn small" type="submit"><%= t('awb.apply') %></button>
</form>
<% } %>
<% } %>
<% if (can('airway_bills', 'edit')) { %>
<form method="POST" action="/airway-bills/<%= awb.id %>/delete" onsubmit="return confirm('<%= t('awb.delete_confirm') %>');">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<button class="btn small danger" type="submit"><%= t('common.delete') %></button>
</form>
<% } %>
</div>
</div>
<% }) %>
</div>
</section>
</main>
<script src="/status-footer.js" defer></script>
</body>
</html>
