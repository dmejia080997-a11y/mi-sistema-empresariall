<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>
<%= t('customer_portal.change_title') %>
</title>
<link rel="stylesheet" href="/styles.css" />
</head>
<body class="page">
<header class="topbar">
<div class="brand">
<%= t('common.brand') %>
</div>
<nav class="nav">
<a href="/customer/logout">
<%= t('customer_portal.logout') %>
</a>
</nav>
</header>
<main class="container">
<section class="card">
<h1>
<%= t('customer_portal.change_heading') %>
</h1>
<p class="muted">
<%= t('customer_portal.change_subtitle') %>
</p>
<% if (error) { %>
<div class="alert">
<%= error %>
</div>
<% } %>
<form method="POST" action="/customer/change-password" class="form">
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<label>
<%= t('customer_portal.new_password') %>
<div class="password-wrapper">
<input type="password" name="password" data-password-input required />
<button type="button" class="password-toggle" data-password-toggle>
<%= t('common.show') %>
</button>
</div>
</label>
<label>
<%= t('customer_portal.confirm_password') %>
<div class="password-wrapper">
<input type="password" name="confirm_password" data-password-input required />
<button type="button" class="password-toggle" data-password-toggle>
<%= t('common.show') %>
</button>
</div>
</label>
<button type="submit" class="btn primary">
<%= t('customer_portal.change_button') %>
</button>
</form>
</section>
</main>
<script>    (function () {      document.querySelectorAll('[data-password-toggle]').forEach((button) => {        const wrapper = button.closest('.password-wrapper');        const input = wrapper ? wrapper.querySelector('[data-password-input]') : null;        if (!input) return;        button.addEventListener('click', () => {          const isPassword = input.getAttribute('type') === 'password';          input.setAttribute('type', isPassword ? 'text' : 'password');          button.textContent = isPassword ? '<%= t('common.hide') %>' : '<%= t('common.show') %>';        });      });    })();  </script>
<script src="/status-footer.js" defer></script>
</body>
</html>
