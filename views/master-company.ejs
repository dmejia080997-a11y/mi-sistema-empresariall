<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'es' %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Panel Master - <%= company.name || 'Empresa' %></title>
<%- include('partials/head-assets') %>
</head>
<body class="page master-shell-page">
<%- include('partials/header', {
  headerBrandText: 'Panel Master',
  homeHref: '/master',
  showDefaultNav: false,
  headerActionsHtml: `
    <nav class="master-tabs" aria-label="Navegacion Master">
      <a href="/master" class="is-active">Empresas</a>
      <a href="/master/activities">Actividad</a>
    </nav>
    <a href="/master/logout" class="btn app-btn">Cerrar sesion</a>
  `
}) %>

<main class="container company-detail-page">
  <div class="company-detail-hero page-header app-page-header">
    <div class="app-page-header__content">
      <p class="master-eyebrow app-page-eyebrow">Panel master</p>
      <h1><%= company.name || 'Detalle de empresa' %></h1>
      <p class="company-detail-sub muted">Informacion general, configuracion, contactos y usuarios asociados a la empresa.</p>
    </div>
    <div class="company-detail-actions app-page-actions">
      <a href="/master" class="btn app-btn">Volver</a>
      <button type="button" class="btn app-btn" data-company-edit>Editar</button>
      <button type="button" class="btn app-btn" data-company-cancel disabled>Cancelar</button>
      <button type="submit" form="company-detail-form" class="btn primary app-btn app-btn-primary" data-company-save disabled>Guardar</button>
    </div>
  </div>

  <% if (flash && flash.message) { %>
  <div class="alert app-message app-message-<%= flash.type || 'info' %> <%= flash.type || '' %>">
    <%= flash.message %>
  </div>
  <% } %>

  <section class="company-detail-card app-card master-status-panel">
    <div class="app-card-header">
      <div>
        <h2 class="company-detail-section-title">Estado de la empresa</h2>
        <p class="muted">Control operativo y acciones de acceso del espacio empresarial.</p>
      </div>
      <% if (status === 'inactive') { %>
      <span class="company-detail-badge app-badge app-badge-warning">Inactiva</span>
      <% } else if (status === 'expired') { %>
      <span class="company-detail-badge app-badge app-badge-danger">Vencida</span>
      <% } else { %>
      <span class="company-detail-badge app-badge app-badge-success">Activa</span>
      <% } %>
    </div>
    <div class="master-status-grid">
      <div>
        <span class="app-field-caption">ID</span>
        <strong><%= company.id %></strong>
      </div>
      <div>
        <span class="app-field-caption">Usuarios</span>
        <strong><%= usersCount %></strong>
      </div>
      <div>
        <span class="app-field-caption">Activo desde</span>
        <strong><%= company.active_from || '-' %></strong>
      </div>
      <div>
        <span class="app-field-caption">Activo hasta</span>
        <strong><%= company.active_until || '-' %></strong>
      </div>
    </div>
    <div class="actions app-flow-top">
      <form action="/master/companies/<%= company.id %>/enter" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="btn app-btn">Entrar al espacio</button>
      </form>
      <% if (status === 'inactive') { %>
      <form action="/master/companies/<%= company.id %>/reactivate" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="return_to" value="/master/companies/<%= company.id %>" />
        <button class="btn app-btn app-btn-success">Reactivar</button>
      </form>
      <% } else { %>
      <details class="action-details">
        <summary>Anular empresa</summary>
        <form action="/master/companies/<%= company.id %>/deactivate" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="return_to" value="/master/companies/<%= company.id %>" />
          <textarea name="inactive_reason" placeholder="Motivo de anulacion" required></textarea>
          <button class="btn danger app-btn app-btn-danger">Confirmar anulacion</button>
        </form>
      </details>
      <% } %>
    </div>
  </section>

  <form id="company-detail-form" action="/companies/<%= company.id %>/update" method="POST" data-company-form>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <section class="company-detail-card app-card">
      <div class="app-card-header">
        <div>
          <h2 class="company-detail-section-title">Datos generales</h2>
          <p class="muted">Identidad comercial, fiscal y configuracion base.</p>
        </div>
      </div>
      <div class="master-detail-grid">
        <div class="app-field master-readonly-field">
          <span>ID</span>
          <strong><%= company.id %></strong>
        </div>
        <label class="app-field">Nombre
          <input class="company-detail-input" type="text" name="name" value="<%= company.name || '' %>" required readonly data-editable>
        </label>
        <label class="app-field">Nombre legal
          <input class="company-detail-input" type="text" name="legal_name" value="<%= company.legal_name || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Usuario
          <input class="company-detail-input" type="text" name="username" value="<%= company.username || '' %>" required readonly data-editable>
        </label>
        <label class="app-field master-field-wide">Direccion
          <textarea class="company-detail-input app-textarea" name="address" rows="3" readonly data-editable><%= company.address || '' %></textarea>
        </label>
        <label class="app-field master-field-wide">Domicilio fiscal
          <textarea class="company-detail-input app-textarea" name="tax_address" rows="3" readonly data-editable><%= company.tax_address || '' %></textarea>
        </label>
        <label class="app-field">Telefono
          <input class="company-detail-input" type="text" name="phone" value="<%= company.phone || '' %>" readonly data-editable>
        </label>
        <label class="app-field">NIT
          <input class="company-detail-input" type="text" name="nit" value="<%= company.nit || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Empleados
          <input class="company-detail-input" type="number" name="employees" value="<%= company.employees || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Tipo de negocio
          <input class="company-detail-input" type="text" name="business_type" value="<%= company.business_type || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Actividad
          <select class="company-detail-input" name="activity_id" disabled data-editable data-lock="disabled">
            <option value="" disabled <%= !company.activity_id ? 'selected' : '' %>>Selecciona una actividad</option>
            <% (activities || []).forEach(activity => { %>
              <option value="<%= activity.id %>" <%= String(company.activity_id || '') === String(activity.id) ? 'selected' : '' %>>
                <%= activity.name %>
              </option>
            <% }) %>
          </select>
        </label>
        <label class="app-field">Pais
          <input class="company-detail-input" type="text" name="country" value="<%= company.country || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Moneda base
          <input class="company-detail-input" type="text" name="base_currency" value="<%= company.base_currency || company.currency || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Monedas permitidas
          <input class="company-detail-input" type="text" name="allowed_currencies" value="<%= company.allowed_currencies || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Impuesto base
          <input class="company-detail-input" type="number" name="tax_rate" value="<%= company.tax_rate || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Nombre del impuesto
          <input class="company-detail-input" type="text" name="tax_name" value="<%= company.tax_name || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Costeo
          <input class="company-detail-input" type="text" name="costing_method" value="<%= company.costing_method || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Moneda anterior
          <input class="company-detail-input" type="text" name="currency" value="<%= company.currency || '' %>" readonly data-editable>
        </label>
        <label class="app-field">Color primario
          <input class="company-detail-input" type="color" name="primary_color" value="<%= company.primary_color || '#26445f' %>" disabled data-editable data-lock="disabled">
        </label>
        <label class="app-field">Color secundario
          <input class="company-detail-input" type="color" name="secondary_color" value="<%= company.secondary_color || '#247c7a' %>" disabled data-editable data-lock="disabled">
        </label>
        <div class="app-field master-readonly-field">
          <span>Creada</span>
          <strong><%= company.created_at || '-' %></strong>
        </div>
        <label class="app-field">Activo desde
          <input class="company-detail-input" type="date" name="active_from" value="<%= company.active_from ? String(company.active_from).slice(0,10) : '' %>" disabled data-editable data-lock="disabled">
        </label>
        <label class="app-field">Activo hasta
          <input class="company-detail-input" type="date" name="active_until" value="<%= company.active_until ? String(company.active_until).slice(0,10) : '' %>" disabled data-editable data-lock="disabled">
        </label>
      </div>
    </section>

    <section class="company-detail-card app-card">
      <div class="app-card-header">
        <div>
          <h2 class="company-detail-section-title">Contactos</h2>
          <p class="muted">Personas de referencia para contacto general, pagos y operacion.</p>
        </div>
      </div>

      <div class="master-contact-section">
        <h3>Contacto general</h3>
        <div class="master-detail-grid">
          <label class="app-field">Nombre
            <input class="company-detail-input" type="text" name="contact_general_first_name" value="<%= company.contact_general_first_name || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Apellido
            <input class="company-detail-input" type="text" name="contact_general_last_name" value="<%= company.contact_general_last_name || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Telefono
            <input class="company-detail-input" type="text" name="contact_general_phone" value="<%= company.contact_general_phone || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Celular
            <input class="company-detail-input" type="text" name="contact_general_mobile" value="<%= company.contact_general_mobile || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Correo
            <input class="company-detail-input" type="email" name="contact_general_email" value="<%= company.contact_general_email || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Puesto
            <input class="company-detail-input" type="text" name="contact_general_position" value="<%= company.contact_general_position || '' %>" readonly data-editable>
          </label>
        </div>
      </div>

      <div class="master-contact-section">
        <h3>Contacto de pagos</h3>
        <div class="master-detail-grid">
          <label class="app-field">Nombre
            <input class="company-detail-input" type="text" name="contact_payments_first_name" value="<%= company.contact_payments_first_name || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Apellido
            <input class="company-detail-input" type="text" name="contact_payments_last_name" value="<%= company.contact_payments_last_name || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Telefono
            <input class="company-detail-input" type="text" name="contact_payments_phone" value="<%= company.contact_payments_phone || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Celular
            <input class="company-detail-input" type="text" name="contact_payments_mobile" value="<%= company.contact_payments_mobile || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Correo
            <input class="company-detail-input" type="email" name="contact_payments_email" value="<%= company.contact_payments_email || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Puesto
            <input class="company-detail-input" type="text" name="contact_payments_position" value="<%= company.contact_payments_position || '' %>" readonly data-editable>
          </label>
        </div>
      </div>

      <div class="master-contact-section">
        <h3>Contacto operativo</h3>
        <div class="master-detail-grid">
          <label class="app-field">Nombre
            <input class="company-detail-input" type="text" name="contact_ops_first_name" value="<%= company.contact_ops_first_name || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Apellido
            <input class="company-detail-input" type="text" name="contact_ops_last_name" value="<%= company.contact_ops_last_name || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Telefono
            <input class="company-detail-input" type="text" name="contact_ops_phone" value="<%= company.contact_ops_phone || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Celular
            <input class="company-detail-input" type="text" name="contact_ops_mobile" value="<%= company.contact_ops_mobile || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Correo
            <input class="company-detail-input" type="email" name="contact_ops_email" value="<%= company.contact_ops_email || '' %>" readonly data-editable>
          </label>
          <label class="app-field">Puesto
            <input class="company-detail-input" type="text" name="contact_ops_position" value="<%= company.contact_ops_position || '' %>" readonly data-editable>
          </label>
        </div>
      </div>
    </section>
  </form>

  <section class="company-detail-card app-card">
    <div class="app-card-header">
      <div>
        <h2 class="company-detail-section-title">Usuarios</h2>
        <p class="muted">Usuarios creados dentro de la empresa.</p>
      </div>
    </div>
    <div class="app-table-wrap">
      <table class="app-table company-detail-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Rol</th>
            <th>Creado</th>
          </tr>
        </thead>
        <tbody>
          <% if (!users || !users.length) { %>
          <tr>
            <td colspan="4">No hay usuarios registrados.</td>
          </tr>
          <% } %>
          <% (users || []).forEach(user => { %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.username %></td>
            <td><%= user.role %></td>
            <td><%= user.created_at || '-' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="company-detail-card app-card">
    <div class="app-card-header">
      <div>
        <h2 class="company-detail-section-title">Renovar suscripcion</h2>
        <p class="muted">Actualiza la ventana de vigencia sin modificar otros datos.</p>
      </div>
    </div>
    <form action="/master/companies/<%= company.id %>/renew" method="POST" class="app-form-grid app-form-grid-fluid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label class="app-field">
        <span>Activo desde</span>
        <input class="company-detail-input" type="date" name="active_from" value="<%= company.active_from ? String(company.active_from).slice(0,10) : '' %>" required>
      </label>
      <label class="app-field">
        <span>Activo hasta</span>
        <input class="company-detail-input" type="date" name="active_until" value="<%= company.active_until ? String(company.active_until).slice(0,10) : '' %>" required>
      </label>
      <button class="btn app-btn app-btn-secondary">Renovar</button>
    </form>
  </section>

  <section class="company-detail-card app-card">
    <div class="app-card-header">
      <div>
        <h2 class="company-detail-section-title">Historial de anulaciones</h2>
        <p class="muted">Motivos registrados al anular esta empresa.</p>
      </div>
    </div>
    <% if (inactiveNotes && inactiveNotes.length) { %>
      <% inactiveNotes.forEach(note => { %>
        <div class="app-note-card">
          <div class="app-note-meta">
            <%= note.created_at ? new Date(note.created_at).toLocaleString() : '-' %>
          </div>
          <div class="app-prewrap"><%= note.note_text %></div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="app-placeholder">Sin anulaciones registradas.</div>
    <% } %>
  </section>
</main>

<script>
  (function () {
    const form = document.querySelector('[data-company-form]');
    const editBtn = document.querySelector('[data-company-edit]');
    const saveBtn = document.querySelector('[data-company-save]');
    const cancelBtn = document.querySelector('[data-company-cancel]');
    if (!form || !editBtn || !saveBtn || !cancelBtn) return;

    const inputs = Array.from(form.querySelectorAll('[data-editable]'));

    function setEditing(isEditing) {
      inputs.forEach((input) => {
        if (input.dataset.lock === 'disabled') {
          input.disabled = !isEditing;
        } else {
          input.readOnly = !isEditing;
        }
      });
      saveBtn.disabled = !isEditing;
      cancelBtn.disabled = !isEditing;
      editBtn.disabled = isEditing;
    }

    editBtn.addEventListener('click', () => setEditing(true));
    cancelBtn.addEventListener('click', () => {
      form.reset();
      setEditing(false);
    });
  })();
</script>
<script src="/status-footer.js" defer></script>
</body>
</html>
