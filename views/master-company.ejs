<style>
  .company-detail-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 24px 48px;
  }
  .company-detail-hero {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 18px;
    margin-bottom: 18px;
  }
  .company-detail-hero h1 {
    margin: 0 0 6px;
    font-size: 2.1rem;
  }
  .company-detail-sub {
    margin: 0;
    color: #5b6472;
  }
  .company-detail-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .company-detail-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 18px;
    padding: 16px 18px;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.08);
    margin-bottom: 18px;
  }
  .company-detail-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }
  .company-detail-table th,
  .company-detail-table td {
    padding: 8px 10px;
    border-bottom: 1px solid #edf0f4;
    text-align: left;
    vertical-align: top;
    font-size: 0.95rem;
  }
  .company-detail-table th {
    width: 220px;
    color: #3a4453;
    background: #f8fafc;
    font-weight: 600;
  }
  .company-detail-table tr:last-child td,
  .company-detail-table tr:last-child th {
    border-bottom: none;
  }
  .company-detail-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.85rem;
    background: #eef2ff;
    color: #4338ca;
  }
  .company-detail-section-title {
    margin: 0 0 12px;
    font-size: 1.1rem;
  }
  .company-detail-input {
    width: 100%;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    padding: 6px 8px;
    font-family: inherit;
    font-size: 0.95rem;
    background: #ffffff;
    color: inherit;
  }
  .company-detail-input[readonly] {
    border-color: transparent;
    background: transparent;
    padding-left: 0;
    padding-right: 0;
  }
  .company-detail-input[disabled] {
    border-color: transparent;
    background: transparent;
    padding-left: 0;
    padding-right: 0;
    color: inherit;
  }
  .company-detail-actions .btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .alert {
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    color: #1f2937;
    margin: 12px 0;
  }
  .alert.success {
    background: #ecfdf3;
    border-color: #c6f6d5;
    color: #166534;
  }
  .alert.error {
    background: #fff0ed;
    border-color: #f0b3a9;
    color: #8a2a1c;
  }
</style>

<div class="company-detail-page">
<form action="/companies/<%= company.id %>/update" method="POST" data-company-form>
<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
<div class="company-detail-hero">
  <div>
    <h1>Detalle de empresa</h1>
    <p class="company-detail-sub">Informacion general y contactos asociados a la empresa.</p>
  </div>
  <div class="company-detail-actions">
    <a href="/master" class="btn">Volver al master</a>
    <button type="button" class="btn" data-company-edit>Editar</button>
    <button type="button" class="btn" data-company-cancel disabled>Cancelar</button>
    <button type="submit" class="btn primary" data-company-save disabled>Guardar</button>
  </div>
</div>
<% if (flash && flash.message) { %>
<div class="alert <%= flash.type || '' %>">
  <%= flash.message %>
</div>
<% } %>

<div class="company-detail-card">
<h2 class="company-detail-section-title">Estado de la empresa</h2>
<div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
  <span class="company-detail-badge">
    <%= status === 'inactive' ? 'Inactiva' : (status === 'expired' ? 'Vencida' : 'Activa') %>
  </span>
</div>
</div>

