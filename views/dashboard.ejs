<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="csrf-token" content="<%= csrfToken %>" />
<title>
<%= t('launcher.title') %>
</title>
<link rel="stylesheet" href="/styles.css" />
</head>
<body class="page launcher-page" style="<% if (companyBrand) { %>--accent:<%= companyBrand.primary_color || '#d97757' %>; --accent-2:<%= companyBrand.secondary_color || '#3d7b6f' %>;<% } %>">
<header class="topbar">
<a class="brand brand-link" href="/dashboard">
<% if (companyBrand && companyBrand.logo) { %>
<img src="<%= companyBrand.logo %>" alt="Logo" class="brand-logo" />
<% } %>
<span class="brand-name">
<%= (companyBrand && companyBrand.name) ? companyBrand.name : t('common.brand') %>
</span>
</a>
<nav class="nav">
<a href="/logout">
<%= t('nav.logout') %>
</a>
</nav>
</header>
<main class="container launcher">
<section class="widget-panel" data-widget-panel>
<div>
<p class="eyebrow">
<%= t('launcher.widgets_eyebrow') %>
</p>
<h2>
<%= t('launcher.widgets_title') %>
</h2>
<p class="muted">
<%= t('launcher.widgets_subtitle') %>
</p>
</div>
<div class="widget-toggles">
<label class="widget-toggle">
<input type="checkbox" data-widget-toggle="hero" />
<span><%= t('launcher.widgets_hero') %></span>
</label>
<label class="widget-toggle">
<input type="checkbox" data-widget-toggle="notes" />
<span><%= t('launcher.widgets_notes') %></span>
</label>
<label class="widget-toggle">
<input type="checkbox" data-widget-toggle="planner" />
<span><%= t('launcher.widgets_planner') %></span>
</label>
<label class="widget-toggle">
<input type="checkbox" data-widget-toggle="apps" />
<span><%= t('launcher.widgets_apps') %></span>
</label>
</div>
</section>
<section class="widgets-layout" data-widgets-layout>
<section class="launcher-hero widget-card" data-launcher-hero data-widget data-widget-key="hero">
<button class="widget-handle" type="button" data-widget-handle aria-label="<%= t('launcher.widgets_move') %>"></button>
<div>
<p class="eyebrow">
<%= t('launcher.eyebrow') %>
</p>
<h1>
<%= t('launcher.title') %>
</h1>
<p class="muted">
<%= t('launcher.subtitle') %>
</p>
</div>
</section>
<section class="notes-board widget-card" data-notes-board data-widget data-widget-key="notes">
<button class="widget-handle" type="button" data-widget-handle aria-label="<%= t('launcher.widgets_move') %>"></button>
<div class="notes-header">
<div>
<p class="eyebrow">
<%= t('launcher.notes_eyebrow') %>
</p>
<h2>
<%= t('launcher.notes_title') %>
</h2>
<p class="muted">
<%= t('launcher.notes_subtitle') %>
</p>
</div>
<div class="notes-actions">
<button class="btn notes-add" type="button" data-notes-add>
<%= t('launcher.notes_add') %>
</button>
<button class="btn notes-layout" type="button" data-notes-layout-toggle data-label-grid="<%= t('launcher.notes_layout_grid') %>" data-label-vertical="<%= t('launcher.notes_layout_vertical') %>">
</button>
<button class="btn notes-hide" type="button" data-notes-hide>
<%= t('launcher.notes_hide') %>
</button>
</div>
</div>
<div class="notes-collapsed" data-notes-collapsed>
<span><%= t('launcher.notes_hidden') %></span>
<button class="notes-show" type="button" data-notes-show>
<%= t('launcher.notes_show') %>
</button>
</div>
<div class="notes-grid" data-notes-grid></div>
</section>
<section class="planner-board widget-card" data-planner-board data-widget data-widget-key="planner">
<button class="widget-handle" type="button" data-widget-handle aria-label="<%= t('launcher.widgets_move') %>"></button>
<div class="planner-header">
<div>
<p class="eyebrow">
<%= t('launcher.planner_eyebrow') %>
</p>
<h2>
<%= t('launcher.planner_title') %>
</h2>
<p class="muted">
<%= t('launcher.planner_subtitle') %>
</p>
</div>
<div class="planner-actions">
<div class="planner-filter">
<label class="planner-filter-label" for="planner-range-start"><%= t('launcher.planner_range_from') %></label>
<input class="planner-filter-input" type="date" id="planner-range-start" data-planner-range-start />
<label class="planner-filter-label" for="planner-range-end"><%= t('launcher.planner_range_to') %></label>
<input class="planner-filter-input" type="date" id="planner-range-end" data-planner-range-end />
<button class="planner-filter-clear" type="button" data-planner-range-today><%= t('launcher.planner_today') %></button>
</div>
<div class="planner-filter">
<label class="planner-filter-label" for="planner-focus-date"><%= t('launcher.planner_focus_date') %></label>
<input class="planner-filter-input" type="date" id="planner-focus-date" data-planner-focus-date />
</div>
<div class="planner-palette" data-planner-palette>
<span class="planner-palette-label"><%= t('launcher.planner_color') %></span>
<div class="planner-palette-swatches" data-planner-palette-swatches></div>
</div>
<button class="btn planner-history" type="button" data-planner-history-toggle data-label-show="<%= t('launcher.planner_show_history') %>" data-label-hide="<%= t('launcher.planner_hide_history') %>">
</button>
<button class="btn planner-quick-toggle" type="button" data-planner-quick-toggle>
<%= t('launcher.planner_quick_toggle') %>
</button>
</div>
</div>
<div class="planner-quick" data-planner-quick>
<div class="planner-quick-fields">
<label class="planner-filter-label" for="planner-quick-date"><%= t('launcher.planner_quick_date') %></label>
<input class="planner-filter-input" type="date" id="planner-quick-date" data-planner-quick-date />
<label class="planner-filter-label" for="planner-quick-text"><%= t('launcher.planner_quick_text') %></label>
<input class="planner-filter-input planner-quick-text" type="text" id="planner-quick-text" data-planner-quick-text placeholder="<%= t('launcher.planner_quick_placeholder') %>" />
</div>
<div class="planner-quick-actions">
<button class="btn planner-quick-save" type="button" data-planner-quick-save><%= t('launcher.planner_quick_add') %></button>
<button class="planner-quick-cancel" type="button" data-planner-quick-cancel><%= t('launcher.planner_quick_cancel') %></button>
</div>
</div>
<div class="planner-grid" data-planner-grid></div>
</section>
<section class="launcher-grid widget-card" data-launcher-grid data-widget data-widget-key="apps">
<button class="widget-handle" type="button" data-widget-handle aria-label="<%= t('launcher.widgets_move') %>"></button>
<% const modules = Array.isArray(launcherModules) ? launcherModules : []; %>
<% modules.forEach((mod) => { %>
<a class="app-card" href="<%= mod.href %>" style="--app-color:<%= mod.color %>" draggable="<%= mod.alwaysVisible ? 'false' : 'true' %>" data-module-key="<%= mod.key %>" data-always-visible="<%= mod.alwaysVisible ? 'true' : 'false' %>">
<div class="app-icon">
<%- icons[mod.icon || mod.key] || icons.default %>
</div>
<div class="app-meta">
<div class="app-name">
<%= mod.name %>
</div>
</div>
</a>
<% }) %>
</section>
</section>
</main>
<script>
  (function () {
    const grid = document.querySelector('[data-launcher-grid]');
    if (!grid) return;
    const csrf = document.querySelector('meta[name="csrf-token"]');
    let dragging = null;
    let suppressClick = false;
    let lastOrder = null;

    const getCard = (event) => event.target.closest('.app-card[draggable="true"]');
    const getOrder = () =>
      Array.from(grid.querySelectorAll('.app-card[draggable="true"]'))
        .map((card) => card.dataset.moduleKey)
        .filter(Boolean);

    const saveOrder = async (order) => {
      if (!order || order.length === 0) return;
      const payload = JSON.stringify(order);
      if (payload === lastOrder) return;
      lastOrder = payload;
      try {
        await fetch('/launcher/order', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrf ? csrf.getAttribute('content') : ''
          },
          body: JSON.stringify({ order })
        });
      } catch (err) {
        // ignore reorder errors silently
      }
    };

    grid.addEventListener('dragstart', (event) => {
      const card = getCard(event);
      if (!card) return;
      dragging = card;
      card.classList.add('dragging');
      if (event.dataTransfer) {
        event.dataTransfer.effectAllowed = 'move';
        event.dataTransfer.setData('text/plain', card.dataset.moduleKey || '');
      }
    });

    grid.addEventListener('dragend', () => {
      if (!dragging) return;
      dragging.classList.remove('dragging');
      dragging = null;
      suppressClick = true;
      setTimeout(() => {
        suppressClick = false;
      }, 0);
      saveOrder(getOrder());
    });

    grid.addEventListener('dragover', (event) => {
      if (!dragging) return;
      event.preventDefault();
      const target = getCard(event);
      if (!target || target === dragging) return;
      const rect = target.getBoundingClientRect();
      const shouldInsertAfter =
        event.clientY > rect.top + rect.height / 2 ||
        event.clientX > rect.left + rect.width / 2;
      if (shouldInsertAfter) {
        grid.insertBefore(dragging, target.nextSibling);
      } else {
        grid.insertBefore(dragging, target);
      }
    });

    grid.addEventListener('click', (event) => {
      if (!suppressClick) return;
      event.preventDefault();
      event.stopPropagation();
    });
  })();
</script>
<script>
  (function () {
    const layout = document.querySelector('[data-widgets-layout]');
    const notesBoard = document.querySelector('[data-notes-board]');
    const plannerBoard = document.querySelector('[data-planner-board]');
    const hero = document.querySelector('[data-launcher-hero]');
    const gridSection = document.querySelector('[data-launcher-grid]');
    const widgetPanel = document.querySelector('[data-widget-panel]');
    const grid = notesBoard ? notesBoard.querySelector('[data-notes-grid]') : null;
    const addButton = notesBoard ? notesBoard.querySelector('[data-notes-add]') : null;
    const layoutToggle = notesBoard ? notesBoard.querySelector('[data-notes-layout-toggle]') : null;
    const hideButton = notesBoard ? notesBoard.querySelector('[data-notes-hide]') : null;
    const showButton = notesBoard ? notesBoard.querySelector('[data-notes-show]') : null;
    const plannerGrid = plannerBoard ? plannerBoard.querySelector('[data-planner-grid]') : null;
    const plannerRangeStart = plannerBoard ? plannerBoard.querySelector('[data-planner-range-start]') : null;
    const plannerRangeEnd = plannerBoard ? plannerBoard.querySelector('[data-planner-range-end]') : null;
    const plannerRangeToday = plannerBoard ? plannerBoard.querySelector('[data-planner-range-today]') : null;
    const plannerFocusDate = plannerBoard ? plannerBoard.querySelector('[data-planner-focus-date]') : null;
    const plannerHistoryToggle = plannerBoard ? plannerBoard.querySelector('[data-planner-history-toggle]') : null;
    const plannerQuickToggle = plannerBoard ? plannerBoard.querySelector('[data-planner-quick-toggle]') : null;
    const plannerQuickWrap = plannerBoard ? plannerBoard.querySelector('[data-planner-quick]') : null;
    const plannerQuickDate = plannerBoard ? plannerBoard.querySelector('[data-planner-quick-date]') : null;
    const plannerQuickText = plannerBoard ? plannerBoard.querySelector('[data-planner-quick-text]') : null;
    const plannerQuickSave = plannerBoard ? plannerBoard.querySelector('[data-planner-quick-save]') : null;
    const plannerQuickCancel = plannerBoard ? plannerBoard.querySelector('[data-planner-quick-cancel]') : null;
    const plannerPalette = plannerBoard ? plannerBoard.querySelector('[data-planner-palette]') : null;
    const plannerPaletteSwatches = plannerPalette
      ? plannerPalette.querySelector('[data-planner-palette-swatches]')
      : null;
    const widgetInputs = widgetPanel ? widgetPanel.querySelectorAll('[data-widget-toggle]') : [];
    const colors = [];
    const placeholder = "<%= t('launcher.notes_placeholder') %>";
    const csrf = document.querySelector('meta[name="csrf-token"]');
    const allowedWidgets = ['hero', 'notes', 'planner', 'apps'];
    let saveTimer = null;
    let widgetSaveTimer = null;
    let plannerSaveTimer = null;
    let notes = [];
    let plannerEntries = new Map();
    let plannerHistoryEntries = new Map();
    let plannerDays = [];
    let plannerState = null;
    let draggingWidget = null;
    const serverWidgetPrefs = <%- JSON.stringify(widgetPrefs || null) %>;

    const resolvePalette = () => {
      if (!notesBoard) return;
      const style = getComputedStyle(notesBoard);
      for (let i = 1; i <= 6; i += 1) {
        const value = style.getPropertyValue(`--note-${i}`).trim();
        if (value) colors.push(value);
      }
      if (!colors.length) {
        colors.push('#fff07a', '#ff9ad7', '#7de7ff', '#b3ff8f', '#ffb86b', '#c9a3ff');
      }
    };

    resolvePalette();

    const defaultPrefs = {
      order: [...allowedWidgets],
      visibility: { hero: true, notes: true, planner: true, apps: true },
      notesCollapsed: false,
      notesLayout: 'vertical',
      plannerHidePast: false,
      plannerHideBefore: '',
      plannerRangeStart: '',
      plannerRangeEnd: '',
      plannerFocusDate: '',
      plannerColor: '',
      plannerShowHistory: false,
      plannerHistoryMode: 'month',
      plannerHistoryCursor: ''
    };

    const normalizePrefs = (raw) => {
      const next = {
        order: [...defaultPrefs.order],
        visibility: { ...defaultPrefs.visibility },
        notesCollapsed: defaultPrefs.notesCollapsed,
        plannerHidePast: defaultPrefs.plannerHidePast,
        plannerHideBefore: defaultPrefs.plannerHideBefore,
        plannerRangeStart: defaultPrefs.plannerRangeStart,
        plannerRangeEnd: defaultPrefs.plannerRangeEnd,
        plannerFocusDate: defaultPrefs.plannerFocusDate,
        plannerColor: defaultPrefs.plannerColor,
        plannerShowHistory: defaultPrefs.plannerShowHistory,
        plannerHistoryMode: defaultPrefs.plannerHistoryMode,
        plannerHistoryCursor: defaultPrefs.plannerHistoryCursor
      };
      if (!raw || typeof raw !== 'object') return next;
      if (Array.isArray(raw.order)) {
        const unique = [];
        raw.order.forEach((key) => {
          if (!allowedWidgets.includes(key)) return;
          if (unique.includes(key)) return;
          unique.push(key);
        });
        allowedWidgets.forEach((key) => {
          if (!unique.includes(key)) unique.push(key);
        });
        next.order = unique;
      }
      if (raw.visibility && typeof raw.visibility === 'object') {
        allowedWidgets.forEach((key) => {
          if (typeof raw.visibility[key] === 'boolean') next.visibility[key] = raw.visibility[key];
        });
      }
      if (typeof raw.notesCollapsed === 'boolean') next.notesCollapsed = raw.notesCollapsed;
      if (raw.notesLayout === 'grid' || raw.notesLayout === 'vertical') next.notesLayout = raw.notesLayout;
      if (typeof raw.plannerHidePast === 'boolean') next.plannerHidePast = raw.plannerHidePast;
      if (typeof raw.plannerHideBefore === 'string') next.plannerHideBefore = raw.plannerHideBefore;
      if (typeof raw.plannerRangeStart === 'string') next.plannerRangeStart = raw.plannerRangeStart;
      if (typeof raw.plannerRangeEnd === 'string') next.plannerRangeEnd = raw.plannerRangeEnd;
      if (typeof raw.plannerFocusDate === 'string') next.plannerFocusDate = raw.plannerFocusDate;
      if (typeof raw.plannerColor === 'string' && colors.includes(raw.plannerColor)) {
        next.plannerColor = raw.plannerColor;
      }
      if (typeof raw.plannerShowHistory === 'boolean') next.plannerShowHistory = raw.plannerShowHistory;
      if (raw.plannerHistoryMode === 'week' || raw.plannerHistoryMode === 'month' || raw.plannerHistoryMode === 'year') {
        next.plannerHistoryMode = raw.plannerHistoryMode;
      }
      if (typeof raw.plannerHistoryCursor === 'string') next.plannerHistoryCursor = raw.plannerHistoryCursor;
      if (!next.plannerRangeStart && next.plannerHideBefore) next.plannerRangeStart = next.plannerHideBefore;
      return next;
    };

    const prefs = normalizePrefs(serverWidgetPrefs);

    const updateNotesCollapsedState = () => {
      if (!notesBoard) return;
      notesBoard.classList.toggle('is-collapsed', !!prefs.notesCollapsed);
      if (hideButton) hideButton.disabled = !!prefs.notesCollapsed;
      if (showButton) showButton.disabled = !prefs.notesCollapsed;
    };

    const updateNotesLayoutState = () => {
      if (!notesBoard) return;
      notesBoard.classList.toggle('is-vertical', prefs.notesLayout === 'vertical');
      if (!layoutToggle) return;
      const labelGrid = layoutToggle.dataset.labelGrid || 'Grid';
      const labelVertical = layoutToggle.dataset.labelVertical || 'Vertical';
      layoutToggle.textContent = prefs.notesLayout === 'vertical' ? labelGrid : labelVertical;
    };

    const applyOrder = () => {
      if (!layout) return;
      const sections = new Map(
        Array.from(layout.querySelectorAll('[data-widget]')).map((section) => [section.dataset.widgetKey, section])
      );
      prefs.order.forEach((key) => {
        const section = sections.get(key);
        if (section) layout.appendChild(section);
      });
    };

    const applyVisibility = () => {
      if (hero) hero.style.display = prefs.visibility.hero ? '' : 'none';
      if (gridSection) gridSection.style.display = prefs.visibility.apps ? '' : 'none';
      if (notesBoard) {
        notesBoard.style.display = prefs.visibility.notes ? '' : 'none';
        if (prefs.visibility.notes) {
          updateNotesCollapsedState();
          updateNotesLayoutState();
        }
      }
      if (plannerBoard) {
        plannerBoard.style.display = prefs.visibility.planner ? '' : 'none';
      }
      if (widgetInputs && widgetInputs.length) {
        widgetInputs.forEach((input) => {
          const key = input.dataset.widgetToggle;
          if (key && prefs.visibility && typeof prefs.visibility[key] !== 'undefined') {
            input.checked = !!prefs.visibility[key];
          }
        });
      }
    };

    applyOrder();
    applyVisibility();

    const widgetHandles = layout ? layout.querySelectorAll('[data-widget-handle]') : [];
    const getWidgetOrder = () =>
      layout
        ? Array.from(layout.querySelectorAll('[data-widget]'))
            .map((section) => section.dataset.widgetKey)
            .filter((key) => allowedWidgets.includes(key))
        : [...allowedWidgets];

    if (widgetHandles && widgetHandles.length) {
      widgetHandles.forEach((handle) => {
        const card = handle.closest('[data-widget]');
        if (!card) return;
        card.setAttribute('draggable', 'false');
        const release = () => {
          if (card === draggingWidget) return;
          card.classList.remove('drag-ready');
          card.setAttribute('draggable', 'false');
        };
        handle.addEventListener('pointerdown', () => {
          card.setAttribute('draggable', 'true');
          card.classList.add('drag-ready');
        });
        handle.addEventListener('pointerup', release);
        handle.addEventListener('pointerleave', release);
        handle.addEventListener('pointercancel', release);
      });
    }

    if (layout) {
      layout.addEventListener('dragstart', (event) => {
        const card = event.target.closest('[data-widget]');
        if (!card || card.getAttribute('draggable') !== 'true') {
          event.preventDefault();
          return;
        }
        draggingWidget = card;
        card.classList.add('dragging');
        if (event.dataTransfer) {
          event.dataTransfer.effectAllowed = 'move';
          event.dataTransfer.setData('text/plain', card.dataset.widgetKey || '');
        }
      });

      layout.addEventListener('dragend', () => {
        if (!draggingWidget) return;
        draggingWidget.classList.remove('dragging');
        draggingWidget.classList.remove('drag-ready');
        draggingWidget.setAttribute('draggable', 'false');
        draggingWidget = null;
        prefs.order = getWidgetOrder();
        scheduleWidgetSave();
      });

      layout.addEventListener('dragover', (event) => {
        if (!draggingWidget) return;
        event.preventDefault();
        const target = event.target.closest('[data-widget]');
        if (!target || target === draggingWidget) return;
        const rect = target.getBoundingClientRect();
        const shouldInsertAfter = event.clientY > rect.top + rect.height / 2;
        if (shouldInsertAfter) {
          layout.insertBefore(draggingWidget, target.nextSibling);
        } else {
          layout.insertBefore(draggingWidget, target);
        }
      });
    }

    const scheduleWidgetSave = () => {
      if (widgetSaveTimer) clearTimeout(widgetSaveTimer);
      widgetSaveTimer = setTimeout(() => {
        saveWidgetPrefs();
      }, 400);
    };

    const saveWidgetPrefs = async () => {
      const payload = {
        order: Array.isArray(prefs.order) ? prefs.order : [...allowedWidgets],
        visibility: { ...prefs.visibility },
        notesCollapsed: !!prefs.notesCollapsed,
        notesLayout: prefs.notesLayout === 'vertical' ? 'vertical' : 'grid',
        plannerHidePast: !!prefs.plannerHidePast,
        plannerHideBefore: prefs.plannerHideBefore || '',
        plannerRangeStart: prefs.plannerRangeStart || '',
        plannerRangeEnd: prefs.plannerRangeEnd || '',
        plannerFocusDate: prefs.plannerFocusDate || '',
        plannerColor: prefs.plannerColor || '',
        plannerShowHistory: !!prefs.plannerShowHistory,
        plannerHistoryMode: prefs.plannerHistoryMode || 'month',
        plannerHistoryCursor: prefs.plannerHistoryCursor || ''
      };
      try {
        await fetch('/launcher/widgets', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrf ? csrf.getAttribute('content') : ''
          },
          body: JSON.stringify({ prefs: payload })
        });
      } catch (err) {
        // ignore save errors
      }
    };

    if (widgetInputs && widgetInputs.length) {
      widgetInputs.forEach((input) => {
        input.addEventListener('change', () => {
          const key = input.dataset.widgetToggle;
          if (!key) return;
          prefs.visibility[key] = !!input.checked;
          applyVisibility();
          scheduleWidgetSave();
        });
      });
    }

    if (hideButton) {
      hideButton.addEventListener('click', () => {
        prefs.notesCollapsed = true;
        updateNotesCollapsedState();
        scheduleWidgetSave();
      });
    }

    if (layoutToggle) {
      layoutToggle.addEventListener('click', () => {
        prefs.notesLayout = prefs.notesLayout === 'vertical' ? 'grid' : 'vertical';
        updateNotesLayoutState();
        scheduleWidgetSave();
      });
    }

    if (showButton) {
      showButton.addEventListener('click', () => {
        prefs.notesCollapsed = false;
        updateNotesCollapsedState();
        scheduleWidgetSave();
      });
    }

    const normalizeRange = () => {
      if (prefs.plannerRangeStart && prefs.plannerRangeEnd && prefs.plannerRangeEnd < prefs.plannerRangeStart) {
        const temp = prefs.plannerRangeStart;
        prefs.plannerRangeStart = prefs.plannerRangeEnd;
        prefs.plannerRangeEnd = temp;
      }
      if (plannerRangeStart) plannerRangeStart.value = prefs.plannerRangeStart || '';
      if (plannerRangeEnd) plannerRangeEnd.value = prefs.plannerRangeEnd || '';
    };

    if (plannerRangeStart) {
      plannerRangeStart.addEventListener('change', () => {
        prefs.plannerRangeStart = plannerRangeStart.value || '';
        normalizeRange();
        loadPlanner();
        scheduleWidgetSave();
      });
    }

    if (plannerRangeEnd) {
      plannerRangeEnd.addEventListener('change', () => {
        prefs.plannerRangeEnd = plannerRangeEnd.value || '';
        normalizeRange();
        loadPlanner();
        scheduleWidgetSave();
      });
    }

    if (plannerRangeToday) {
      plannerRangeToday.addEventListener('click', () => {
        const todayIso = toIsoDate(new Date());
        prefs.plannerRangeStart = todayIso;
        prefs.plannerRangeEnd = todayIso;
        prefs.plannerFocusDate = todayIso;
        normalizeRange();
        loadPlanner();
        scheduleWidgetSave();
      });
    }

    if (plannerFocusDate) {
      plannerFocusDate.addEventListener('change', () => {
        const nextFocus = plannerFocusDate.value || '';
        prefs.plannerFocusDate = nextFocus;
        if (nextFocus) {
          if (!prefs.plannerRangeStart || !prefs.plannerRangeEnd || nextFocus < prefs.plannerRangeStart || nextFocus > prefs.plannerRangeEnd) {
            prefs.plannerRangeStart = nextFocus;
            prefs.plannerRangeEnd = nextFocus;
            normalizeRange();
          }
        }
        loadPlanner();
        scheduleWidgetSave();
      });
    }

    if (plannerHistoryToggle) {
      plannerHistoryToggle.addEventListener('click', () => {
        prefs.plannerShowHistory = !prefs.plannerShowHistory;
        loadPlanner();
        scheduleWidgetSave();
      });
    }

    const setQuickOpen = (nextOpen) => {
      if (!plannerQuickWrap) return;
      plannerQuickWrap.classList.toggle('is-open', !!nextOpen);
      if (plannerQuickToggle) {
        plannerQuickToggle.classList.toggle('is-active', !!nextOpen);
      }
    };

    if (plannerQuickToggle) {
      plannerQuickToggle.addEventListener('click', () => {
        const isOpen = plannerQuickWrap && plannerQuickWrap.classList.contains('is-open');
        setQuickOpen(!isOpen);
        if (plannerQuickText && !isOpen) {
          plannerQuickText.focus();
        }
      });
    }

    if (plannerQuickCancel) {
      plannerQuickCancel.addEventListener('click', () => {
        setQuickOpen(false);
      });
    }

    const getPlannerColor = () => (prefs.plannerColor && colors.includes(prefs.plannerColor) ? prefs.plannerColor : '');

    const renderPlannerPalette = () => {
      if (!plannerPaletteSwatches || !colors.length) return;
      plannerPaletteSwatches.innerHTML = '';
      const active = getPlannerColor();
      colors.forEach((color) => {
        const swatch = document.createElement('button');
        swatch.type = 'button';
        swatch.className = 'planner-swatch';
        if (color === active) swatch.classList.add('is-active');
        swatch.style.setProperty('--swatch-color', color);
        swatch.addEventListener('click', () => {
          prefs.plannerColor = color;
          renderPlannerPalette();
          renderPlanner(plannerState);
          renderPlannerHistory(plannerState);
          scheduleWidgetSave();
        });
        plannerPaletteSwatches.appendChild(swatch);
      });
    };

    if (plannerQuickSave) {
      plannerQuickSave.addEventListener('click', () => {
        if (!plannerQuickText) return;
        const text = (plannerQuickText.value || '').trim();
        if (!text) return;
        const todayIso = toIsoDate(new Date());
        const dateValue = plannerQuickDate && plannerQuickDate.value ? plannerQuickDate.value : todayIso;
        if (!isIsoDateString(dateValue)) return;
        const items = Array.isArray(plannerEntries.get(dateValue)) ? plannerEntries.get(dateValue) : [];
        items.push({ id: createId(), text, done: false });
        plannerEntries.set(dateValue, sortPlannerItems(items));
        prefs.plannerFocusDate = dateValue;
        if (!prefs.plannerRangeStart || !prefs.plannerRangeEnd || dateValue < prefs.plannerRangeStart || dateValue > prefs.plannerRangeEnd) {
          prefs.plannerRangeStart = dateValue;
          prefs.plannerRangeEnd = dateValue;
          normalizeRange();
        }
        const state = buildPlannerState();
        plannerState = state;
        renderPlanner(state);
        renderPlannerHistory(state);
        schedulePlannerSave();
        scheduleWidgetSave();
        plannerQuickText.value = '';
        setQuickOpen(false);
      });
    }

    if (layout) {
      let pressTimer = null;
      let pressTarget = null;
      let pressHandled = false;

      const clearPress = () => {
        if (pressTimer) clearTimeout(pressTimer);
        pressTimer = null;
        pressTarget = null;
        pressHandled = false;
      };

      const enableDrag = (section) => {
        if (!section) return;
        section.setAttribute('draggable', 'true');
        section.classList.add('drag-ready');
      };

      const disableDrag = (section) => {
        if (!section) return;
        section.removeAttribute('draggable');
        section.classList.remove('drag-ready');
      };

      layout.addEventListener('pointerdown', (event) => {
        if (event.button !== 0) return;
        const section = event.target.closest('[data-widget]');
        if (!section) return;
        const handle = event.target.closest('[data-widget-handle]');
        if (handle) {
          pressTarget = section;
          pressHandled = true;
          enableDrag(section);
          return;
        }
        if (event.target.closest('input, textarea, button, select, option, a, [contenteditable="true"]')) return;
        pressTarget = section;
        pressHandled = false;
        pressTimer = setTimeout(() => {
          enableDrag(section);
          pressHandled = true;
        }, 350);
      });

      layout.addEventListener('pointerup', () => {
        if (pressTarget && !draggingWidget) disableDrag(pressTarget);
        clearPress();
      });

      layout.addEventListener('pointercancel', () => {
        if (pressTarget && !draggingWidget) disableDrag(pressTarget);
        clearPress();
      });

      layout.addEventListener('dragstart', (event) => {
        const section = event.target.closest('[data-widget]');
        if (!section) return;
        if (!section.hasAttribute('draggable')) return;
        draggingWidget = section;
        section.classList.add('dragging');
        if (event.dataTransfer) {
          event.dataTransfer.effectAllowed = 'move';
          event.dataTransfer.setData('text/plain', section.dataset.widgetKey || '');
        }
      });

      layout.addEventListener('dragend', () => {
        if (!draggingWidget) return;
        draggingWidget.classList.remove('dragging');
        disableDrag(draggingWidget);
        draggingWidget = null;
        prefs.order = Array.from(layout.querySelectorAll('[data-widget]'))
          .map((section) => section.dataset.widgetKey)
          .filter((key) => allowedWidgets.includes(key));
        scheduleWidgetSave();
      });

      layout.addEventListener('dragover', (event) => {
        if (!draggingWidget) return;
        event.preventDefault();
        const target = event.target.closest('[data-widget]');
        if (!target || target === draggingWidget) return;
        const rect = target.getBoundingClientRect();
        const shouldInsertAfter =
          event.clientY > rect.top + rect.height / 2 ||
          event.clientX > rect.left + rect.width / 2;
        if (shouldInsertAfter) {
          layout.insertBefore(draggingWidget, target.nextSibling);
        } else {
          layout.insertBefore(draggingWidget, target);
        }
      });
    }

    const createId = () => `${Date.now()}-${Math.random().toString(16).slice(2)}`;

    const createNote = (note) => {
      const card = document.createElement('div');
      card.className = 'note-card';
      card.style.setProperty('--note-color', note.color || colors[0]);

      const actions = document.createElement('div');
      actions.className = 'note-actions';

      const palette = document.createElement('div');
      palette.className = 'note-palette';
      colors.forEach((color) => {
        const swatch = document.createElement('button');
        swatch.type = 'button';
        swatch.className = 'note-swatch';
        swatch.style.setProperty('--swatch-color', color);
        swatch.addEventListener('click', () => {
          note.color = color;
          card.style.setProperty('--note-color', color);
          scheduleSave();
        });
        palette.appendChild(swatch);
      });

      const removeButton = document.createElement('button');
      removeButton.type = 'button';
      removeButton.className = 'note-delete';
      removeButton.textContent = "<%= t('launcher.notes_delete') %>";
      removeButton.addEventListener('click', () => {
        notes = notes.filter((item) => item.id !== note.id);
        renderNotes();
        scheduleSave();
      });

      actions.appendChild(palette);
      actions.appendChild(removeButton);

      const textarea = document.createElement('textarea');
      textarea.className = 'note-text';
      textarea.placeholder = placeholder;
      textarea.value = note.text || '';
      textarea.addEventListener('input', (event) => {
        note.text = event.target.value;
        scheduleSave();
      });

      card.appendChild(actions);
      card.appendChild(textarea);
      return card;
    };

    const renderNotes = () => {
      if (!grid) return;
      grid.innerHTML = '';
      if (notes.length === 0) notes.push({ id: createId(), text: '', color: colors[0] });
      notes.forEach((note) => grid.appendChild(createNote(note)));
    };

    if (addButton) {
      addButton.addEventListener('click', () => {
        const nextColor = colors[notes.length % colors.length];
        const note = { id: createId(), text: '', color: nextColor };
        notes.unshift(note);
        renderNotes();
        scheduleSave();
        const firstTextarea = grid.querySelector('.note-text');
        if (firstTextarea) firstTextarea.focus();
      });
    }

    const scheduleSave = () => {
      if (saveTimer) clearTimeout(saveTimer);
      saveTimer = setTimeout(() => {
        persistNotes();
      }, 600);
    };

    const persistNotes = async () => {
      const payload = notes.map((note, index) => ({
        id: note.id,
        text: note.text || '',
        color: note.color || colors[0],
        position: index
      }));
      try {
        await fetch('/launcher/notes', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrf ? csrf.getAttribute('content') : ''
          },
          body: JSON.stringify({ notes: payload })
        });
      } catch (err) {
        // ignore save errors
      }
    };

    const loadNotes = async () => {
      try {
        const resp = await fetch('/launcher/notes', {
          headers: { 'Accept': 'application/json' }
        });
        if (!resp.ok) throw new Error('Failed to load');
        const data = await resp.json();
        if (data && Array.isArray(data.notes)) {
          notes = data.notes.map((note, idx) => ({
            id: note.id || createId(),
            text: note.text || '',
            color: note.color || colors[idx % colors.length]
          }));
        }
      } catch (err) {
        notes = [];
      }
      renderNotes();
    };

    const padNumber = (value) => String(value).padStart(2, '0');

    const toIsoDate = (date) =>
      `${date.getFullYear()}-${padNumber(date.getMonth() + 1)}-${padNumber(date.getDate())}`;

    const toDayStart = (date) => new Date(date.getFullYear(), date.getMonth(), date.getDate());

    const addDays = (date, amount) => {
      const next = new Date(date);
      next.setDate(next.getDate() + amount);
      return next;
    };

    const getWeekStart = (date) => {
      const base = toDayStart(date);
      const day = (base.getDay() + 6) % 7;
      base.setDate(base.getDate() - day);
      return base;
    };

    const isIsoDateString = (value) => /^\d{4}-\d{2}-\d{2}$/.test(value || '');
    const clampDate = (date) => new Date(date.getFullYear(), date.getMonth(), date.getDate());

    const getHistoryCursorDate = () => {
      if (isIsoDateString(prefs.plannerHistoryCursor)) {
        return clampDate(new Date(`${prefs.plannerHistoryCursor}T00:00:00`));
      }
      const today = clampDate(new Date());
      prefs.plannerHistoryCursor = toIsoDate(today);
      return today;
    };

    const getHistoryRange = () => {
      const cursor = getHistoryCursorDate();
      const mode = prefs.plannerHistoryMode || 'month';
      let start = cursor;
      let end = cursor;
      if (mode === 'week') {
        start = getWeekStart(cursor);
        end = addDays(start, 6);
      } else if (mode === 'month') {
        start = new Date(cursor.getFullYear(), cursor.getMonth(), 1);
        end = new Date(cursor.getFullYear(), cursor.getMonth() + 1, 0);
      } else {
        start = new Date(cursor.getFullYear(), 0, 1);
        end = new Date(cursor.getFullYear(), 11, 31);
      }
      return { mode, cursor, start: clampDate(start), end: clampDate(end) };
    };

    const buildPlannerState = () => {
      const locale = document.documentElement.lang || 'es';
      const dayFormatter = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'short' });
      const rangeFormatter = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'short' });
      const today = toDayStart(new Date());
      const focusDate = isIsoDateString(prefs.plannerFocusDate)
        ? toDayStart(new Date(`${prefs.plannerFocusDate}T00:00:00`))
        : today;
      const weekStart = getWeekStart(focusDate);
      const historyWeeks = prefs.plannerShowHistory ? 4 : 0;
      const startIndex = 0 - historyWeeks;
      const endIndex = 1;
      const weekLabels = {
        current: "<%= t('launcher.planner_week_current') %>",
        next: "<%= t('launcher.planner_week_next') %>",
        history: "<%= t('launcher.planner_week_history') %>"
      };
      const weeks = [];
      for (let index = startIndex; index <= endIndex; index += 1) {
        const start = addDays(weekStart, index * 7);
        const end = addDays(start, 6);
        const label =
          index === 0
            ? weekLabels.current
            : index === 1
              ? weekLabels.next
              : weekLabels.history;
        weeks.push({
          index,
          start,
          end,
          label,
          range: `${rangeFormatter.format(start)} - ${rangeFormatter.format(end)}`
        });
      }
      const days = [];
      weeks.forEach((week) => {
        for (let i = 0; i < 7; i += 1) {
          const date = addDays(week.start, i);
          const iso = toIsoDate(date);
          const rangeStart = prefs.plannerRangeStart && isIsoDateString(prefs.plannerRangeStart)
            ? toDayStart(new Date(`${prefs.plannerRangeStart}T00:00:00`))
            : null;
          const rangeEnd = prefs.plannerRangeEnd && isIsoDateString(prefs.plannerRangeEnd)
            ? toDayStart(new Date(`${prefs.plannerRangeEnd}T00:00:00`))
            : null;
          const isOutOfRange =
            (rangeStart && date < rangeStart) ||
            (rangeEnd && date > rangeEnd);
          days.push({
            weekIndex: week.index,
            date,
            iso,
            label: dayFormatter.format(date),
            isToday: iso === toIsoDate(today),
            isPast: date < today,
            isHidden: isOutOfRange
          });
        }
      });
      return {
        weeks,
        days,
        startDate: toIsoDate(addDays(weekStart, startIndex * 7)),
        endDate: toIsoDate(addDays(weekStart, (endIndex * 7) + 6))
      };
    };

    const setPlannerToggleLabel = () => {
      if (!plannerHistoryToggle) return;
      const labelShow = plannerHistoryToggle.dataset.labelShow || 'Show history';
      const labelHide = plannerHistoryToggle.dataset.labelHide || 'Hide history';
      plannerHistoryToggle.textContent = prefs.plannerShowHistory ? labelHide : labelShow;
    };

    const sortPlannerItems = (items) =>
      [...(Array.isArray(items) ? items : [])].sort((a, b) => {
        const aDone = a && a.done ? 1 : 0;
        const bDone = b && b.done ? 1 : 0;
        if (aDone !== bDone) return aDone - bDone;
        return 0;
      });

    const renderPlanner = (state) => {
      if (!plannerGrid || !state) return;
      plannerState = state;
      plannerDays = state.days;
      setPlannerToggleLabel();
      if (plannerRangeStart) plannerRangeStart.value = prefs.plannerRangeStart || '';
      if (plannerRangeEnd) plannerRangeEnd.value = prefs.plannerRangeEnd || '';
      if (plannerFocusDate) plannerFocusDate.value = prefs.plannerFocusDate || '';
      plannerGrid.innerHTML = '';
      const fragment = document.createDocumentFragment();
      const placeholder = "<%= t('launcher.planner_day_placeholder') %>";
      const selectedColor = getPlannerColor();

      state.weeks.forEach((week) => {
        const weekWrap = document.createElement('div');
        weekWrap.className = 'planner-week';

        const header = document.createElement('div');
        header.className = 'planner-week-header';

        const title = document.createElement('div');
        title.className = 'planner-week-title';
        title.textContent = week.label || '';

        const range = document.createElement('div');
        range.className = 'planner-week-range';
        range.textContent = week.range || '';

        header.appendChild(title);
        header.appendChild(range);
        weekWrap.appendChild(header);

        const daysWrap = document.createElement('div');
        daysWrap.className = 'planner-days';

        const weekDays = plannerDays.filter((day) => day.weekIndex === week.index);
        weekDays.forEach((day, dayIndex) => {
            const card = document.createElement('div');
            card.className = 'planner-day';
            if (day.isToday) card.classList.add('is-today');
            if (day.isHidden) card.classList.add('is-hidden');
            if (selectedColor) {
              card.style.setProperty('--planner-note', selectedColor);
            } else if (colors.length) {
              card.style.setProperty('--planner-note', colors[dayIndex % colors.length]);
            }

            const label = document.createElement('div');
            label.className = 'planner-day-label';
            label.textContent = day.label || '';

            const list = document.createElement('div');
            list.className = 'planner-list';

            const items = sortPlannerItems(plannerEntries.get(day.iso));
            plannerEntries.set(day.iso, items);

            items.forEach((item) => {
              const row = document.createElement('div');
              row.className = 'planner-item';

              const checkbox = document.createElement('input');
              checkbox.type = 'checkbox';
              checkbox.className = 'planner-item-check';
              checkbox.checked = !!item.done;
              checkbox.disabled = day.isHidden;
              checkbox.addEventListener('change', (event) => {
                item.done = !!event.target.checked;
                plannerEntries.set(day.iso, sortPlannerItems(items));
                renderPlanner(plannerState);
                schedulePlannerSave();
              });

              const input = document.createElement('input');
              input.type = 'text';
              input.className = 'planner-item-input';
              input.placeholder = placeholder;
              input.value = item.text || '';
              input.disabled = day.isHidden;
              input.addEventListener('input', (event) => {
                item.text = event.target.value;
                schedulePlannerSave();
              });

              const remove = document.createElement('button');
              remove.type = 'button';
              remove.className = 'planner-item-remove';
              remove.textContent = "<%= t('launcher.planner_item_remove') %>";
              remove.disabled = day.isHidden;
              remove.addEventListener('click', () => {
                const nextItems = items.filter((entry) => entry.id !== item.id);
                plannerEntries.set(day.iso, sortPlannerItems(nextItems));
                renderPlanner(plannerState);
                schedulePlannerSave();
              });

              row.appendChild(checkbox);
              row.appendChild(input);
              row.appendChild(remove);
              list.appendChild(row);
            });

            const addRow = document.createElement('button');
            addRow.type = 'button';
            addRow.className = 'planner-item-add';
            addRow.textContent = "<%= t('launcher.planner_item_add') %>";
            addRow.disabled = day.isHidden;
            addRow.addEventListener('click', () => {
              const nextItems = Array.isArray(plannerEntries.get(day.iso))
                ? plannerEntries.get(day.iso)
                : [];
              nextItems.push({ id: createId(), text: '', done: false });
              plannerEntries.set(day.iso, sortPlannerItems(nextItems));
              renderPlanner(plannerState);
            });

            card.appendChild(label);
            card.appendChild(list);
            card.appendChild(addRow);
            daysWrap.appendChild(card);
          });

        weekWrap.appendChild(daysWrap);
        fragment.appendChild(weekWrap);
      });

      plannerGrid.appendChild(fragment);
    };

    const renderPlannerHistory = (state) => {
      if (!plannerGrid || !state || !prefs.plannerShowHistory) return;
      const historyWrap = document.createElement('div');
      historyWrap.className = 'planner-history';
      const selectedColor = getPlannerColor();

      const historyHeader = document.createElement('div');
      historyHeader.className = 'planner-history-header';

      const title = document.createElement('div');
      title.className = 'planner-history-title';
      title.textContent = "<%= t('launcher.planner_history_title') %>";

      const controls = document.createElement('div');
      controls.className = 'planner-history-controls';

      const prevBtn = document.createElement('button');
      prevBtn.type = 'button';
      prevBtn.className = 'planner-history-nav';
      prevBtn.textContent = "<%= t('launcher.planner_history_prev') %>";

      const nextBtn = document.createElement('button');
      nextBtn.type = 'button';
      nextBtn.className = 'planner-history-nav';
      nextBtn.textContent = "<%= t('launcher.planner_history_next') %>";

      const modeSelect = document.createElement('select');
      modeSelect.className = 'planner-history-select';
      modeSelect.innerHTML = `
        <option value="week"><%= t('launcher.planner_history_mode_week') %></option>
        <option value="month"><%= t('launcher.planner_history_mode_month') %></option>
        <option value="year"><%= t('launcher.planner_history_mode_year') %></option>
      `;
      modeSelect.value = prefs.plannerHistoryMode || 'month';

      const rangeLabel = document.createElement('div');
      rangeLabel.className = 'planner-history-range';

      const historyRange = getHistoryRange();
      const rangeFormatter = new Intl.DateTimeFormat(document.documentElement.lang || 'es', { day: 'numeric', month: 'short', year: 'numeric' });
      rangeLabel.textContent = `${rangeFormatter.format(historyRange.start)} - ${rangeFormatter.format(historyRange.end)}`;

      prevBtn.addEventListener('click', () => {
        const range = getHistoryRange();
        const cursor = range.cursor;
        if (range.mode === 'week') {
          prefs.plannerHistoryCursor = toIsoDate(addDays(cursor, -7));
        } else if (range.mode === 'month') {
          prefs.plannerHistoryCursor = toIsoDate(new Date(cursor.getFullYear(), cursor.getMonth() - 1, 1));
        } else {
          prefs.plannerHistoryCursor = toIsoDate(new Date(cursor.getFullYear() - 1, 0, 1));
        }
        loadPlanner();
        scheduleWidgetSave();
      });

      nextBtn.addEventListener('click', () => {
        const range = getHistoryRange();
        const cursor = range.cursor;
        if (range.mode === 'week') {
          prefs.plannerHistoryCursor = toIsoDate(addDays(cursor, 7));
        } else if (range.mode === 'month') {
          prefs.plannerHistoryCursor = toIsoDate(new Date(cursor.getFullYear(), cursor.getMonth() + 1, 1));
        } else {
          prefs.plannerHistoryCursor = toIsoDate(new Date(cursor.getFullYear() + 1, 0, 1));
        }
        loadPlanner();
        scheduleWidgetSave();
      });

      modeSelect.addEventListener('change', () => {
        prefs.plannerHistoryMode = modeSelect.value;
        loadPlanner();
        scheduleWidgetSave();
      });

      historyHeader.appendChild(title);
      controls.appendChild(prevBtn);
      controls.appendChild(rangeLabel);
      controls.appendChild(nextBtn);
      controls.appendChild(modeSelect);
      historyHeader.appendChild(controls);
      historyWrap.appendChild(historyHeader);

      const weeksMap = new Map();
      plannerHistoryEntries.forEach((items, dateIso) => {
        if (!isIsoDateString(dateIso)) return;
        const date = toDayStart(new Date(`${dateIso}T00:00:00`));
        const weekStart = getWeekStart(date);
        const weekKey = toIsoDate(weekStart);
        if (!weeksMap.has(weekKey)) {
          weeksMap.set(weekKey, {
            start: weekStart,
            end: addDays(weekStart, 6),
            days: new Map()
          });
        }
        weeksMap.get(weekKey).days.set(dateIso, items);
      });

      const dayFormatter = new Intl.DateTimeFormat(document.documentElement.lang || 'es', { weekday: 'short', day: 'numeric', month: 'short' });

      Array.from(weeksMap.values())
        .sort((a, b) => a.start - b.start)
        .forEach((week) => {
          const weekWrap = document.createElement('div');
          weekWrap.className = 'planner-week planner-week-history';

          const header = document.createElement('div');
          header.className = 'planner-week-header';

          const titleEl = document.createElement('div');
          titleEl.className = 'planner-week-title';
          titleEl.textContent = "<%= t('launcher.planner_week_history') %>";

          const range = document.createElement('div');
          range.className = 'planner-week-range';
          range.textContent = `${new Intl.DateTimeFormat(document.documentElement.lang || 'es', { day: 'numeric', month: 'short' }).format(week.start)} - ${new Intl.DateTimeFormat(document.documentElement.lang || 'es', { day: 'numeric', month: 'short' }).format(week.end)}`;

          header.appendChild(titleEl);
          header.appendChild(range);
          weekWrap.appendChild(header);

          const daysWrap = document.createElement('div');
          daysWrap.className = 'planner-days';

          Array.from(week.days.entries())
            .sort((a, b) => a[0].localeCompare(b[0]))
            .forEach(([dateIso, items], dayIndex) => {
              const card = document.createElement('div');
              card.className = 'planner-day';
              if (selectedColor) {
                card.style.setProperty('--planner-note', selectedColor);
              } else if (colors.length) {
                card.style.setProperty('--planner-note', colors[dayIndex % colors.length]);
              }

              const label = document.createElement('div');
              label.className = 'planner-day-label';
              label.textContent = dayFormatter.format(new Date(`${dateIso}T00:00:00`));

              const list = document.createElement('div');
              list.className = 'planner-list';

              sortPlannerItems(items).forEach((item) => {
                const row = document.createElement('div');
                row.className = 'planner-item';

                const checkbox = document.createElement('input');
                checkbox.type = 'checkbox';
                checkbox.className = 'planner-item-check';
                checkbox.checked = !!item.done;
                checkbox.addEventListener('change', (event) => {
                  item.done = !!event.target.checked;
                  plannerHistoryEntries.set(dateIso, sortPlannerItems(items));
                  renderPlannerHistory(state);
                  schedulePlannerSave();
                });

                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'planner-item-input';
                input.placeholder = placeholder;
                input.value = item.text || '';
                input.addEventListener('input', (event) => {
                  item.text = event.target.value;
                  schedulePlannerSave();
                });

                const remove = document.createElement('button');
                remove.type = 'button';
                remove.className = 'planner-item-remove';
                remove.textContent = "<%= t('launcher.planner_item_remove') %>";
                remove.addEventListener('click', () => {
                  const nextItems = items.filter((entry) => entry.id !== item.id);
                  plannerHistoryEntries.set(dateIso, sortPlannerItems(nextItems));
                  renderPlannerHistory(state);
                  schedulePlannerSave();
                });

                row.appendChild(checkbox);
                row.appendChild(input);
                row.appendChild(remove);
                list.appendChild(row);
              });

              const addRow = document.createElement('button');
              addRow.type = 'button';
              addRow.className = 'planner-item-add';
              addRow.textContent = "<%= t('launcher.planner_item_add') %>";
              addRow.addEventListener('click', () => {
                const nextItems = Array.isArray(plannerHistoryEntries.get(dateIso))
                  ? plannerHistoryEntries.get(dateIso)
                  : [];
                nextItems.push({ id: createId(), text: '', done: false });
                plannerHistoryEntries.set(dateIso, sortPlannerItems(nextItems));
                renderPlannerHistory(state);
              });

              card.appendChild(label);
              card.appendChild(list);
              card.appendChild(addRow);
              daysWrap.appendChild(card);
            });

          weekWrap.appendChild(daysWrap);
          historyWrap.appendChild(weekWrap);
        });

      plannerGrid.appendChild(historyWrap);
    };

    const schedulePlannerSave = () => {
      if (plannerSaveTimer) clearTimeout(plannerSaveTimer);
      plannerSaveTimer = setTimeout(() => {
        persistPlanner();
      }, 600);
    };

    const persistPlanner = async () => {
      if (!plannerDays.length) return;
      const payload = [];
      plannerDays.forEach((day) => {
        payload.push({
          date: day.iso,
          items: Array.isArray(plannerEntries.get(day.iso))
            ? plannerEntries.get(day.iso)
            : []
        });
      });
      plannerHistoryEntries.forEach((items, dateIso) => {
        if (!plannerEntries.has(dateIso)) {
          payload.push({ date: dateIso, items: Array.isArray(items) ? items : [] });
        }
      });
      try {
        await fetch('/launcher/planner', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrf ? csrf.getAttribute('content') : ''
          },
          body: JSON.stringify({ entries: payload })
        });
      } catch (err) {
        // ignore save errors
      }
    };

    const loadPlanner = async () => {
      if (!plannerGrid) return;
      const todayIso = toIsoDate(new Date());
      if (!prefs.plannerRangeStart) prefs.plannerRangeStart = todayIso;
      if (!prefs.plannerRangeEnd) prefs.plannerRangeEnd = todayIso;
      if (!prefs.plannerFocusDate) prefs.plannerFocusDate = todayIso;
      if (!prefs.plannerHistoryMode) prefs.plannerHistoryMode = 'month';
      if (!prefs.plannerHistoryCursor) prefs.plannerHistoryCursor = todayIso;
      const state = buildPlannerState();
      plannerState = state;
      if (plannerQuickDate) {
        plannerQuickDate.value = prefs.plannerFocusDate || todayIso;
      }
      try {
        const resp = await fetch(`/launcher/planner?start=${state.startDate}&end=${state.endDate}`, {
          headers: { 'Accept': 'application/json' }
        });
        if (!resp.ok) throw new Error('Failed to load');
        const data = await resp.json();
        if (data && Array.isArray(data.entries)) {
          plannerEntries = new Map(
            data.entries.map((entry) => [entry.date, Array.isArray(entry.items) ? entry.items : []])
          );
        }
      } catch (err) {
        plannerEntries = new Map();
      }
      if (prefs.plannerShowHistory) {
        try {
          const historyRange = getHistoryRange();
          const historyResp = await fetch(`/launcher/planner?start=${toIsoDate(historyRange.start)}&end=${toIsoDate(historyRange.end)}`, {
            headers: { 'Accept': 'application/json' }
          });
          if (historyResp.ok) {
            const historyData = await historyResp.json();
            if (historyData && Array.isArray(historyData.entries)) {
              plannerHistoryEntries = new Map(
                historyData.entries.map((entry) => [entry.date, Array.isArray(entry.items) ? entry.items : []])
              );
            }
          }
        } catch (err) {
          plannerHistoryEntries = new Map();
        }
      } else {
        plannerHistoryEntries = new Map();
      }
      renderPlanner(state);
      renderPlannerHistory(state);
      renderPlannerPalette();
    };

    if (grid) loadNotes();
    if (plannerGrid) loadPlanner();
  })();
</script>
<script src="/status-footer.js" defer></script>
</body>
</html>


