<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= (companyBrand && companyBrand.name) ? companyBrand.name : t('common.brand') %></title>
<link rel="stylesheet" href="/styles.css" />
</head>
<body class="page launcher-page launcher-page--<%= effectiveLauncherType %> theme-font-<%= (companyBrand && companyBrand.font_family) ? companyBrand.font_family : 'space-grotesk' %>" data-icon-frame="<%= companyBrand && companyBrand.icon_frame ? '1' : '0' %>" style="<%= companyBrand && companyBrand.theme_style ? companyBrand.theme_style : '' %>">
<header class="topbar">
<a class="brand brand-link" href="/dashboard">
<% if (companyBrand && companyBrand.logo) { %>
<img src="<%= companyBrand.logo %>" alt="Logo" class="brand-logo" />
<% } %>
<span class="brand-name"><%= (companyBrand && companyBrand.name) ? companyBrand.name : t('common.brand') %></span>
</a>
<nav class="nav">
<% if (can('settings', 'view')) { %>
<a href="/settings"><%= t('settings.title') %></a>
<% } %>
<a href="/logout"><%= t('nav.logout') %></a>
</nav>
</header>
<main class="container launcher-shell">
<% if (flash) { %>
<div class="alert <%= flash.type || 'info' %>"><%= flash.message %></div>
<% } %>
<% if (effectiveLauncherType === 'original') { %>
<%- include('partials/launcher-dashboard-original') %>
<% } else if (effectiveLauncherType === 'icons') { %>
<%- include('partials/launcher-dashboard-icons') %>
<% } else if (effectiveLauncherType === 'executive') { %>
<%- include('partials/launcher-dashboard-executive') %>
<% } else { %>
<%- include('partials/launcher-dashboard-classic') %>
<% } %>
</main>
<% if (effectiveLauncherType === 'original') { %>
<script src="/js/launcher-original.js" defer></script>
<% } %>
<script src="/status-footer.js" defer></script>
</body>
</html>
